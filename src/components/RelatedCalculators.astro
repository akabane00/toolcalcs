---
import { getRelatedCalculators } from '../data/calculators';

interface Props {
  currentSlug: string;
  limit?: number;
}

const { currentSlug, limit = 5 } = Astro.props;
const related = getRelatedCalculators(currentSlug, limit);
---

{related.length > 0 && (
  <section class="related-calcs">
    <h3>Related Calculators</h3>
    <div class="related-calcs-list">
      {related.map(calc => (
        <a href={`/${calc.categorySlug}/${calc.slug}/`}>
          <span class="rc-icon">{calc.icon}</span>
          <span class="rc-text">
            <span class="rc-title">{calc.title}</span>
            <span class="rc-desc">{calc.description.slice(0, 60)}...</span>
          </span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-calcs {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .related-calcs h3 {
    font-size: 1.05rem;
    margin-bottom: 12px;
    color: var(--color-text);
  }
  .related-calcs-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 8px;
  }
  .related-calcs-list a {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    background: var(--color-surface);
    transition: border-color 0.15s, box-shadow 0.15s;
    text-decoration: none;
  }
  .related-calcs-list a:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
  }
  .rc-icon { font-size: 1.3rem; flex-shrink: 0; }
  .rc-text { display: flex; flex-direction: column; min-width: 0; }
  .rc-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .rc-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
