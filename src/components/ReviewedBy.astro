---
interface Props {
  date?: string;
}

const { date = '2026-03-31' } = Astro.props;
const formattedDate = new Date(date + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<div class="reviewed-by">
  <span class="rb-icon">&#x2714;</span>
  <span class="rb-text">
    Formulas checked against official sources &middot; Last updated {formattedDate}
  </span>
  <a href="/editorial-standards/" class="rb-link">Our standards</a>
</div>

<style>
  .reviewed-by {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    font-size: 0.82rem;
    color: #166534;
    margin: 16px 0;
    flex-wrap: wrap;
  }
  [data-theme="dark"] .reviewed-by {
    background: #052e16;
    border-color: #166534;
    color: #86efac;
  }
  .rb-icon {
    font-size: 1rem;
    flex-shrink: 0;
  }
  .rb-text {
    flex: 1;
    min-width: 200px;
  }
  .rb-text strong {
    color: #15803d;
  }
  [data-theme="dark"] .rb-text strong {
    color: #4ade80;
  }
  .rb-link {
    font-size: 0.78rem;
    color: #15803d;
    text-decoration: none;
    white-space: nowrap;
  }
  .rb-link:hover {
    text-decoration: underline;
  }
  [data-theme="dark"] .rb-link {
    color: #4ade80;
  }
</style>
