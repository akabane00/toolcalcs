---
// Auto-generated Table of Contents — client-side from H2 headings
---

<nav class="toc" id="toc" aria-label="Table of Contents">
  <details open>
    <summary class="toc-title">Table of Contents</summary>
    <ol class="toc-list" id="toc-list"></ol>
  </details>
</nav>

<script>
  (function() {
    var list = document.getElementById('toc-list');
    var article = document.querySelector('.blog-article') || document.querySelector('.content-section') || document.querySelector('main');
    if (!list || !article) return;

    var headings = article.querySelectorAll('h2');
    if (headings.length < 3) {
      var toc = document.getElementById('toc');
      if (toc) toc.style.display = 'none';
      return;
    }

    headings.forEach(function(h, i) {
      if (h.textContent.trim() === 'Frequently Asked Questions') return;
      var id = h.id || 'section-' + (i + 1);
      h.id = id;
      var li = document.createElement('li');
      var a = document.createElement('a');
      a.href = '#' + id;
      a.textContent = h.textContent.trim();
      li.appendChild(a);
      list.appendChild(li);
    });

    if (list.children.length === 0) {
      var toc = document.getElementById('toc');
      if (toc) toc.style.display = 'none';
    }
  })();
</script>

<style>
  .toc {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0;
    margin: 20px 0 24px;
    max-width: 600px;
  }
  .toc details {
    padding: 0;
  }
  .toc-title {
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    padding: 14px 20px;
    color: var(--color-text);
    user-select: none;
  }
  .toc-title::-webkit-details-marker {
    margin-right: 8px;
  }
  .toc-list {
    list-style: decimal;
    padding: 0 20px 16px 44px;
    margin: 0;
  }
  .toc-list li {
    margin-bottom: 6px;
    font-size: 0.88rem;
    line-height: 1.5;
  }
  .toc-list a {
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .toc-list a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>
