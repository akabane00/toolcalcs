---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ToolCalcs",
    "url": "https://toolcalcs.com",
    "description": "Free, accurate online calculators for finance, health, math, and everyday needs — built by finance writers, engineers, and subject-matter experts.",
    "foundingDate": "2024",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "contact@toolcalcs.com",
      "contactType": "editorial"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "ToolCalcs",
    "url": "https://toolcalcs.com",
    "description": "Free online calculators for finance, health, math, real estate, business, and everyday needs.",
    "publisher": {
      "@type": "Organization",
      "name": "ToolCalcs"
    }
  }
];
---

<BaseLayout
  title="About ToolCalcs - Editorial Standards & Our Team"
  description="ToolCalcs provides free, accurate calculators and educational guides reviewed by finance professionals. Learn about our editorial process, data sources, and accuracy standards."
  structuredData={structuredData}
>
  <div class="page-content">
    <h1>About ToolCalcs</h1>
    <p class="page-lead">ToolCalcs provides free, accurate, and transparent calculators and financial guides for everyday decisions. Our content is written by experienced finance writers, verified against authoritative government and institutional sources, and updated regularly to reflect current laws, rates, and regulations.</p>

    <h2>Our Mission</h2>
    <p>Financial decisions — buying a home, planning for retirement, starting a business, managing debt — should not require expensive advisors for basic information. Our mission is to make accurate, professional-grade financial tools and education freely accessible to everyone.</p>
    <p>Too many calculator sites show results without explanation, use outdated formulas, or bury answers behind paywalls. ToolCalcs is built differently: every tool shows the formula, every article cites its sources, and every calculation runs directly in your browser without sending your data anywhere.</p>

    <h2>Editorial Standards</h2>
    <p>We hold our content to strict editorial standards, particularly for financial, tax, and health topics — areas where inaccurate information can cause real harm.</p>

    <div class="standards-grid">
      <div class="standard-card">
        <div class="standard-icon">📋</div>
        <h3>Source Verification</h3>
        <p>Financial data is sourced from primary government publications: IRS tax brackets and publications, Federal Reserve Statistical Releases, Bureau of Labor Statistics, Social Security Administration, and Department of Housing and Urban Development. We do not publish figures from secondary sources without cross-referencing the primary source.</p>
      </div>
      <div class="standard-card">
        <div class="standard-icon">🔄</div>
        <h3>Annual Updates</h3>
        <p>Tax brackets, contribution limits (401k, IRA, HSA), Social Security wage bases, standard deductions, and Medicare rates change annually. We review and update all affected calculators and articles at the start of each tax year. Time-sensitive figures include a "Last updated" date on every page.</p>
      </div>
      <div class="standard-card">
        <div class="standard-icon">✅</div>
        <h3>Formula Accuracy</h3>
        <p>Every calculator uses standard industry formulas: loan amortization uses the standard fixed-payment annuity formula, TDEE uses the Mifflin-St Jeor equation (the most validated for general populations), BMI uses the WHO-standard formula. Results are cross-validated against reference implementations and government calculators.</p>
      </div>
      <div class="standard-card">
        <div class="standard-icon">⚖️</div>
        <h3>Balanced Perspective</h3>
        <p>Financial content presents multiple perspectives where reasonable people disagree (e.g., renting vs. buying, active vs. passive investing). We present the evidence and let readers draw their own conclusions rather than pushing particular financial products or strategies.</p>
      </div>
    </div>

    <h2>Our Content Team</h2>
    <p>ToolCalcs articles are written by experienced finance writers and reviewed for factual accuracy. Our editorial team covers:</p>

    <div class="team-grid">
      <div class="team-card">
        <h3>Personal Finance</h3>
        <p>Budgeting, debt management, emergency funds, credit scores, and savings strategies. Articles reference Federal Reserve consumer finance data, CFPB guidelines, and FICO scoring methodology documentation.</p>
      </div>
      <div class="team-card">
        <h3>Tax & Retirement</h3>
        <p>Federal and state income tax, self-employment tax, capital gains, IRA and 401(k) rules, and retirement planning. All tax figures sourced directly from IRS publications and updated for the current tax year.</p>
      </div>
      <div class="team-card">
        <h3>Real Estate & Mortgages</h3>
        <p>Home affordability, mortgage calculations, rental property analysis, and closing costs. Rate benchmarks sourced from Freddie Mac Primary Mortgage Market Survey and NAR reports.</p>
      </div>
      <div class="team-card">
        <h3>Business & Investing</h3>
        <p>Small business finance, ROI analysis, break-even calculations, and investment returns. Articles reference SEC investor publications, SBA guidelines, and Federal Reserve economic research.</p>
      </div>
    </div>

    <h2>What We Offer</h2>
    <p>ToolCalcs has grown into a comprehensive platform with tools and educational resources across 12 categories:</p>
    <ul>
      <li><strong><a href="/financial-calculators/">Financial Calculators:</a></strong> Mortgage, compound interest, loan amortization, retirement savings, investment, net worth, credit card payoff, debt payoff, and more.</li>
      <li><strong><a href="/tax-calculators/">Tax Calculators:</a></strong> Federal income tax, self-employment tax, capital gains, tax withholding, sales tax, and property tax — updated for 2026.</li>
      <li><strong><a href="/real-estate-calculators/">Real Estate Calculators:</a></strong> Rental property analysis, cap rate, mortgage refinance break-even, home affordability, and closing costs.</li>
      <li><strong><a href="/business-calculators/">Business Calculators:</a></strong> Break-even analysis, profit margins, LLC vs S-Corp tax comparison, payroll costs, SBA loans, and ROI.</li>
      <li><strong><a href="/insurance-calculators/">Insurance Calculators:</a></strong> Life insurance needs, auto, home, renters insurance, and term vs. whole life comparison.</li>
      <li><strong><a href="/health-calculators/">Health Calculators:</a></strong> BMI, TDEE, calorie needs, body fat, protein intake, sleep, pace, and pregnancy calculators.</li>
      <li><strong><a href="/math-calculators/">Math Calculators:</a></strong> Percentage, GPA, standard deviation, area, probability, scientific calculator, and more.</li>
      <li><strong><a href="/date-time-calculators/">Date & Time Calculators:</a></strong> Age, date difference, time zones, business days, and countdowns.</li>
      <li><strong><a href="/conversion-calculators/">Conversion Calculators:</a></strong> Units, currency, temperature, length, weight, and data size.</li>
      <li><strong><a href="/everyday-calculators/">Everyday Calculators:</a></strong> Tip, discount, square footage, gas cost, word counter, and more daily tools.</li>
      <li><strong><a href="/construction-calculators/">Construction Calculators:</a></strong> Concrete, flooring, paint, roofing, tile, and more project estimators.</li>
      <li><strong><a href="/blog/">Educational Blog (175+ articles):</a></strong> In-depth guides covering personal finance, investing, taxes, real estate, and business — all with cited sources.</li>
    </ul>

    <h2>Accuracy & Limitations</h2>
    <p>We take accuracy seriously and maintain the following practices:</p>
    <ul>
      <li><strong>Client-side calculations:</strong> All computations run in your browser. No data is sent to our servers.</li>
      <li><strong>Disclosed formulas:</strong> We show the mathematical formulas and data sources so you can verify results independently.</li>
      <li><strong>Regular review:</strong> Time-sensitive figures (tax rates, limits, benchmarks) are reviewed annually and whenever major regulatory changes occur.</li>
      <li><strong>Scope disclosure:</strong> Our tools use national averages and standardized formulas. Individual results will vary based on local laws, personal circumstances, and factors our tools cannot account for.</li>
    </ul>
    <p><strong>Important:</strong> ToolCalcs calculators and articles are for informational and educational purposes only. They do not constitute financial, tax, legal, or medical advice. For decisions with significant financial consequences, consult a qualified professional such as a CPA, CFP, or licensed attorney.</p>

    <h2>Contact & Corrections</h2>
    <p>Found an error? We take accuracy concerns seriously. Contact our editorial team at <a href="mailto:contact@toolcalcs.com">contact@toolcalcs.com</a> with the page URL and the specific error. We investigate all accuracy reports and publish corrections promptly.</p>
    <p>For general questions, suggestions, or partnership inquiries, visit our <a href="/contact/">contact page</a>.</p>

    <p style="margin-top:24px"><a href="/editorial-standards/">→ Read our full Editorial Standards</a></p>
  </div>
</BaseLayout>

<style>
  .page-content { max-width: 740px; line-height: 1.8; }
  .page-lead { font-size: 1.05rem; color: var(--color-text-muted); margin-bottom: 24px; line-height: 1.7; }
  h1 { font-size: 1.9rem; margin-bottom: 12px; }
  h2 { font-size: 1.3rem; margin: 32px 0 12px; border-bottom: 1px solid var(--color-border); padding-bottom: 6px; }
  h3 { font-size: 1.05rem; margin: 16px 0 8px; }
  p { margin-bottom: 12px; }
  ul, ol { margin: 0 0 16px 24px; }
  li { margin-bottom: 8px; }

  .standards-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 16px 0 24px;
  }
  .standard-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 20px;
  }
  .standard-icon { font-size: 1.5rem; margin-bottom: 8px; }
  .standard-card h3 { margin: 0 0 8px; font-size: 1rem; }
  .standard-card p { font-size: 0.88rem; color: var(--color-text-muted); margin: 0; line-height: 1.6; }

  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 16px 0 24px;
  }
  .team-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 18px;
  }
  .team-card h3 { margin: 0 0 8px; font-size: 1rem; color: var(--color-primary); }
  .team-card p { font-size: 0.88rem; color: var(--color-text-muted); margin: 0; line-height: 1.6; }

  @media (max-width: 640px) {
    .standards-grid, .team-grid { grid-template-columns: 1fr; }
  }
</style>
