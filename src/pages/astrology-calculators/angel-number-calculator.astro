  const digitMeanings: Record<number, {keyword: string, energy: string}> = {
    0: { keyword: "infinite potential", energy: "wholeness, eternity, and the beginning of a spiritual journey" },
    1: { keyword: "new beginnings", energy: "creation, independence, leadership, and manifestation" },
    2: { keyword: "balance and partnership", energy: "cooperation, trust, patience, and divine timing" },
