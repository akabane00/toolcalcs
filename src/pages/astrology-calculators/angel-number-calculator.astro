    6: { keyword: "harmony and home", energy: "family, nurturing, responsibility, and domestic balance" },
    7: { keyword: "spirituality and wisdom", energy: "inner wisdom, intuition, mystical insight, and spiritual awakening" },
    8: { keyword: "abundance and power", energy: "prosperity, karmic balance, personal authority, and material success" },
    9: { keyword: "completion and humanitarianism", energy: "endings, fulfillment, compassion, and universal love" }
  };

  function getDigits(num: number): number[] {
    return String(num).split('').map(Number);
  }

  function isRepeating(num: number): boolean {
    const s = String(num);
    return s.length > 1 && s.split('').every(d => d === s[0]);
  }

  function isSequential(num: number): boolean {
    const digits = getDigits(num);
    if (digits.length < 3) return false;
    let ascending = true;
    let descending = true;
    for (let i = 1; i < digits.length; i++) {
      if (digits[i] !== digits[i - 1] + 1) ascending = false;
      if (digits[i] !== digits[i - 1] - 1) descending = false;
    }
    return ascending || descending;
  }

  function isMirror(num: number): boolean {
    const s = String(num);
    if (s.length < 3) return false;
    return s === s.split('').reverse().join('');
  }

  function digitRoot(num: number): number {
    let n = num;
    while (n > 9) {
      n = String(n).split('').reduce((sum, d) => sum + parseInt(d), 0);
    }
    return n;
  }

  function generateFallback(num: number): AngelNumberData {
    const digits = getDigits(num);
    const uniqueDigits = [...new Set(digits)];
    const root = digitRoot(num);
    const rootInfo = digitMeanings[root];
    const repeating = isRepeating(num);
    const sequential = isSequential(num);
    const mirror = isMirror(num);

    let patternType = "unique combination";
    let patternDesc = "";
    if (repeating) {
      patternType = "repeating";
      const d = digits[0];
      const info = digitMeanings[d];
      patternDesc = `As a repeating number, ${num} amplifies the energy of ${d} (${info.keyword}) ${digits.length} times over, creating an intensified vibration of ${info.energy}. The repetition is a clear sign that this message is urgent and demands your attention.`;
    } else if (sequential) {
      patternType = "sequential";
      const ascending = digits[1] > digits[0];
      patternDesc = ascending
        ? `As an ascending sequence, ${num} represents forward progress, natural growth, and step-by-step advancement. Each digit builds upon the last, showing a clear trajectory of development and evolution in your journey.`
        : `As a descending sequence, ${num} represents revisiting past lessons, simplification, and returning to fundamentals. It encourages you to strip away complexity and reconnect with what truly matters.`;
    } else if (mirror) {
      patternDesc = `As a mirror number, ${num} reflects themes of balance, self-reflection, and duality. The palindromic structure invites you to examine how your outer world mirrors your inner state and to seek harmony between the two.`;
    } else {
      const digitDescs = uniqueDigits.map(d => `${d} (${digitMeanings[d].keyword})`).join(', ');
      patternDesc = `This number combines the energies of ${digitDescs}. Together, they create a unique message tailored specifically to your current life circumstances and spiritual journey.`;
    }

    const primaryDigit = repeating ? digits[0] : root;
    const primaryInfo = digitMeanings[primaryDigit];

    const shortMeaning = repeating
      ? `The energy of ${primaryInfo.keyword} is powerfully amplified. Pay close attention to ${primaryInfo.energy}.`
      : `A ${patternType} number carrying the vibration of ${rootInfo.keyword} and ${rootInfo.energy}.`;

    const detailed = `Angel number ${num} carries a distinctive spiritual vibration that combines multiple layers of meaning. ${patternDesc} The digit root of ${num} is ${root}, which connects this number to the fundamental energy of ${rootInfo.keyword}: ${rootInfo.energy}. When you encounter ${num} repeatedly, the universe is drawing your attention to themes of ${rootInfo.keyword} in your current life situation. ` +
      `Each digit in ${num} contributes its own frequency to the overall message. ${digits.map((d, i) => `The ${['first', 'second', 'third', 'fourth'][i] || 'next'} digit, ${d}, brings the energy of ${digitMeanings[d].keyword}`).join('. ')}. ` +
      `Combined, these energies suggest that you are in a period where ${rootInfo.energy} are particularly relevant to your growth and well-being. The universe is using this specific combination to communicate a nuanced message about maintaining awareness of these interconnected themes as you navigate your current path. Trust that seeing this number is not random but a purposeful sign meant to guide you toward greater alignment with your highest self and deepest purpose.`;

    const love = repeating
      ? `In love, the repeated energy of ${primaryInfo.keyword} suggests that ${primaryInfo.energy} are central themes in your romantic life right now. ${primaryDigit <= 4 ? 'Focus on building a strong, stable foundation in your relationships and communicating your needs clearly.' : 'Embrace changes in your love life and trust that they are leading you toward a more authentic and fulfilling connection.'}`
      : `In love, the combined energy of ${num} encourages you to bring ${rootInfo.keyword} into your relationships. ${root <= 4 ? 'This is a time for building trust, deepening commitment, and creating stability with your partner or within yourself before seeking partnership.' : 'This is a time for transformation in love, being open to new connections, and allowing your romantic life to evolve in ways that honor your growth.'}`;

    const career = repeating
      ? `For career and finances, the amplified energy of ${primaryDigit} (${primaryInfo.keyword}) directs you toward ${primaryInfo.energy} in your professional life. ${primaryDigit >= 7 ? 'Trust your intuition about professional opportunities and know that prosperity is aligning with your efforts.' : 'Focus on practical steps, consistent effort, and building professional relationships that support your goals.'}`
      : `For career and money, ${num} brings the vibration of ${rootInfo.keyword} to your professional life. ${root >= 7 ? 'You are being guided toward work that aligns with your deeper purpose, and financial abundance will follow authenticity.' : 'Practical effort and disciplined action are your path to professional success right now. Stay focused and trust the process.'}`;

    const spiritual = `Spiritually, angel number ${num} with its digit root of ${root} connects you to the energy of ${rootInfo.keyword}. This number invites deeper exploration of ${rootInfo.energy} as part of your spiritual journey. ${repeating ? 'The repeating pattern amplifies this spiritual message, suggesting that this lesson is particularly important for your soul growth right now.' : mirror ? 'The mirror pattern of this number encourages introspection and finding spiritual balance between your inner and outer worlds.' : sequential ? 'The sequential pattern suggests spiritual progress and evolutionary growth, one step at a time.' : 'The unique combination of digits in this number creates a personalized spiritual message meant specifically for you at this moment in your journey.'}`;

    const actions = [
      `Reflect on how the theme of ${rootInfo.keyword} is showing up in your life and what adjustments might bring greater alignment.`,
      `Meditate on the number ${num}, focusing on each digit individually and then as a unified message from the universe.`,
      `Journal about what was on your mind or happening around you each time you noticed ${num}, looking for patterns in the context.`,
      `Trust that this number is a purposeful sign and take one meaningful action today that aligns with its energy of ${rootInfo.keyword}.`
    ];

    const relatedNums: number[] = [];
    if (repeating && digits.length < 4) {
      relatedNums.push(parseInt(String(digits[0]).repeat(digits.length + 1)));
    }
    if (root !== 0) {
      const tripleRoot = parseInt(String(root).repeat(3));
      if (tripleRoot !== num && !relatedNums.includes(tripleRoot)) relatedNums.push(tripleRoot);
    }
    uniqueDigits.forEach(d => {
      if (d !== 0) {
        const triple = parseInt(String(d).repeat(3));
        if (triple !== num && !relatedNums.includes(triple)) relatedNums.push(triple);
      }
    });
    [111, 222, 333, 444, 555, 777, 888, 999, 1111, 1212].forEach(n => {
      if (n !== num && !relatedNums.includes(n) && relatedNums.length < 5) relatedNums.push(n);
    });

    return {
      shortMeaning,
      detailed,
      love,
      career,
      spiritual,
      actions,
      related: relatedNums.slice(0, 5)
    };
  }

  function lookupNumber(num: number): void {
    const data = angelDatabase[num] || generateFallback(num);

    const resultsEl = document.getElementById('results')!;
    resultsEl.style.display = 'block';

    document.getElementById('displayNumber')!.textContent = String(num);
    document.getElementById('shortMeaning')!.textContent = data.shortMeaning;
    document.getElementById('detailedMeaning')!.textContent = data.detailed;
    document.getElementById('loveMeaning')!.textContent = data.love;
    document.getElementById('careerMeaning')!.textContent = data.career;
    document.getElementById('spiritualMeaning')!.textContent = data.spiritual;

    const actionList = document.getElementById('actionSteps')!;
    actionList.innerHTML = '';
    data.actions.forEach(action => {
      const li = document.createElement('li');
      li.className = 'action-item';
      const check = document.createElement('span');
      check.className = 'action-check';
      check.textContent = '\u2713';
      const text = document.createElement('span');
      text.textContent = action;
      li.appendChild(check);
      li.appendChild(text);
      actionList.appendChild(li);
    });

    const relatedGrid = document.getElementById('relatedNumbers')!;
    relatedGrid.innerHTML = '';
    data.related.forEach(rn => {
      const a = document.createElement('a');
      a.className = 'related-num-link';
      a.href = '#';
      a.textContent = String(rn);
      a.addEventListener('click', (e) => {
        e.preventDefault();
        (document.getElementById('angelNumber') as HTMLInputElement).value = String(rn);
        lookupNumber(rn);
        resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      relatedGrid.appendChild(a);
    });

    const linkContainer = document.getElementById('fullPageLink')!;
    linkContainer.innerHTML = `<a href="/angel-number/angel-number-${num}/">Read the full guide for Angel Number ${num} &rarr;</a>`;
  }

  document.getElementById('lookupBtn')?.addEventListener('click', () => {
    const input = document.getElementById('angelNumber') as HTMLInputElement;
    const val = parseInt(input.value);
    if (isNaN(val) || val < 0 || val > 9999) {
      input.setCustomValidity('Please enter a number between 0 and 9999.');
      input.reportValidity();
      return;
    }
    input.setCustomValidity('');
    lookupNumber(val);
  });

  document.getElementById('angelNumber')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      document.getElementById('lookupBtn')?.click();
    }
  });

  document.querySelectorAll('.quick-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const num = parseInt((btn as HTMLElement).dataset.num || '0');
      (document.getElementById('angelNumber') as HTMLInputElement).value = String(num);
      lookupNumber(num);
    });
  });
</script>
