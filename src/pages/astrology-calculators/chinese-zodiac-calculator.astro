    var radius = isMobile ? 86 : 105;

    for (var i = 0; i < 12; i++) {
      var angle = (i * 30 - 90) * (Math.PI / 180);
      var x = 50 + (radius / (isMobile ? 110 : 130)) * 50 * Math.cos(angle);
      var y = 50 + (radius / (isMobile ? 110 : 130)) * 50 * Math.sin(angle);

      var el = document.createElement('span');
      el.className = 'cz-wheel-animal' + (i === activeIndex ? ' active' : '');
      el.textContent = zodiacAnimals[i].emoji;
      el.title = zodiacAnimals[i].name;
      el.style.left = x + '%';
      el.style.top = y + '%';
      wheel.appendChild(el);
    }

    document.getElementById('wheelCenter').textContent = zodiacAnimals[activeIndex].emoji;
  }

  function calculate() {
    var yearInput = document.getElementById('birthYear');
    var year = parseInt(yearInput.value, 10);
    if (isNaN(year) || year < 1924 || year > 2031) {
      document.getElementById('resultArea').style.display = 'none';
      return;
    }

    var animalIndex = getAnimalIndex(year);
    var animal = zodiacAnimals[animalIndex];
    var element = getElement(year);

    // Show result area
    document.getElementById('resultArea').style.display = 'block';

    // Hero
    document.getElementById('animalEmoji').textContent = animal.emoji;
    document.getElementById('animalName').textContent = element + ' ' + animal.name + ' (' + year + ')';

    var badge = document.getElementById('elementBadge');
    badge.style.backgroundColor = elementColors[element];
    document.getElementById('elementName').textContent = element + ' Element';

    // Wheel
    buildWheel(animalIndex);

    // Personality
    document.getElementById('personalityDesc').textContent = animal.description;

    // Traits
    var traitsList = document.getElementById('keyTraits');
    traitsList.innerHTML = '';
    for (var i = 0; i < animal.traits.length; i++) {
      var li = document.createElement('li');
      li.textContent = animal.traits[i];
      traitsList.appendChild(li);
    }

    // Strengths & weaknesses
    document.getElementById('strengths').textContent = animal.strengths;
    document.getElementById('weaknesses').textContent = animal.weaknesses;

    // Compatibility
    var bestContainer = document.getElementById('bestMatch');
    bestContainer.innerHTML = '';
    for (var i = 0; i < animal.bestMatch.length; i++) {
      var matchName = animal.bestMatch[i];
      var matchAnimal = null;
      for (var j = 0; j < zodiacAnimals.length; j++) {
        if (zodiacAnimals[j].name === matchName) { matchAnimal = zodiacAnimals[j]; break; }
      }
      if (matchAnimal) {
        var chip = document.createElement('span');
        chip.className = 'cz-compat-chip';
        chip.textContent = matchAnimal.emoji + ' ' + matchAnimal.name;
        bestContainer.appendChild(chip);
      }
    }

    var worstContainer = document.getElementById('worstMatch');
    worstContainer.innerHTML = '';
    for (var i = 0; i < animal.worstMatch.length; i++) {
      var matchName = animal.worstMatch[i];
      var matchAnimal = null;
      for (var j = 0; j < zodiacAnimals.length; j++) {
        if (zodiacAnimals[j].name === matchName) { matchAnimal = zodiacAnimals[j]; break; }
      }
      if (matchAnimal) {
        var chip = document.createElement('span');
        chip.className = 'cz-compat-chip';
        chip.textContent = matchAnimal.emoji + ' ' + matchAnimal.name;
        worstContainer.appendChild(chip);
      }
    }

    // Lucky
    document.getElementById('luckyNumbers').textContent = animal.luckyNumbers.join(', ');
    document.getElementById('luckyColors').textContent = animal.luckyColors.join(', ');

    // Famous people
    document.getElementById('famousPeople').textContent = animal.famousPeople.join(', ');
  }

  // Real-time calculation
  document.getElementById('birthYear').addEventListener('input', calculate);

  // Initial calculation
  calculate();
</script>
