  .cz-traits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .cz-traits li {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 6px 14px;
    font-size: 0.85rem;
    font-weight: 500;
    margin: 0;
  }

  /* Strengths & Weaknesses */
  .cz-strengths-weaknesses {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .cz-sw-col h3 { font-size: 0.95rem; }

  /* Compatibility */
  .cz-compat {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .cz-compat-group h4 {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }
  .cz-compat-animals {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .cz-compat-chip {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .cz-compat-best .cz-compat-chip {
    border-color: #86efac;
    background: #f0fdf4;
  }
  .cz-compat-worst .cz-compat-chip {
    border-color: #fca5a5;
    background: #fef2f2;
  }
  [data-theme="dark"] .cz-compat-best .cz-compat-chip {
    background: #14532d;
    border-color: #166534;
  }
  [data-theme="dark"] .cz-compat-worst .cz-compat-chip {
    background: #450a0a;
    border-color: #7f1d1d;
  }

  /* Lucky numbers & colors */
  .cz-lucky {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .cz-lucky-col h3 { font-size: 0.95rem; }

  /* Disclaimer */
  .cz-disclaimer {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 20px;
    font-style: italic;
  }

  /* FAQ */
  .faq-list { margin-top: 16px; }
  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    margin-bottom: 8px;
    background: var(--color-surface);
  }
  .faq-item summary {
    padding: 14px 16px;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.95rem;
  }
  .faq-item p {
    padding: 0 16px 14px;
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  /* Table in SEO content */
  .table-responsive { overflow-x: auto; margin: 16px 0; }
  .table-responsive table {
    width: 100%;
    border-collapse: collapse;
  }
  .table-responsive th,
  .table-responsive td {
    padding: 8px 12px;
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .table-responsive th {
    background: var(--color-bg);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .cz-big-emoji { font-size: 3.5rem; }
    .cz-animal-name { font-size: 1.3rem; }
    .cz-wheel { width: 220px; height: 220px; }
    .cz-wheel-animal { font-size: 1.1rem; width: 30px; height: 30px; }
    .cz-wheel-animal.active { font-size: 1.3rem; width: 38px; height: 38px; }
    .cz-strengths-weaknesses,
    .cz-compat,
    .cz-lucky { grid-template-columns: 1fr; }
  }
