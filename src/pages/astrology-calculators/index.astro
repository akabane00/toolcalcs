---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('astrology-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Astrology Calculators"
    }
  ]
};
---

<BaseLayout
  title="Astrology Calculators - Zodiac, Tarot, Numerology & Angel Numbers"
  description="Free astrology tools: zodiac sign calculator, compatibility checker, tarot card reading, numerology life path, angel numbers, and Chinese zodiac. Discover yourself."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Astrology Calculators</span>
  </nav>

  <h1>Astrology Calculators</h1>
  <p class="page-desc">Free tools for zodiac signs, tarot readings, numerology, and spiritual self-discovery.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/astrology-calculators/zodiac-compatibility-calculator/" class="popular-chip">Zodiac Compatibility</a>
      <a href="/astrology-calculators/tarot-reading/" class="popular-chip">Tarot Reading</a>
      <a href="/astrology-calculators/numerology-calculator/" class="popular-chip">Life Path Number</a>
      <a href="/astrology-calculators/angel-number-calculator/" class="popular-chip">Angel Numbers</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/astrology-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Quick Reference Guides</h2>
    <p class="quick-ref-desc">Explore zodiac signs and angel number meanings:</p>
    <div class="quick-ref-grid">
      <a href="/zodiac/" class="quick-ref-card"><span>♈</span> All 12 Zodiac Signs</a>
      <a href="/angel-number/" class="quick-ref-card"><span>👼</span> Angel Number Meanings</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="astrology-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
