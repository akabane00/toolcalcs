  function reduceToDigit(num: number): number {
    while (num > 9 && num !== 11 && num !== 22 && num !== 33) {
      let sum = 0;
      while (num > 0) {
        sum += num % 10;
        num = Math.floor(num / 10);
      }
      num = sum;
    }
    return num;
  }

  function sumDigits(num: number): number {
    let sum = 0;
    const str = String(num);
    for (let i = 0; i < str.length; i++) {
      sum += parseInt(str[i]);
    }
    return sum;
  }

  function getReductionSteps(num: number): string {
    const digits = String(num).split('');
    const steps: string[] = [];
    steps.push(digits.join(' + '));
    let current = digits.reduce((a, b) => a + parseInt(b), 0);
    steps.push(String(current));
    while (current > 9 && current !== 11 && current !== 22 && current !== 33) {
      const d = String(current).split('');
      steps.push(d.join(' + '));
      current = d.reduce((a, b) => a + parseInt(b), 0);
      steps.push(String(current));
    }
    return steps.join(' = ');
  }

  function calculate(): void {
    const month = parseInt((document.getElementById('birthMonth') as HTMLSelectElement).value);
    const day = parseInt((document.getElementById('birthDay') as HTMLSelectElement).value);
    const year = parseInt((document.getElementById('birthYear') as HTMLInputElement).value);

    if (!year || year < 1900 || year > 2026) return;

    // Reduce each component to single digit (no master number check at component level for standard Pythagorean)
    const reducedMonth = reduceToDigit(sumDigits(month));
    const reducedDay = reduceToDigit(sumDigits(day));

    // Year needs full digit sum reduction
    let yearSum = sumDigits(year);
    while (yearSum > 9 && yearSum !== 11 && yearSum !== 22 && yearSum !== 33) {
      yearSum = sumDigits(yearSum);
    }
    const reducedYear = yearSum;

    // Final sum
    let finalSum = reducedMonth + reducedDay + reducedYear;
    const lifePathNumber = reduceToDigit(finalSum);

    const data = lifePathData[lifePathNumber];
    if (!data) return;

    // Show results
    const resultsEl = document.getElementById('results')!;
    resultsEl.style.display = 'block';

    // Life Path Number circle
    const circle = document.getElementById('lifePathCircle')!;
    const numberEl = document.getElementById('lifePathNumber')!;
    const nameEl = document.getElementById('lifePathName')!;
    const masterBadge = document.getElementById('masterBadge')!;

    numberEl.textContent = String(lifePathNumber);
    nameEl.textContent = data.name;

    if (data.isMaster) {
      circle.classList.add('master');
      masterBadge.style.display = 'inline-block';
    } else {
      circle.classList.remove('master');
      masterBadge.style.display = 'none';
    }

    // Build calculation breakdown
    const breakdownEl = document.getElementById('calcBreakdown')!;
    const monthNames = ['', 'January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

    let breakdownHTML = '<div class="breakdown-title">Calculation Breakdown</div>';
    breakdownHTML += `<div class="breakdown-step"><strong>Month:</strong> ${monthNames[month]} (${month}) → ${getReductionSteps(month)} = <strong>${reducedMonth}</strong></div>`;
    breakdownHTML += `<div class="breakdown-step"><strong>Day:</strong> ${day} → ${getReductionSteps(day)} = <strong>${reducedDay}</strong></div>`;
    breakdownHTML += `<div class="breakdown-step"><strong>Year:</strong> ${year} → ${getReductionSteps(year)} = <strong>${reducedYear}</strong></div>`;

    let finalReduction = `${reducedMonth} + ${reducedDay} + ${reducedYear} = ${finalSum}`;
    if (finalSum !== lifePathNumber) {
      finalReduction += ` → ${getReductionSteps(finalSum)} = ${lifePathNumber}`;
    }
    breakdownHTML += `<div class="breakdown-final">Life Path: ${finalReduction}${data.isMaster ? ' (Master Number!)' : ''}</div>`;

    breakdownEl.innerHTML = breakdownHTML;

    // Meaning
    document.getElementById('meaningText')!.textContent = data.meaning;

    // Traits
    const traitsPills = document.getElementById('traitsPills')!;
    traitsPills.innerHTML = '';
    data.traits.forEach(trait => {
      const pill = document.createElement('span');
      pill.className = 'trait-pill' + (data.isMaster ? ' master' : '');
      pill.textContent = trait;
      traitsPills.appendChild(pill);
    });

    // Careers
    const careersList = document.getElementById('careersList')!;
    careersList.innerHTML = '';
    data.careers.forEach(career => {
      const li = document.createElement('li');
      li.textContent = career;
      careersList.appendChild(li);
    });

    // Strengths & Challenges
    document.getElementById('strengthsText')!.textContent = data.strengths;
    document.getElementById('challengesText')!.textContent = data.challenges;

    // Compatible numbers
    const compatEl = document.getElementById('compatNumbers')!;
    compatEl.innerHTML = '';
    data.compatibility.forEach(num => {
      const chip = document.createElement('span');
      chip.className = 'compat-chip';
      chip.textContent = String(num);
      chip.title = lifePathData[num] ? lifePathData[num].name : '';
      compatEl.appendChild(chip);
    });

    // Celebrities
    document.getElementById('celebritiesList')!.textContent = data.celebrities.join(', ');

    // Smooth scroll to results
    resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  document.getElementById('calculateBtn')?.addEventListener('click', calculate);

  // Auto-calculate on any input change
  ['birthMonth', 'birthDay', 'birthYear'].forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.addEventListener('change', calculate);
      el.addEventListener('input', calculate);
    }
  });

  calculate();
</script>
