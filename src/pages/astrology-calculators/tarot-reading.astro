    { name: "King of Cups", arcana: "minor", suit: "cups", number: 14, keywords: ["emotional mastery", "diplomacy", "calm"], uprightMeaning: "Emotional maturity and calm wisdom. You balance heart and mind with grace and compassion.", reversedMeaning: "Emotional manipulation, volatility beneath a calm surface, or suppressed feelings.", symbol: "\uD83C\uDFC6" },

