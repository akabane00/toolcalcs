    { name: "Ten of Cups", arcana: "minor", suit: "cups", number: 10, keywords: ["harmony", "family", "happiness"], uprightMeaning: "Lasting emotional happiness and harmony in family and relationships. The ultimate in fulfillment.", reversedMeaning: "Family discord, broken homes, or idealized expectations of happiness.", symbol: "\uD83C\uDFC6" },
    { name: "Page of Cups", arcana: "minor", suit: "cups", number: 11, keywords: ["creativity", "curiosity", "sensitivity"], uprightMeaning: "A sweet message of creativity and emotional exploration. Let your imagination and intuition guide you.", reversedMeaning: "Emotional immaturity, creative blocks, or oversensitivity.", symbol: "\uD83C\uDFC6" },
