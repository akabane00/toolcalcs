    { name: "Six of Wands", arcana: "minor", suit: "wands", number: 6, keywords: ["victory", "recognition", "pride"], uprightMeaning: "Public recognition and victory are yours. Your achievements are noticed and celebrated by others.", reversedMeaning: "Lack of recognition, self-doubt after success, or arrogance. Stay humble in victory.", symbol: "\uD83E\uDE84" },
    { name: "Seven of Wands", arcana: "minor", suit: "wands", number: 7, keywords: ["defense", "perseverance", "challenge"], uprightMeaning: "Stand your ground against opposition. You have the higher ground and the strength to defend your position.", reversedMeaning: "Feeling overwhelmed, giving up too easily, or being unable to defend your stance.", symbol: "\uD83E\uDE84" },
