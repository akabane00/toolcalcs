    { name: "Page of Wands", arcana: "minor", suit: "wands", number: 11, keywords: ["enthusiasm", "exploration", "discovery"], uprightMeaning: "A burst of enthusiasm and curiosity leads you to explore new ideas and creative pursuits.", reversedMeaning: "Lack of direction, hasty decisions, or unreliable energy. Focus your enthusiasm.", symbol: "\uD83E\uDE84" },
    { name: "Knight of Wands", arcana: "minor", suit: "wands", number: 12, keywords: ["adventure", "energy", "impulsiveness"], uprightMeaning: "Bold action and adventurous energy propel you forward. Pursue your passion with courage.", reversedMeaning: "Recklessness, impatience, or scattered energy. Channel your fire constructively.", symbol: "\uD83E\uDE84" },
    { name: "Queen of Wands", arcana: "minor", suit: "wands", number: 13, keywords: ["confidence", "warmth", "determination"], uprightMeaning: "Radiant confidence and social magnetism help you lead and inspire others effortlessly.", reversedMeaning: "Jealousy, insecurity masked by bravado, or demanding too much attention.", symbol: "\uD83E\uDE84" },
    { name: "King of Wands", arcana: "minor", suit: "wands", number: 14, keywords: ["leadership", "vision", "entrepreneurship"], uprightMeaning: "A natural leader with bold vision and the charisma to inspire action in others.", reversedMeaning: "Tyrannical behavior, unrealistic expectations, or rash decision-making.", symbol: "\uD83E\uDE84" },

