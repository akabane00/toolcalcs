<script is:inline>
(function() {
  'use strict';

  // ==================== FULL 78-CARD TAROT DECK ====================
  var deck = [
    // ===== MAJOR ARCANA (22 cards) =====
    { name: "The Fool", arcana: "major", suit: null, number: 0, keywords: ["beginnings", "innocence", "spontaneity"], uprightMeaning: "The Fool signals a fresh start, an exciting leap into the unknown. Embrace new adventures with an open heart and trust in the journey ahead, even if the path is uncertain.", reversedMeaning: "Reversed, The Fool warns of recklessness or fear holding you back from necessary change. You may be taking foolish risks without thinking, or hesitating when you should be moving forward.", symbol: "\u2728" },
    { name: "The Magician", arcana: "major", suit: null, number: 1, keywords: ["willpower", "manifestation", "skill"], uprightMeaning: "The Magician indicates you have all the tools and resources needed to achieve your goals. Channel your focus and willpower to manifest your desires into reality.", reversedMeaning: "Reversed, The Magician suggests manipulation, untapped potential, or scattered energy. You may be doubting your abilities or using your skills for the wrong purposes.", symbol: "\u2728" },
    { name: "The High Priestess", arcana: "major", suit: null, number: 2, keywords: ["intuition", "mystery", "subconscious"], uprightMeaning: "The High Priestess calls you to trust your intuition and look beneath the surface. Hidden knowledge is available to you if you quiet your mind and listen to your inner voice.", reversedMeaning: "Reversed, The High Priestess indicates ignored intuition or hidden agendas. You may be disconnected from your inner self or overwhelmed by others' opinions.", symbol: "\u2728" },
    { name: "The Empress", arcana: "major", suit: null, number: 3, keywords: ["abundance", "nurturing", "fertility"], uprightMeaning: "The Empress represents abundance, creativity, and nurturing energy. This is a time of growth and flourishing, whether in relationships, creative projects, or material comfort.", reversedMeaning: "Reversed, The Empress suggests creative blocks, dependence, or neglecting self-care. You may be giving too much to others while ignoring your own needs.", symbol: "\u2728" },
    { name: "The Emperor", arcana: "major", suit: null, number: 4, keywords: ["authority", "structure", "stability"], uprightMeaning: "The Emperor brings structure, order, and strong leadership. Establish clear boundaries, create solid plans, and take charge of your situation with confidence and discipline.", reversedMeaning: "Reversed, The Emperor warns of rigidity, control issues, or abuse of power. You may be either too domineering or struggling with a lack of discipline and direction.", symbol: "\u2728" },
    { name: "The Hierophant", arcana: "major", suit: null, number: 5, keywords: ["tradition", "teaching", "conformity"], uprightMeaning: "The Hierophant represents spiritual wisdom, traditional values, and established institutions. Seek guidance from a mentor, follow proven paths, or explore your spiritual beliefs more deeply.", reversedMeaning: "Reversed, The Hierophant suggests rebellion against convention or rigid thinking. You may need to break free from outdated beliefs or find your own spiritual path.", symbol: "\u2728" },
    { name: "The Lovers", arcana: "major", suit: null, number: 6, keywords: ["love", "harmony", "choices"], uprightMeaning: "The Lovers represents deep connection, harmony, and meaningful choices about relationships and values. This card often appears at crossroads where heart-centered decisions must be made.", reversedMeaning: "Reversed, The Lovers indicates disharmony, misalignment, or avoidance of an important choice. A relationship may be unbalanced, or you may be compromising your values.", symbol: "\u2728" },
    { name: "The Chariot", arcana: "major", suit: null, number: 7, keywords: ["determination", "victory", "control"], uprightMeaning: "The Chariot signals triumph through willpower and determination. Stay focused on your goal, harness opposing forces, and charge forward with confidence. Victory is within reach.", reversedMeaning: "Reversed, The Chariot suggests lack of direction, aggression, or feeling out of control. You may be pushing too hard or have lost sight of what you are truly pursuing.", symbol: "\u2728" },
    { name: "Strength", arcana: "major", suit: null, number: 8, keywords: ["courage", "patience", "inner strength"], uprightMeaning: "Strength encourages you to face challenges with quiet courage and compassion rather than brute force. Your inner strength, patience, and gentle persistence will see you through.", reversedMeaning: "Reversed, Strength indicates self-doubt, insecurity, or losing your temper. You may be struggling with inner fears or allowing anxiety to undermine your natural confidence.", symbol: "\u2728" },
    { name: "The Hermit", arcana: "major", suit: null, number: 9, keywords: ["introspection", "solitude", "guidance"], uprightMeaning: "The Hermit invites you to withdraw from the noise and seek answers within. This is a time for solitude, reflection, and inner wisdom. The light you seek is inside you.", reversedMeaning: "Reversed, The Hermit warns of excessive isolation, loneliness, or refusing to seek guidance. You may be withdrawing too much or avoiding necessary inner work.", symbol: "\u2728" },
    { name: "Wheel of Fortune", arcana: "major", suit: null, number: 10, keywords: ["destiny", "cycles", "change"], uprightMeaning: "The Wheel of Fortune signals a turning point, a shift in circumstances driven by the natural cycles of life. Embrace change, trust the process, and know that what goes down must come up.", reversedMeaning: "Reversed, the Wheel suggests resistance to change, bad luck, or being stuck in a negative cycle. You may need to take action rather than waiting for fate to intervene.", symbol: "\u2728" },
    { name: "Justice", arcana: "major", suit: null, number: 11, keywords: ["fairness", "truth", "accountability"], uprightMeaning: "Justice calls for honesty, fairness, and accountability. The truth will come to light, and decisions should be made with logic and integrity. Legal matters may be involved.", reversedMeaning: "Reversed, Justice indicates unfairness, dishonesty, or avoiding responsibility. You may be refusing to see the truth or experiencing the consequences of past dishonesty.", symbol: "\u2728" },
    { name: "The Hanged Man", arcana: "major", suit: null, number: 12, keywords: ["surrender", "perspective", "letting go"], uprightMeaning: "The Hanged Man asks you to pause, surrender control, and see things from a completely new perspective. What feels like a sacrifice now may lead to profound insight and growth.", reversedMeaning: "Reversed, The Hanged Man suggests stalling, resistance to necessary sacrifice, or martyrdom. You may be stuck because you refuse to let go of something that no longer serves you.", symbol: "\u2728" },
    { name: "Death", arcana: "major", suit: null, number: 13, keywords: ["transformation", "endings", "renewal"], uprightMeaning: "Death signals profound transformation and the end of a chapter. Something must be released so that something new and better can emerge. This is not physical death but a powerful metamorphosis.", reversedMeaning: "Reversed, Death indicates resistance to change, stagnation, or clinging to the past. You may be afraid of letting go, prolonging a situation that has already run its course.", symbol: "\u2728" },
    { name: "Temperance", arcana: "major", suit: null, number: 14, keywords: ["balance", "patience", "moderation"], uprightMeaning: "Temperance encourages balance, patience, and moderation in all things. Blend opposing forces harmoniously, take the middle path, and trust that slow and steady progress will lead to lasting results.", reversedMeaning: "Reversed, Temperance warns of excess, imbalance, or impatience. You may be overindulging, rushing things, or struggling to find equilibrium between competing demands.", symbol: "\u2728" },
    { name: "The Devil", arcana: "major", suit: null, number: 15, keywords: ["shadow", "attachment", "addiction"], uprightMeaning: "The Devil reveals unhealthy attachments, addictions, or shadow behaviors that are keeping you trapped. Recognize what binds you and understand that the chains are often of your own making.", reversedMeaning: "Reversed, The Devil signals breaking free from bondage, releasing attachments, or the beginning of recovery. You are reclaiming your power and facing your shadows honestly.", symbol: "\u2728" },
    { name: "The Tower", arcana: "major", suit: null, number: 16, keywords: ["upheaval", "revelation", "breakthrough"], uprightMeaning: "The Tower represents sudden upheaval, destruction of false structures, and unexpected revelations. While this can feel shocking, it clears the way for rebuilding on a more authentic foundation.", reversedMeaning: "Reversed, The Tower suggests avoiding inevitable change, a narrowly avoided disaster, or internal transformation. You may be resisting a breakdown that would ultimately lead to a breakthrough.", symbol: "\u2728" },
    { name: "The Star", arcana: "major", suit: null, number: 17, keywords: ["hope", "inspiration", "serenity"], uprightMeaning: "The Star brings hope, healing, and renewed faith after a difficult period. You are entering a time of peace and inspiration. Trust that the universe is supporting your highest good.", reversedMeaning: "Reversed, The Star indicates loss of faith, disconnection, or hopelessness. You may be struggling to see the light at the end of the tunnel or feeling spiritually drained.", symbol: "\u2728" },
    { name: "The Moon", arcana: "major", suit: null, number: 18, keywords: ["illusion", "fear", "subconscious"], uprightMeaning: "The Moon warns that things are not as they seem. Illusions, fears, and subconscious anxieties may be clouding your judgment. Navigate carefully and trust your deepest instincts to guide you through uncertainty.", reversedMeaning: "Reversed, The Moon suggests clarity emerging from confusion, release of fear, or repressed emotions surfacing. Illusions are lifting and you can begin to see the truth.", symbol: "\u2728" },
    { name: "The Sun", arcana: "major", suit: null, number: 19, keywords: ["joy", "success", "vitality"], uprightMeaning: "The Sun radiates joy, success, and vitality. This is one of the most positive cards in the deck, indicating happiness, achievement, and confidence. Everything is coming together beautifully.", reversedMeaning: "Reversed, The Sun suggests temporary setbacks, diminished enthusiasm, or a need to find your inner child again. The light is still there but may be temporarily obscured by clouds.", symbol: "\u2728" },
    { name: "Judgement", arcana: "major", suit: null, number: 20, keywords: ["rebirth", "calling", "evaluation"], uprightMeaning: "Judgement signals a powerful awakening, a call to rise up and embrace your true purpose. Evaluate your past honestly, forgive yourself and others, and answer the call to a higher version of yourself.", reversedMeaning: "Reversed, Judgement indicates self-doubt, refusal of a calling, or harsh self-judgment. You may be ignoring an important inner calling or being too critical of yourself and others.", symbol: "\u2728" },
    { name: "The World", arcana: "major", suit: null, number: 21, keywords: ["completion", "achievement", "fulfillment"], uprightMeaning: "The World represents completion, wholeness, and the successful end of a major cycle. You have achieved something significant and integrated its lessons. Celebrate before the next journey begins.", reversedMeaning: "Reversed, The World suggests an incomplete cycle, delays in reaching a goal, or taking shortcuts. You may be close to completion but something still needs attention before you can move on.", symbol: "\u2728" },

    // ===== MINOR ARCANA: WANDS (14 cards) =====
