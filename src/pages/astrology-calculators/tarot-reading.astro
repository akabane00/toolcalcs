    { name: "Eight of Pentacles", arcana: "minor", suit: "pentacles", number: 8, keywords: ["mastery", "skill", "diligence"], uprightMeaning: "Dedicated practice and attention to detail lead to mastery of your craft. Keep refining.", reversedMeaning: "Perfectionism, lack of motivation, or cutting corners in your work.", symbol: "\u2B50" },
    { name: "Nine of Pentacles", arcana: "minor", suit: "pentacles", number: 9, keywords: ["independence", "luxury", "self-sufficiency"], uprightMeaning: "Financial independence and the enjoyment of your hard-earned success. Savor the rewards.", reversedMeaning: "Over-reliance on material comfort, financial setback, or workaholism.", symbol: "\u2B50" },
    { name: "Ten of Pentacles", arcana: "minor", suit: "pentacles", number: 10, keywords: ["legacy", "wealth", "family"], uprightMeaning: "Lasting wealth, family legacy, and long-term financial security. The fruits of generations.", reversedMeaning: "Family financial disputes, loss of inheritance, or valuing money over relationships.", symbol: "\u2B50" },
    { name: "Page of Pentacles", arcana: "minor", suit: "pentacles", number: 11, keywords: ["ambition", "studiousness", "opportunity"], uprightMeaning: "An eager student or a new financial opportunity. Approach with diligence and a desire to learn.", reversedMeaning: "Lack of focus, procrastination, or an unrealistic approach to money and goals.", symbol: "\u2B50" },
    { name: "Knight of Pentacles", arcana: "minor", suit: "pentacles", number: 12, keywords: ["reliability", "hard work", "routine"], uprightMeaning: "Steady, reliable effort and methodical progress. Slow and consistent wins the race.", reversedMeaning: "Stagnation, laziness, or being stuck in a boring routine without growth.", symbol: "\u2B50" },
    { name: "Queen of Pentacles", arcana: "minor", suit: "pentacles", number: 13, keywords: ["nurturing", "practicality", "abundance"], uprightMeaning: "A warm, practical nurturer who creates abundance and comfort for all around them.", reversedMeaning: "Neglecting self-care for work, financial insecurity, or smothering behavior.", symbol: "\u2B50" },
    { name: "King of Pentacles", arcana: "minor", suit: "pentacles", number: 14, keywords: ["wealth", "business", "discipline"], uprightMeaning: "Material success through discipline and business acumen. A provider and empire builder.", reversedMeaning: "Greed, materialism at the expense of relationships, or financial mismanagement.", symbol: "\u2B50" }
  ];

  // ==================== STATE ====================
  var spreadType = 'three';
  var drawnCards = [];
  var flippedCount = 0;
  var totalCards = 3;
  var positionLabels = ['Past', 'Present', 'Future'];

  // ==================== DOM REFS ====================
  var cardSlotsEl = document.getElementById('cardSlots');
  var drawBtn = document.getElementById('drawBtn');
  var readingOutput = document.getElementById('readingOutput');
  var cardReadingsEl = document.getElementById('cardReadings');
  var readingSummaryEl = document.getElementById('readingSummary');

  // ==================== SPREAD TOGGLE ====================
  document.querySelectorAll('.spread-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.spread-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      spreadType = btn.getAttribute('data-spread');
      resetReading();
    });
  });

  // ==================== DRAW BUTTON ====================
  drawBtn.addEventListener('click', function() {
    if (spreadType === 'daily') {
      totalCards = 1;
      positionLabels = ['Daily Card'];
    } else {
      totalCards = 3;
      positionLabels = ['Past', 'Present', 'Future'];
    }
    drawCards();
  });

  // ==================== RESET ====================
  function resetReading() {
    drawnCards = [];
    flippedCount = 0;
    cardSlotsEl.innerHTML = '';
    readingOutput.style.display = 'none';
    cardReadingsEl.innerHTML = '';
    readingSummaryEl.style.display = 'none';
    readingSummaryEl.innerHTML = '';
    drawBtn.style.display = '';
  }

  // ==================== DRAW CARDS ====================
  function drawCards() {
    resetReading();
    drawBtn.style.display = 'none';

    var shuffled = deck.slice();
    for (var i = shuffled.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = shuffled[i];
      shuffled[i] = shuffled[j];
      shuffled[j] = tmp;
    }

    drawnCards = [];
    for (var c = 0; c < totalCards; c++) {
      var card = Object.assign({}, shuffled[c]);
      card.isReversed = Math.random() < 0.35;
      card.positionLabel = positionLabels[c];
      drawnCards.push(card);
    }

    for (var c = 0; c < drawnCards.length; c++) {
      var slot = createCardSlot(drawnCards[c], c);
      cardSlotsEl.appendChild(slot);
    }

    readingOutput.style.display = 'block';
  }

  // ==================== CREATE CARD SLOT ====================
  function createCardSlot(card, index) {
    var slot = document.createElement('div');
    slot.className = 'card-slot';

    var label = document.createElement('div');
    label.className = 'position-label';
    label.textContent = card.positionLabel;
    slot.appendChild(label);

    var tarotCard = document.createElement('div');
    tarotCard.className = 'tarot-card';
    if (card.isReversed) tarotCard.classList.add('reversed-card');
    tarotCard.setAttribute('data-index', index);

    var suitClass = card.arcana === 'major' ? 'suit-major' : 'suit-' + card.suit;

    tarotCard.innerHTML =
      '<div class="card-inner">' +
        '<div class="card-face card-back">' +
          '<div class="card-back-corner tl"></div>' +
          '<div class="card-back-corner tr"></div>' +
          '<div class="card-back-corner bl"></div>' +
          '<div class="card-back-corner br"></div>' +
          '<div class="card-back-design">' +
            '<div class="mandala-star"></div>' +
            '<div class="mandala-dot"></div>' +
          '</div>' +
        '</div>' +
        '<div class="card-face card-front ' + suitClass + '">' +
          '<div class="card-name">' + card.name + '</div>' +
          (card.isReversed ? '<div class="card-reversed-tag">Reversed</div>' : '') +
          '<div class="card-symbol">' + card.symbol + '</div>' +
          '<div class="card-keywords">' + card.keywords.join(' \u2022 ') + '</div>' +
        '</div>' +
      '</div>';

    tarotCard.addEventListener('click', function() {
      flipCard(this, index);
    });

    slot.appendChild(tarotCard);
    return slot;
  }

  // ==================== FLIP CARD ====================
  function flipCard(cardEl, index) {
    if (cardEl.classList.contains('flipped')) return;
    cardEl.classList.add('flipped');
    flippedCount++;

    var card = drawnCards[index];
    showCardReading(card);

    if (flippedCount === totalCards) {
      setTimeout(function() { showSummary(); }, 500);
    }
  }

  // ==================== SHOW CARD READING ====================
  function showCardReading(card) {
    var meaning = card.isReversed ? card.reversedMeaning : card.uprightMeaning;
    var orientationClass = card.isReversed ? 'reversed' : 'upright';
    var orientationText = card.isReversed ? 'Reversed' : 'Upright';

    var reading = document.createElement('div');
    reading.className = 'card-reading';
    reading.innerHTML =
      '<div class="card-reading-header">' +
        '<span class="card-reading-position">' + card.positionLabel + '</span>' +
        '<span class="card-reading-name">' + card.name + '</span>' +
        '<span class="card-reading-orientation ' + orientationClass + '">' + orientationText + '</span>' +
      '</div>' +
      '<p class="card-reading-meaning">' + meaning + '</p>';

    cardReadingsEl.appendChild(reading);
  }

  // ==================== SHOW SUMMARY ====================
  function showSummary() {
    readingSummaryEl.style.display = 'block';
    var summaryText = '';

    if (totalCards === 1) {
      var c = drawnCards[0];
      var orientation = c.isReversed ? 'reversed' : 'upright';
      summaryText = 'Your daily card is <strong>' + c.name + '</strong> (' + orientation + '). ' +
        'Today\u2019s theme centers on <strong>' + c.keywords.join(', ') + '</strong>. ' +
        'Carry this card\u2019s energy with you throughout the day and reflect on how its message resonates with your current experiences.';
    } else {
      var pastCard = drawnCards[0];
      var presentCard = drawnCards[1];
      var futureCard = drawnCards[2];
      summaryText =
        'Your reading weaves together a story from past to future. ' +
        '<strong>' + pastCard.name + '</strong> (' + (pastCard.isReversed ? 'reversed' : 'upright') + ') in the Past position suggests that <strong>' + pastCard.keywords[0] + '</strong> has been a significant influence. ' +
        'In the Present, <strong>' + presentCard.name + '</strong> (' + (presentCard.isReversed ? 'reversed' : 'upright') + ') shows that <strong>' + presentCard.keywords[0] + '</strong> is the energy shaping your current moment. ' +
        'Looking ahead, <strong>' + futureCard.name + '</strong> (' + (futureCard.isReversed ? 'reversed' : 'upright') + ') points toward <strong>' + futureCard.keywords[0] + '</strong> as the emerging theme. ' +
        'Reflect on how these three cards connect and what actions they inspire you to take.';
    }

    readingSummaryEl.innerHTML =
      '<h3>\u2728 Reading Summary</h3>' +
      '<p>' + summaryText + '</p>';
  }
})();
</script>
