    { name: "Ace of Swords", arcana: "minor", suit: "swords", number: 1, keywords: ["clarity", "truth", "breakthrough"], uprightMeaning: "A powerful breakthrough of clarity and truth. Cut through confusion with sharp mental focus.", reversedMeaning: "Confusion, misinformation, or a truth you are not ready to face.", symbol: "\u2694\uFE0F" },
