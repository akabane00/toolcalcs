    { name: "King of Swords", arcana: "minor", suit: "swords", number: 14, keywords: ["authority", "intellect", "truth"], uprightMeaning: "Intellectual authority and impartial judgment guide fair decisions. Lead with logic and integrity.", reversedMeaning: "Abuse of intellectual power, manipulation through words, or tyrannical authority.", symbol: "\u2694\uFE0F" },

