  // Element interaction descriptions
  var ELEMENT_INTERACTIONS = {
    'Fire+Fire':   { label: 'Passionate', icon: '\uD83D\uDD25', desc: 'Two Fire signs create an intensely passionate, energetic, and action-oriented bond. You fuel each other\'s ambitions and enthusiasm.' },
    'Fire+Earth':  { label: 'Challenging', icon: '\uD83C\uDF0B', desc: 'Fire and Earth can forge or fracture. Fire\'s impulsiveness clashes with Earth\'s caution, but Fire can inspire Earth to take risks, and Earth can help Fire build something lasting.' },
    'Fire+Air':   { label: 'Dynamic', icon: '\u2728', desc: 'Air feeds Fire, creating a dynamic, inspiring, and energizing combination. You stimulate each other\'s ideas and turn conversation into action.' },
    'Fire+Water':  { label: 'Steamy', icon: '\uD83C\uDF2B\uFE0F', desc: 'Fire and Water create steam: intense and transformative, but potentially volatile. Fire can warm Water\'s emotions, and Water can temper Fire\'s intensity.' },
    'Earth+Earth': { label: 'Grounded', icon: '\uD83C\uDF3F', desc: 'Two Earth signs build a stable, reliable, and deeply committed partnership. You share practical values and a love of security and comfort.' },
