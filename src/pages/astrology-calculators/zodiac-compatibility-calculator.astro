    'Water+Water': { label: 'Deep', icon: '\uD83C\uDF0A', desc: 'Two Water signs share a profound emotional and intuitive connection. You understand each other\'s depths, moods, and unspoken feelings at a soul level.' }
  };

  function getSignByKey(key) {
    for (var i = 0; i < ZODIAC_SIGNS.length; i++) {
      if (ZODIAC_SIGNS[i].key === key) return ZODIAC_SIGNS[i];
    }
    return null;
  }

  function getZodiacSignFromDate(month, day) {
    for (var i = 0; i < ZODIAC_SIGNS.length; i++) {
      var s = ZODIAC_SIGNS[i];
      if (s.monthStart === s.monthEnd) {
        if (month === s.monthStart && day >= s.dayStart && day <= s.dayEnd) return s;
      } else if (s.monthStart > s.monthEnd) {
        // Capricorn wraps around year
        if ((month === s.monthStart && day >= s.dayStart) || (month === s.monthEnd && day <= s.dayEnd)) return s;
      } else {
        if ((month === s.monthStart && day >= s.dayStart) || (month === s.monthEnd && day <= s.dayEnd)) return s;
      }
    }
    return ZODIAC_SIGNS[0]; // fallback
  }

  function getCompatData(keyA, keyB) {
    if (COMPAT[keyA] && COMPAT[keyA][keyB]) return COMPAT[keyA][keyB];
    if (COMPAT[keyB] && COMPAT[keyB][keyA]) return COMPAT[keyB][keyA];
    return { overall: 50, love: 50, friendship: 50, work: 50, description: 'A unique pairing with potential for growth and discovery.', tips: 'Focus on communication and mutual respect to build a strong foundation.' };
  }

  function getElementInteraction(elA, elB) {
    var key1 = elA + '+' + elB;
    var key2 = elB + '+' + elA;
    return ELEMENT_INTERACTIONS[key1] || ELEMENT_INTERACTIONS[key2] || { label: 'Unique', icon: '\u2B50', desc: 'A unique elemental combination.' };
  }

  function getScoreColor(score) {
    if (score >= 75) return '#22c55e';
    if (score >= 55) return '#eab308';
    if (score >= 40) return '#f97316';
    return '#ef4444';
  }

  function getScoreGradient(score) {
    if (score >= 75) return 'linear-gradient(90deg, #22c55e, #16a34a)';
    if (score >= 55) return 'linear-gradient(90deg, #eab308, #ca8a04)';
    if (score >= 40) return 'linear-gradient(90deg, #f97316, #ea580c)';
    return 'linear-gradient(90deg, #ef4444, #dc2626)';
  }

  function renderHearts(score) {
    var heartCount = Math.round(score / 20);
    if (heartCount < 1) heartCount = 1;
    if (heartCount > 5) heartCount = 5;
    var filled = '';
    for (var i = 0; i < 5; i++) {
      if (i < heartCount) {
        filled += '\u2764\uFE0F';
      } else {
        filled += '\uD83E\uDD0D';
      }
    }
    return filled;
  }

  function calculate() {
    var mode = document.querySelector('.mode-btn.active').dataset.mode;
    var signAKey, signBKey;

    if (mode === 'birthday') {
      var bdA = document.getElementById('birthdayA').value;
      var bdB = document.getElementById('birthdayB').value;
      if (!bdA || !bdB) return;
      var partsA = bdA.split('-');
      var partsB = bdB.split('-');
      var monthA = parseInt(partsA[1], 10);
      var dayA = parseInt(partsA[2], 10);
      var monthB = parseInt(partsB[1], 10);
      var dayB = parseInt(partsB[2], 10);
      var sA = getZodiacSignFromDate(monthA, dayA);
      var sB = getZodiacSignFromDate(monthB, dayB);
      signAKey = sA.key;
      signBKey = sB.key;
      // Update dropdowns to reflect detected signs
      document.getElementById('signA').value = signAKey;
      document.getElementById('signB').value = signBKey;
    } else {
      signAKey = document.getElementById('signA').value;
      signBKey = document.getElementById('signB').value;
    }

    var signA = getSignByKey(signAKey);
    var signB = getSignByKey(signBKey);
    if (!signA || !signB) return;

    var compat = getCompatData(signAKey, signBKey);

    // Display signs
    document.getElementById('signASymbol').textContent = signA.symbol;
    document.getElementById('signAName').textContent = signA.name;
    document.getElementById('signAElement').textContent = signA.element + ' Sign';

    document.getElementById('signBSymbol').textContent = signB.symbol;
    document.getElementById('signBName').textContent = signB.name;
    document.getElementById('signBElement').textContent = signB.element + ' Sign';

    // Heart icon
    var heartCount = Math.round(compat.love / 20);
    if (heartCount < 1) heartCount = 1;
    document.getElementById('heartIcon').textContent = heartCount >= 3 ? '\u2764\uFE0F' : '\uD83E\uDD0D';

    // Overall score bar
    var overallBar = document.getElementById('overallBar');
    overallBar.style.width = compat.overall + '%';
    overallBar.style.background = getScoreGradient(compat.overall);
    document.getElementById('overallPercent').textContent = compat.overall + '%';

    // Love bar
    var loveBar = document.getElementById('loveBar');
    loveBar.style.width = compat.love + '%';
    loveBar.style.background = getScoreGradient(compat.love);
    document.getElementById('lovePercent').textContent = compat.love + '%';
    document.getElementById('loveHearts').textContent = renderHearts(compat.love);

    // Friendship bar
    var friendshipBar = document.getElementById('friendshipBar');
    friendshipBar.style.width = compat.friendship + '%';
    friendshipBar.style.background = getScoreGradient(compat.friendship);
    document.getElementById('friendshipPercent').textContent = compat.friendship + '%';

    // Work bar
    var workBar = document.getElementById('workBar');
    workBar.style.width = compat.work + '%';
    workBar.style.background = getScoreGradient(compat.work);
    document.getElementById('workPercent').textContent = compat.work + '%';

    // Element interaction
    var interaction = getElementInteraction(signA.element, signB.element);
    document.getElementById('elementInteraction').innerHTML =
      '<strong>' + interaction.icon + ' ' + signA.element + ' + ' + signB.element + ' = ' + interaction.label + '</strong><br/>' + interaction.desc;

    // Description
    document.getElementById('compatDescription').innerHTML =
      '<strong>' + signA.name + ' & ' + signB.name + '</strong><br/>' + compat.description;

    // Tips
    document.getElementById('relationshipTips').innerHTML =
      '<strong>Tips for This Pairing</strong><br/>' + compat.tips;

    // Show results
    document.getElementById('results').classList.remove('hidden');
  }

  // Mode toggle
  document.querySelectorAll('.mode-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.mode-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var mode = btn.dataset.mode;
      document.getElementById('signInputs').classList.toggle('hidden', mode !== 'sign');
      document.getElementById('birthdayInputs').classList.toggle('hidden', mode !== 'birthday');
    });
  });

  // Calculate on button click
  document.getElementById('calculateBtn').addEventListener('click', calculate);

  // Also calculate on select/input change for instant feedback
  document.getElementById('signA').addEventListener('change', calculate);
  document.getElementById('signB').addEventListener('change', calculate);
  document.getElementById('birthdayA').addEventListener('change', calculate);
  document.getElementById('birthdayB').addEventListener('change', calculate);

  // Initial calculation
  calculate();
</script>
