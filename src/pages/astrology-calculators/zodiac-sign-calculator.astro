    traitsList.innerHTML = sign.traits.map(t => `<li>${t}</li>`).join('');

    // Strengths
    const strengthsList = document.getElementById('zodiacStrengths')!;
    strengthsList.innerHTML = sign.strengths.map(s => `<li>${s}</li>`).join('');

    // Weaknesses
    const weaknessesList = document.getElementById('zodiacWeaknesses')!;
    weaknessesList.innerHTML = sign.weaknesses.map(w => `<li>${w}</li>`).join('');

    // Compatibility chips
