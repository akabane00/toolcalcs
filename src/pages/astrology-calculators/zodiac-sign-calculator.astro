    compatContainer.innerHTML = sign.bestMatch.map(m =>
      `<span class="compat-chip"><span class="chip-symbol">${signSymbols[m] || ''}</span> ${m}</span>`
    ).join('');

    // Scroll result into view
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

