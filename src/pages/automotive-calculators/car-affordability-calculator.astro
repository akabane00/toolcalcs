  <RelatedCalculators currentSlug="car-affordability-calculator" />
  <RelatedArticles calculatorSlug="car-affordability-calculator" />
  <AdUnit slot="bottom" format="horizontal" />
</BaseLayout>

<script>
  function formatMoney(n) {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  function getRateFromCredit(credit) {
    var rates = {
      excellent: 5.0,
      good: 7.0,
      fair: 10.0,
      poor: 15.0
    };
    return rates[credit] || 7.0;
  }

  function calculate() {
    var income = parseFloat(document.getElementById('monthlyIncome').value) || 0;
    var expenses = parseFloat(document.getElementById('monthlyExpenses').value) || 0;
    var downPayment = parseFloat(document.getElementById('downPayment').value) || 0;
    var tradeIn = parseFloat(document.getElementById('tradeIn').value) || 0;
    var creditScore = document.getElementById('creditScore').value;
    var months = parseInt(document.getElementById('loanTerm').value) || 60;

    var disposable = income - expenses;
    var maxMonthly = disposable * 0.15;
    if (maxMonthly < 0) maxMonthly = 0;

    var annualRate = getRateFromCredit(creditScore);
    var r = annualRate / 100 / 12;

    // Reverse-calculate max loan amount from monthly payment
    var maxLoan = 0;
    if (r === 0) {
      maxLoan = maxMonthly * months;
    } else {
      // P = M * [(1+r)^n - 1] / [r * (1+r)^n]
      var factor = Math.pow(1 + r, months);
      maxLoan = maxMonthly * (factor - 1) / (r * factor);
    }

    var maxPrice = maxLoan + downPayment + tradeIn;
    var totalPaid = (maxMonthly * months) + downPayment + tradeIn;
    var insuranceEst = 150;

    document.getElementById('maxCarPrice').textContent = formatMoney(maxPrice);
    document.getElementById('maxPayment').textContent = formatMoney(maxMonthly);
    document.getElementById('estRate').textContent = annualRate.toFixed(1) + '%';
    document.getElementById('totalPaid').textContent = formatMoney(totalPaid);
    document.getElementById('insurance').textContent = formatMoney(insuranceEst) + '/mo';

    // Advisory message
    var advisory = document.getElementById('advisory');
    var ratio = income > 0 ? maxMonthly / income : 0;
    advisory.style.display = 'block';

    if (disposable <= 0) {
      advisory.style.background = '#fee2e2';
      advisory.style.color = '#991b1b';
      advisory.textContent = 'Your expenses exceed your income. Focus on reducing expenses before taking on a car payment.';
    } else if (ratio <= 0.10) {
      advisory.style.background = '#dcfce7';
      advisory.style.color = '#166534';
      advisory.textContent = 'You can comfortably afford a car at this price. Your payment is well within safe limits.';
    } else if (ratio <= 0.15) {
      advisory.style.background = '#fef9c3';
      advisory.style.color = '#854d0e';
      advisory.textContent = 'This is affordable but stretching your budget. Consider a smaller down payment or longer term to free up monthly cash.';
    } else {
      advisory.style.background = '#fee2e2';
      advisory.style.color = '#991b1b';
      advisory.textContent = 'This payment would strain your budget. Consider a less expensive vehicle or a larger down payment.';
    }
  }

  document.getElementById('calculateBtn').addEventListener('click', calculate);
  calculate();
</script>
