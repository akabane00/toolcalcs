<script>
  function fmt(n) { return '$' + Math.round(n).toLocaleString('en-US'); }

  document.getElementById('calculateBtn').addEventListener('click', function() {
    var price = parseFloat(document.getElementById('vehiclePrice').value) || 0;
    var down = parseFloat(document.getElementById('downPayment').value) || 0;
    var trade = parseFloat(document.getElementById('tradeIn').value) || 0;
    var taxRate = (parseFloat(document.getElementById('salesTax').value) || 0) / 100;
    var rate = (parseFloat(document.getElementById('interestRate').value) || 0) / 100;
    var term = parseInt(document.getElementById('loanTerm').value) || 60;

    var taxAmt = price * taxRate;
    var loanAmt = price - down - trade + taxAmt;
    if (loanAmt < 0) loanAmt = 0;

    var monthly = 0;
    var totalPaid = 0;
    var totalInt = 0;

    if (loanAmt > 0 && rate > 0) {
      var r = rate / 12;
      var n = term;
      monthly = loanAmt * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
      totalPaid = monthly * n;
      totalInt = totalPaid - loanAmt;
    } else if (loanAmt > 0) {
      monthly = loanAmt / term;
      totalPaid = loanAmt;
      totalInt = 0;
    }

    document.getElementById('monthlyPayment').textContent = fmt(monthly);
    document.getElementById('totalPaid').textContent = fmt(totalPaid);
    document.getElementById('totalInterest').textContent = fmt(totalInt);
    document.getElementById('loanAmount').textContent = fmt(loanAmt);
    document.getElementById('taxAmount').textContent = fmt(taxAmt);

    var card = document.getElementById('paymentCard');
    var advice = document.getElementById('paymentAdvice');
    var benchmark = 5000;
    var pct = monthly / benchmark * 100;

    if (pct < 15) {
      card.className = 'result-card primary';
      advice.style.background = '#f0fdf4';
      advice.style.border = '1px solid #bbf7d0';
      advice.innerHTML = '<strong>Affordable:</strong> Your payment is ' + pct.toFixed(1) + '% of a $5,000/mo income benchmark. This is within the recommended range for car payments.';
    } else if (pct <= 20) {
      card.className = 'result-card primary';
      card.style.borderColor = '#f59e0b';
      advice.style.background = '#fffbeb';
      advice.style.border = '1px solid #fde68a';
      advice.innerHTML = '<strong>Moderate:</strong> Your payment is ' + pct.toFixed(1) + '% of a $5,000/mo income benchmark. Consider increasing your down payment or choosing a shorter term to reduce total cost.';
    } else {
      card.className = 'result-card primary';
      card.style.borderColor = '#ef4444';
      advice.style.background = '#fef2f2';
      advice.style.border = '1px solid #fecaca';
      advice.innerHTML = '<strong>High payment:</strong> Your payment is ' + pct.toFixed(1) + '% of a $5,000/mo income benchmark. This exceeds the recommended 15-20% threshold. Consider a less expensive vehicle or a larger down payment.';
    }

    document.getElementById('results').style.display = '';
  });
</script>
