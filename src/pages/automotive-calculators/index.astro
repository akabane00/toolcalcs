---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('automotive-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Automotive Calculators"
    }
  ]
};
---

<BaseLayout
  title="6 Free Automotive Calculators (2026) - Car Payment, Depreciation & More"
  description="Free automotive calculators: car payment, depreciation, fuel cost, EV vs gas comparison, car affordability, and total cost of ownership."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Automotive Calculators</span>
  </nav>

  <h1>Automotive Calculators</h1>
  <p class="page-desc">Free tools for car buyers, owners, and commuters. Calculate payments, compare fuel costs, estimate depreciation, and find out what you can truly afford.</p>

  <section class="cat-intro">
    <p>Our 6 automotive calculators help you make smarter car buying decisions. Compare loan terms, estimate year-by-year depreciation, calculate fuel costs for any commute, and see the true 5-year cost of owning any vehicle. All tools are free, instant, and run privately in your browser.</p>
  </section>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/automotive-calculators/car-payment-calculator/" class="popular-chip">Car Payment</a>
      <a href="/automotive-calculators/car-depreciation-calculator/" class="popular-chip">Depreciation</a>
      <a href="/automotive-calculators/fuel-cost-calculator/" class="popular-chip">Fuel Cost</a>
      <a href="/automotive-calculators/ev-vs-gas-calculator/" class="popular-chip">EV vs Gas</a>
      <a href="/automotive-calculators/car-affordability-calculator/" class="popular-chip">Affordability</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/automotive-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Automotive Guides & Articles</h2>
    <p class="quick-ref-desc">Learn how to save money on your next car purchase:</p>
    <div class="quick-ref-grid">
      <a href="/blog/car-lease-vs-buy/" class="quick-ref-card"><span>🚗</span> Car Lease vs Buy: Which Is Better?</a>
      <a href="/blog/how-to-calculate-gas-cost/" class="quick-ref-card"><span>⛽</span> How to Calculate Gas Cost</a>
      <a href="/blog/how-much-car-insurance-do-i-need/" class="quick-ref-card"><span>🛡️</span> How Much Car Insurance Do I Need?</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="automotive-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .cat-intro {
    padding: 16px 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 24px;
  }
  .cat-intro a { color: var(--color-primary); font-weight: 500; }
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
