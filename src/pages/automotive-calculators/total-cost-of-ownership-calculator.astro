        "item": "https://toolcalcs.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Automotive Calculators",
        "item": "https://toolcalcs.com/automotive-calculators/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Total Cost of Ownership Calculator"
