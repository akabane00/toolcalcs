          <tr><td>1/2 cup (8 tbsp)</td><td>1/4 cup (4 tbsp)</td><td>1 cup (16 tbsp)</td><td>1 1/2 cups (24 tbsp)</td></tr>
          <tr><td>1/3 cup (5 tbsp + 1 tsp)</td><td>2 tbsp + 2 tsp</td><td>2/3 cup (10 tbsp + 2 tsp)</td><td>1 cup (16 tbsp)</td></tr>
