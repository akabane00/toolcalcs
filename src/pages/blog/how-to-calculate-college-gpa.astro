        <tr><td style="padding: 10px; border: 1px solid var(--color-border);">U.S. History</td><td style="padding: 10px; text-align: center; border: 1px solid var(--color-border);">3</td><td style="padding: 10px; text-align: center; border: 1px solid var(--color-border);">A</td><td style="padding: 10px; text-align: center; border: 1px solid var(--color-border);">4.0</td><td style="padding: 10px; text-align: center; border: 1px solid var(--color-border);">12.0</td></tr>
        <tr style="background-color: var(--color-surface);"><td style="padding: 10px; border: 1px solid var(--color-border);"><strong>Totals</strong></td><td style="padding: 10px; text-align: center; border: 1px solid var(--color-border);"><strong>17</strong></td><td style="padding: 10px; text-align: center; border: 1px solid var(--color-border);"></td><td style="padding: 10px; text-align: center; border: 1px solid var(--color-border);"></td><td style="padding: 10px; text-align: center; border: 1px solid var(--color-border);"><strong>60.3</strong></td></tr>
      </tbody>
