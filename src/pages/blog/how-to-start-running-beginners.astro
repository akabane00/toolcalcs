            </tr>
            <tr style="border-bottom:1px solid var(--color-border)">
              <td style="padding:0.75rem">Week 4</td>
              <td style="padding:0.75rem">Run 4 min, Walk 1 min (repeat 5x)</td>
              <td style="padding:0.75rem">~25 min</td>
            </tr>
            <tr style="border-bottom:1px solid var(--color-border)">
              <td style="padding:0.75rem">Week 5</td>
