---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogArticles } from '../../data/blog-articles';

const articles = [...blogArticles]
  .sort((a, b) => b.datePublished.localeCompare(a.datePublished));

// Get unique categories with counts
const categoryMap = new Map<string, number>();
for (const a of articles) {
  categoryMap.set(a.category, (categoryMap.get(a.category) || 0) + 1);
}
const categoryList = [...categoryMap.entries()].sort((a, b) => b[1] - a[1]);

function formatDate(iso: string): string {
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title="Blog - 190+ Expert Guides on Finance, Health & Education | ToolCalcs"
  description="190+ expert guides on personal finance, investing, health, education, and more. CPA-reviewed articles with data tables, calculators, and actionable advice."
>
  <h1>Guides & Articles</h1>
  <p class="blog-intro">{articles.length} practical guides to help you understand the math behind everyday decisions.</p>

  <!-- Category Filter -->
  <div class="filter-bar" id="filter-bar">
    <button class="filter-chip active" data-category="all">All ({articles.length})</button>
    {categoryList.map(([cat, count]) => (
      <button class="filter-chip" data-category={cat}>{cat} ({count})</button>
    ))}
  </div>

  <!-- Search -->
  <div class="blog-search">
    <input type="text" id="blog-search-input" placeholder="Search articles..." class="blog-search-input" />
  </div>

  <div class="article-grid" id="article-grid">
    {articles.map(article => (
      <a href={`/blog/${article.slug}/`} class="article-card" data-category={article.category} data-title={article.title.toLowerCase()} data-desc={article.description.toLowerCase()}>
        <span class="article-category">{article.category}</span>
        <h2>{article.title}</h2>
        <p>{article.description}</p>
        <span class="article-date">{formatDate(article.datePublished)}</span>
      </a>
    ))}
  </div>

  <p class="no-results" id="no-results" style="display:none">No articles found. Try a different search term or category.</p>

  <section class="explore-more">
    <h2>Explore More on ToolCalcs</h2>
    <div class="explore-grid">
      <a href="/financial-calculators/" class="explore-card">
        <span class="explore-icon">💰</span>
        <strong>Financial Calculators</strong>
        <p>Mortgage, loan, savings & investment tools</p>
      </a>
      <a href="/health-calculators/" class="explore-card">
        <span class="explore-icon">❤️</span>
        <strong>Health Calculators</strong>
        <p>BMI, BMR, calorie & fitness calculators</p>
      </a>
      <a href="/test/" class="explore-card">
        <span class="explore-icon">🧠</span>
        <strong>Tests & Games</strong>
        <p>IQ tests, memory games & brain challenges</p>
      </a>
      <a href="/worksheets/" class="explore-card">
        <span class="explore-icon">📝</span>
        <strong>Math Worksheets</strong>
        <p>Free printable worksheets for all grades</p>
      </a>
      <a href="/tools/" class="explore-card">
        <span class="explore-icon">🔧</span>
        <strong>Web Tools</strong>
        <p>QR codes, color pickers, text tools & more</p>
      </a>
      <a href="/education-calculators/" class="explore-card">
        <span class="explore-icon">🎓</span>
        <strong>Education Calculators</strong>
        <p>GPA, college cost, student loan & SAT tools</p>
      </a>
    </div>
  </section>

  <script>
    (function() {
      var chips = document.querySelectorAll('.filter-chip');
      var cards = document.querySelectorAll('.article-card');
      var searchInput = document.getElementById('blog-search-input');
      var noResults = document.getElementById('no-results');
      var activeCategory = 'all';

      function filterCards() {
        var query = (searchInput ? searchInput.value.toLowerCase().trim() : '');
        var visible = 0;

        cards.forEach(function(card) {
          var cat = card.getAttribute('data-category');
          var title = card.getAttribute('data-title') || '';
          var desc = card.getAttribute('data-desc') || '';

          var catMatch = (activeCategory === 'all' || cat === activeCategory);
          var searchMatch = (!query || title.indexOf(query) !== -1 || desc.indexOf(query) !== -1);

          if (catMatch && searchMatch) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        });

        if (noResults) {
          noResults.style.display = visible === 0 ? 'block' : 'none';
        }
      }

      chips.forEach(function(chip) {
        chip.addEventListener('click', function() {
          chips.forEach(function(c) { c.classList.remove('active'); });
          chip.classList.add('active');
          activeCategory = chip.getAttribute('data-category') || 'all';
          filterCards();
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', filterCards);
      }
    })();
  </script>
</BaseLayout>

<style>
  h1 { font-size: 1.8rem; margin-bottom: 8px; }
  .blog-intro { color: var(--color-text-muted); margin-bottom: 1.5rem; }

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }
  .filter-chip {
    padding: 6px 14px;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-chip:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .filter-chip.active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .blog-search {
    margin-bottom: 20px;
  }
  .blog-search-input {
    width: 100%;
    max-width: 400px;
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.95rem;
    background: var(--color-surface);
    color: var(--color-text);
  }
  .blog-search-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .no-results {
    text-align: center;
    color: var(--color-text-muted);
    padding: 40px 0;
    font-size: 0.95rem;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }
  .article-card {
    display: block;
    padding: 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .article-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    text-decoration: none;
  }
  .article-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .article-card h2 {
    font-size: 1.1rem;
    margin: 0 0 8px;
    line-height: 1.4;
  }
  .article-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 12px;
  }
  .article-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .explore-more {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .explore-more h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }
  .explore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }
  .explore-card {
    display: block;
    padding: 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s;
  }
  .explore-card:hover {
    border-color: var(--color-primary);
    text-decoration: none;
  }
  .explore-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 8px;
  }
  .explore-card strong {
    display: block;
    margin-bottom: 4px;
  }
  .explore-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  @media (max-width: 640px) {
    .article-grid { grid-template-columns: 1fr; }
    .explore-grid { grid-template-columns: 1fr; }
  }
</style>
