---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogArticles } from '../../data/blog-articles';

const articles = [...blogArticles]
  .sort((a, b) => b.datePublished.localeCompare(a.datePublished));

function formatDate(iso: string): string {
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Blog - Guides & Tips | ToolCalcs" description="Practical guides on finance, health, math, and everyday calculations. Learn how to use percentages, understand your paycheck, calculate compound interest, and more.">
  <h1>Guides & Articles</h1>
  <p class="blog-intro">Practical guides to help you understand the math behind everyday decisions.</p>

  <div class="article-grid">
    {articles.map(article => (
      <a href={`/blog/${article.slug}/`} class="article-card">
        <span class="article-category">{article.category}</span>
        <h2>{article.title}</h2>
        <p>{article.description}</p>
        <span class="article-date">{formatDate(article.datePublished)}</span>
      </a>
    ))}
  </div>

  <section class="explore-more">
    <h2>Explore More on ToolCalcs</h2>
    <div class="explore-grid">
      <a href="/financial-calculators/" class="explore-card">
        <span class="explore-icon">💰</span>
        <strong>Financial Calculators</strong>
        <p>Mortgage, loan, savings & investment tools</p>
      </a>
      <a href="/health-calculators/" class="explore-card">
        <span class="explore-icon">❤️</span>
        <strong>Health Calculators</strong>
        <p>BMI, BMR, calorie & fitness calculators</p>
      </a>
      <a href="/test/" class="explore-card">
        <span class="explore-icon">🧠</span>
        <strong>Tests & Games</strong>
        <p>IQ tests, memory games & brain challenges</p>
      </a>
      <a href="/worksheets/" class="explore-card">
        <span class="explore-icon">📝</span>
        <strong>Math Worksheets</strong>
        <p>Free printable worksheets for all grades</p>
      </a>
      <a href="/tools/" class="explore-card">
        <span class="explore-icon">🔧</span>
        <strong>Web Tools</strong>
        <p>QR codes, color pickers, text tools & more</p>
      </a>
      <a href="/math-calculators/" class="explore-card">
        <span class="explore-icon">🔢</span>
        <strong>Math Calculators</strong>
        <p>Percentage, fraction & algebra solvers</p>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  h1 { font-size: 1.8rem; margin-bottom: 8px; }
  .blog-intro { color: var(--color-text-muted); margin-bottom: 2rem; }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }
  .article-card {
    display: block;
    padding: 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .article-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    text-decoration: none;
  }
  .article-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-primary);
    margin-bottom: 8px;
  }
  .article-card h2 {
    font-size: 1.1rem;
    margin: 0 0 8px;
    line-height: 1.4;
  }
  .article-card p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 12px;
  }
  .article-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
  .explore-more {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .explore-more h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }
  .explore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }
  .explore-card {
    display: block;
    padding: 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s;
  }
  .explore-card:hover {
    border-color: var(--color-primary);
    text-decoration: none;
  }
  .explore-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 8px;
  }
  .explore-card strong {
    display: block;
    margin-bottom: 4px;
  }
  .explore-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
