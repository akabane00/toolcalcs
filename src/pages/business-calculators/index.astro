---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('business-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Business Calculators" }
  ]
};
---

<BaseLayout
  title="Business Calculators - Break-Even, Profit Margin, LLC vs S-Corp & More"
  description="Free business calculators for entrepreneurs: break-even analysis, profit margins, LLC vs S-Corp tax comparison, payroll costs, SBA loans, and ROI."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Business Calculators</span>
  </nav>

  <h1>Business Calculators</h1>
  <p class="page-desc">Free tools for entrepreneurs, freelancers, and small business owners. Analyze profitability, compare business structures, calculate payroll costs, and make smarter financial decisions.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/business-calculators/break-even-calculator/" class="popular-chip">Break-Even</a>
      <a href="/business-calculators/profit-margin-calculator/" class="popular-chip">Profit Margin</a>
      <a href="/business-calculators/llc-vs-scorp-calculator/" class="popular-chip">LLC vs S-Corp</a>
      <a href="/business-calculators/payroll-cost-calculator/" class="popular-chip">Payroll Cost</a>
      <a href="/business-calculators/business-roi-calculator/" class="popular-chip">Business ROI</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/business-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Business Guides & Articles</h2>
    <p class="quick-ref-desc">Learn the financial fundamentals every business owner needs:</p>
    <div class="quick-ref-grid">
      <a href="/blog/how-to-calculate-break-even-point/" class="quick-ref-card"><span>📊</span> How to Calculate Break-Even Point</a>
      <a href="/blog/llc-vs-s-corp-comparison/" class="quick-ref-card"><span>🏢</span> LLC vs S-Corp Tax Comparison</a>
      <a href="/blog/true-cost-of-employee/" class="quick-ref-card"><span>👥</span> True Cost of Hiring an Employee</a>
      <a href="/blog/profit-margin-guide/" class="quick-ref-card"><span>💰</span> Profit Margin Guide</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="business-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
