---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import RelatedCalculators from '../../components/RelatedCalculators.astro';
import ShareResults from '../../components/ShareResults.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import '../../styles/calculator.css';
import ReviewedBy from '../../components/ReviewedBy.astro';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Business Calculators", "item": "https://toolcalcs.com/business-calculators/" },
      { "@type": "ListItem", "position": 3, "name": "SBA Loan Calculator" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "What are current SBA 7(a) loan interest rates?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "SBA 7(a) loan rates are tied to the Prime Rate plus a spread set by the lender and capped by the SBA. For loans over $50,000 with terms over 7 years, the maximum rate is Prime + 2.75%. For loans $25,000–$50,000, the cap is Prime + 3.25%. For loans under $25,000, up to Prime + 4.25%. With the Prime Rate at 7.5% (early 2026), effective rates range from approximately 9.75% to 12% depending on loan size and term. Fixed-rate loans are available but less common."
        }
      },
      {
        "@type": "Question",
        name: "What is the SBA guarantee fee?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "The SBA charges a guarantee fee on the guaranteed portion of 7(a) loans over $150,000. The fee varies by loan size and term: loans $150,001–$700,000: 2% of guaranteed amount. Loans $700,001–$5M: 3% on first $1M guaranteed + 3.5% above $1M. Loans with terms of 12 months or less: 0.25% of guaranteed amount. The SBA guarantees 75–85% of the loan depending on size. This fee is typically financed into the loan. For SBA 504 loans, the fee structure is different — typically 0.5–1.5% of the CDC portion."
        }
      },
      {
        "@type": "Question",
        name: "What is the difference between SBA 7(a) and SBA 504 loans?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "SBA 7(a) loans are the most flexible — they can be used for working capital, equipment, real estate, inventory, or debt refinancing. Maximum loan: $5 million. Terms up to 25 years for real estate, 10 years for other uses. SBA 504 loans are specifically for fixed assets — commercial real estate and large equipment. Structure: 50% bank, 40% SBA/CDC, 10% borrower equity. Maximum SBA/CDC portion: $5.5 million ($5 million plus eligible public policy goals). Rates on 504 debentures are typically lower than 7(a) rates and fixed for the term (10, 20, or 25 years)."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="SBA Loan Calculator 2026 - Monthly Payment & Total Cost"
  description="Calculate monthly payments and total cost for SBA 7(a) and 504 loans. Compare SBA vs conventional business loan rates and see how much you can save."
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/business-calculators/">Business Calculators</a> &rsaquo;
    <span>SBA Loan Calculator</span>
  </nav>
  <p class="last-updated">Last updated March 2026</p>
  <h1>SBA Loan Calculator 2026</h1>
  <p class="page-desc">Calculate monthly payments, total interest, and total cost for SBA 7(a) and 504 loans. Compare against conventional business financing to see your savings.</p>

  <ReviewedBy />

  <div class="calc-box">
    <div class="calc-grid-2">
      <div class="input-group">
        <label for="sba-amount">Loan Amount</label>
        <div class="input-prefix"><span>$</span><input type="number" id="sba-amount" value="250000" min="5000" max="5000000" step="5000" /></div>
      </div>
      <div class="input-group">
        <label for="sba-type">Loan Type</label>
        <select id="sba-type">
          <option value="7a-wc">SBA 7(a) — Working Capital / Equipment (10yr)</option>
          <option value="7a-re">SBA 7(a) — Real Estate (25yr)</option>
          <option value="504">SBA 504 — Fixed Assets (20yr)</option>
          <option value="conventional">Conventional Business Loan (compare)</option>
        </select>
      </div>
      <div class="input-group">
        <label for="sba-rate">Interest Rate</label>
        <div class="input-prefix"><input type="number" id="sba-rate" value="10.5" min="1" max="30" step="0.25" /><span style="margin-left:4px">%</span></div>
        <small>SBA 7(a) typical: Prime + 2.75% = ~10.25% (2026). 504: ~7–8% fixed.</small>
      </div>
      <div class="input-group">
        <label for="sba-term">Custom Term (months)</label>
        <input type="number" id="sba-term" value="120" min="12" max="300" step="12" />
        <small>120 = 10yr, 180 = 15yr, 240 = 20yr, 300 = 25yr</small>
      </div>
      <div class="input-group">
        <label for="sba-fee-pct">SBA Guarantee Fee</label>
        <div class="input-prefix"><input type="number" id="sba-fee-pct" value="2" min="0" max="5" step="0.25" /><span style="margin-left:4px">% of loan</span></div>
        <small>Typically 2–3.5% for loans over $150K. 0% for loans under $150K or SBA Express.</small>
      </div>
      <div class="input-group">
        <label for="sba-conv-rate">Conventional Rate (for comparison)</label>
        <div class="input-prefix"><input type="number" id="sba-conv-rate" value="13.5" min="1" max="30" step="0.25" /><span style="margin-left:4px">%</span></div>
        <small>Typical conventional business loan: 3–5% above SBA rates</small>
      </div>
    </div>
    <button class="calc-btn" id="calcBtnSBA">Calculate SBA Loan Cost</button>

    <div class="results" id="results-sba" style="display:none">
      <div class="result-cards">
        <div class="result-card primary">
          <div class="result-label">Monthly Payment</div>
          <div class="result-value" id="res-sba-monthly">$0</div>
        </div>
        <div class="result-card">
          <div class="result-label">Total Interest Paid</div>
          <div class="result-value" id="res-sba-interest">$0</div>
        </div>
        <div class="result-card">
          <div class="result-label">Total Cost (incl. fees)</div>
          <div class="result-value" id="res-sba-total">$0</div>
        </div>
        <div class="result-card">
          <div class="result-label">SBA Guarantee Fee</div>
          <div class="result-value" id="res-sba-fee">$0</div>
        </div>
      </div>
      <div class="result-cards" style="margin-top:12px">
        <div class="result-card">
          <div class="result-label">Conventional Monthly Payment</div>
          <div class="result-value" id="res-sba-conv-monthly">$0</div>
        </div>
        <div class="result-card">
          <div class="result-label">Monthly Savings vs Conventional</div>
          <div class="result-value" id="res-sba-savings-monthly">$0</div>
        </div>
        <div class="result-card">
          <div class="result-label">Total Interest (Conventional)</div>
          <div class="result-value" id="res-sba-conv-interest">$0</div>
        </div>
        <div class="result-card">
          <div class="result-label">Total Savings vs Conventional</div>
          <div class="result-value" id="res-sba-savings-total">$0</div>
        </div>
      </div>
    </div>
  </div>

  <AdUnit slot="calc-mid" format="rectangle" />
  <RelatedCalculators currentSlug="sba-loan-calculator" />

  <article class="seo-content">
    <h2>SBA Loan Guide 2026: Types, Rates, and How to Qualify</h2>
    <p>Small Business Administration loans offer below-market interest rates and longer repayment terms than conventional business loans — making them one of the most cost-effective forms of business financing available. However, the application process is more involved than a conventional loan, and approval can take weeks to months. Understanding the landscape before applying can significantly improve your chances of success.</p>

    <h3>SBA 7(a) Loans — The Most Flexible Option</h3>
    <p>The SBA 7(a) loan program is the SBA's primary lending program and the most versatile. Uses include working capital, equipment purchases, real estate acquisition, business acquisition, and refinancing existing business debt.</p>
    <ul>
      <li><strong>Maximum loan amount:</strong> $5 million</li>
      <li><strong>SBA guarantee:</strong> 85% for loans up to $150,000; 75% for larger loans</li>
      <li><strong>Terms:</strong> Up to 10 years for working capital/equipment; up to 25 years for real estate</li>
      <li><strong>Rates:</strong> Variable, tied to Prime Rate. Maximum spread: Prime + 2.75% for loans over $50K with terms over 7 years (approximately 10.25% as of early 2026)</li>
      <li><strong>Minimum requirements:</strong> 2+ years in business, good personal credit (680+ preferred), able to repay from business cash flow</li>
    </ul>

    <h3>SBA 504 Loans — For Major Fixed Assets</h3>
    <p>The 504 program is specifically designed for long-term, fixed-rate financing of major fixed assets: commercial real estate and large equipment. The structure involves three parties: a bank (50%), a Certified Development Company/CDC (40%), and the borrower (10% down).</p>
    <ul>
      <li><strong>Maximum CDC/SBA portion:</strong> $5.5 million (higher for manufacturing and clean energy)</li>
      <li><strong>Down payment:</strong> Only 10% (vs 20–30% for conventional commercial real estate loans)</li>
      <li><strong>Rates:</strong> Fixed rate, tied to Treasury bonds. Typically 6.5–8% for the CDC portion (2026); bank portion varies</li>
      <li><strong>Terms:</strong> 10, 20, or 25 years</li>
      <li><strong>Job creation requirement:</strong> Must create or retain one job per $75,000 of SBA financing</li>
    </ul>

    <h3>SBA Express Loans — Faster but Smaller</h3>
    <p>For smaller and faster funding needs, SBA Express loans offer a 36-hour turnaround on approval decisions (though full funding still takes longer). Maximum loan: $500,000. SBA guarantee: 50% (lower guarantee = faster process). These are best for revolving lines of credit or quick working capital needs.</p>

    <h3>How to Improve Your SBA Loan Application</h3>
    <ul>
      <li><strong>Credit score:</strong> Most SBA lenders want 680+ personal credit. Some preferred lenders go as low as 650. Work on your score before applying.</li>
      <li><strong>Time in business:</strong> 2+ years is the standard minimum. Newer businesses have fewer options (SBA Microloan, community lenders, SBDC assistance).</li>
      <li><strong>Business plan:</strong> SBA lenders review your plan, financial projections, and ability to repay from business cash flow. A well-prepared business plan accelerates approval.</li>
      <li><strong>Down payment:</strong> Having 10–20% of the loan amount as a down payment demonstrates financial commitment and reduces the lender's risk.</li>
      <li><strong>Collateral:</strong> SBA loans require collateral where available — often the business assets being purchased, and sometimes personal real estate.</li>
    </ul>
  </article>

  <section class="faq-section">
    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      <div class="faq-item">
        <h3>What are current SBA 7(a) loan interest rates?</h3>
        <p>SBA 7(a) rates are Prime Rate + lender spread (SBA-capped). For loans over $50K with terms over 7 years, max rate = Prime + 2.75%. With Prime at 7.5% (2026), effective rates run approximately 10–10.5%. SBA 504 rates are lower and fixed, typically 6.5–8% on the CDC portion.</p>
      </div>
      <div class="faq-item">
        <h3>What is the SBA guarantee fee?</h3>
        <p>For 7(a) loans over $150K: 2% of the guaranteed portion for loans $150K–$700K. 3–3.5% for larger loans. Loans under $150K: often fee-free. The fee is typically financed into the loan. SBA periodically waives fees for small loans (check current SBA guidance).</p>
      </div>
      <div class="faq-item">
        <h3>What is the difference between SBA 7(a) and SBA 504 loans?</h3>
        <p>7(a) is flexible — working capital, equipment, real estate, acquisition. 504 is for fixed assets (commercial real estate, large equipment) only. 504 offers a lower fixed rate and requires only 10% down. 7(a) has a variable rate and is faster to fund. Most small businesses start with 7(a); 504 is ideal for real estate purchases.</p>
      </div>
    </div>
  </section>

  <RelatedArticles calculatorSlug="sba-loan-calculator" />
  <AdUnit slot="calc-bottom" format="horizontal" />
</BaseLayout>

<script>
  function fmt(n) { return '$' + Math.round(Math.abs(n)).toLocaleString('en-US'); }

  function calcPayment(principal, annualRate, months) {
    var r = annualRate / 100 / 12;
    if (r === 0) return principal / months;
    return principal * (r * Math.pow(1 + r, months)) / (Math.pow(1 + r, months) - 1);
  }

  document.getElementById('calcBtnSBA').addEventListener('click', function() {
    var amount = parseFloat(document.getElementById('sba-amount').value) || 0;
    var rate = parseFloat(document.getElementById('sba-rate').value) || 10.5;
    var term = parseInt(document.getElementById('sba-term').value) || 120;
    var feePct = (parseFloat(document.getElementById('sba-fee-pct').value) || 0) / 100;
    var convRate = parseFloat(document.getElementById('sba-conv-rate').value) || 13.5;

    var fee = amount * feePct;
    var totalLoan = amount + fee;

    var monthly = calcPayment(totalLoan, rate, term);
    var totalInterest = (monthly * term) - totalLoan;
    var totalCost = monthly * term;

    var convMonthly = calcPayment(amount, convRate, term);
    var convTotalInterest = (convMonthly * term) - amount;

    var savingsMonthly = convMonthly - monthly;
    var savingsTotal = convTotalInterest - totalInterest - fee;

    document.getElementById('res-sba-monthly').textContent = fmt(monthly);
    document.getElementById('res-sba-interest').textContent = fmt(totalInterest);
    document.getElementById('res-sba-total').textContent = fmt(totalCost);
    document.getElementById('res-sba-fee').textContent = fmt(fee);
    document.getElementById('res-sba-conv-monthly').textContent = fmt(convMonthly);
    document.getElementById('res-sba-savings-monthly').textContent = fmt(Math.abs(savingsMonthly));
    document.getElementById('res-sba-conv-interest').textContent = fmt(convTotalInterest);
    document.getElementById('res-sba-savings-total').textContent = (savingsTotal >= 0 ? '' : '-') + fmt(savingsTotal);
    document.getElementById('results-sba').style.display = '';
  });
</script>
