---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import '../../styles/calculator.css';
import { getAllCompoundInterestPages, PRINCIPALS, RATES, formatMoney } from '../../data/compound-interest';
import type { CompoundInterestPage } from '../../data/compound-interest';

const allPages = getAllCompoundInterestPages();
const count = allPages.length;

// Build a matrix: for each principal, pick ~8-10 popular combos
const principalLabels: { value: number; display: string }[] = [
  { value: 1000, display: '$1,000' },
  { value: 5000, display: '$5,000' },
  { value: 10000, display: '$10,000' },
  { value: 25000, display: '$25,000' },
  { value: 50000, display: '$50,000' },
  { value: 100000, display: '$100,000' },
];

// Popular combos per principal: mix of rates and years
const popularCombos = [
  { rate: 3, years: 5 },
  { rate: 4, years: 10 },
  { rate: 5, years: 5 },
  { rate: 5, years: 10 },
  { rate: 5, years: 20 },
  { rate: 6, years: 10 },
  { rate: 7, years: 10 },
  { rate: 7, years: 20 },
  { rate: 8, years: 10 },
  { rate: 10, years: 15 },
];

function getPagesForPrincipal(principalVal: number): CompoundInterestPage[] {
  var results: CompoundInterestPage[] = [];
  for (var i = 0; i < popularCombos.length; i++) {
    var combo = popularCombos[i];
    var match = allPages.find(function (p) {
      return p.principal === principalVal && p.rate === combo.rate && p.years === combo.years;
    });
    if (match) {
      results.push(match);
    }
  }
  return results;
}

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Compound Interest Calculator"
    }
  ]
};
---

<BaseLayout
  title="Compound Interest Calculator - See How Your Money Grows | ToolCalcs"
  description={`Browse ${count} pre-calculated compound interest scenarios. See how investments from $1,000 to $100,000 grow at various rates over 1 to 30 years with monthly compounding.`}
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Compound Interest Calculator</span>
  </nav>

  <h1>Compound Interest Calculator</h1>
  <p class="page-desc">See how your money grows with compound interest. Browse {count} pre-calculated scenarios below, or click any card to view the full year-by-year breakdown.</p>

  <AdUnit slot="ci-idx-top" format="horizontal" />

  {principalLabels.map(function (pl) {
    var pages = getPagesForPrincipal(pl.value);
    return (
      <section class="ci-principal-section">
        <h2 class="ci-principal-heading">{pl.display} Compound Interest</h2>
        <div class="ci-card-grid">
          {pages.map(function (p) {
            return (
              <a href={`/compound-interest/${p.slug}/`} class="ci-card">
                <span class="ci-card-rate">{p.rate}% for {p.years} yrs</span>
                <span class="ci-card-result">${formatMoney(p.finalAmount)}</span>
                <span class="ci-card-interest">+${formatMoney(p.totalInterest)} interest</span>
              </a>
            );
          })}
        </div>
      </section>
    );
  })}

  <!-- SEO Content -->
  <article class="content-section">
    <h2>What Is Compound Interest?</h2>
    <p>
      Compound interest is the process of earning interest not only on your original principal, but also on all the interest that has already been added to your balance. Unlike simple interest, which is calculated only on the initial amount, compound interest causes your money to grow exponentially over time. This is why compound interest is often called the most powerful force in finance.
    </p>
    <p>
      The compound interest formula is A = P(1 + r/n)<sup>nt</sup>, where P is the principal, r is the annual interest rate, n is the number of compounding periods per year, and t is the time in years. All scenarios on this page use monthly compounding (n = 12), which is the most common compounding frequency for savings accounts and investments.
    </p>

    <h2>Why Compound Interest Matters</h2>
    <p>
      The key to building wealth through compound interest is time. The longer your money is invested, the more dramatic the compounding effect becomes. An investment that earns a modest return of 5% to 7% annually can grow to several times its original value over 20 or 30 years, thanks to the snowball effect of compounding.
    </p>
    <p>
      For example, $10,000 invested at 7% compounded monthly grows to over $40,000 in 20 years, with more than $30,000 of that coming from interest alone. Starting early and staying invested is the single most effective strategy for maximizing the benefits of compound interest.
    </p>

    <h2>How to Use These Pages</h2>
    <p>
      Browse the scenarios above organized by starting amount. Each card shows the interest rate, time period, and final balance. Click any card to see a complete year-by-year breakdown, the effective annual rate, doubling time, and a detailed explanation of the math. You can also use the interactive calculator on each page to try custom values. Whether you are saving for retirement, a home, or your children's education, understanding compound interest is essential for making smart financial decisions.
    </p>

    <p><a href="/">Back to ToolCalcs Home &rarr;</a></p>
  </article>

  <AdUnit slot="ci-idx-bottom" format="horizontal" />
</BaseLayout>

<style>
  .ci-principal-section {
    margin-bottom: 36px;
  }
  .ci-principal-heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
  }
  .ci-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 10px;
    margin-bottom: 8px;
  }
  .ci-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 16px 12px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .ci-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.1);
  }
  .ci-card-rate {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .ci-card-result {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--color-primary);
  }
  .ci-card-interest {
    font-size: 0.8rem;
    color: var(--color-success, #16a34a);
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .ci-card-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    }
    .ci-card-result {
      font-size: 1.1rem;
    }
  }
</style>
