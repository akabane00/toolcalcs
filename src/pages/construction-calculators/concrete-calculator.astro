<script is:inline>
  var activeShape = 'slab';

  function calculate() {
    var volumeFt3 = 0;

    if (activeShape === 'slab') {
      var slabL = parseFloat(document.getElementById('slabLength').value) || 0;
      var slabW = parseFloat(document.getElementById('slabWidth').value) || 0;
      var slabD = parseFloat(document.getElementById('slabDepth').value) || 0;
      volumeFt3 = slabL * slabW * (slabD / 12);
    } else if (activeShape === 'footing') {
      var footL = parseFloat(document.getElementById('footingLength').value) || 0;
      var footW = parseFloat(document.getElementById('footingWidth').value) || 0;
      var footD = parseFloat(document.getElementById('footingDepth').value) || 0;
      volumeFt3 = footL * (footW / 12) * (footD / 12);
    } else if (activeShape === 'column') {
      var colDia = parseFloat(document.getElementById('columnDiameter').value) || 0;
      var colH = parseFloat(document.getElementById('columnHeight').value) || 0;
      var colCount = parseInt(document.getElementById('columnCount').value) || 0;
      var radiusFt = colDia / 24;
      volumeFt3 = Math.PI * radiusFt * radiusFt * colH * colCount;
    } else if (activeShape === 'stairs') {
      var steps = parseInt(document.getElementById('stairSteps').value) || 0;
      var stairW = parseFloat(document.getElementById('stairWidth').value) || 0;
      var stairRise = parseFloat(document.getElementById('stairRise').value) || 0;
      var stairRun = parseFloat(document.getElementById('stairRun').value) || 0;
      volumeFt3 = stairW * (stairRun / 12) * (stairRise / 12) * steps * (steps + 1) / 2;
    }

    var cubicYards = volumeFt3 / 27;
    var pricePerYard = parseFloat(document.getElementById('pricePerYard').value) || 0;
    var bags40 = Math.ceil(cubicYards * 81);
    var bags60 = Math.ceil(cubicYards * 54);
    var bags80 = Math.ceil(cubicYards * 40.5);
    var cost = cubicYards * pricePerYard;

    document.getElementById('resultCubicYards').textContent = cubicYards.toFixed(2);
    document.getElementById('resultCubicFeet').textContent = volumeFt3.toFixed(2);
    document.getElementById('resultBags40').textContent = bags40.toLocaleString();
    document.getElementById('resultBags60').textContent = bags60.toLocaleString();
    document.getElementById('resultBags80').textContent = bags80.toLocaleString();
    document.getElementById('resultCost').textContent = '$' + cost.toFixed(2);
  }

  // Shape tab switching
  var shapeTabs = document.querySelectorAll('.shape-tab');
  for (var i = 0; i < shapeTabs.length; i++) {
    shapeTabs[i].addEventListener('click', function () {
      var shape = this.getAttribute('data-shape');
      activeShape = shape;

      var allTabs = document.querySelectorAll('.shape-tab');
      for (var j = 0; j < allTabs.length; j++) {
        allTabs[j].classList.remove('active');
      }
      this.classList.add('active');

      var allPanels = document.querySelectorAll('.shape-panel');
      for (var k = 0; k < allPanels.length; k++) {
        allPanels[k].classList.remove('active');
      }
      document.getElementById('panel-' + shape).classList.add('active');

      calculate();
    });
  }

  // Real-time calculation on input changes
  document.querySelectorAll('.calc-inputs input, .calc-inputs select').forEach(function (el) {
    el.addEventListener('input', calculate);
  });

  // Initial calculation
  calculate();
</script>