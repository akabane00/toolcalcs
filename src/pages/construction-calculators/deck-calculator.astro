        </div>
        <div class="result-card">
          <span class="result-label">Decking Boards</span>
          <span class="result-value" id="deckingBoards">0</span>
          <span class="result-sub" id="deckingLinFt"></span>
        </div>
        <div class="result-card">
          <span class="result-label">Joists</span>
          <span class="result-value" id="joistCount">0</span>
