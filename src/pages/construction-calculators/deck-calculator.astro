<script is:inline>
  function calculate() {
    var deckLength = parseFloat(document.getElementById('deckLength').value) || 0;
    var deckWidth = parseFloat(document.getElementById('deckWidth').value) || 0;
    var boardWidth = parseFloat(document.getElementById('boardWidth').value) || 5.5;
    var joistSpacing = parseFloat(document.getElementById('joistSpacing').value) || 16;
    var deckHeight = parseFloat(document.getElementById('deckHeight').value) || 3;
    var railingLength = parseFloat(document.getElementById('railingLength').value) || 0;
    var pricePerLinFt = parseFloat(document.getElementById('pricePerLinFt').value) || 0;

    // Deck area
    var area = deckLength * deckWidth;

    // Decking boards: width in inches / (board width + 1/8" gap)
    var boardCount = Math.ceil((deckWidth * 12) / (boardWidth + 0.125));
    var totalDeckingLinFt = boardCount * deckLength;

    // Joists: length in inches / spacing + 1
    var joistCount = Math.ceil((deckLength * 12) / joistSpacing) + 1;
    var totalJoistLinFt = joistCount * deckWidth;

    // Support posts: ~6ft beam spacing, 2 rows
    var postsPerRow = Math.ceil(deckLength / 6) + 1;
    var supportPosts = postsPerRow * 2;

    // Railing posts: every 6 ft + 1
    var railingPosts = 0;
    var balusterCount = 0;
    var railingPostsCard = document.getElementById('railingPostsCard');
    var balustersCard = document.getElementById('balustersCard');

    if (railingLength > 0) {
      railingPosts = Math.ceil(railingLength / 6) + 1;
      balusterCount = Math.ceil((railingLength * 12) / 4.75);
      railingPostsCard.style.display = 'block';
      balustersCard.style.display = 'block';
    } else {
      railingPostsCard.style.display = 'none';
      balustersCard.style.display = 'none';
    }

    // Cost: decking + joist linear feet * price
    var totalLinFt = totalDeckingLinFt + totalJoistLinFt;
    var cost = totalLinFt * pricePerLinFt;

    // Update results
    document.getElementById('deckArea').textContent = area.toFixed(0).toLocaleString() + ' sq ft';
    document.getElementById('deckingBoards').textContent = boardCount.toLocaleString();
    document.getElementById('deckingLinFt').textContent = totalDeckingLinFt.toLocaleString() + ' linear ft';
    document.getElementById('joistCount').textContent = joistCount.toLocaleString();
    document.getElementById('joistLinFt').textContent = totalJoistLinFt.toLocaleString() + ' linear ft';
    document.getElementById('supportPosts').textContent = supportPosts.toLocaleString();
    document.getElementById('railingPosts').textContent = railingPosts.toLocaleString();
    document.getElementById('balusters').textContent = balusterCount.toLocaleString();
    document.getElementById('estimatedCost').textContent = '$' + Math.round(cost).toLocaleString();
    document.getElementById('totalLinFtLabel').textContent = totalLinFt.toLocaleString() + ' total linear ft';
  }

  document.querySelectorAll('.calc-inputs input, .calc-inputs select').forEach(function(el) {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  calculate();
</script>
