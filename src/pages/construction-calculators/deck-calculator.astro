          <span class="result-label">Support Posts (4&times;4)</span>
          <span class="result-value" id="supportPosts">0</span>
        </div>
        <div class="result-card" id="railingPostsCard">
          <span class="result-label">Railing Posts</span>
          <span class="result-value" id="railingPosts">0</span>
        </div>
