        <input type="number" id="deckWidth" value="12" min="1" step="0.5" />
      </div>
      <div class="input-group">
        <label for="boardWidth">Board Width</label>
        <select id="boardWidth">
          <option value="3.5">3.5" (2&times;4)</option>
          <option value="5.5" selected>5.5" (2&times;6)</option>
          <option value="7.25">7.25" (2&times;8)</option>
        </select>
      </div>
      <div class="input-group">
        <label for="joistSpacing">Joist Spacing</label>
        <select id="joistSpacing">
          <option value="12">12" on center</option>
          <option value="16" selected>16" on center</option>
          <option value="24">24" on center</option>
        </select>
      </div>
      <div class="input-group">
