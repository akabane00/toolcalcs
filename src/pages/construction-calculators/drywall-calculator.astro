      <div class="result-cards">
        <div class="result-card primary">
          <span class="result-label">Total Area (sq ft)</span>
          <span class="result-value" id="resultTotalArea">0</span>
        </div>
        <div class="result-card">
          <span class="result-label">Sheets Needed</span>
          <span class="result-value" id="resultSheets">0</span>
        </div>
