<script is:inline>
  function calculate() {
    var length = parseFloat(document.getElementById('roomLength').value) || 0;
    var width = parseFloat(document.getElementById('roomWidth').value) || 0;
    var height = parseFloat(document.getElementById('ceilingHeight').value) || 0;
    var doors = parseInt(document.getElementById('numDoors').value) || 0;
    var windows = parseInt(document.getElementById('numWindows').value) || 0;
    var includeCeiling = document.getElementById('includeCeiling').value;
    var sheetSize = document.getElementById('sheetSize').value;
    var pricePerSheet = parseFloat(document.getElementById('pricePerSheet').value) || 0;

    // Sheet area lookup
    var sheetAreas = { '4x8': 32, '4x10': 40, '4x12': 48 };
    var sheetArea = sheetAreas[sheetSize] || 32;

    // Wall area
    var wallArea = 2 * (length + width) * height;

    // Door and window deductions
    var doorDeduction = doors * 21;
    var windowDeduction = windows * 15;

    // Ceiling area
    var ceilingArea = 0;
    if (includeCeiling === 'yes') {
      ceilingArea = length * width;
    }

    // Total area
    var totalArea = wallArea + ceilingArea - doorDeduction - windowDeduction;
    if (totalArea < 0) totalArea = 0;

    // Sheets needed (10% waste)
    var sheetsNeeded = Math.ceil(totalArea / sheetArea * 1.1);

    // Joint compound (gallons) - 1 gallon per 100 sq ft
    var compound = Math.ceil(totalArea / 100);

    // Joint tape (ft) - perimeter × rows of sheets × 2
    var perimeter = 2 * (length + width);
    var rows = Math.ceil(height / 4);
    var tape = Math.round(perimeter * rows * 2);

    // Estimated cost
    var cost = sheetsNeeded * pricePerSheet;

    // Display results
    document.getElementById('resultTotalArea').textContent = totalArea.toFixed(2);
    document.getElementById('resultSheets').textContent = sheetsNeeded.toLocaleString();
    document.getElementById('resultCompound').textContent = compound.toLocaleString();
    document.getElementById('resultTape').textContent = tape.toLocaleString();
    document.getElementById('resultCost').textContent = '$' + Math.round(cost).toLocaleString();
  }

  document.querySelectorAll('.calc-inputs input, .calc-inputs select').forEach(function(el) {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  calculate();
</script>
