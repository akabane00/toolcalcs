        <label for="sheetSize">Sheet Size</label>
        <select id="sheetSize">
          <option value="4x8" selected>4×8 (32 sq ft)</option>
          <option value="4x10">4×10 (40 sq ft)</option>
          <option value="4x12">4×12 (48 sq ft)</option>
        </select>
      </div>
      <div class="input-group">
