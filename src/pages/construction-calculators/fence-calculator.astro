<script is:inline>
  function calculate() {
    var totalLength = parseFloat(document.getElementById('totalLength').value) || 0;
    var fenceHeight = parseFloat(document.getElementById('fenceHeight').value) || 6;
    var fenceStyle = document.getElementById('fenceStyle').value;
    var postSpacing = parseFloat(document.getElementById('postSpacing').value) || 8;
    var gateCount = parseInt(document.getElementById('gateCount').value) || 0;
    var gateWidth = parseFloat(document.getElementById('gateWidth').value) || 4;
    var postPrice = parseFloat(document.getElementById('postPrice').value) || 0;
    var picketPrice = parseFloat(document.getElementById('picketPrice').value) || 0;

    // Ensure post spacing within bounds
    if (postSpacing < 4) postSpacing = 4;
    if (postSpacing > 10) postSpacing = 10;

    // Calculate fenceable length
    var fenceableLength = totalLength - (gateCount * gateWidth);
    if (fenceableLength < 0) fenceableLength = 0;

    // Calculate sections and posts
    var sections = Math.ceil(fenceableLength / postSpacing);
    var posts = sections + 1 + (gateCount * 2);

    // Calculate rails per section based on style
    var railsPerSection = 3;
    if (fenceStyle === 'picket') railsPerSection = 2;
    if (fenceStyle === 'ranch') railsPerSection = 3;
    var rails = sections * railsPerSection;

    // Calculate pickets/boards based on style
    var pickets = 0;
    var picketsCard = document.getElementById('picketsCard');
    var picketsLabel = document.getElementById('picketsLabel');

    if (fenceStyle === 'privacy') {
      // 5.5" boards with no gap
      pickets = sections * Math.ceil((postSpacing * 12) / 5.5);
      picketsLabel.textContent = 'Boards Needed';
      picketsCard.style.display = 'block';
    } else if (fenceStyle === 'picket') {
      // 3.5" picket + 3.5" gap = 7" per picket
      pickets = sections * Math.ceil((postSpacing * 12) / 7);
      picketsLabel.textContent = 'Pickets Needed';
      picketsCard.style.display = 'block';
    } else {
      // Ranch - rails only, no pickets
      pickets = 0;
      picketsLabel.textContent = 'Rails Only';
      picketsCard.style.display = 'none';
    }

    // Concrete: 2 bags per post
    var concreteBags = posts * 2;

    // Estimated cost
    var cost = (posts * postPrice) + (pickets * picketPrice) + (rails * 8) + (concreteBags * 6);

    // Update results
    document.getElementById('postsNeeded').textContent = posts.toLocaleString();
    document.getElementById('railsNeeded').textContent = rails.toLocaleString();
    document.getElementById('picketsNeeded').textContent = pickets.toLocaleString();
    document.getElementById('concreteBags').textContent = concreteBags.toLocaleString();
    document.getElementById('estimatedCost').textContent = '$' + Math.round(cost).toLocaleString();
  }

  document.querySelectorAll('.calc-inputs input, .calc-inputs select').forEach(function(el) {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  calculate();
</script>
