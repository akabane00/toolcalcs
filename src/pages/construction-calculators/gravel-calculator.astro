<script is:inline>
  var gravelData = {
    pea_gravel:         { density: 1.35, costMin: 35, costMax: 55 },
    crushed_stone:      { density: 1.4,  costMin: 30, costMax: 50 },
    river_rock:         { density: 1.3,  costMin: 40, costMax: 80 },
    decomposed_granite: { density: 1.35, costMin: 25, costMax: 50 },
    marble_chips:       { density: 1.3,  costMin: 70, costMax: 120 }
  };

  function calculate() {
    var length = parseFloat(document.getElementById('areaLength').value) || 0;
    var width = parseFloat(document.getElementById('areaWidth').value) || 0;
    var depth = parseFloat(document.getElementById('gravelDepth').value) || 0;
    var type = document.getElementById('gravelType').value;

    var data = gravelData[type] || gravelData.crushed_stone;

    var depthFt = depth / 12;
    var cubicFeet = length * width * depthFt;
    var cubicYards = cubicFeet / 27;

    var tons = cubicYards * data.density;
    var bags = Math.ceil(tons * 2000 / 50);

    var costMin = tons * data.costMin;
    var costMax = tons * data.costMax;

    document.getElementById('resultCubicYards').textContent = cubicYards.toFixed(2);
    document.getElementById('resultTons').textContent = tons.toFixed(2);
    document.getElementById('resultBags').textContent = bags.toLocaleString();
    document.getElementById('resultCost').textContent = '$' + Math.round(costMin).toLocaleString() + ' - $' + Math.round(costMax).toLocaleString();
  }

  document.querySelectorAll('.calc-inputs input, .calc-inputs select').forEach(function(el) {
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
