---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('construction-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Construction Calculators"
    }
  ]
};
---

<BaseLayout
  title="Construction Calculators - Concrete, Roofing & Home Improvement | ToolCalcs"
  description="Free construction calculators for concrete, roofing, paint, flooring, mulch, fence, drywall, and deck projects. Estimate materials and costs instantly."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Construction Calculators</span>
  </nav>

  <h1>Construction & Home Improvement Calculators</h1>
  <p class="page-desc">Estimate materials, quantities, and costs for your next building or renovation project.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/construction-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Related Tools</h2>
    <p class="quick-ref-desc">More tools for your projects:</p>
    <div class="quick-ref-grid">
      <a href="/everyday-calculators/square-footage-calculator/" class="quick-ref-card"><span>📏</span> Square Footage</a>
      <a href="/conversion-calculators/unit-converter/" class="quick-ref-card"><span>🔄</span> Unit Converter</a>
      <a href="/math-calculators/area-calculator/" class="quick-ref-card"><span>📐</span> Area Calculator</a>
      <a href="/math-calculators/percentage-calculator/" class="quick-ref-card"><span>%</span> Percentages</a>
    </div>
  </section>

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
