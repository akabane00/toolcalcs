  description="Free mulch calculator. Calculate cubic yards and bags of mulch, gravel, topsoil, or compost for your landscaping project with cost estimates."
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/construction-calculators/">Construction Calculators</a> &rsaquo;
    <span>Mulch Calculator</span>
