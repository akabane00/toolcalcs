<style>
  /* No page-specific styles needed */
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script is:inline>
  function calculate() {
    var length = parseFloat(document.getElementById('areaLength').value) || 0;
    var width = parseFloat(document.getElementById('areaWidth').value) || 0;
    var depth = parseFloat(document.getElementById('desiredDepth').value) || 0;
    var material = document.getElementById('materialType').value;
    var pricePerYard = parseFloat(document.getElementById('pricePerYard').value) || 0;

    var depthFt = depth / 12;
    var cubicFeet = length * width * depthFt;
    var cubicYards = cubicFeet / 27;

    var bags = Math.ceil(cubicFeet / 2);

    var weightPerYard = { mulch: 600, gravel: 2800, topsoil: 2200, sand: 2700, compost: 1000 };
    var weight = cubicYards * (weightPerYard[material] || 600);

    var cost = cubicYards * pricePerYard;

    document.getElementById('resultCubicYards').textContent = cubicYards.toFixed(2);
    document.getElementById('resultCubicFeet').textContent = cubicFeet.toFixed(2);
    document.getElementById('resultBags').textContent = bags.toLocaleString();
    document.getElementById('resultWeight').textContent = Math.round(weight).toLocaleString() + ' lbs';
    document.getElementById('resultCost').textContent = '$' + cost.toFixed(2);
  }

  document.querySelectorAll('.calc-inputs input, .calc-inputs select').forEach(function(el) {
    el.addEventListener('input', calculate);
  });

  calculate();
</script>
