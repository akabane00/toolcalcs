<script is:inline>
  function calculate() {
    var roomLength = parseFloat(document.getElementById('roomLength').value) || 0;
    var roomWidth = parseFloat(document.getElementById('roomWidth').value) || 0;
    var ceilingHeight = parseFloat(document.getElementById('ceilingHeight').value) || 0;
    var numDoors = parseInt(document.getElementById('numDoors').value) || 0;
    var numWindows = parseInt(document.getElementById('numWindows').value) || 0;
    var numCoats = parseInt(document.getElementById('numCoats').value) || 1;
    var coverage = parseFloat(document.getElementById('coverage').value) || 350;
    var includeCeiling = document.getElementById('includeCeiling').value;
    var pricePerGallon = parseFloat(document.getElementById('pricePerGallon').value) || 0;

    // Wall area = perimeter * height - doors - windows
    var perimeter = 2 * (roomLength + roomWidth);
    var grossWallArea = perimeter * ceilingHeight;
    var doorArea = numDoors * 21;
    var windowArea = numWindows * 15;
    var wallArea = grossWallArea - doorArea - windowArea;
    if (wallArea < 0) wallArea = 0;

    // Ceiling area
    var ceilingArea = 0;
    if (includeCeiling === 'yes') {
      ceilingArea = roomLength * roomWidth;
    }

    var totalArea = wallArea + ceilingArea;
    var totalWithCoats = totalArea * numCoats;
    var gallons = Math.ceil(totalWithCoats / coverage);
    var cost = gallons * pricePerGallon;

    document.getElementById('resultWallArea').textContent = Math.round(wallArea).toLocaleString() + ' sq ft';
    document.getElementById('resultTotalArea').textContent = Math.round(totalArea).toLocaleString() + ' sq ft';
    document.getElementById('resultGallons').textContent = gallons.toLocaleString();
    document.getElementById('resultCost').textContent = '$' + cost.toFixed(2);
  }

  // Real-time calculation on input changes
  document.querySelectorAll('.calc-inputs input, .calc-inputs select').forEach(function (el) {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // Initial calculation
  calculate();
</script>