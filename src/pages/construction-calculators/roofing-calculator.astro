<style>
  .shape-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 20px;
    border-bottom: 2px solid var(--color-border);
  }
  .shape-tab {
    padding: 10px 16px;
    border: none;
    background: none;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
  }
  .shape-tab:hover {
    color: var(--color-primary);
  }
  .shape-tab.active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }
  .shape-panel {
    display: none;
  }
  .shape-panel.active {
    display: block;
  }
  .shared-inputs {
    margin-top: 8px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }
</style>

<script is:inline>
  var activeTab = 'dimensions';

  var pitchMultipliers = {
    2: 1.014,
    3: 1.031,
    4: 1.054,
    5: 1.083,
    6: 1.118,
    7: 1.158,
    8: 1.202,
    9: 1.250,
    10: 1.302,
    11: 1.357,
    12: 1.414
  };

  function calculate() {
    var wasteFactor = parseFloat(document.getElementById('wasteFactor').value) || 0;
    var pricePerSquare = parseFloat(document.getElementById('pricePerSquare').value) || 0;

    var roofArea = 0;

    if (activeTab === 'dimensions') {
      var houseLength = parseFloat(document.getElementById('houseLength').value) || 0;
      var houseWidth = parseFloat(document.getElementById('houseWidth').value) || 0;
      var pitchValue = parseInt(document.getElementById('roofPitch').value) || 6;
      var multiplier = pitchMultipliers[pitchValue] || 1.118;
      var footprint = houseLength * houseWidth;
      roofArea = footprint * multiplier;
    } else {
      roofArea = parseFloat(document.getElementById('knownRoofArea').value) || 0;
    }

    // Apply waste factor
    var totalArea = roofArea * (1 + wasteFactor / 100);

    // Roofing squares
    var squares = totalArea / 100;

    // Shingle bundles (3 per square)
    var bundles = Math.ceil(squares * 3);

    // Underlayment rolls (1 roll covers ~400 sq ft)
    var underlaymentRolls = Math.ceil(totalArea / 400);

    // Nails (lbs) - ~2.5 lbs per square
    var nails = Math.ceil(squares * 2.5);

    // Estimated cost
    var cost = squares * pricePerSquare;

    // Display results
    document.getElementById('resultRoofArea').textContent = totalArea.toFixed(2);
    document.getElementById('resultSquares').textContent = squares.toFixed(2);
    document.getElementById('resultBundles').textContent = bundles.toLocaleString();
    document.getElementById('resultUnderlayment').textContent = underlaymentRolls.toLocaleString();
    document.getElementById('resultNails').textContent = nails.toLocaleString();
    document.getElementById('resultCost').textContent = '$' + Math.round(cost).toLocaleString();
  }

  // Tab switching
  document.querySelectorAll('.shape-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      var tabName = tab.getAttribute('data-tab');
      activeTab = tabName;

      // Update active tab
      document.querySelectorAll('.shape-tab').forEach(function(t) {
        t.classList.remove('active');
      });
      tab.classList.add('active');

      // Update active panel
      document.querySelectorAll('.shape-panel').forEach(function(p) {
        p.classList.remove('active');
      });
      document.getElementById('panel-' + tabName).classList.add('active');

      calculate();
    });
  });

  // Listen to all inputs
  document.querySelectorAll('.calc-inputs input, .calc-inputs select').forEach(function(el) {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  calculate();
</script>
