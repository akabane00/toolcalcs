        </div>
      </div>
    </div>

    <div class="calc-inputs shared-inputs">
      <div class="input-group">
        <label for="wasteFactor">Waste Factor (%)</label>
        <input type="number" id="wasteFactor" value="10" min="0" max="50" step="1" />
      </div>
      <div class="input-group">
        <label for="pricePerSquare">Price per Square ($)</label>
        <input type="number" id="pricePerSquare" value="120" min="0" step="1" />
      </div>
    </div>

    <div class="calc-results">
      <div class="result-cards">
        <div class="result-card primary">
          <span class="result-label">Roof Area (sq ft)</span>
          <span class="result-value" id="resultRoofArea">0</span>
        </div>
        <div class="result-card">
          <span class="result-label">Roofing Squares</span>
          <span class="result-value" id="resultSquares">0</span>
        </div>
        <div class="result-card">
          <span class="result-label">Shingle Bundles</span>
          <span class="result-value" id="resultBundles">0</span>
        </div>
        <div class="result-card">
          <span class="result-label">Underlayment Rolls</span>
          <span class="result-value" id="resultUnderlayment">0</span>
        </div>
        <div class="result-card">
          <span class="result-label">Nails (lbs)</span>
          <span class="result-value" id="resultNails">0</span>
        </div>
        <div class="result-card success">
