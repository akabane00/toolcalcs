<script is:inline>
  function calculate() {
    var systemCost = parseFloat(document.getElementById('systemCost').value) || 0;
    var systemSize = parseFloat(document.getElementById('systemSize').value) || 0;
    var taxCredit = parseFloat(document.getElementById('taxCredit').value) || 0;
    var stateIncentive = parseFloat(document.getElementById('stateIncentive').value) || 0;
    var monthlyBill = parseFloat(document.getElementById('monthlyBill').value) || 0;
    var sunHours = parseFloat(document.getElementById('sunHours').value) || 0;
    var elecRate = parseFloat(document.getElementById('elecRate').value) || 0;
    var rateIncrease = parseFloat(document.getElementById('rateIncrease').value) || 0;

    var netCost = systemCost - (systemCost * taxCredit / 100) - stateIncentive;
    if (netCost < 0) {
      netCost = 0;
    }

    var annualProduction = systemSize * sunHours * 365; // kWh
    var year1Savings = Math.min(annualProduction * elecRate, monthlyBill * 12);

    var totalSavings = 0;
    var tableYears = [1, 5, 10, 15, 20, 25];
    var tableData = [];
    var cumulative = 0;

    for (var yr = 0; yr < 25; yr++) {
      var rate = elecRate * Math.pow(1 + rateIncrease / 100, yr);
      var annualSave = Math.min(annualProduction * rate, monthlyBill * 12 * Math.pow(1 + rateIncrease / 100, yr));
      totalSavings += annualSave;
      cumulative += annualSave;

      if (tableYears.indexOf(yr + 1) !== -1) {
        tableData.push({
          year: yr + 1,
          rate: rate,
          annual: annualSave,
          cumulative: cumulative
        });
      }
    }

    var paybackYears = year1Savings > 0 ? netCost / year1Savings : 0;
    var roi = netCost > 0 ? ((totalSavings - netCost) / netCost) * 100 : 0;
    var monthlySavings = year1Savings / 12;
    var co2Offset = annualProduction * 0.000417 * 25; // tons

    // Display results
    document.getElementById('resultNetCost').textContent = '$' + Math.round(netCost).toLocaleString();
    document.getElementById('resultPayback').textContent = paybackYears > 0 ? paybackYears.toFixed(1) : '0';
    document.getElementById('resultTotalSavings').textContent = '$' + Math.round(totalSavings).toLocaleString();
    document.getElementById('resultMonthlySavings').textContent = '$' + Math.round(monthlySavings).toLocaleString();
    document.getElementById('resultRoi').textContent = roi > 0 ? roi.toFixed(1) + '%' : '0%';
    document.getElementById('resultCo2').textContent = co2Offset.toFixed(1);

    // Build savings table
    var tbody = document.getElementById('savingsTableBody');
    tbody.innerHTML = '';
    for (var i = 0; i < tableData.length; i++) {
      var row = document.createElement('tr');
      row.innerHTML =
        '<td>' + tableData[i].year + '</td>' +
        '<td>$' + tableData[i].rate.toFixed(3) + '/kWh</td>' +
        '<td>$' + Math.round(tableData[i].annual).toLocaleString() + '</td>' +
        '<td>$' + Math.round(tableData[i].cumulative).toLocaleString() + '</td>';
      tbody.appendChild(row);
    }
    document.getElementById('savingsTable').style.display = 'block';
  }

  // Button click handler
  document.getElementById('calculateBtn').addEventListener('click', calculate);

  // Also calculate on Enter key in any input
  document.querySelectorAll('.calc-inputs input').forEach(function(el) {
    el.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        calculate();
      }
    });
  });

  // Initial calculation
  calculate();
</script>
