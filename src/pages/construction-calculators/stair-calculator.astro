    height: auto;
  }
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script is:inline>
  function calculate() {
    var unitEl = document.getElementById('unit');
    var unit = unitEl.value;
    var suffix = unit === 'in' ? '"' : ' cm';
    var toInches = unit === 'cm' ? 1 / 2.54 : 1;
    var fromInches = unit === 'cm' ? 2.54 : 1;

    var totalRiseInput = parseFloat(document.getElementById('totalRise').value) || 0;
    var runPerStepInput = parseFloat(document.getElementById('runPerStep').value) || 0;

    // Convert to inches for calculation
    var totalRiseIn = totalRiseInput * toInches;
    var runPerStepIn = runPerStepInput * toInches;

    // Calculate number of steps (aiming for ~7.5" rise per step)
    var numSteps = Math.round(totalRiseIn / 7.5);
    if (numSteps < 1) numSteps = 1;

    // Actual rise per step
    var risePerStepIn = totalRiseIn / numSteps;

    // Total run (one fewer tread than risers)
    var totalRunIn = (numSteps - 1) * runPerStepIn;

    // Stringer length (Pythagorean theorem)
    var stringerLengthIn = Math.sqrt(totalRiseIn * totalRiseIn + totalRunIn * totalRunIn);

    // Stair angle
    var stairAngleDeg = 0;
    if (totalRunIn > 0) {
      stairAngleDeg = Math.atan(totalRiseIn / totalRunIn) * (180 / Math.PI);
    }

    // Convert back to display unit
    var risePerStepDisplay = risePerStepIn * fromInches;
    var runPerStepDisplay = runPerStepInput;
    var totalRunDisplay = totalRunIn * fromInches;
    var stringerLengthDisplay = stringerLengthIn * fromInches;

    // Update result displays
    document.getElementById('numSteps').textContent = numSteps;
    document.getElementById('risePerStep').textContent = risePerStepDisplay.toFixed(2) + suffix;
    document.getElementById('runDisplay').textContent = runPerStepDisplay.toFixed(2) + suffix;
    document.getElementById('totalRun').textContent = totalRunDisplay.toFixed(2) + suffix;
    document.getElementById('stringerLength').textContent = stringerLengthDisplay.toFixed(2) + suffix;
    document.getElementById('stairAngle').textContent = stairAngleDeg.toFixed(1) + '\u00B0';

    // Code compliance check (always in inches)
    var checks = [];
    var allPass = true;

    // Rise check: 4" to 7.75"
    if (risePerStepIn >= 4 && risePerStepIn <= 7.75) {
      checks.push('\u2705 Rise per step: ' + risePerStepIn.toFixed(2) + '" (code: 4" - 7.75")');
    } else {
      allPass = false;
      checks.push('\u274C Rise per step: ' + risePerStepIn.toFixed(2) + '" (code: 4" - 7.75")');
    }

    // Run check: minimum 10"
    if (runPerStepIn >= 10) {
      checks.push('\u2705 Run per step: ' + runPerStepIn.toFixed(2) + '" (code: min 10")');
    } else {
      allPass = false;
      checks.push('\u274C Run per step: ' + runPerStepIn.toFixed(2) + '" (code: min 10")');
    }

    // Comfort rule: rise + run = 17" to 18"
    var comfortSum = risePerStepIn + runPerStepIn;
    if (comfortSum >= 17 && comfortSum <= 18) {
      checks.push('\u2705 Comfort rule (rise + run): ' + comfortSum.toFixed(2) + '" (ideal: 17" - 18")');
    } else {
      allPass = false;
      checks.push('\u274C Comfort rule (rise + run): ' + comfortSum.toFixed(2) + '" (ideal: 17" - 18")');
    }

    var complianceEl = document.getElementById('codeCompliance');
    complianceEl.className = 'code-compliance ' + (allPass ? 'pass' : 'fail');
    complianceEl.innerHTML = '<strong>' + (allPass ? 'Code Compliant' : 'Code Issues Detected') + '</strong><br>' + checks.join('<br>');

    // Draw SVG diagram
    drawStairDiagram(numSteps, risePerStepIn, runPerStepIn, totalRiseIn, totalRunIn, stringerLengthIn, stairAngleDeg);
  }

  function drawStairDiagram(numSteps, risePerStep, runPerStep, totalRise, totalRun, stringerLength, angle) {
    var container = document.getElementById('stairDiagram');
    var maxStepsToShow = Math.min(numSteps, 12);

    var padding = 60;
    var stepW = 40;
    var stepH = 25;
    var svgW = maxStepsToShow * stepW + padding * 2 + 80;
    var svgH = maxStepsToShow * stepH + padding * 2 + 40;

    var startX = padding;
    var startY = svgH - padding;

    var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' + svgW + ' ' + svgH + '" width="' + svgW + '" height="' + svgH + '">';

    // Background
    svg += '<rect width="' + svgW + '" height="' + svgH + '" fill="#f8fafc" rx="8"/>';

    // Draw steps
    var path = 'M ' + startX + ' ' + startY;
    for (var i = 0; i < maxStepsToShow; i++) {
      var x1 = startX + i * stepW;
      var y1 = startY - i * stepH;
      var x2 = startX + i * stepW;
      var y2 = startY - (i + 1) * stepH;
      var x3 = startX + (i + 1) * stepW;
      var y3 = startY - (i + 1) * stepH;
      path += ' L ' + x2 + ' ' + y2 + ' L ' + x3 + ' ' + y3;
    }
    svg += '<path d="' + path + '" fill="none" stroke="#3b82f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>';

    // Stringer line (dashed)
    var endX = startX + maxStepsToShow * stepW;
    var endY = startY - maxStepsToShow * stepH;
    svg += '<line x1="' + startX + '" y1="' + startY + '" x2="' + endX + '" y2="' + endY + '" stroke="#ef4444" stroke-width="1.5" stroke-dasharray="6,4"/>';

    // Total rise dimension (right side)
    var dimX = endX + 20;
    svg += '<line x1="' + dimX + '" y1="' + startY + '" x2="' + dimX + '" y2="' + endY + '" stroke="#64748b" stroke-width="1"/>';
    svg += '<line x1="' + (dimX - 5) + '" y1="' + startY + '" x2="' + (dimX + 5) + '" y2="' + startY + '" stroke="#64748b" stroke-width="1"/>';
    svg += '<line x1="' + (dimX - 5) + '" y1="' + endY + '" x2="' + (dimX + 5) + '" y2="' + endY + '" stroke="#64748b" stroke-width="1"/>';
    var midY = (startY + endY) / 2;
    svg += '<text x="' + (dimX + 8) + '" y="' + midY + '" font-size="11" fill="#334155" font-family="sans-serif" dominant-baseline="middle">Total Rise</text>';

    // Total run dimension (bottom)
    var dimY = startY + 25;
    svg += '<line x1="' + startX + '" y1="' + dimY + '" x2="' + endX + '" y2="' + dimY + '" stroke="#64748b" stroke-width="1"/>';
    svg += '<line x1="' + startX + '" y1="' + (dimY - 5) + '" x2="' + startX + '" y2="' + (dimY + 5) + '" stroke="#64748b" stroke-width="1"/>';
    svg += '<line x1="' + endX + '" y1="' + (dimY - 5) + '" x2="' + endX + '" y2="' + (dimY + 5) + '" stroke="#64748b" stroke-width="1"/>';
    var midX = (startX + endX) / 2;
    svg += '<text x="' + midX + '" y="' + (dimY + 16) + '" font-size="11" fill="#334155" font-family="sans-serif" text-anchor="middle">Total Run</text>';

    // Rise and run labels on one step
    if (maxStepsToShow >= 2) {
      var labelStep = 1;
      var lx1 = startX + labelStep * stepW;
      var ly1 = startY - labelStep * stepH;
      var ly2 = startY - (labelStep + 1) * stepH;
      var lx2 = startX + (labelStep + 1) * stepW;

      // Rise arrow
      svg += '<line x1="' + (lx1 - 12) + '" y1="' + ly1 + '" x2="' + (lx1 - 12) + '" y2="' + ly2 + '" stroke="#16a34a" stroke-width="1.5"/>';
      svg += '<text x="' + (lx1 - 16) + '" y="' + ((ly1 + ly2) / 2) + '" font-size="9" fill="#16a34a" font-family="sans-serif" text-anchor="end" dominant-baseline="middle">Rise</text>';

      // Run arrow
      svg += '<line x1="' + lx1 + '" y1="' + (ly2 + 12) + '" x2="' + lx2 + '" y2="' + (ly2 + 12) + '" stroke="#ea580c" stroke-width="1.5"/>';
      svg += '<text x="' + ((lx1 + lx2) / 2) + '" y="' + (ly2 + 24) + '" font-size="9" fill="#ea580c" font-family="sans-serif" text-anchor="middle">Run</text>';
    }

    // Stringer label
    var sMidX = (startX + endX) / 2 - 20;
    var sMidY = (startY + endY) / 2 - 10;
    svg += '<text x="' + sMidX + '" y="' + sMidY + '" font-size="10" fill="#ef4444" font-family="sans-serif" text-anchor="middle" transform="rotate(' + (-Math.atan2(maxStepsToShow * stepH, maxStepsToShow * stepW) * 180 / Math.PI) + ' ' + sMidX + ' ' + sMidY + ')">Stringer</text>';

    // Angle arc
    var arcR = 30;
    var angleRad = Math.atan2(maxStepsToShow * stepH, maxStepsToShow * stepW);
    var arcEndX = startX + arcR * Math.cos(angleRad);
    var arcEndY = startY - arcR * Math.sin(angleRad);
    svg += '<path d="M ' + (startX + arcR) + ' ' + startY + ' A ' + arcR + ' ' + arcR + ' 0 0 0 ' + arcEndX.toFixed(1) + ' ' + arcEndY.toFixed(1) + '" fill="none" stroke="#8b5cf6" stroke-width="1.5"/>';
    svg += '<text x="' + (startX + arcR + 8) + '" y="' + (startY - 8) + '" font-size="10" fill="#8b5cf6" font-family="sans-serif">' + angle.toFixed(1) + '\u00B0</text>';

    svg += '</svg>';
    container.innerHTML = svg;
  }

  // Event listeners
  document.querySelectorAll('.calc-inputs input, .calc-inputs select').forEach(function (el) {
    el.addEventListener('input', calculate);
  });

  // Initial calculation
  calculate();
</script>
