      <li><a href="/construction-calculators/gravel-calculator/">Gravel Calculator</a> - Calculate tons and cubic yards of gravel for driveways and landscaping.</li>
    </ul>
  </article>

  <AdUnit slot="calc-bottom" format="horizontal" />
  <RelatedArticles calculatorSlug="tile-calculator" />
  <RelatedCalculators currentSlug="tile-calculator" />
</BaseLayout>

<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script is:inline>
  document.getElementById('calculateBtn').addEventListener('click', function() {
    var roomLength = parseFloat(document.getElementById('roomLength').value) || 0;
    var roomWidth = parseFloat(document.getElementById('roomWidth').value) || 0;
    var tileLength = parseFloat(document.getElementById('tileLength').value) || 0;
    var tileWidth = parseFloat(document.getElementById('tileWidth').value) || 0;
    var wastage = parseFloat(document.getElementById('wastage').value) || 0;
    var tilesPerBox = parseInt(document.getElementById('tilesPerBox').value) || 1;
    var pricePerTile = parseFloat(document.getElementById('pricePerTile').value) || 0;

    if (roomLength <= 0 || roomWidth <= 0) {
      alert('Please enter room dimensions greater than 0.');
      return;
    }
    if (tileLength <= 0 || tileWidth <= 0) {
      alert('Please enter tile dimensions greater than 0.');
      return;
    }

    var roomArea = roomLength * roomWidth;
    var tileLengthFt = tileLength / 12;
    var tileWidthFt = tileWidth / 12;
    var tileArea = tileLengthFt * tileWidthFt;

    var baseTiles = roomArea / tileArea;
    var tilesNeeded = Math.ceil(baseTiles * (1 + wastage / 100));
    var boxesNeeded = Math.ceil(tilesNeeded / tilesPerBox);
    var totalCost = tilesNeeded * pricePerTile;

    document.getElementById('resultArea').textContent = roomArea.toFixed(2) + ' sq ft';
    document.getElementById('resultTiles').textContent = tilesNeeded.toLocaleString() + ' tiles';
    document.getElementById('resultBoxes').textContent = boxesNeeded.toLocaleString() + ' boxes';
    document.getElementById('resultCost').textContent = '$' + totalCost.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});

    document.getElementById('resultsSection').style.display = '';
  });
</script>
