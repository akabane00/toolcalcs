<style>
  .converter-area { display: flex; flex-direction: column; gap: 16px; }
  .swap-row { display: flex; justify-content: center; }
  .swap-btn { padding: 8px 24px; background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius); font-size: 1.4rem; cursor: pointer; color: var(--color-text); transition: all 0.15s; line-height: 1; }
  .swap-btn:hover { border-color: var(--color-primary); color: var(--color-primary); background: #eff6ff; }
  .conversion-summary { text-align: center; font-size: 0.95rem; color: var(--color-text-muted); padding: 12px; background: var(--color-bg); border-radius: var(--radius); min-height: 20px; }
  .reference-table { margin-top: 24px; }
  .reference-table h3 { font-size: 1rem; font-weight: 600; margin-bottom: 12px; }
  @media (max-width: 640px) { .calc-inputs { grid-template-columns: 1fr; } }
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script is:inline>
  var units = {
    'Cups': 236.588,
    'Tablespoons': 14.787,
    'Teaspoons': 4.929,
    'Milliliters': 1,
    'Fluid Ounces': 29.5735,
    'Liters': 1000,
    'Pints': 473.176,
    'Quarts': 946.353,
    'Gallons': 3785.41
  };

  function formatResult(num) {
    if (Number.isInteger(num)) return num.toString();
    var str = num.toFixed(6);
    str = str.replace(/(\.\d*?)0+$/, '$1');
    str = str.replace(/\.$/, '');
    return str;
  }

  function convert(direction) {
    var fromValue = parseFloat(document.getElementById('fromValue').value);
    var toValue = parseFloat(document.getElementById('toValue').value);
    var fromUnit = document.getElementById('fromUnit').value;
    var toUnit = document.getElementById('toUnit').value;
    var summaryEl = document.getElementById('conversionSummary');

    if (direction === 'forward') {
      if (isNaN(fromValue)) { document.getElementById('toValue').value = ''; summaryEl.textContent = ''; return; }
      var result = fromValue * units[fromUnit] / units[toUnit];
      document.getElementById('toValue').value = formatResult(result);
      summaryEl.textContent = formatResult(fromValue) + ' ' + fromUnit + ' = ' + formatResult(result) + ' ' + toUnit;
    } else {
      if (isNaN(toValue)) { document.getElementById('fromValue').value = ''; summaryEl.textContent = ''; return; }
      var result = toValue * units[toUnit] / units[fromUnit];
      document.getElementById('fromValue').value = formatResult(result);
      summaryEl.textContent = formatResult(toValue) + ' ' + toUnit + ' = ' + formatResult(result) + ' ' + fromUnit;
    }
  }

  function swapUnits() {
    var fromSelect = document.getElementById('fromUnit');
    var toSelect = document.getElementById('toUnit');
    var fromVal = document.getElementById('fromValue');
    var toVal = document.getElementById('toValue');
    var tempUnit = fromSelect.value;
    fromSelect.value = toSelect.value;
    toSelect.value = tempUnit;
    var tempValue = fromVal.value;
    fromVal.value = toVal.value;
    toVal.value = tempValue;
    convert('forward');
  }

  document.getElementById('fromValue').addEventListener('input', function() { convert('forward'); });
  document.getElementById('toValue').addEventListener('input', function() { convert('reverse'); });
  document.getElementById('fromUnit').addEventListener('change', function() { convert('forward'); });
  document.getElementById('toUnit').addEventListener('change', function() { convert('forward'); });
  document.getElementById('swapBtn').addEventListener('click', swapUnits);

  convert('forward');
</script>
