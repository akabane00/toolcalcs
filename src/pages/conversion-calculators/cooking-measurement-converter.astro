    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Conversion Calculators", "item": "https://toolcalcs.com/conversion-calculators/" },
      { "@type": "ListItem", "position": 3, "name": "Cooking Measurement Converter" }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How many tablespoons are in a cup?', acceptedAnswer: { '@type': 'Answer', text: 'There are 16 tablespoons in one US cup. Since one cup equals 236.588 milliliters and one tablespoon equals 14.787 milliliters, dividing 236.588 by 14.787 gives you exactly 16 tablespoons per cup.' } },
      { '@type': 'Question', name: 'What is the difference between a fluid ounce and a dry ounce?', acceptedAnswer: { '@type': 'Answer', text: 'A fluid ounce measures volume (how much space something takes up), while a dry ounce measures weight. One US fluid ounce equals about 29.5735 milliliters. The weight of one fluid ounce of a substance depends on its density. For water, one fluid ounce weighs approximately one ounce by weight, but for denser or lighter ingredients, the weight will differ.' } },
      { '@type': 'Question', name: 'How many cups are in a gallon?', acceptedAnswer: { '@type': 'Answer', text: 'There are 16 cups in one US gallon. A gallon contains 4 quarts, each quart contains 2 pints, and each pint contains 2 cups, so 4 x 2 x 2 = 16 cups per gallon. In metric terms, one US gallon equals approximately 3,785 milliliters or 3.785 liters.' } },
    ],
  },
];
