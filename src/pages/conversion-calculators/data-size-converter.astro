    <ul>
      <li><a href="/conversion-calculators/unit-converter/">Unit Converter</a> - Convert between length, weight, temperature, and more.</li>
      <li><a href="/conversion-calculators/speed-converter/">Speed Converter</a> - Convert between mph, km/h, knots, and more.</li>
      <li><a href="/math-calculators/percentage-calculator/">Percentage Calculator</a> - Calculate any percentage of a number.</li>
    </ul>
  </article>

  <AdUnit slot="calc-bottom" format="horizontal" />
  <RelatedArticles calculatorSlug="data-size-converter" />
  <RelatedCalculators currentSlug="data-size-converter" />
</BaseLayout>

<style>
  .formula-show {
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--color-bg);
    border-radius: var(--radius);
    font-size: 0.9rem;
    line-height: 1.7;
  }
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
  @media (max-width: 640px) {
    .calc-inputs { grid-template-columns: 1fr; }
    .result-cards { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  var unitNames = ['Bytes', 'KB', 'MB', 'GB', 'TB', 'PB'];

  function formatNumber(num) {
    if (num === 0) return '0';
    if (Math.abs(num) >= 1) {
      return num.toLocaleString(undefined, { maximumFractionDigits: 4 });
    }
    var s = num.toPrecision(6);
    return parseFloat(s).toString();
  }

  function convertData() {
    var value = parseFloat(document.getElementById('dataValue').value);
    var fromIdx = parseInt(document.getElementById('fromUnit').value);
    var toIdx = parseInt(document.getElementById('toUnit').value);

    if (isNaN(value)) return;

    // Convert to bytes first, then to target unit
    var bytes = value * Math.pow(1024, fromIdx);
    var result = bytes / Math.pow(1024, toIdx);

    document.getElementById('convLabel').textContent = value + ' ' + unitNames[fromIdx] + ' =';
    document.getElementById('convValue').textContent = formatNumber(result) + ' ' + unitNames[toIdx];

    // Show formula
    var steps = Math.abs(toIdx - fromIdx);
    var direction = toIdx > fromIdx ? 'divide' : 'multiply';
    var formula = '';
    if (fromIdx === toIdx) {
      formula = '<strong>Same unit:</strong> No conversion needed.';
    } else {
      formula = '<strong>Formula:</strong> ' + value + ' ' + unitNames[fromIdx];
      if (direction === 'multiply') {
        formula += ' &times; 1024<sup>' + steps + '</sup> = ' + formatNumber(result) + ' ' + unitNames[toIdx];
      } else {
        formula += ' &divide; 1024<sup>' + steps + '</sup> = ' + formatNumber(result) + ' ' + unitNames[toIdx];
      }
      formula += '<br><strong>Factor:</strong> 1024<sup>' + steps + '</sup> = ' + Math.pow(1024, steps).toLocaleString();
    }
    document.getElementById('formulaShow').innerHTML = formula;

    // All conversions table
    var tbody = document.getElementById('allUnitsBody');
    tbody.innerHTML = '';
    for (var i = 0; i < unitNames.length; i++) {
      var converted = bytes / Math.pow(1024, i);
      var row = document.createElement('tr');
      var td1 = document.createElement('td');
      td1.textContent = unitNames[i];
      var td2 = document.createElement('td');
      td2.textContent = formatNumber(converted);
      row.appendChild(td1);
      row.appendChild(td2);
      tbody.appendChild(row);
    }

    document.getElementById('results').style.display = 'block';
  }

  document.getElementById('calculateBtn').addEventListener('click', convertData);
  convertData();
</script>
