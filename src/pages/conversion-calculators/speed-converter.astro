<BaseLayout title="Speed Converter - MPH, KM/H, M/S, Knots & Mach | ToolCalcs" description="Free speed converter for miles per hour, kilometers per hour, meters per second, feet per second, knots, and Mach. Convert between speed units instantly." type="article" structuredData={structuredData}>
