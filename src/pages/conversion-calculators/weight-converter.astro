const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Conversion Calculators", "item": "https://toolcalcs.com/conversion-calculators/" },
      { "@type": "ListItem", "position": 3, "name": "Weight Converter" }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How many grams are in a pound?', acceptedAnswer: { '@type': 'Answer', text: 'There are approximately 453.592 grams in one pound. To convert pounds to grams, multiply by 453.592. To convert grams to pounds, divide by 453.592 or multiply by 0.00220462. For example, 5 pounds equals about 2,268 grams or 2.268 kilograms.' } },
      { '@type': 'Question', name: 'What is the difference between weight and mass?', acceptedAnswer: { '@type': 'Answer', text: 'Mass is the amount of matter in an object and remains constant regardless of location. Weight is the force of gravity acting on that mass and varies depending on gravitational field strength. On Earth, we use the terms interchangeably for practical purposes, but an object weighing 1 kilogram on Earth would weigh about 0.17 kilograms on the Moon while its mass remains 1 kilogram.' } },
      { '@type': 'Question', name: 'How many ounces are in a kilogram?', acceptedAnswer: { '@type': 'Answer', text: 'There are approximately 35.274 ounces in one kilogram. One kilogram equals 1,000 grams, and one ounce equals approximately 28.3495 grams, so 1,000 divided by 28.3495 gives about 35.274 ounces. This conversion is commonly needed when comparing food packaging between metric and imperial systems.' } },
    ],
  },
];
---

<BaseLayout title="Weight Converter - Kg, Pounds, Ounces, Grams & Stones | ToolCalcs" description="Free weight converter for milligrams, grams, kilograms, metric tons, ounces, pounds, and stones. Convert between metric and imperial weight units instantly." type="article" structuredData={structuredData}>
