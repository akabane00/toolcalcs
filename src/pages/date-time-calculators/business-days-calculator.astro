<script is:inline>
  var startDateInput = document.getElementById('startDate');
  var endDateInput = document.getElementById('endDate');
  var excludeHolidaysCheckbox = document.getElementById('excludeHolidays');

  // Set default dates
  var today = new Date();
  endDateInput.value = formatDate(today);
  var thirtyAgo = new Date(today);
  thirtyAgo.setDate(thirtyAgo.getDate() - 30);
  startDateInput.value = formatDate(thirtyAgo);

  function formatDate(d) {
    var y = d.getFullYear();
    var m = String(d.getMonth() + 1).padStart(2, '0');
    var day = String(d.getDate()).padStart(2, '0');
    return y + '-' + m + '-' + day;
  }

  // US Federal Holidays with observed dates 2024-2027
  function getObservedHolidays(year) {
    var holidays = [];

    function observe(month, day, name) {
      var d = new Date(year, month, day);
      var dow = d.getDay();
      if (dow === 6) { d.setDate(d.getDate() - 1); }
      else if (dow === 0) { d.setDate(d.getDate() + 1); }
      holidays.push({ date: formatDate(d), name: name });
    }

    function nthDayOfMonth(month, dayOfWeek, n) {
      var d = new Date(year, month, 1);
      var count = 0;
      while (count < n) {
        if (d.getDay() === dayOfWeek) { count++; }
        if (count < n) { d.setDate(d.getDate() + 1); }
      }
      return d;
    }

    function lastDayOfMonth(month, dayOfWeek) {
      var d = new Date(year, month + 1, 0);
      while (d.getDay() !== dayOfWeek) {
        d.setDate(d.getDate() - 1);
      }
      return d;
    }

    // New Year's Day - Jan 1
    observe(0, 1, "New Year's Day");

    // MLK Day - 3rd Monday in January
    var mlk = nthDayOfMonth(0, 1, 3);
    holidays.push({ date: formatDate(mlk), name: 'Martin Luther King Jr. Day' });

    // Presidents' Day - 3rd Monday in February
    var pres = nthDayOfMonth(1, 1, 3);
    holidays.push({ date: formatDate(pres), name: "Presidents' Day" });

    // Memorial Day - Last Monday in May
    var mem = lastDayOfMonth(4, 1);
    holidays.push({ date: formatDate(mem), name: 'Memorial Day' });

    // Juneteenth - June 19
    observe(5, 19, 'Juneteenth');

    // Independence Day - July 4
    observe(6, 4, 'Independence Day');

    // Labor Day - 1st Monday in September
    var lab = nthDayOfMonth(8, 1, 1);
    holidays.push({ date: formatDate(lab), name: 'Labor Day' });

    // Columbus Day - 2nd Monday in October
    var col = nthDayOfMonth(9, 1, 2);
    holidays.push({ date: formatDate(col), name: 'Columbus Day' });

    // Veterans Day - Nov 11
    observe(10, 11, "Veterans Day");

    // Thanksgiving - 4th Thursday in November
    var thanks = nthDayOfMonth(10, 4, 4);
    holidays.push({ date: formatDate(thanks), name: 'Thanksgiving Day' });

    // Christmas - Dec 25
    observe(11, 25, 'Christmas Day');

    return holidays;
  }

  function getAllHolidays(startYear, endYear) {
    var all = [];
    for (var y = startYear; y <= endYear; y++) {
      all = all.concat(getObservedHolidays(y));
    }
    return all;
  }

  function calculate() {
    var startVal = startDateInput.value;
    var endVal = endDateInput.value;
    if (!startVal || !endVal) return;

    var start = new Date(startVal + 'T00:00:00');
    var end = new Date(endVal + 'T00:00:00');
    if (isNaN(start.getTime()) || isNaN(end.getTime())) return;

    var earlier = start < end ? start : end;
    var later = start < end ? end : start;

    var msPerDay = 86400000;
    var calendarDays = Math.round((later.getTime() - earlier.getTime()) / msPerDay);

    var excludeH = excludeHolidaysCheckbox.checked;
    var startYear = earlier.getFullYear();
    var endYear = later.getFullYear();
    var holidays = excludeH ? getAllHolidays(startYear, endYear) : [];
    var holidayDates = {};
    for (var i = 0; i < holidays.length; i++) {
      holidayDates[holidays[i].date] = holidays[i].name;
    }

    var businessDays = 0;
    var weekendDays = 0;
    var excludedHolidays = [];
    var current = new Date(earlier.getTime());
    current.setDate(current.getDate() + 1);

    for (var d = 0; d < calendarDays; d++) {
      var dow = current.getDay();
      var dateStr = formatDate(current);
      if (dow === 0 || dow === 6) {
        weekendDays++;
      } else if (excludeH && holidayDates[dateStr]) {
        excludedHolidays.push({ date: dateStr, name: holidayDates[dateStr] });
      } else {
        businessDays++;
      }
      current.setDate(current.getDate() + 1);
    }

    document.getElementById('businessDays').textContent = businessDays.toLocaleString();
    document.getElementById('calendarDays').textContent = calendarDays.toLocaleString();
    document.getElementById('weekendDays').textContent = weekendDays.toLocaleString();
    document.getElementById('holidaysExcluded').textContent = excludedHolidays.length.toString();

    var holidayListEl = document.getElementById('holidayList');
    var holidayItemsEl = document.getElementById('holidayItems');
    if (excludedHolidays.length > 0) {
      holidayListEl.style.display = 'block';
      var html = '';
      for (var h = 0; h < excludedHolidays.length; h++) {
        var parts = excludedHolidays[h].date.split('-');
        var dispDate = new Date(parseInt(parts[0]), parseInt(parts[1]) - 1, parseInt(parts[2]));
        var options = { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' };
        html += '<li>' + excludedHolidays[h].name + ' &mdash; ' + dispDate.toLocaleDateString('en-US', options) + '</li>';
      }
      holidayItemsEl.innerHTML = html;
    } else {
      holidayListEl.style.display = 'none';
      holidayItemsEl.innerHTML = '';
    }
  }

  startDateInput.addEventListener('change', calculate);
  endDateInput.addEventListener('change', calculate);
  excludeHolidaysCheckbox.addEventListener('change', calculate);

  calculate();
</script>
