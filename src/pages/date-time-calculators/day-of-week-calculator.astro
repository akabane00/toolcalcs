<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
  .result-card.primary {
    background: #eff6ff;
    grid-column: 1 / -1;
  }
  .result-card.primary .result-value {
    font-size: 2.8rem;
    font-weight: 800;
    color: var(--color-primary);
  }
  .result-cards.secondary {
    margin-bottom: 0;
  }
  .result-value.small {
    font-size: 1.1rem;
  }
  .result-detail {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 2px;
  }
  .fun-fact-box {
    margin-top: 16px;
    padding: 16px;
    background: var(--color-bg);
    border-radius: var(--radius);
    border-left: 4px solid var(--color-primary);
  }
  .fun-fact-box h3 {
    font-size: 0.95rem;
    margin: 0 0 6px;
    color: var(--color-primary);
  }
  .fun-fact-box p {
    font-size: 0.9rem;
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  [data-theme="dark"] .result-card.primary { background: #1e3a5f; }

  @media (max-width: 640px) {
    .calc-inputs { grid-template-columns: 1fr; }
    .result-cards { grid-template-columns: 1fr; }
    .result-card.primary { grid-column: auto; }
  }
</style>

<script is:inline>
  var dateInput = document.getElementById('dateInput');

  // Default to today
  var today = new Date();
  var y = today.getFullYear();
  var m = String(today.getMonth() + 1).padStart(2, '0');
  var d = String(today.getDate()).padStart(2, '0');
  dateInput.value = y + '-' + m + '-' + d;

  var dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];

  var funFacts = {
    'Sunday': 'Sunday is named after the Sun. In many cultures, it is considered the first day of the week. In the International Organization for Standardization (ISO 8601), Sunday is the seventh and last day of the week.',
    'Monday': 'Monday is named after the Moon (Moon-day). It is widely considered the first working day of the week and is often cited as the least favorite day in workplace surveys. The ISO 8601 standard designates Monday as the first day of the week.',
    'Tuesday': 'Tuesday is named after Tiw (or Tyr), the Norse god of single combat and law. In the Gregorian calendar, any month that begins on a Sunday will have a Friday the 13th, and the 13th will also fall on a Tuesday when the month starts on a Thursday.',
    'Wednesday': 'Wednesday is named after Woden (Odin), the chief Norse god. In many Romance languages, the name derives from Mercury (Mercredi in French, Miercoles in Spanish). Wednesday is often called "hump day" because it marks the middle of the traditional workweek.',
    'Thursday': 'Thursday is named after Thor, the Norse god of thunder. In many countries, elections are traditionally held on Thursdays. Thanksgiving in the United States always falls on the fourth Thursday of November.',
    'Friday': 'Friday is named after Frigga (or Freya), the Norse goddess of love. It is often considered the best day of the workweek because it precedes the weekend. The superstition surrounding Friday the 13th has been traced to the arrest of the Knights Templar on Friday, October 13, 1307.',
    'Saturday': 'Saturday is named after Saturn, the Roman god of agriculture and time. It is the only day of the English week that retains its Roman name. In many cultures, Saturday is considered a day of rest and leisure.',
  };

  function getISOWeekNumber(date) {
    var d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
    var dayNum = d.getUTCDay() || 7;
    d.setUTCDate(d.getUTCDate() + 4 - dayNum);
    var yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
    var weekNum = Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
    return weekNum;
  }

  function isLeapYear(year) {
    return (year % 4 === 0 && year % 100 !== 0) || (year % 400 === 0);
  }

  function getDayOfYear(date) {
    var start = new Date(date.getFullYear(), 0, 0);
    var diff = date - start;
    var oneDay = 86400000;
    return Math.floor(diff / oneDay);
  }

  function calculate() {
    var val = dateInput.value;
    if (!val) return;

    var date = new Date(val + 'T00:00:00');
    if (isNaN(date.getTime())) return;

    var dayOfWeek = dayNames[date.getDay()];
    var dayOfYear = getDayOfYear(date);
    var year = date.getFullYear();
    var totalDaysInYear = isLeapYear(year) ? 366 : 365;
    var daysLeft = totalDaysInYear - dayOfYear;
    var weekNum = getISOWeekNumber(date);
    var month = date.getMonth();
    var quarter = Math.floor(month / 3) + 1;
    var leap = isLeapYear(year);

    document.getElementById('dayOfWeek').textContent = dayOfWeek;
    document.getElementById('dayOfYear').textContent = dayOfYear.toString();
    document.getElementById('dayOfYearDetail').textContent = 'of ' + totalDaysInYear + ' days';
    document.getElementById('weekNumber').textContent = 'Week ' + weekNum;
    document.getElementById('daysLeft').textContent = daysLeft.toString();
    document.getElementById('quarter').textContent = 'Q' + quarter;
    document.getElementById('leapYear').textContent = leap ? 'Yes' : 'No';

    // Fun fact
    var funFactBox = document.getElementById('funFact');
    var funFactText = document.getElementById('funFactText');
    funFactBox.style.display = 'block';
    funFactText.textContent = funFacts[dayOfWeek];
  }

  dateInput.addEventListener('change', calculate);
  calculate();
</script>
