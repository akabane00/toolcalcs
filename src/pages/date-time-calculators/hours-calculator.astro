---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import '../../styles/calculator.css';
import RelatedCalculators from '../../components/RelatedCalculators.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolcalcs.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Date & Time Calculators",
        "item": "https://toolcalcs.com/date-time-calculators/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Hours Calculator"
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I calculate hours between two times?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Convert both times to 24-hour format, then subtract the start time from the end time. If the end time is smaller (crosses midnight), add 24 hours to the end time before subtracting. For example, from 9:00 AM to 5:30 PM: 17.5 - 9.0 = 8.5 hours, or 8 hours and 30 minutes.',
        },
      },
      {
        '@type': 'Question',
        name: 'How do I convert decimal hours to hours and minutes?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Take the whole number as hours. Multiply the decimal portion by 60 to get minutes. For example, 6.75 hours = 6 hours + (0.75 x 60) = 6 hours and 45 minutes. To go from hours and minutes to decimal, divide the minutes by 60 and add to the hours: 6 hours 45 minutes = 6 + 45/60 = 6.75 hours.',
        },
      },
      {
        '@type': 'Question',
        name: 'How do I calculate work hours for a timesheet?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Enter your clock-in time as the start and clock-out time as the end. Subtract any unpaid break time (usually 30 or 60 minutes for lunch). If you work overnight, check the "End time is next day" option. For weekly totals, add the daily decimal hours together. For example, five days of 8.5 hours each = 42.5 hours per week.',
        },
      },
    ],
  },
];
---

<BaseLayout
  title="Hours Calculator - Time Between Two Times"
  description="Free hours calculator. Find the exact time between two clock times in hours, minutes, and decimal format. Supports AM/PM and next-day calculations."
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/date-time-calculators/">Date &amp; Time Calculators</a> &rsaquo;
    <span>Hours Calculator</span>
  </nav>
  <p class="last-updated">Last updated March 2026</p>
  <h1>Hours Calculator &mdash; Time Between Two Times</h1>
  <p class="page-desc">Calculate the exact duration between two clock times in hours, minutes, and decimal format.</p>

  <div class="calculator-box">
    <h3 class="section-label">Start Time</h3>
    <div class="calc-inputs time-row">
      <div class="input-group">
