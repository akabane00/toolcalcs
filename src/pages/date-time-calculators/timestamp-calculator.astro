<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
  .section-block {
    margin-bottom: 8px;
  }
  .section-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 12px;
    color: var(--color-text);
  }
  .section-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 20px 0;
  }
  .btn-group {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .result-card.primary {
    background: #eff6ff;
    grid-column: 1 / -1;
  }
  .result-card.primary .result-value {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--color-primary);
    font-family: 'Courier New', Courier, monospace;
  }
  .result-value.small {
    font-size: 0.95rem;
    word-break: break-all;
  }
  .result-detail {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  [data-theme="dark"] .result-card.primary { background: #1e3a5f; }

  @media (max-width: 640px) {
    .calc-inputs { grid-template-columns: 1fr; }
    .result-cards { grid-template-columns: 1fr; }
    .result-card.primary { grid-column: auto; }
    .result-card.primary .result-value { font-size: 1.6rem; }
  }
</style>

<script is:inline>
  // Section 1: Live current timestamp
  function updateCurrentTs() {
    document.getElementById('currentTs').textContent = Math.floor(Date.now() / 1000).toString();
  }
  updateCurrentTs();
  setInterval(updateCurrentTs, 1000);

  // Section 2: Timestamp to Date
  var tsInput = document.getElementById('tsInput');
  var tsToDateBtn = document.getElementById('tsToDateBtn');

  // Set default timestamp to current
  tsInput.value = Math.floor(Date.now() / 1000).toString();

  function convertTsToDate() {
    var val = tsInput.value.trim();
    if (!val) return;

    var ts = parseInt(val, 10);
    if (isNaN(ts)) return;

    // Detect if milliseconds (13+ digits) and convert to seconds
    if (val.length >= 13) {
      ts = Math.floor(ts / 1000);
    }

    var date = new Date(ts * 1000);
    if (isNaN(date.getTime())) return;

    var resultsEl = document.getElementById('tsToDateResults');
    resultsEl.style.display = 'block';

    var localOpts = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true };
    document.getElementById('tsLocal').textContent = date.toLocaleString('en-US', localOpts);

    var utcOpts = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: true, timeZone: 'UTC' };
    document.getElementById('tsUTC').textContent = date.toLocaleString('en-US', utcOpts) + ' UTC';

    document.getElementById('tsISO').textContent = date.toISOString();

    var dayNames = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    document.getElementById('tsDOW').textContent = dayNames[date.getDay()];
  }

  tsToDateBtn.addEventListener('click', convertTsToDate);
  tsInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') convertTsToDate();
  });

  // Section 3: Date to Timestamp
  var dtDate = document.getElementById('dtDate');
  var dtTime = document.getElementById('dtTime');
  var dateToTsBtn = document.getElementById('dateToTsBtn');

  // Set default date to today
  var now = new Date();
  var y = now.getFullYear();
  var m = String(now.getMonth() + 1).padStart(2, '0');
  var d = String(now.getDate()).padStart(2, '0');
  dtDate.value = y + '-' + m + '-' + d;

  function convertDateToTs() {
    var dateVal = dtDate.value;
    var timeVal = dtTime.value;
    if (!dateVal) return;
    if (!timeVal) timeVal = '00:00';

    var dateObj = new Date(dateVal + 'T' + timeVal + ':00');
    if (isNaN(dateObj.getTime())) return;

    var resultsEl = document.getElementById('dateToTsResults');
    resultsEl.style.display = 'block';

    var ts = Math.floor(dateObj.getTime() / 1000);
    document.getElementById('dtTs').textContent = ts.toString();
    document.getElementById('dtTsMs').textContent = (ts * 1000).toString();
  }

  dateToTsBtn.addEventListener('click', convertDateToTs);

  // Run initial conversions
  convertTsToDate();
  convertDateToTs();
</script>
