    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is a Unix timestamp?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A Unix timestamp (also called epoch time or POSIX time) is the number of seconds that have elapsed since January 1, 1970, at 00:00:00 UTC. It is a single integer that represents a specific point in time, used widely in programming, databases, and operating systems. For example, the timestamp 1700000000 represents November 14, 2023, at 10:13:20 PM UTC.',
        },
      },
      {
        '@type': 'Question',
        name: 'Why does Unix time start from January 1, 1970?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'January 1, 1970, was chosen as the Unix epoch because it was a convenient, round date close to the time when Unix was being developed at Bell Labs in the late 1960s and early 1970s. The date is arbitrary and was selected for simplicity. Using a single reference point allows all dates and times to be represented as a single number, which simplifies storage and comparison in computer systems.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the Year 2038 problem?',
        acceptedAnswer: {
          '@type': 'Answer',
