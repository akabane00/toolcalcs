    tr.innerHTML = '<td style="padding:4px;"><input type="text" class="gpa-course" placeholder="Course ' + num + '" style="width:100%;" /></td>' +
      '<td style="padding:4px;"><select class="gpa-credits"><option value="1">1</option><option value="2">2</option><option selected value="3">3</option><option value="4">4</option><option value="5">5</option></select></td>' +
      '<td style="padding:4px;"><select class="gpa-grade"><option value="4.0">A+</option><option value="4.0" selected>A</option><option value="3.7">A-</option><option value="3.3">B+</option><option value="3.0">B</option><option value="2.7">B-</option><option value="2.3">C+</option><option value="2.0">C</option><option value="1.7">C-</option><option value="1.3">D+</option><option value="1.0">D</option><option value="0.7">D-</option><option value="0.0">F</option></select></td>' +
      '<td class="gpa-col-type" style="padding:4px;display:' + typeDisplay + ';"><select class="gpa-type"><option value="regular">Regular</option><option value="honors">Honors</option><option value="ap">AP/IB</option></select></td>' +
      '<td style="padding:4px;text-align:center;"><button class="gpa-remove-btn" title="Remove" style="background:none;border:none;cursor:pointer;font-size:1.1rem;color:var(--color-text-muted);">&#10005;</button></td>';
    return tr;
  }

  document.getElementById('addCourseBtn').addEventListener('click', function() {
    courseCount++;
    tbody.appendChild(createRow(courseCount));
  });

  tbody.addEventListener('click', function(e) {
    if (e.target.classList.contains('gpa-remove-btn')) {
      var rows = tbody.querySelectorAll('.gpa-row');
      if (rows.length > 1) {
        e.target.closest('.gpa-row').remove();
      }
    }
  });

  weightedCheckbox.addEventListener('change', function() {
    var typeCols = document.querySelectorAll('.gpa-col-type');
    var display = weightedCheckbox.checked ? '' : 'none';
    for (var i = 0; i < typeCols.length; i++) {
      typeCols[i].style.display = display;
    }
  });

  document.getElementById('calcGpaBtn').addEventListener('click', function() {
    var rows = tbody.querySelectorAll('.gpa-row');
    var totalQP = 0;
    var totalCredits = 0;
    var isWeighted = weightedCheckbox.checked;

    for (var i = 0; i < rows.length; i++) {
      var row = rows[i];
      var credits = parseInt(row.querySelector('.gpa-credits').value) || 0;
      var grade = parseFloat(row.querySelector('.gpa-grade').value) || 0;
      var bonus = 0;

      if (isWeighted) {
        var courseType = row.querySelector('.gpa-type').value;
        if (courseType === 'honors') bonus = 0.5;
        if (courseType === 'ap') bonus = 1.0;
      }

      totalQP += (grade + bonus) * credits;
      totalCredits += credits;
    }

    var semesterGPA = totalCredits > 0 ? (totalQP / totalCredits) : 0;

    var priorGPA = parseFloat(document.getElementById('gpa-prior-gpa').value) || 0;
    var priorCredits = parseFloat(document.getElementById('gpa-prior-credits').value) || 0;
    var priorQP = priorGPA * priorCredits;

    var cumulativeCredits = totalCredits + priorCredits;
    var cumulativeQP = totalQP + priorQP;
    var cumulativeGPA = cumulativeCredits > 0 ? (cumulativeQP / cumulativeCredits) : 0;

    document.getElementById('res-semester-gpa').textContent = semesterGPA.toFixed(2);
    document.getElementById('res-cumulative-gpa').textContent = cumulativeGPA.toFixed(2);
    document.getElementById('res-total-credits').textContent = cumulativeCredits;
    document.getElementById('res-quality-points').textContent = cumulativeQP.toFixed(2);

    var adviceEl = document.getElementById('gpa-advice');
    var displayGPA = priorCredits > 0 ? cumulativeGPA : semesterGPA;

    if (displayGPA >= 3.7) {
      adviceEl.style.background = '#f0fdf4';
      adviceEl.style.border = '1px solid #bbf7d0';
      adviceEl.innerHTML = '<strong>Excellent!</strong> A ' + displayGPA.toFixed(2) + ' GPA puts you in a strong position for competitive scholarships, honors programs, and selective graduate school admissions.';
    } else if (displayGPA >= 3.0) {
      adviceEl.style.background = '#f0fdf4';
      adviceEl.style.border = '1px solid #bbf7d0';
      adviceEl.innerHTML = '<strong>Good standing.</strong> A ' + displayGPA.toFixed(2) + ' GPA meets the requirements for most scholarships and graduate programs. Focus on your strongest subjects to push higher.';
    } else if (displayGPA >= 2.0) {
      adviceEl.style.background = '#fffbeb';
      adviceEl.style.border = '1px solid #fde68a';
      adviceEl.innerHTML = '<strong>Room for improvement.</strong> A ' + displayGPA.toFixed(2) + ' GPA meets minimum graduation requirements at most schools but may limit scholarship and graduate school options. Consider tutoring and office hours to boost your grades.';
    } else {
      adviceEl.style.background = '#fef2f2';
      adviceEl.style.border = '1px solid #fecaca';
      adviceEl.innerHTML = '<strong>Academic warning.</strong> A ' + displayGPA.toFixed(2) + ' GPA is below the minimum required by most institutions. Speak with your academic advisor about support resources and consider reducing your course load.';
    }

    document.getElementById('gpa-results').style.display = '';
  });
</script>
