import ShareResults from '../../components/ShareResults.astro';
import ReviewedBy from '../../components/ReviewedBy.astro';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Education Calculators", "item": "https://toolcalcs.com/education-calculators/" },
      { "@type": "ListItem", "position": 3, "name": "GPA Calculator" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "How is GPA calculated?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "GPA is calculated by assigning a numeric value to each letter grade (A=4.0, B=3.0, C=2.0, D=1.0, F=0.0), multiplying each grade value by the credit hours for that course to get quality points, summing all quality points, and dividing by total credit hours. For example, an A in a 3-credit course gives 12 quality points. If you also earn a B in a 4-credit course (12 points), your GPA is (12+12)/(3+4) = 3.43."
        }
      },
      {
        "@type": "Question",
        name: "What is the difference between weighted and unweighted GPA?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "An unweighted GPA uses the standard 4.0 scale for all courses. A weighted GPA adds extra points for advanced courses: typically +0.5 for honors classes and +1.0 for AP or IB courses. This means a weighted GPA can exceed 4.0. For example, an A in an AP course would be worth 5.0 on a weighted scale instead of 4.0. Colleges consider both scales when evaluating applicants."
        }
      },
      {
        "@type": "Question",
        name: "What GPA do I need for college admission?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "GPA requirements vary widely by institution. Most four-year colleges require a minimum 2.0 GPA, but competitive schools typically expect 3.5 or higher. Ivy League and top-tier universities often see admitted students with 3.9+ unweighted GPAs. However, GPA is just one factor — colleges also consider test scores, extracurriculars, essays, and course rigor. Taking AP/IB courses and earning slightly lower grades may be viewed more favorably than earning straight As in easier courses."
        }
      }
    ]
  }
];
