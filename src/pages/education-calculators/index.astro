---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('education-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Education Calculators" }
  ]
};
---

<BaseLayout
  title="Education Calculators - GPA, College Cost, Student Loan & More"
  description="Free education calculators: GPA, college cost estimator, student loan repayment planner, scholarship impact, SAT scores, and teacher salary."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Education Calculators</span>
  </nav>

  <h1>Education Calculators</h1>
  <p class="page-desc">Free tools for students, parents, and educators. Calculate your GPA, estimate college costs, compare student loan repayment plans, and plan your education finances.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/education-calculators/gpa-calculator/" class="popular-chip">GPA</a>
      <a href="/education-calculators/college-cost-calculator/" class="popular-chip">College Cost</a>
      <a href="/education-calculators/student-loan-calculator/" class="popular-chip">Student Loan</a>
      <a href="/education-calculators/scholarship-calculator/" class="popular-chip">Scholarship</a>
      <a href="/education-calculators/sat-score-calculator/" class="popular-chip">SAT Score</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/education-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Education Guides & Articles</h2>
    <p class="quick-ref-desc">Learn the essentials of education planning and finances:</p>
    <div class="quick-ref-grid">
      <a href="/blog/how-to-refinance-student-loans/" class="quick-ref-card"><span>🎓</span> Student Loan Refinancing Guide</a>
      <a href="/blog/529-plan-college-savings/" class="quick-ref-card"><span>💰</span> 529 College Savings Guide</a>
      <a href="/blog/how-gpa-is-calculated/" class="quick-ref-card"><span>📊</span> How GPA Is Calculated</a>
      <a href="/blog/how-to-pay-off-student-loans/" class="quick-ref-card"><span>📋</span> How to Pay Off Student Loans</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="education-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
