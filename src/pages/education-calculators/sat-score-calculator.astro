<script is:inline>
  // R&W conversion table: [raw, scaled]
  var rwTable = [
    [54, 800], [52, 770], [50, 750], [48, 730], [46, 710],
    [45, 700], [43, 680], [42, 670], [40, 650], [38, 630],
    [37, 620], [35, 600], [33, 580], [32, 570], [30, 550],
    [28, 530], [27, 520], [25, 500], [23, 480], [22, 470],
    [20, 450], [18, 430], [17, 420], [15, 400], [13, 380],
    [12, 370], [10, 350], [8, 330], [7, 320], [5, 300],
    [3, 260], [2, 240], [1, 220], [0, 200]
  ];

  // Math conversion table: [raw, scaled]
  var mathTable = [
    [44, 800], [43, 780], [42, 760], [41, 750], [40, 740],
    [39, 720], [38, 710], [37, 700], [36, 690], [35, 680],
    [34, 660], [33, 650], [32, 640], [31, 630], [30, 620],
    [29, 600], [28, 590], [27, 580], [26, 570], [25, 560],
    [24, 540], [23, 530], [22, 520], [21, 510], [20, 500],
    [19, 490], [18, 470], [17, 460], [16, 450], [15, 440],
    [14, 420], [13, 410], [12, 400], [11, 390], [10, 380],
    [9, 360], [8, 350], [7, 340], [6, 330], [5, 320],
    [4, 290], [3, 270], [2, 240], [1, 220], [0, 200]
  ];

  function interpolate(table, raw) {
    raw = Math.max(0, Math.min(raw, table[0][0]));
    for (var i = 0; i < table.length; i++) {
      if (raw >= table[i][0]) {
        if (i === 0) return table[0][1];
        var upperRaw = table[i - 1][0];
        var upperScaled = table[i - 1][1];
        var lowerRaw = table[i][0];
        var lowerScaled = table[i][1];
        var frac = (raw - lowerRaw) / (upperRaw - lowerRaw);
        return Math.round(lowerScaled + frac * (upperScaled - lowerScaled));
      }
    }
    return 200;
  }

  function getPercentile(total) {
    if (total >= 1550) return 99;
    if (total >= 1500) return 98;
    if (total >= 1450) return 96;
    if (total >= 1400) return 94;
    if (total >= 1350) return 91;
    if (total >= 1300) return 87;
    if (total >= 1250) return 82;
    if (total >= 1200) return 75;
    if (total >= 1150) return 68;
    if (total >= 1100) return 60;
    if (total >= 1050) return 51;
    if (total >= 1000) return 42;
    if (total >= 950) return 33;
    if (total >= 900) return 25;
    if (total >= 850) return 18;
    if (total >= 800) return 12;
    if (total >= 750) return 7;
    if (total >= 700) return 4;
    if (total >= 650) return 2;
    return 1;
  }

  function getCompetitiveness(total) {
    if (total >= 1400) return 'Highly Competitive';
    if (total >= 1200) return 'Competitive';
    if (total >= 1000) return 'Average';
    return 'Below Average';
  }

  function calculate() {
    var rwRaw = parseInt(document.getElementById('rwRaw').value) || 0;
    var mathRaw = parseInt(document.getElementById('mathRaw').value) || 0;

    rwRaw = Math.max(0, Math.min(54, rwRaw));
    mathRaw = Math.max(0, Math.min(44, mathRaw));

    var rwScaled = interpolate(rwTable, rwRaw);
    var mathScaled = interpolate(mathTable, mathRaw);
    var total = rwScaled + mathScaled;
    var percentile = getPercentile(total);
    var level = getCompetitiveness(total);

    document.getElementById('rwScore').textContent = rwScaled;
    document.getElementById('mathScore').textContent = mathScaled;
    document.getElementById('totalScore').textContent = total;
    document.getElementById('percentile').textContent = percentile + 'th';
    document.getElementById('competitiveness').textContent = level;
  }

  document.getElementById('calculateBtn').addEventListener('click', calculate);

  ['rwRaw', 'mathRaw'].forEach(function(id) {
    document.getElementById(id).addEventListener('input', calculate);
  });

  calculate();
</script>
