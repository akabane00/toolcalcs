---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free Embeddable Calculators — Add to Your Website | ToolCalcs"
  description="Embed free calculators on your website. Mortgage, BMI, and more. Copy one line of code and add a professional calculator widget to any page."
>
  <h1>Embed Our Calculators on Your Website</h1>
  <p class="page-desc">Add a free, professional calculator to your blog, website, or app with a single line of code. No API key required. Mobile-friendly and lightweight.</p>

  <section class="embed-section">
    <h2>Mortgage Calculator Widget</h2>
    <p>A complete mortgage payment calculator with home price, down payment, interest rate, and loan term inputs.</p>
    <div class="embed-preview">
      <iframe src="/embed/mortgage/" width="100%" height="380" style="border:1px solid #e5e7eb;border-radius:8px" loading="lazy" title="Mortgage Calculator"></iframe>
    </div>
    <div class="embed-code">
      <label>Copy this code:</label>
      <textarea readonly rows="2" id="code-mortgage">&lt;iframe src="https://toolcalcs.com/embed/mortgage/" width="100%" height="380" style="border:1px solid #e5e7eb;border-radius:8px" title="Mortgage Calculator"&gt;&lt;/iframe&gt;</textarea>
      <button class="copy-btn" data-target="code-mortgage">Copy Code</button>
    </div>
  </section>

  <section class="embed-section">
    <h2>BMI Calculator Widget</h2>
    <p>A simple BMI calculator with height/weight inputs and color-coded results.</p>
    <div class="embed-preview">
      <iframe src="/embed/bmi/" width="100%" height="340" style="border:1px solid #e5e7eb;border-radius:8px" loading="lazy" title="BMI Calculator"></iframe>
    </div>
    <div class="embed-code">
      <label>Copy this code:</label>
      <textarea readonly rows="2" id="code-bmi">&lt;iframe src="https://toolcalcs.com/embed/bmi/" width="100%" height="340" style="border:1px solid #e5e7eb;border-radius:8px" title="BMI Calculator"&gt;&lt;/iframe&gt;</textarea>
      <button class="copy-btn" data-target="code-bmi">Copy Code</button>
    </div>
  </section>

  <section class="embed-info">
    <h2>Why Embed Our Calculators?</h2>
    <div class="info-grid">
      <div class="info-card">
        <strong>100% Free</strong>
        <p>No cost, no API keys, no registration. Just copy the code.</p>
      </div>
      <div class="info-card">
        <strong>Mobile Responsive</strong>
        <p>Widgets adapt to any screen size automatically.</p>
      </div>
      <div class="info-card">
        <strong>Lightweight</strong>
        <p>Under 5KB per widget. No external dependencies.</p>
      </div>
      <div class="info-card">
        <strong>Privacy First</strong>
        <p>No cookies, no tracking. Calculations run in the browser.</p>
      </div>
    </div>
  </section>

  <section class="embed-info">
    <h2>Need a Custom Calculator?</h2>
    <p>If you need a calculator widget for a specific use case, <a href="/contact/">contact us</a> and we will build it for you.</p>
  </section>

  <script>
    document.querySelectorAll('.copy-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var target = btn.getAttribute('data-target');
        var textarea = document.getElementById(target);
        if (textarea) {
          textarea.select();
          navigator.clipboard.writeText(textarea.value).then(function() {
            btn.textContent = 'Copied!';
            setTimeout(function() { btn.textContent = 'Copy Code'; }, 2000);
          });
        }
      });
    });
  </script>
</BaseLayout>

<style>
  .page-desc { color: var(--color-text-muted); margin-bottom: 32px; font-size: 1.05rem; }
  .embed-section { margin-bottom: 48px; }
  .embed-section h2 { font-size: 1.3rem; margin-bottom: 8px; }
  .embed-section > p { color: var(--color-text-muted); margin-bottom: 16px; font-size: 0.95rem; }
  .embed-preview { margin-bottom: 16px; }
  .embed-code { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 16px; }
  .embed-code label { font-size: 0.85rem; font-weight: 600; color: var(--color-text-muted); display: block; margin-bottom: 8px; }
  .embed-code textarea {
    width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: 6px;
    font-family: 'Courier New', monospace; font-size: 0.82rem; background: var(--color-bg);
    color: var(--color-text); resize: none;
  }
  .copy-btn {
    margin-top: 8px; padding: 8px 20px; background: var(--color-primary); color: #fff;
    border: none; border-radius: var(--radius); font-weight: 600; font-size: 0.85rem; cursor: pointer;
  }
  .copy-btn:hover { background: var(--color-primary-dark); }
  .embed-info { margin-bottom: 40px; }
  .embed-info h2 { font-size: 1.3rem; margin-bottom: 16px; }
  .info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
  .info-card {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: var(--radius); padding: 20px;
  }
  .info-card strong { display: block; margin-bottom: 6px; font-size: 1rem; }
  .info-card p { font-size: 0.85rem; color: var(--color-text-muted); margin: 0; line-height: 1.5; }
</style>
