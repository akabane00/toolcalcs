<script is:inline>
  function getAgeParts(birthDate, today) {
    var years = today.getFullYear() - birthDate.getFullYear();
    var months = today.getMonth() - birthDate.getMonth();
    var days = today.getDate() - birthDate.getDate();

    if (days < 0) {
      months--;
      var prevMonth = new Date(today.getFullYear(), today.getMonth(), 0);
      days += prevMonth.getDate();
    }
    if (months < 0) {
      years--;
      months += 12;
    }
    return { years: years, months: months, days: days };
  }

  function getDaysBetween(d1, d2) {
    var ms = Math.abs(d2.getTime() - d1.getTime());
    return Math.round(ms / (1000 * 60 * 60 * 24));
  }

  document.getElementById('calculateBtn').addEventListener('click', function() {
    var val1 = document.getElementById('birthday1').value;
    var val2 = document.getElementById('birthday2').value;

    if (!val1 || !val2) {
      alert('Please enter both birthdays.');
      return;
    }

    var parts1 = val1.split('-');
    var parts2 = val2.split('-');
    var date1 = new Date(parseInt(parts1[0]), parseInt(parts1[1]) - 1, parseInt(parts1[2]));
    var date2 = new Date(parseInt(parts2[0]), parseInt(parts2[1]) - 1, parseInt(parts2[2]));
    var today = new Date();
    today.setHours(0, 0, 0, 0);

    if (isNaN(date1.getTime()) || isNaN(date2.getTime())) {
      alert('Please enter valid dates for both birthdays.');
      return;
    }

    var olderDate, youngerDate, olderLabel, youngerLabel;
    if (date1.getTime() <= date2.getTime()) {
      olderDate = date1;
      youngerDate = date2;
      olderLabel = 'Person 1';
      youngerLabel = 'Person 2';
    } else {
      olderDate = date2;
      youngerDate = date1;
      olderLabel = 'Person 2';
      youngerLabel = 'Person 1';
    }

    var diff = getAgeParts(olderDate, youngerDate);
    var totalDays = getDaysBetween(date1, date2);

    var diffText = diff.years + ' year' + (diff.years !== 1 ? 's' : '');
    diffText += ', ' + diff.months + ' month' + (diff.months !== 1 ? 's' : '');
    diffText += ', ' + diff.days + ' day' + (diff.days !== 1 ? 's' : '');

    document.getElementById('resultDiff').textContent = diffText;
    document.getElementById('resultDays').textContent = totalDays.toLocaleString() + ' days';

    if (date1.getTime() === date2.getTime()) {
      document.getElementById('resultOlder').textContent = 'Same birthday!';
    } else {
      document.getElementById('resultOlder').textContent = olderLabel + ' is older';
    }

    var age1 = getAgeParts(date1, today);
    var age2 = getAgeParts(date2, today);

    var age1Text = age1.years + ' years, ' + age1.months + ' months, ' + age1.days + ' days';
    var age2Text = age2.years + ' years, ' + age2.months + ' months, ' + age2.days + ' days';

    document.getElementById('resultAge1').textContent = age1Text;
    document.getElementById('resultAge2').textContent = age2Text;

    var olderAge = olderDate === date1 ? age1.years : age2.years;
    var youngerAge = olderDate === date1 ? age2.years : age1.years;
    var minAge = Math.floor(olderAge / 2) + 7;
    var ruleText = '';
    if (youngerAge >= minAge) {
      ruleText = 'Within range (min age: ' + minAge + ' for the older partner aged ' + olderAge + ')';
    } else {
      ruleText = 'Below range (min age: ' + minAge + ' for the older partner aged ' + olderAge + ')';
    }
    document.getElementById('resultRule').textContent = ruleText;

    document.getElementById('resultsSection').style.display = '';
  });
</script>
