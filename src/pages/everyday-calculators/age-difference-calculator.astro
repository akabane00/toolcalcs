        <input type="date" id="birthday2" value="1995-09-20" />
      </div>
    </div>

    <button class="calc-btn" id="calculateBtn">Calculate Age Difference</button>

    <div class="calc-results" id="resultsSection" style="display:none;">
      <div class="result-cards">
        <div class="result-card primary">
          <span class="result-label">Age Difference</span>
          <span class="result-value" id="resultDiff">--</span>
        </div>
        <div class="result-card">
