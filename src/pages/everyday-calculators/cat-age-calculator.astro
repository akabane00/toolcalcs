<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script is:inline>
  function catToHuman(catAge) {
    if (catAge <= 0) return 0;
    if (catAge <= 1) return catAge * 15;
    if (catAge <= 2) return 15 + (catAge - 1) * 9;
    return 24 + (catAge - 2) * 4;
  }

  function getLifeStage(catAge) {
    if (catAge < 1) return 'Kitten';
    if (catAge < 2) return 'Junior';
    if (catAge < 7) return 'Prime';
    if (catAge < 11) return 'Mature';
    if (catAge < 15) return 'Senior';
    return 'Geriatric';
  }

  function calculateCatAge() {
    var catAgeInput = document.getElementById('catAge');
    var catTypeInput = document.getElementById('catType');

    var catAge = parseFloat(catAgeInput.value) || 0;
    var catType = catTypeInput.value;

    if (catAge < 0) catAge = 0;

    var lifeExpectancies = {
      indoor: '15\u201317 years',
      outdoor: '10\u201312 years',
      both: '12\u201315 years'
    };

    var humanAge = catToHuman(catAge);
    var lifeStage = getLifeStage(catAge);

    document.getElementById('humanAge').textContent = humanAge % 1 === 0 ? humanAge.toString() : humanAge.toFixed(1);
    document.getElementById('lifeStage').textContent = lifeStage;
    document.getElementById('lifeExpectancy').textContent = lifeExpectancies[catType] || '--';
  }

  document.getElementById('catAge').addEventListener('input', calculateCatAge);
  document.getElementById('catType').addEventListener('change', calculateCatAge);

  calculateCatAge();
</script>
