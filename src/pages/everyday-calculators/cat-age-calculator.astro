          <tr><td>11</td><td>60</td><td>Senior</td></tr>
          <tr><td>12</td><td>64</td><td>Senior</td></tr>
          <tr><td>13</td><td>68</td><td>Senior</td></tr>
          <tr><td>14</td><td>72</td><td>Senior</td></tr>
