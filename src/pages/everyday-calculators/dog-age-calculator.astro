<script is:inline>
  function calculateDogAge() {
    var dogAgeInput = document.getElementById('dogAge');
    var dogSizeInput = document.getElementById('dogSize');

    var dogAge = parseFloat(dogAgeInput.value) || 0;
    var dogSize = dogSizeInput.value;

    if (dogAge < 0) dogAge = 0;

    // Rate per year after age 2
    var rateAfterTwo = { small: 4, medium: 5, large: 6, giant: 7 };
    var rate = rateAfterTwo[dogSize] || 5;

    // Life expectancy ranges
    var lifeExpectancies = {
      small: '15\u201316 years',
      medium: '12\u201314 years',
      large: '10\u201312 years',
      giant: '8\u201310 years'
    };

    // Calculate human equivalent age
    var humanAge = 0;
    if (dogAge <= 0) {
      humanAge = 0;
    } else if (dogAge <= 1) {
      humanAge = dogAge * 15;
    } else if (dogAge <= 2) {
      humanAge = 15 + (dogAge - 1) * 9;
    } else {
      humanAge = 15 + 9 + (dogAge - 2) * rate;
    }

    // Determine life stage
    var lifeStage = '';
    if (dogAge < 1) {
      lifeStage = 'Puppy';
    } else if (dogAge < 2) {
      lifeStage = 'Junior';
    } else if (dogAge < 6) {
      lifeStage = 'Adult';
    } else if (dogAge < 9) {
      lifeStage = 'Mature';
    } else if (dogAge < 12) {
      lifeStage = 'Senior';
    } else {
      lifeStage = 'Geriatric';
    }

    // Update display
    document.getElementById('humanAge').textContent = humanAge % 1 === 0 ? humanAge.toString() : humanAge.toFixed(1);
    document.getElementById('lifeStage').textContent = lifeStage;
    document.getElementById('lifeExpectancy').textContent = lifeExpectancies[dogSize] || '--';
  }

  // Real-time calculation on input changes
  document.getElementById('dogAge').addEventListener('input', calculateDogAge);
  document.getElementById('dogSize').addEventListener('change', calculateDogAge);

  // Initial calculation on load
  calculateDogAge();
</script>
