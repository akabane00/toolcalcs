---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('everyday-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Everyday Calculators"
    }
  ]
};
---

<BaseLayout
  title="Everyday Calculators - Tip, Discount & Practical Tools"
  description="Free everyday calculators: tip calculator, discount calculator, hours calculator, and more practical tools for daily life."

  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Everyday Calculators</span>
  </nav>

  <h1>Everyday Calculators</h1>
  <p class="page-desc">Free practical tools for tips, discounts, time tracking, and more.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/everyday-calculators/tip-calculator/" class="popular-chip">Tip Calculator</a>
      <a href="/everyday-calculators/discount-calculator/" class="popular-chip">Discount Calculator</a>
      <a href="/everyday-calculators/square-footage-calculator/" class="popular-chip">Square Footage</a>
      <a href="/everyday-calculators/hours-calculator/" class="popular-chip">Hours Calculator</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/everyday-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Related Articles</h2>
    <p class="quick-ref-desc">Helpful guides for everyday life:</p>
    <div class="quick-ref-grid">
      <a href="/blog/complete-guide-to-tipping/" class="quick-ref-card"><span>🍽️</span> Guide to Tipping</a>
      <a href="/blog/how-to-negotiate-your-salary/" class="quick-ref-card"><span>💰</span> Salary Negotiation Tips</a>
      <a href="/blog/how-to-read-a-tape-measure/" class="quick-ref-card"><span>📏</span> Reading a Tape Measure</a>
      <a href="/blog/excel-formulas-cheat-sheet/" class="quick-ref-card"><span>📊</span> Excel Formulas Cheat Sheet</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="everyday-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
