<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }

  .calc-btn {
    display: block;
    width: 100%;
    padding: 14px 24px;
    margin-top: 8px;
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #e8457c, #f0326a);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .calc-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(232, 69, 124, 0.35);
  }
  .calc-btn:active {
    transform: translateY(0);
  }

  .love-card {
    background: linear-gradient(135deg, #ff6b9d, #e8457c, #c62368) !important;
    color: #fff !important;
    position: relative;
    overflow: hidden;
  }
  .love-card .result-label {
    color: rgba(255, 255, 255, 0.9) !important;
  }
  .love-card .result-value {
    color: #fff !important;
    font-size: 3rem;
    line-height: 1.1;
  }
  .love-card::before {
    content: '';
    position: absolute;
    top: -20px;
    right: -20px;
    width: 80px;
    height: 80px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    pointer-events: none;
  }
  .love-card::after {
    content: '';
    position: absolute;
    bottom: -30px;
    left: -10px;
    width: 60px;
    height: 60px;
    background: rgba(255, 255, 255, 0.07);
    border-radius: 50%;
    pointer-events: none;
  }

  .love-score {
    display: inline-block;
  }

  .love-message {
    font-size: 0.95rem !important;
    line-height: 1.4;
  }

  @keyframes love-pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }
  .love-score.animate {
    animation: love-pulse 0.6s ease-in-out 2;
  }

  @keyframes love-fade-in {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .calc-results.show {
    animation: love-fade-in 0.4s ease-out;
  }
</style>

<script is:inline>
  function calculateLove() {
    var yourNameEl = document.getElementById('yourName');
    var partnerNameEl = document.getElementById('partnerName');
    var resultsSection = document.getElementById('resultsSection');

    var name1 = yourNameEl.value.trim().toLowerCase().replace(/[^a-z]/g, '');
    var name2 = partnerNameEl.value.trim().toLowerCase().replace(/[^a-z]/g, '');

    if (!name1 || !name2) {
      alert('Please enter both names to calculate your love score.');
      return;
    }

    // Deterministic love score algorithm
    var combined = name1 + name2;
    var sorted = (name1 < name2) ? name1 + name2 : name2 + name1;

    // Count occurrences of letters in "lovestrue"
    var keyword = 'lovestrue';
    var counts = [];
    for (var k = 0; k < keyword.length; k++) {
      var ch = keyword[k];
      var count = 0;
      for (var c = 0; c < sorted.length; c++) {
        if (sorted[c] === ch) count++;
      }
      counts.push(count);
    }

    // Create a hash from sorted name pair
    var hash = 0;
    for (var i = 0; i < sorted.length; i++) {
      hash = ((hash << 5) - hash + sorted.charCodeAt(i)) | 0;
    }
    if (hash < 0) hash = -hash;

    // Combine letter counts with hash for final score
    var countSum = 0;
    for (var j = 0; j < counts.length; j++) {
      countSum += counts[j] * (j + 1);
    }

    var raw = (hash + countSum * 7) % 99 + 1;
    var score = raw;

    // Get compatibility rating and message
    var rating = '';
    var message = '';

    if (score >= 90) {
      rating = 'Perfect Match!';
      message = name1.charAt(0).toUpperCase() + name1.slice(1) + ' and ' + name2.charAt(0).toUpperCase() + name2.slice(1) + ' are written in the stars! This connection is rare and beautiful. Hold on tight!';
    } else if (score >= 80) {
      rating = 'Soulmate Energy';
      message = 'The universe is definitely shipping ' + name1.charAt(0).toUpperCase() + name1.slice(1) + ' and ' + name2.charAt(0).toUpperCase() + name2.slice(1) + '. This bond has serious soulmate potential!';
    } else if (score >= 70) {
      rating = 'Strong Connection';
      message = 'There is a powerful spark between you two! With care and attention, this connection could blossom into something truly special.';
    } else if (score >= 60) {
      rating = 'Great Potential';
      message = 'The chemistry is real! You two have a solid foundation for building something meaningful together. Keep exploring!';
    } else if (score >= 50) {
      rating = 'Growing Bond';
      message = 'There is genuine warmth here. Like a garden, this relationship will flourish with patience, communication, and a little sunshine.';
    } else if (score >= 40) {
      rating = 'Interesting Match';
      message = 'Opposites can attract! Your differences might be exactly what makes this pairing exciting and full of surprises.';
    } else if (score >= 30) {
      rating = 'Slow Burn';
      message = 'Great love stories do not always start with fireworks. Sometimes the best connections simmer slowly and surprise everyone!';
    } else if (score >= 20) {
      rating = 'Friends First';
      message = 'The best romances often start as friendships. Take your time getting to know each other and see where the journey leads.';
    } else {
      rating = 'Mystery Match';
      message = 'The heart wants what it wants! Some of the greatest love stories in history started against all odds. Never say never!';
    }

    // Update display
    var loveScoreEl = document.getElementById('loveScore');
    loveScoreEl.textContent = score + '%';
    loveScoreEl.classList.remove('animate');
    void loveScoreEl.offsetWidth;
    loveScoreEl.classList.add('animate');

    document.getElementById('compatRating').textContent = rating;
    document.getElementById('funMessage').textContent = message;

    resultsSection.style.display = '';
    resultsSection.classList.remove('show');
    void resultsSection.offsetWidth;
    resultsSection.classList.add('show');
  }

  document.getElementById('calcBtn').addEventListener('click', calculateLove);

  // Allow Enter key to trigger calculation
  document.getElementById('yourName').addEventListener('keydown', function(e) {
