      <li><a href="/financial-calculators/tax-calculator/">Tax Calculator</a> &ndash; Estimate your federal and state income tax liability.</li>
    </ul>
  </article>

  <AdUnit slot="calc-bottom" format="horizontal" />
  <RelatedArticles calculatorSlug="sales-tax-calculator" />
  <RelatedCalculators currentSlug="sales-tax-calculator" />
</BaseLayout>

<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
  .quick-btns { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }
  .quick-btn { padding: 4px 12px; border: 1px solid var(--color-border); border-radius: var(--radius); background: transparent; cursor: pointer; font-size: 0.85rem; color: var(--color-text); transition: all 0.15s; }
  .quick-btn:hover, .quick-btn.active { border-color: var(--color-primary); color: var(--color-primary); background: #eff6ff; }
</style>

<script is:inline>
  function formatCurrency(n) {
    return '$' + n.toFixed(2);
  }

  function calculate() {
    var price = parseFloat(document.getElementById('priceInput').value) || 0;
    var rate = parseFloat(document.getElementById('taxRate').value) || 0;
    var qty = parseInt(document.getElementById('quantityInput').value) || 1;

    if (price < 0) price = 0;
    if (rate < 0) rate = 0;
    if (qty < 1) qty = 1;

    var perItemTax = price * (rate / 100);
    var taxAmount = perItemTax * qty;
    var subtotal = price * qty;
    var totalPrice = subtotal + taxAmount;
    var effectiveRate = subtotal > 0 ? (taxAmount / subtotal * 100).toFixed(2) + '%' : '0%';

    document.getElementById('taxAmount').textContent = formatCurrency(taxAmount);
    document.getElementById('totalPrice').textContent = formatCurrency(totalPrice);
    document.getElementById('effectiveRate').textContent = effectiveRate;
    document.getElementById('perItemTax').textContent = formatCurrency(perItemTax);
  }

  document.getElementById('priceInput').addEventListener('input', calculate);
  document.getElementById('taxRate').addEventListener('input', function() {
    var val = parseFloat(this.value) || 0;
    document.querySelectorAll('.quick-btn').forEach(function(btn) {
      var btnRate = parseFloat(btn.getAttribute('data-rate'));
      if (btnRate === val) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
    calculate();
  });
  document.getElementById('quantityInput').addEventListener('input', calculate);

  document.querySelectorAll('.quick-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var rateVal = parseFloat(this.getAttribute('data-rate'));
      document.getElementById('taxRate').value = rateVal;
      document.querySelectorAll('.quick-btn').forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      calculate();
    });
  });

  calculate();
</script>
