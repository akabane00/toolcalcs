const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolcalcs.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Everyday Calculators",
        "item": "https://toolcalcs.com/everyday-calculators/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Time Card Calculator"
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I calculate hours worked from a time card?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'To calculate hours worked, subtract your clock-in time from your clock-out time to get gross hours, then subtract any unpaid break time. Convert the result to decimal hours by dividing remaining minutes by 60. For example, clocking in at 8:30 AM and out at 5:00 PM with a 30-minute break gives 8 gross hours minus 0.5 hours break, equaling 7.5 net hours worked.',
        },
      },
      {
        '@type': 'Question',
        name: 'When does overtime pay start?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Under the federal Fair Labor Standards Act (FLSA), overtime begins after 40 hours worked in a single workweek. Hours beyond 40 must be paid at 1.5 times the regular hourly rate. Some states like California also require daily overtime for hours worked beyond 8 in a single day, and double time for hours beyond 12 in a day.',
        },
      },
      {
        '@type': 'Question',
        name: 'Are meal breaks deducted from hours worked?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Under federal law, bona fide meal periods of 30 minutes or longer are not considered compensable work time and should be deducted from hours worked, provided the employee is completely relieved of duties. Short rest breaks of 5 to 20 minutes are considered paid work time and should not be deducted. State laws may impose additional break requirements.',
        },
      },
      {
        '@type': 'Question',
        name: 'How is time-and-a-half calculated?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Time-and-a-half means multiplying your regular hourly rate by 1.5 to get the overtime rate. For example, if you earn $20 per hour, your overtime rate is $30 per hour ($20 x 1.5). This rate applies to all hours worked beyond 40 in a workweek under federal law. Some employers offer double time (2x) for holidays or excessive hours.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do I need to track hours if I am a salaried employee?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'It depends on your exemption status. Salaried employees classified as "exempt" under the FLSA are not entitled to overtime pay and typically do not need to track hours. However, salaried "non-exempt" employees must still receive overtime for hours over 40 per week and should track their time. Employers are legally required to keep records of hours worked for all non-exempt employees regardless of pay structure.',
        },
      },
    ],
  },
];
