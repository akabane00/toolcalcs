      margin-bottom: 4px;
    }
    .tc-row .input-group::before {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .tc-row .input-group:nth-child(2)::before { content: 'Clock In'; }
    .tc-row .input-group:nth-child(3)::before { content: 'Clock Out'; }
    .tc-row .input-group:nth-child(4)::before { content: 'Break (min)'; }
    .day-hours {
      text-align: left;
      font-size: 1rem;
    }
    .day-hours::before {
      content: 'Hours: ';
      font-weight: 500;
      color: var(--color-text-muted);
      font-size: 0.85rem;
    }
    .result-cards {
      grid-template-columns: 1fr;
    }
    .tc-buttons {
      flex-direction: column;
    }
    .tc-buttons .calc-btn {
      width: 100%;
    }
  }
</style>

<script is:inline>
  function formatMoney(n) {
    return '$' + n.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  function calculateTimeCard() {
    var rows = document.querySelectorAll('.tc-row[data-day]');
    var hourlyRate = parseFloat(document.getElementById('hourlyRate').value) || 0;
    var otThreshold = parseFloat(document.getElementById('otThreshold').value) || 40;
    var otMultiplier = parseFloat(document.getElementById('otMultiplier').value) || 1.5;
    var totalMinutes = 0;

    rows.forEach(function(row) {
      var clockIn = row.querySelector('.clock-in');
      var clockOut = row.querySelector('.clock-out');
      var breakInput = row.querySelector('.break-min');
      var dayDisplay = row.querySelector('.day-hours');

      var inVal = clockIn.value;
      var outVal = clockOut.value;
      var breakMin = parseInt(breakInput.value) || 0;

      if (!inVal || !outVal) {
        dayDisplay.textContent = '0.00';
        return;
      }

      var inParts = inVal.split(':');
      var outParts = outVal.split(':');
      var inMinutes = parseInt(inParts[0]) * 60 + parseInt(inParts[1]);
      var outMinutes = parseInt(outParts[0]) * 60 + parseInt(outParts[1]);

      // Handle overnight shifts
      if (outMinutes <= inMinutes) {
        outMinutes += 1440; // add 24 hours
      }

      var worked = outMinutes - inMinutes - breakMin;
      if (worked < 0) worked = 0;

      var dayHours = worked / 60;
      dayDisplay.textContent = dayHours.toFixed(2);
      totalMinutes += worked;
    });

    var totalHours = totalMinutes / 60;
    var regularHours = Math.min(totalHours, otThreshold);
    var overtimeHours = Math.max(totalHours - otThreshold, 0);
    var regPay = regularHours * hourlyRate;
    var otPay = overtimeHours * hourlyRate * otMultiplier;
    var totalPay = regPay + otPay;

    document.getElementById('totalHours').textContent = totalHours.toFixed(2);
    document.getElementById('regularHours').textContent = regularHours.toFixed(2);
    document.getElementById('overtimeHours').textContent = overtimeHours.toFixed(2);
    document.getElementById('regularPay').textContent = formatMoney(regPay);
    document.getElementById('overtimePay').textContent = formatMoney(otPay);
    document.getElementById('totalPay').textContent = formatMoney(totalPay);
  }

  function clearAll() {
    var rows = document.querySelectorAll('.tc-row[data-day]');
    rows.forEach(function(row) {
      row.querySelector('.clock-in').value = '';
      row.querySelector('.clock-out').value = '';
      row.querySelector('.break-min').value = '0';
      row.querySelector('.day-hours').textContent = '0.00';
    });
    document.getElementById('totalHours').textContent = '0.00';
    document.getElementById('regularHours').textContent = '0.00';
    document.getElementById('overtimeHours').textContent = '0.00';
    document.getElementById('regularPay').textContent = '$0.00';
    document.getElementById('overtimePay').textContent = '$0.00';
    document.getElementById('totalPay').textContent = '$0.00';
  }

  function setDefault95() {
    var rows = document.querySelectorAll('.tc-row[data-day]');
    var weekdays = ['mon', 'tue', 'wed', 'thu', 'fri'];
    rows.forEach(function(row) {
      var day = row.getAttribute('data-day');
      if (weekdays.indexOf(day) !== -1) {
        row.querySelector('.clock-in').value = '09:00';
        row.querySelector('.clock-out').value = '17:00';
        row.querySelector('.break-min').value = '30';
      } else {
        row.querySelector('.clock-in').value = '';
        row.querySelector('.clock-out').value = '';
        row.querySelector('.break-min').value = '0';
      }
    });
    calculateTimeCard();
  }

  document.getElementById('calculateBtn').addEventListener('click', calculateTimeCard);
  document.getElementById('clearBtn').addEventListener('click', clearAll);
  document.getElementById('defaultBtn').addEventListener('click', setDefault95);
</script>
