  </article>

  <AdUnit slot="bep-bottom" format="horizontal" />
<RelatedCalculators currentSlug="breakeven-calculator" />
</BaseLayout>

<script>
  function formatCurrency(n: number): string {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function formatPct(n: number): string {
    return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '%';
  }

  function calculate() {
    var fixedCosts = parseFloat((document.getElementById('fixedCosts') as HTMLInputElement).value) || 0;
    var variableCost = parseFloat((document.getElementById('variableCost') as HTMLInputElement).value) || 0;
    var sellingPrice = parseFloat((document.getElementById('sellingPrice') as HTMLInputElement).value) || 0;
    var expectedUnits = parseFloat((document.getElementById('expectedUnits') as HTMLInputElement).value) || 0;

    var contributionMargin = sellingPrice - variableCost;

    if (sellingPrice <= variableCost || contributionMargin <= 0) {
      document.getElementById('breakevenUnits')!.textContent = 'N/A - Price must exceed variable cost';
      document.getElementById('breakevenRevenue')!.textContent = 'N/A';
      document.getElementById('contributionMarginDollar')!.textContent = formatCurrency(contributionMargin);
      document.getElementById('contributionMarginPct')!.textContent = sellingPrice > 0 ? formatPct((contributionMargin / sellingPrice) * 100) : '0.00%';
      document.getElementById('profitAtExpected')!.textContent = 'N/A';
      document.getElementById('safetyMargin')!.textContent = 'N/A';
      return;
    }

    var breakevenUnits = Math.ceil(fixedCosts / contributionMargin);
    var breakevenRevenue = breakevenUnits * sellingPrice;
    var contributionMarginPct = (contributionMargin / sellingPrice) * 100;
    var profitAtExpected = (expectedUnits - breakevenUnits) * contributionMargin;
    var safetyMargin = expectedUnits > 0 ? ((expectedUnits - breakevenUnits) / expectedUnits) * 100 : 0;

    document.getElementById('breakevenUnits')!.textContent = breakevenUnits.toLocaleString('en-US');
    document.getElementById('breakevenRevenue')!.textContent = formatCurrency(breakevenRevenue);
    document.getElementById('contributionMarginDollar')!.textContent = formatCurrency(contributionMargin);
    document.getElementById('contributionMarginPct')!.textContent = formatPct(contributionMarginPct);
    document.getElementById('profitAtExpected')!.textContent = formatCurrency(profitAtExpected);
    document.getElementById('safetyMargin')!.textContent = formatPct(safetyMargin);
  }

  document.getElementById('calculateBtn')?.addEventListener('click', calculate);
  calculate();
</script>
