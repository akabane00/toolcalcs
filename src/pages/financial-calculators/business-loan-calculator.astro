  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Financial Calculators", "item": "https://toolcalcs.com/financial-calculators/" },
      { "@type": "ListItem", "position": 3, "name": "Business Loan Calculator" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you calculate a business loan payment?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Business loan payments are calculated using the PMT formula: PMT = P × r(1+r)^n / ((1+r)^n - 1), where P is the loan principal, r is the monthly interest rate (annual rate divided by 12), and n is the total number of monthly payments. For example, a $250,000 loan at 7.5% annual interest over 10 years would have a monthly payment of approximately $2,966. The formula assumes fixed-rate amortization where each payment covers both interest and principal.",
        },
      },
      {
        "@type": "Question",
        "name": "What is a typical business loan interest rate?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Business loan interest rates vary significantly by loan type and lender. SBA loans typically range from 5% to 8%, traditional bank term loans from 6% to 12%, and business lines of credit from 7% to 25%. Rates depend on factors including credit score, time in business, annual revenue, collateral, and overall economic conditions. Borrowers with strong credit profiles and established businesses generally qualify for the lowest rates.",
        },
      },
      {
        "@type": "Question",
        "name": "How much can I borrow for a business loan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The amount you can borrow for a business loan depends on several factors: annual revenue (lenders typically lend 10-30% of annual revenue), personal and business credit scores, available collateral, time in business (most lenders require at least 2 years), and the specific loan program. SBA 7(a) loans go up to $5 million, while SBA microloans cap at $50,000. Traditional bank loans can range from $25,000 to several million depending on the lender and your qualifications.",
        },
      },
    ],
  },
];
---

<BaseLayout
