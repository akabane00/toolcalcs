<style>
  .input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 640px) { .input-grid { grid-template-columns: 1fr; } }
  .amort-section { margin-top: 24px; overflow-x: auto; }
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script>
  var startDateInput = document.getElementById('startDate');
  if (!startDateInput.value) {
    var now = new Date();
    startDateInput.value = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0');
  }

  function formatCurrency(n) {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function formatPct(n) {
    return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '%';
  }

  function getMonthName(monthIndex) {
    var names = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    return names[monthIndex];
  }

  function calculate() {
    var P = parseFloat(document.getElementById('loanAmount').value);
    var annualRate = parseFloat(document.getElementById('interestRate').value);
    var years = parseFloat(document.getElementById('loanTerm').value);
    var extra = parseFloat(document.getElementById('extraPayment').value) || 0;
    var loanType = document.getElementById('loanType').value;
    var startDateVal = document.getElementById('startDate').value;

    if (isNaN(P) || isNaN(annualRate) || isNaN(years) || P <= 0 || annualRate <= 0 || years <= 0) return;

    var r = annualRate / 100 / 12;
    var n = Math.round(years * 12);

    // SBA guaranty fees
    var fees = 0;
    if (loanType === 'sba') {
      if (P > 1000000) fees = P * 0.035;
      else if (P > 500000) fees = P * 0.03;
      else if (P > 150000) fees = P * 0.02;
    }

    // Standard monthly payment (without extra)
    var monthlyPayment = P * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
    var totalPaidStandard = monthlyPayment * n;
    var totalInterestStandard = totalPaidStandard - P;

    // Amortization with extra payments
    var balance = P;
    var totalPaidExtra = 0;
    var totalInterestExtra = 0;
    var monthsWithExtra = 0;
    var schedule = [];

    while (balance > 0.01 && monthsWithExtra < n * 2) {
      monthsWithExtra++;
      var interestPmt = balance * r;
      var principalPmt = monthlyPayment - interestPmt + extra;
      if (principalPmt > balance) {
        principalPmt = balance;
      }
      var actualPayment = principalPmt + interestPmt;
      totalPaidExtra += actualPayment;
      totalInterestExtra += interestPmt;
      balance = balance - principalPmt;
      if (balance < 0.01) balance = 0;

      schedule.push({
        month: monthsWithExtra,
        payment: actualPayment,
        principal: principalPmt,
        interest: interestPmt,
        balance: balance
      });
    }

    var interestSaved = totalInterestStandard - totalInterestExtra;
    if (interestSaved < 0) interestSaved = 0;

    // Effective APR considering fees
    var effectiveAPR = annualRate;
    if (fees > 0) {
      var totalCostWithFees = totalInterestExtra + fees;
      effectiveAPR = (totalCostWithFees / P) / (monthsWithExtra / 12) * 100;
    }

    // Payoff date
    var payoffDate = '--';
    if (startDateVal) {
      var parts = startDateVal.split('-');
      var startYear = parseInt(parts[0]);
      var startMonth = parseInt(parts[1]) - 1;
      var endDate = new Date(startYear, startMonth + monthsWithExtra, 1);
      payoffDate = getMonthName(endDate.getMonth()) + ' ' + endDate.getFullYear();
    }

    // Update result cards
    document.getElementById('monthlyPayment').textContent = formatCurrency(monthlyPayment);
    document.getElementById('totalInterest').textContent = formatCurrency(totalInterestExtra);
    document.getElementById('totalCost').textContent = formatCurrency(P + totalInterestExtra + fees);
    document.getElementById('payoffDate').textContent = payoffDate;
    document.getElementById('interestSavings').textContent = extra > 0 ? formatCurrency(interestSaved) : '$0.00';
    document.getElementById('effectiveAPR').textContent = formatPct(effectiveAPR);

    // Build amortization table
    var tbody = document.getElementById('amortBody');
    var rows = '';

    // Monthly view for first 12 months
    var monthLimit = Math.min(12, schedule.length);
    for (var i = 0; i < monthLimit; i++) {
      var s = schedule[i];
      rows += '<tr>';
      rows += '<td>Month ' + s.month + '</td>';
      rows += '<td>' + formatCurrency(s.payment) + '</td>';
      rows += '<td>' + formatCurrency(s.principal) + '</td>';
      rows += '<td>' + formatCurrency(s.interest) + '</td>';
      rows += '<td>' + formatCurrency(s.balance) + '</td>';
      rows += '</tr>';
    }

    // Yearly summaries for remaining months
    if (schedule.length > 12) {
      var currentYear = 2;
      var yearPayment = 0;
      var yearPrincipal = 0;
      var yearInterest = 0;
      var yearEndBalance = 0;

      for (var j = 12; j < schedule.length; j++) {
        var entry = schedule[j];
        yearPayment += entry.payment;
        yearPrincipal += entry.principal;
        yearInterest += entry.interest;
        yearEndBalance = entry.balance;

        if ((j + 1) % 12 === 0 || j === schedule.length - 1) {
          rows += '<tr>';
          rows += '<td>Year ' + currentYear + '</td>';
          rows += '<td>' + formatCurrency(yearPayment) + '</td>';
          rows += '<td>' + formatCurrency(yearPrincipal) + '</td>';
          rows += '<td>' + formatCurrency(yearInterest) + '</td>';
          rows += '<td>' + formatCurrency(yearEndBalance) + '</td>';
          rows += '</tr>';
          currentYear++;
          yearPayment = 0;
          yearPrincipal = 0;
          yearInterest = 0;
          yearEndBalance = 0;
        }
      }
    }

    tbody.innerHTML = rows;
  }

  document.getElementById('calcBtn').addEventListener('click', calculate);
  calculate();
</script>
