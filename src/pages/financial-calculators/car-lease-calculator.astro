  <RelatedArticles calculatorSlug="car-lease-calculator" />

  <RelatedCalculators currentSlug="car-lease-calculator" />
</BaseLayout>

<style>
  .comparison-table-wrapper {
    overflow-x: auto;
    margin: 16px 0;
  }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .comparison-table th,
  .comparison-table td {
    padding: 10px 14px;
    text-align: left;
    border: 1px solid var(--color-border, #e5e7eb);
  }
  .comparison-table th {
    background: var(--color-bg-muted, #f9fafb);
    font-weight: 600;
  }
  .comparison-table tr:nth-child(even) td {
    background: var(--color-bg-muted, #f9fafb);
  }
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script>
  function formatCurrency(n: number): string {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function calculate() {
    const msrp = parseFloat((document.getElementById('msrp') as HTMLInputElement).value) || 0;
    const negotiatedPrice = parseFloat((document.getElementById('negotiatedPrice') as HTMLInputElement).value) || 0;
    const residualPct = parseFloat((document.getElementById('residualPct') as HTMLInputElement).value) || 0;
    const moneyFactor = parseFloat((document.getElementById('moneyFactor') as HTMLInputElement).value) || 0;
    const term = parseInt((document.getElementById('leaseTerm') as HTMLSelectElement).value) || 36;
    const downPayment = parseFloat((document.getElementById('downPayment') as HTMLInputElement).value) || 0;
    const tradeIn = parseFloat((document.getElementById('tradeIn') as HTMLInputElement).value) || 0;
    const fees = parseFloat((document.getElementById('fees') as HTMLInputElement).value) || 0;

    // Adjusted capitalized cost
    const adjustedCapCost = negotiatedPrice + fees - downPayment - tradeIn;

    // Residual value (based on MSRP)
    const residualValue = msrp * (residualPct / 100);

    // Depreciation
    const depreciation = adjustedCapCost - residualValue;
    const monthlyDepreciation = depreciation / term;

    // Finance charge
    const monthlyFinanceCharge = (adjustedCapCost + residualValue) * moneyFactor;

    // Monthly payment
    const monthlyPayment = monthlyDepreciation + monthlyFinanceCharge;

    // Totals
    const totalLeaseCost = (monthlyPayment * term) + downPayment;
    const totalFinanceCharges = monthlyFinanceCharge * term;
    const depreciationCost = monthlyDepreciation * term;
    const equivalentApr = moneyFactor * 2400;

    document.getElementById('monthlyPayment')!.textContent = formatCurrency(Math.max(0, monthlyPayment));
    document.getElementById('totalLeaseCost')!.textContent = formatCurrency(Math.max(0, totalLeaseCost));
    document.getElementById('totalFinanceCharges')!.textContent = formatCurrency(Math.max(0, totalFinanceCharges));
    document.getElementById('depreciationCost')!.textContent = formatCurrency(Math.max(0, depreciationCost));
    document.getElementById('equivalentApr')!.textContent = equivalentApr.toFixed(1) + '%';
  }

  document.getElementById('calculateBtn')?.addEventListener('click', calculate);

  // Auto-calculate on load
  calculate();
</script>
