<script>
  function formatCurrency(n) {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function calculate() {
    var monthlyInvestment = parseFloat(document.getElementById('monthlyInvestment').value) || 0;
    var duration = parseInt(document.getElementById('duration').value) || 1;
    var annualReturn = parseFloat(document.getElementById('annualReturn').value) || 0;
    var startingBalance = parseFloat(document.getElementById('startingBalance').value) || 0;

    var monthlyRate = annualReturn / 100 / 12;
    var months = duration * 12;
    var totalInvested = startingBalance + (monthlyInvestment * months);

    var fvContributions;
    var fvStarting;

    if (monthlyRate === 0) {
      fvContributions = monthlyInvestment * months;
      fvStarting = startingBalance;
    } else {
      fvContributions = monthlyInvestment * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate) * (1 + monthlyRate);
      fvStarting = startingBalance * Math.pow(1 + monthlyRate, months);
    }

    var finalValue = fvContributions + fvStarting;
    var totalReturn = finalValue - totalInvested;
    var totalReturnPercent = totalInvested > 0 ? (totalReturn / totalInvested) * 100 : 0;

    var cagr = 0;
    if (totalInvested > 0 && finalValue > 0 && duration > 0) {
      cagr = (Math.pow(finalValue / totalInvested, 1 / duration) - 1) * 100;
    }

    document.getElementById('finalValue').textContent = formatCurrency(finalValue);
    document.getElementById('totalInvested').textContent = formatCurrency(totalInvested);
    document.getElementById('totalReturnDollar').textContent = formatCurrency(totalReturn);
    document.getElementById('totalReturnPercent').textContent = totalReturnPercent.toFixed(1) + '%';
    document.getElementById('cagr').textContent = cagr.toFixed(2) + '%';

    // Build year-by-year growth table
    var tbody = document.querySelector('#growthTable tbody');
    var rows = '';
    var balance = startingBalance;
    var cumulativeContributions = startingBalance;

    for (var year = 1; year <= duration; year++) {
      var startOfYearBalance = balance;
      for (var m = 0; m < 12; m++) {
        balance = balance * (1 + monthlyRate) + monthlyInvestment;
      }
      cumulativeContributions = cumulativeContributions + (monthlyInvestment * 12);
      var interestEarned = balance - cumulativeContributions;

      rows += '<tr>';
      rows += '<td>' + year + '</td>';
      rows += '<td>' + formatCurrency(cumulativeContributions) + '</td>';
      rows += '<td>' + formatCurrency(interestEarned) + '</td>';
      rows += '<td>' + formatCurrency(balance) + '</td>';
      rows += '</tr>';
    }

    tbody.innerHTML = rows;
  }

  document.getElementById('calculateBtn').addEventListener('click', calculate);
  // Auto-calculate on load
  calculate();
</script>
