<script>
  interface Debt {
    name: string;
    balance: number;
    apr: number;
    minPayment: number;
  }

  interface PayoffResult {
    months: number;
    totalInterest: number;
    totalPaid: number;
  }

  let debtCounter = 0;

  function createDebtRow(name: string, balance: number, apr: number, minPayment: number): HTMLDivElement {
    const row = document.createElement('div');
    row.className = 'debt-row';
    row.dataset.id = String(debtCounter++);

    row.innerHTML = `
      <div class="debt-name-group">
        <label>Debt Name</label>
        <input type="text" class="debt-name" value="${name}" placeholder="e.g. Credit Card" />
      </div>
      <div>
        <label>Balance ($)</label>
        <input type="number" class="debt-balance" value="${balance}" min="0" step="100" />
      </div>
      <div>
        <label>APR (%)</label>
        <input type="number" class="debt-apr" value="${apr}" min="0" max="40" step="0.01" />
      </div>
      <div>
        <label>Min Payment ($)</label>
        <input type="number" class="debt-min" value="${minPayment}" min="0" step="5" />
      </div>
      <button type="button" class="remove-debt-btn" title="Remove this debt">&times;</button>
    `;

    row.querySelector('.remove-debt-btn')!.addEventListener('click', () => {
      row.remove();
    });

    return row;
  }

  function getDebts(): Debt[] {
    const rows = document.querySelectorAll('.debt-row');
    const debts: Debt[] = [];
    rows.forEach(row => {
      const name = (row.querySelector('.debt-name') as HTMLInputElement).value || 'Unnamed Debt';
      const balance = parseFloat((row.querySelector('.debt-balance') as HTMLInputElement).value) || 0;
      const apr = parseFloat((row.querySelector('.debt-apr') as HTMLInputElement).value) || 0;
      const minPayment = parseFloat((row.querySelector('.debt-min') as HTMLInputElement).value) || 0;
      if (balance > 0) {
        debts.push({ name, balance, apr, minPayment });
      }
    });
    return debts;
  }

  function simulatePayoff(debts: Debt[], extraPayment: number, sortFn: (a: Debt, b: Debt) => number): PayoffResult {
    if (debts.length === 0) return { months: 0, totalInterest: 0, totalPaid: 0 };

    // Deep copy and sort
    let debtsCopy = debts.map(d => ({ ...d, remaining: d.balance }));
    debtsCopy.sort(sortFn);

    let totalInterest = 0;
    let totalPaid = 0;
    let months = 0;
    const maxMonths = 1200;

    while (debtsCopy.some(d => d.remaining > 0.01) && months < maxMonths) {
      months++;
      let extraAvailable = extraPayment;

      // Apply minimum payments and interest to all debts
      for (const debt of debtsCopy) {
        if (debt.remaining <= 0.01) continue;

        const monthlyRate = debt.apr / 100 / 12;
        const interest = debt.remaining * monthlyRate;
        totalInterest += interest;
        debt.remaining += interest;

        let payment = Math.min(debt.minPayment, debt.remaining);
        debt.remaining -= payment;
        totalPaid += payment;

        if (debt.remaining < 0.01) {
          // Debt is paid off by minimum alone, reclaim leftover min payment
          extraAvailable += (debt.minPayment - payment);
          debt.remaining = 0;
        }
      }

      // Apply extra payment to priority debts in order
      for (const debt of debtsCopy) {
        if (debt.remaining <= 0.01 || extraAvailable <= 0) continue;

        const payment = Math.min(extraAvailable, debt.remaining);
        debt.remaining -= payment;
        totalPaid += payment;
        extraAvailable -= payment;

        if (debt.remaining < 0.01) {
          debt.remaining = 0;
          // The freed-up minimum payment will be available next month through the loop logic
        }
      }
    }

    const totalOriginalBalance = debts.reduce((sum, d) => sum + d.balance, 0);
    return { months, totalInterest, totalPaid };
  }

  function formatCurrency(n: number): string {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function calculate() {
    const debts = getDebts();
    const extraPayment = parseFloat((document.getElementById('extraPayment') as HTMLInputElement).value) || 0;

    if (debts.length === 0) return;

    // Avalanche: highest APR first
    const avalanche = simulatePayoff(debts, extraPayment, (a, b) => b.apr - a.apr);

    // Snowball: smallest balance first
    const snowball = simulatePayoff(debts, extraPayment, (a, b) => a.balance - b.balance);

    // Display avalanche results
    document.getElementById('avalancheMonths')!.textContent = String(avalanche.months);
    document.getElementById('avalancheInterest')!.textContent = formatCurrency(avalanche.totalInterest);
    document.getElementById('avalancheTotal')!.textContent = formatCurrency(avalanche.totalPaid);

    // Display snowball results
    document.getElementById('snowballMonths')!.textContent = String(snowball.months);
    document.getElementById('snowballInterest')!.textContent = formatCurrency(snowball.totalInterest);
    document.getElementById('snowballTotal')!.textContent = formatCurrency(snowball.totalPaid);

    // Display savings
    const interestSaved = snowball.totalInterest - avalanche.totalInterest;
    const monthsSaved = snowball.months - avalanche.months;

    document.getElementById('interestSaved')!.textContent = formatCurrency(Math.max(0, interestSaved));

    if (monthsSaved > 12) {
      const years = Math.floor(monthsSaved / 12);
      const remainMonths = monthsSaved % 12;
      document.getElementById('timeSaved')!.textContent = years + (years === 1 ? ' year' : ' years') + (remainMonths > 0 ? ', ' + remainMonths + (remainMonths === 1 ? ' month' : ' months') : '');
    } else if (monthsSaved > 0) {
      document.getElementById('timeSaved')!.textContent = monthsSaved + (monthsSaved === 1 ? ' month' : ' months');
    } else {
      document.getElementById('timeSaved')!.textContent = '0 months';
    }
  }

  // Initialize with sample debts
  const debtList = document.getElementById('debtList')!;
  const sampleDebts = [
    { name: 'Credit Card', balance: 5000, apr: 22.99, minPayment: 100 },
    { name: 'Car Loan', balance: 15000, apr: 6.5, minPayment: 300 },
    { name: 'Student Loan', balance: 25000, apr: 5.5, minPayment: 280 },
  ];

  sampleDebts.forEach(d => {
    debtList.appendChild(createDebtRow(d.name, d.balance, d.apr, d.minPayment));
  });

  document.getElementById('addDebtBtn')!.addEventListener('click', () => {
    debtList.appendChild(createDebtRow('', 0, 0, 0));
  });

  document.getElementById('calculateBtn')!.addEventListener('click', calculate);

  // Auto-calculate on load
  calculate();
</script>
