  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/financial-calculators/">Financial Calculators</a> &rsaquo;
    <span>Debt Payoff Calculator</span>
  </nav>
  <p class="last-updated">Last updated March 2026</p>
  <h1>Debt Payoff Calculator</h1>
  <p class="page-desc">Compare the debt snowball and debt avalanche methods side by side. Add your debts below to see which payoff strategy saves you the most money and gets you debt-free fastest.</p>

  <ReviewedBy />

  <div class="calculator-box">
    <div class="debt-list-section">
