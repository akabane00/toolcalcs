---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('financial-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Financial Calculators"
    }
  ]
};
---

<BaseLayout
  title="Financial Calculators - Loan, Interest & Savings Tools"
  description="Free financial calculators: compound interest, loan amortization, take-home pay, and more. Plan your finances with accurate, easy-to-use tools."

  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Financial Calculators</span>
  </nav>

  <h1>Financial Calculators</h1>
  <p class="page-desc">Free tools to help you plan savings, compare loans, and understand your finances.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/financial-calculators/mortgage-calculator/" class="popular-chip">Mortgage Calculator</a>
      <a href="/financial-calculators/compound-interest-calculator/" class="popular-chip">Compound Interest</a>
      <a href="/financial-calculators/take-home-pay-calculator/" class="popular-chip">Take-Home Pay</a>
      <a href="/financial-calculators/auto-loan-calculator/" class="popular-chip">Auto Loan</a>
      <a href="/financial-calculators/retirement-savings-calculator/" class="popular-chip">Retirement Savings</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/financial-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Related Articles</h2>
    <p class="quick-ref-desc">In-depth guides to help you make better financial decisions:</p>
    <div class="quick-ref-grid">
      <a href="/blog/how-compound-interest-works/" class="quick-ref-card"><span>📈</span> How Compound Interest Works</a>
      <a href="/blog/roth-ira-vs-traditional-ira/" class="quick-ref-card"><span>🏦</span> Roth IRA vs Traditional IRA</a>
      <a href="/blog/how-to-start-investing/" class="quick-ref-card"><span>💹</span> How to Start Investing</a>
      <a href="/blog/understanding-interest-rates-explained/" class="quick-ref-card"><span>💰</span> Understanding Interest Rates</a>
      <a href="/blog/debt-snowball-vs-avalanche-method/" class="quick-ref-card"><span>💳</span> Debt Snowball vs Avalanche</a>
      <a href="/blog/how-to-create-a-monthly-budget/" class="quick-ref-card"><span>📊</span> How to Create a Budget</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="financial-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
