const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolcalcs.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Financial Calculators",
        "item": "https://toolcalcs.com/financial-calculators/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Mortgage Amortization Calculator"
      }
    ]
  },
  {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is a mortgage amortization schedule?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A mortgage amortization schedule is a detailed table showing every monthly payment over the life of your mortgage, broken down into principal and interest components. It reveals how much of each payment reduces your loan balance versus how much goes to the lender as interest. Early payments are mostly interest, while later payments are mostly principal.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much can I save by making extra mortgage payments?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Extra mortgage payments can save tens of thousands of dollars in interest and shorten your loan by years. For example, adding $200 per month to a $350,000 mortgage at 6.5% over 30 years can save over $100,000 in interest and pay off the loan roughly 7 years early. The savings are largest when extra payments begin early in the loan term.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why does most of my mortgage payment go to interest at the beginning?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Interest is calculated on the outstanding loan balance each month. At the start of your mortgage, the balance is at its highest, so the interest charge is largest. As you gradually pay down the principal, less interest accrues each month and a larger share of each payment goes toward reducing the balance. This shift accelerates over time.',
      },
    },
  ],
},
];
---

<BaseLayout
