      <li><a href="/financial-calculators/down-payment-calculator/">Down Payment Calculator</a> - Calculate how much to save for a down payment.</li>
    </ul>
  </article>

  <AdUnit slot="calc-bottom" format="horizontal" />
<RelatedArticles calculatorSlug="mortgage-amortization-calculator" />

<RelatedCalculators currentSlug="mortgage-amortization-calculator" />
</BaseLayout>

<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }

  .amort-section { margin-top: 24px; }
  .amort-heading {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 12px;
    color: var(--color-text);
  }
  .amort-table-wrap {
    overflow-x: auto;
    max-height: 600px;
    overflow-y: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .amort-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    white-space: nowrap;
  }
  .amort-table th,
  .amort-table td {
    padding: 6px 10px;
    text-align: right;
    border-bottom: 1px solid var(--color-border);
  }
  .amort-table th {
    font-weight: 600;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    text-transform: uppercase;
    position: sticky;
    top: 0;
    background: var(--color-surface);
    z-index: 2;
  }
  .amort-table th:first-child,
  .amort-table td:first-child {
    text-align: left;
  }
  .amort-table tbody tr:nth-child(even) {
    background: var(--color-bg);
  }
  .amort-table tbody tr:nth-child(odd) {
    background: var(--color-surface);
  }
  .amort-table .year-row {
    background: var(--color-primary-light, #eef2ff) !important;
    font-weight: 700;
    cursor: pointer;
    user-select: none;
  }
  .amort-table .year-row:hover {
    background: var(--color-primary-lighter, #dbeafe) !important;
  }
  .amort-table .year-row td:first-child {
    padding-left: 8px;
  }
  .amort-table .month-row {
    display: none;
  }
  .amort-table .month-row.expanded {
    display: table-row;
  }
  .amort-table .month-row td:first-child {
    padding-left: 24px;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  .toggle-arrow {
    display: inline-block;
    width: 14px;
    font-size: 0.7rem;
    transition: transform 0.15s ease;
  }
  .toggle-arrow.open {
    transform: rotate(90deg);
  }
</style>

<script>
  function fmtCurrency(n: number): string {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }
  function fmtCurrency2(n: number): string {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function calculate() {
    const P = parseFloat((document.getElementById('loanAmount') as HTMLInputElement).value) || 0;
    const annualRate = parseFloat((document.getElementById('interestRate') as HTMLInputElement).value) || 0;
    const years = parseInt((document.getElementById('loanTerm') as HTMLSelectElement).value) || 30;
    const extra = parseFloat((document.getElementById('extraPayment') as HTMLInputElement).value) || 0;

    const r = annualRate / 100 / 12;
    const n = years * 12;

    if (P <= 0 || r <= 0) {
      document.getElementById('monthlyPayment')!.textContent = '$0';
      document.getElementById('totalInterest')!.textContent = '$0';
      document.getElementById('totalCost')!.textContent = '$0';
      document.getElementById('payoffDate')!.textContent = '--';
      (document.getElementById('savedCard') as HTMLElement).style.display = 'none';
      (document.getElementById('timeSavedCard') as HTMLElement).style.display = 'none';
      document.getElementById('amortBody')!.innerHTML = '';
      return;
    }

    // Monthly payment using standard amortization formula: M = P[r(1+r)^n]/[(1+r)^n-1]
    const monthlyPayment = P * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);

    // Build month-by-month amortization schedule
    interface MonthData {
      month: number;
      payment: number;
      principal: number;
      interest: number;
      extraApplied: number;
      balance: number;
    }

    const schedule: MonthData[] = [];
    let balance = P;
    let totalInterestPaid = 0;
    let totalPaid = 0;
    let actualMonths = 0;

    for (let month = 1; month <= n && balance > 0.005; month++) {
      const interestPart = balance * r;
      let principalPart = monthlyPayment - interestPart;
      let extraApplied = extra;

      // Ensure we don't overpay
      if (principalPart + extraApplied > balance) {
        const totalPrincipal = balance;
        extraApplied = Math.max(0, totalPrincipal - principalPart);
        principalPart = totalPrincipal - extraApplied;
      }

      balance -= (principalPart + extraApplied);
      if (balance < 0.005) balance = 0;

      totalInterestPaid += interestPart;
      const paymentThisMonth = principalPart + interestPart + extraApplied;
      totalPaid += paymentThisMonth;
      actualMonths = month;

      schedule.push({
        month,
        payment: paymentThisMonth,
        principal: principalPart,
        interest: interestPart,
        extraApplied,
        balance
      });

      if (balance === 0) break;
    }

    // Calculate standard totals (no extra payments) for comparison
    const totalInterestNoExtra = (monthlyPayment * n) - P;
    const totalCostNoExtra = monthlyPayment * n;

    // Display results
    document.getElementById('monthlyPayment')!.textContent = fmtCurrency(monthlyPayment + extra);
    document.getElementById('totalInterest')!.textContent = fmtCurrency(totalInterestPaid);
    document.getElementById('totalCost')!.textContent = fmtCurrency(totalPaid);

    // Calculate payoff date from current date
    const now = new Date();
    const payoffDate = new Date(now.getFullYear(), now.getMonth() + actualMonths, 1);
    const payoffMonthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    document.getElementById('payoffDate')!.textContent = payoffMonthNames[payoffDate.getMonth()] + ' ' + payoffDate.getFullYear();

    // Show savings from extra payments
    if (extra > 0) {
      const interestSaved = totalInterestNoExtra - totalInterestPaid;
      const monthsSaved = n - actualMonths;
      const yearsSaved = Math.floor(monthsSaved / 12);
      const remainingMonths = monthsSaved % 12;

      document.getElementById('interestSaved')!.textContent = fmtCurrency(interestSaved);
      (document.getElementById('savedCard') as HTMLElement).style.display = '';

      let timeStr = '';
      if (yearsSaved > 0) timeStr += yearsSaved + ' yr' + (yearsSaved > 1 ? 's' : '');
      if (remainingMonths > 0) timeStr += (timeStr ? ' ' : '') + remainingMonths + ' mo';
      if (!timeStr) timeStr = '0 mo';
      document.getElementById('timeSaved')!.textContent = timeStr;
      (document.getElementById('timeSavedCard') as HTMLElement).style.display = '';
    } else {
      (document.getElementById('savedCard') as HTMLElement).style.display = 'none';
      (document.getElementById('timeSavedCard') as HTMLElement).style.display = 'none';
    }

    // Build amortization table with yearly summaries (collapsed) and monthly details (expandable)
    const tbody = document.getElementById('amortBody')!;
    const rows: string[] = [];

    // Group schedule by year
    let currentYear = 1;
    let yearStart = 0;

    while (yearStart < schedule.length) {
      const yearEnd = Math.min(yearStart + 12, schedule.length);
      const yearMonths = schedule.slice(yearStart, yearEnd);

      // Calculate yearly totals
      let yearPayment = 0;
      let yearPrincipal = 0;
      let yearInterest = 0;
      let yearExtra = 0;

      for (const m of yearMonths) {
        yearPayment += m.payment;
        yearPrincipal += m.principal;
        yearInterest += m.interest;
        yearExtra += m.extraApplied;
      }

      const endBalance = yearMonths[yearMonths.length - 1].balance;
      const yearId = 'year-' + currentYear;

      // Yearly summary row (clickable)
      rows.push(
        `<tr class="year-row" data-year="${yearId}">` +
          `<td><span class="toggle-arrow" id="arrow-${yearId}">&#9654;</span> Year ${currentYear}</td>` +
          `<td>${fmtCurrency(yearPayment)}</td>` +
          `<td>${fmtCurrency(yearPrincipal)}</td>` +
          `<td>${fmtCurrency(yearInterest)}</td>` +
          `<td>${yearExtra > 0 ? fmtCurrency(yearExtra) : '$0'}</td>` +
          `<td>${fmtCurrency2(endBalance)}</td>` +
        `</tr>`
      );

      // Monthly detail rows (hidden by default)
      for (const m of yearMonths) {
        rows.push(
          `<tr class="month-row ${yearId}">` +
            `<td>${m.month}</td>` +
            `<td>${fmtCurrency2(m.payment)}</td>` +
            `<td>${fmtCurrency2(m.principal)}</td>` +
            `<td>${fmtCurrency2(m.interest)}</td>` +
            `<td>${m.extraApplied > 0 ? fmtCurrency2(m.extraApplied) : '$0.00'}</td>` +
            `<td>${fmtCurrency2(m.balance)}</td>` +
          `</tr>`
        );
      }

      currentYear++;
      yearStart = yearEnd;
    }

    tbody.innerHTML = rows.join('');

    // Attach click handlers to year rows for expand/collapse
    document.querySelectorAll('.year-row').forEach(row => {
      row.addEventListener('click', () => {
        const yearId = (row as HTMLElement).dataset.year!;
        const monthRows = document.querySelectorAll(`.month-row.${yearId}`);
        const arrow = document.getElementById('arrow-' + yearId);
        const isExpanded = monthRows[0]?.classList.contains('expanded');

        monthRows.forEach(r => {
          if (isExpanded) {
            r.classList.remove('expanded');
          } else {
            r.classList.add('expanded');
          }
        });

        if (arrow) {
          if (isExpanded) {
            arrow.classList.remove('open');
          } else {
            arrow.classList.add('open');
          }
        }
      });
    });
  }

  // Auto-calculate on button click
  document.getElementById('calculateBtn')?.addEventListener('click', calculate);

  // Auto-recalculate on any input change
  document.querySelectorAll('#loanAmount, #interestRate, #loanTerm, #extraPayment').forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // Auto-calculate on load with defaults
  calculate();
</script>
