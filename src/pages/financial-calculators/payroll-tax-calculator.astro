<script>
  function formatCurrency(n) {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function formatPct(n) {
    return n.toFixed(1) + '%';
  }

  // 2024 Federal Tax Brackets
  var federalBrackets = {
    single: [
      { min: 0, max: 11600, rate: 0.10 },
      { min: 11600, max: 47150, rate: 0.12 },
      { min: 47150, max: 100525, rate: 0.22 },
      { min: 100525, max: 191950, rate: 0.24 },
      { min: 191950, max: 243725, rate: 0.32 },
      { min: 243725, max: 609350, rate: 0.35 },
      { min: 609350, max: Infinity, rate: 0.37 }
    ],
    married: [
      { min: 0, max: 23200, rate: 0.10 },
      { min: 23200, max: 94300, rate: 0.12 },
      { min: 94300, max: 201050, rate: 0.22 },
      { min: 201050, max: 383900, rate: 0.24 },
      { min: 383900, max: 487450, rate: 0.32 },
      { min: 487450, max: 731200, rate: 0.35 },
      { min: 731200, max: Infinity, rate: 0.37 }
    ],
    hoh: [
      { min: 0, max: 16550, rate: 0.10 },
      { min: 16550, max: 63100, rate: 0.12 },
      { min: 63100, max: 100500, rate: 0.22 },
      { min: 100500, max: 191950, rate: 0.24 },
      { min: 191950, max: 243725, rate: 0.32 },
      { min: 243725, max: 609350, rate: 0.35 },
      { min: 609350, max: Infinity, rate: 0.37 }
    ]
  };

  function calculateBrackets(taxableIncome, filingStatus) {
    var brackets = federalBrackets[filingStatus] || federalBrackets.single;
    var tax = 0;
    for (var i = 0; i < brackets.length; i++) {
      var bracket = brackets[i];
      if (taxableIncome <= bracket.min) break;
      var taxableInBracket = Math.min(taxableIncome, bracket.max) - bracket.min;
      tax += taxableInBracket * bracket.rate;
    }
    return tax;
  }

  function calculate() {
    var grossSalary = parseFloat(document.getElementById('grossSalary').value) || 0;
    var payPeriods = parseInt(document.getElementById('payFrequency').value) || 26;
    var filingStatus = document.getElementById('filingStatus').value;
    var federalDeductions = parseFloat(document.getElementById('federalDeductions').value) || 0;
    var retirementPct = parseFloat(document.getElementById('retirementPct').value) || 0;

    // Pre-tax retirement contribution
    var retirementContrib = grossSalary * retirementPct / 100;

    // Taxable income after deductions and retirement
    var taxableIncome = Math.max(0, grossSalary - federalDeductions - retirementContrib);

    // Federal income tax
    var federalTax = calculateBrackets(taxableIncome, filingStatus);

    // Social Security (6.2% up to wage base)
    var socialSecurity = Math.min(grossSalary, 168600) * 0.062;

    // Medicare (1.45% + 0.9% additional above $200,000)
    var medicare = grossSalary * 0.0145 + Math.max(0, grossSalary - 200000) * 0.009;

    // Total tax and net pay
    var totalTax = federalTax + socialSecurity + medicare;
    var netPay = grossSalary - totalTax - retirementContrib;
    var perPaycheck = netPay / payPeriods;
    var effectiveRate = grossSalary > 0 ? (totalTax / grossSalary) * 100 : 0;

    // Total deductions (taxes + retirement)
    var totalDeductions = totalTax + retirementContrib;

    // Update result cards
    document.getElementById('netAnnualPay').textContent = formatCurrency(netPay);
    document.getElementById('federalTax').textContent = formatCurrency(federalTax);
    document.getElementById('socialSecurity').textContent = formatCurrency(socialSecurity);
    document.getElementById('medicareTax').textContent = formatCurrency(medicare);
    document.getElementById('effectiveRate').textContent = formatPct(effectiveRate);
    document.getElementById('perPaycheckNet').textContent = formatCurrency(perPaycheck);

    // Build breakdown table
    var rows = [
      { label: 'Gross Salary', amount: grossSalary, pct: 100 },
      { label: '401(k) Contribution', amount: retirementContrib, pct: grossSalary > 0 ? (retirementContrib / grossSalary) * 100 : 0 },
      { label: 'Federal Income Tax', amount: federalTax, pct: grossSalary > 0 ? (federalTax / grossSalary) * 100 : 0 },
      { label: 'Social Security', amount: socialSecurity, pct: grossSalary > 0 ? (socialSecurity / grossSalary) * 100 : 0 },
      { label: 'Medicare', amount: medicare, pct: grossSalary > 0 ? (medicare / grossSalary) * 100 : 0 },
      { label: 'Total Deductions', amount: totalDeductions, pct: grossSalary > 0 ? (totalDeductions / grossSalary) * 100 : 0 },
      { label: 'Net Annual Pay', amount: netPay, pct: grossSalary > 0 ? (netPay / grossSalary) * 100 : 0 },
      { label: 'Per Paycheck', amount: perPaycheck, pct: grossSalary > 0 ? (perPaycheck / grossSalary) * 100 : 0 }
    ];

    var tbody = document.getElementById('breakdownBody');
    tbody.innerHTML = '';
    for (var i = 0; i < rows.length; i++) {
      var row = rows[i];
      var tr = document.createElement('tr');
      var tdLabel = document.createElement('td');
      var tdAmount = document.createElement('td');
      var tdPct = document.createElement('td');
      tdLabel.textContent = row.label;
      tdAmount.textContent = formatCurrency(row.amount);
      tdPct.textContent = formatPct(row.pct);
      tr.appendChild(tdLabel);
      tr.appendChild(tdAmount);
      tr.appendChild(tdPct);

      // Highlight key rows
      if (row.label === 'Net Annual Pay' || row.label === 'Gross Salary') {
        tr.style.fontWeight = '700';
      }
      if (row.label === 'Total Deductions') {
        tr.style.borderTop = '2px solid var(--color-border)';
      }

      tbody.appendChild(tr);
    }

    // Show table and disclaimer
    document.getElementById('breakdownTable').style.display = '';
    document.getElementById('disclaimer').style.display = '';
  }

  document.getElementById('calculateBtn').addEventListener('click', calculate);

  // Auto-calculate on load
  calculate();
</script>
