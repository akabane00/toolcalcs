  .breakdown-table td:nth-child(3),
  .breakdown-table th:nth-child(2),
  .breakdown-table th:nth-child(3) {
    text-align: right;
  }
  .breakdown-table tr:last-child td {
    border-bottom: none;
    font-weight: 600;
  }
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }

  @media (max-width: 640px) {
    .calc-inputs { grid-template-columns: 1fr; }
    .result-cards { grid-template-columns: 1fr; }
    .rule-buttons { justify-content: center; }
  }
</style>

<script is:inline>
  var currentRule = 30;

  function formatMoney(n) {
    return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function formatPct(n) {
    return n.toFixed(1) + '%';
  }

  function calculate() {
    var grossIncome = parseFloat(document.getElementById('grossIncome').value) || 0;
    var debtPayments = parseFloat(document.getElementById('debtPayments').value) || 0;
    var savingsGoal = parseFloat(document.getElementById('savingsGoal').value) || 0;

    var ruleFraction = currentRule / 100;

    // Max Rent based on selected rule (% of gross income)
    var maxRentRule = grossIncome * ruleFraction;

    // Max Rent after debts: (gross income - debts) * 30%
    var incomeAfterDebt = Math.max(grossIncome - debtPayments, 0);
    var maxRentDebts = incomeAfterDebt * 0.30;

    // Comfortable Rent: (gross income - debts - savings) * 40%
    var incomeAfterDebtSavings = Math.max(grossIncome - debtPayments - savingsGoal, 0);
    var comfortableRent = incomeAfterDebtSavings * 0.40;

    // Use the comfortable rent for breakdown calculations
    var rentForBreakdown = comfortableRent;

    // Rent-to-Income Ratio (based on comfortable rent)
    var rentRatio = grossIncome > 0 ? (rentForBreakdown / grossIncome) * 100 : 0;

    // Remaining After Rent + Debts
    var remaining = grossIncome - rentForBreakdown - debtPayments;

    // Update results
    document.getElementById('ruleLabel').textContent = currentRule + '%';
    document.getElementById('maxRentRule').textContent = formatMoney(Math.round(maxRentRule));
    document.getElementById('maxRentDebts').textContent = formatMoney(Math.round(maxRentDebts));
    document.getElementById('comfortableRent').textContent = formatMoney(Math.round(comfortableRent));
    document.getElementById('rentRatio').textContent = formatPct(rentRatio);
    document.getElementById('remaining').textContent = formatMoney(Math.round(remaining));

    // Breakdown table
    var livingExpenses = grossIncome - rentForBreakdown - debtPayments - savingsGoal;
    document.getElementById('bkRent').textContent = formatMoney(Math.round(rentForBreakdown));
    document.getElementById('bkRentPct').textContent = grossIncome > 0 ? formatPct((rentForBreakdown / grossIncome) * 100) : '0%';
    document.getElementById('bkDebt').textContent = formatMoney(Math.round(debtPayments));
    document.getElementById('bkDebtPct').textContent = grossIncome > 0 ? formatPct((debtPayments / grossIncome) * 100) : '0%';
    document.getElementById('bkSave').textContent = formatMoney(Math.round(savingsGoal));
    document.getElementById('bkSavePct').textContent = grossIncome > 0 ? formatPct((savingsGoal / grossIncome) * 100) : '0%';
    document.getElementById('bkLiving').textContent = formatMoney(Math.round(livingExpenses));
    document.getElementById('bkLivingPct').textContent = grossIncome > 0 ? formatPct((livingExpenses / grossIncome) * 100) : '0%';
  }

  document.getElementById('calculateBtn').addEventListener('click', calculate);

  // Rule buttons
  var ruleBtns = document.querySelectorAll('.rule-btn');
  for (var i = 0; i < ruleBtns.length; i++) {
    ruleBtns[i].addEventListener('click', function() {
      for (var j = 0; j < ruleBtns.length; j++) {
        ruleBtns[j].classList.remove('active');
      }
      this.classList.add('active');
      currentRule = parseInt(this.getAttribute('data-rule'));
      calculate();
    });
  }

  // Auto-calculate on load
  calculate();
</script>
