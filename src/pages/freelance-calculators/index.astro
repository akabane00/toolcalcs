---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('freelance-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Freelance Calculators" }
  ]
};
---

<BaseLayout
  title="5 Free Freelance Calculators (2026) - Hourly Rate, Taxes & Pricing"
  description="Free freelance calculators: hourly rate, project pricing, self-employment tax, invoice generator, and side hustle profit for independent workers."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Freelance Calculators</span>
  </nav>

  <h1>Freelance Calculators</h1>
  <p class="page-desc">Free tools for freelancers, contractors, and side hustlers. Calculate your ideal hourly rate, price projects accurately, estimate taxes, and track true profit.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <section class="cat-intro">
    <p>Going independent means you are not just a worker — you are a business. Every hour you bill needs to cover taxes you no longer have withheld, benefits your employer used to pay for, business expenses, unpaid admin time, and the profit that funds your future. The calculators below handle the math so you can set rates, price projects, and plan taxes with confidence.</p>
    <p>Whether you are a full-time freelancer, a contractor between W-2 gigs, or running a side hustle alongside a day job, these tools give you a fast, realistic view of what you actually earn — and what you actually need to charge to hit your income goals.</p>
  </section>

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/freelance-calculators/freelance-hourly-rate-calculator/" class="popular-chip">Hourly Rate</a>
      <a href="/freelance-calculators/freelance-project-pricing-calculator/" class="popular-chip">Project Pricing</a>
      <a href="/freelance-calculators/self-employment-tax-calculator-freelance/" class="popular-chip">SE Tax</a>
      <a href="/freelance-calculators/invoice-calculator/" class="popular-chip">Invoice</a>
      <a href="/freelance-calculators/side-hustle-profit-calculator/" class="popular-chip">Side Hustle</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/freelance-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Freelance Guides & Articles</h2>
    <p class="quick-ref-desc">Master the business side of freelancing with these in-depth guides:</p>
    <div class="quick-ref-grid">
      <a href="/blog/freelance-hourly-rate-guide/" class="quick-ref-card"><span>⏱️</span> Freelance Hourly Rate Guide</a>
      <a href="/blog/freelance-taxes-explained/" class="quick-ref-card"><span>🧾</span> Freelance Taxes Explained</a>
      <a href="/blog/freelance-project-pricing-guide/" class="quick-ref-card"><span>💵</span> Freelance Project Pricing Guide</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="freelance-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .cat-intro {
    margin: 24px 0 32px;
    padding: 20px 24px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .cat-intro p {
    margin: 0 0 12px;
    color: var(--color-text);
    font-size: 0.95rem;
    line-height: 1.65;
  }
  .cat-intro p:last-child { margin-bottom: 0; }

  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
