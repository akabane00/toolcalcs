<script>
  const bodyWeightEl = document.getElementById('bodyWeight') as HTMLInputElement;
  const weightUnitEl = document.getElementById('weightUnit') as HTMLSelectElement;
  const numDrinksEl = document.getElementById('numDrinks') as HTMLInputElement;
  const drinkTypeEl = document.getElementById('drinkType') as HTMLSelectElement;
  const customOzEl = document.getElementById('customOz') as HTMLInputElement;
  const customAbvEl = document.getElementById('customAbv') as HTMLInputElement;
  const hoursDrinkingEl = document.getElementById('hoursDrinking') as HTMLInputElement;
  const customDrinkGroups = document.querySelectorAll('.custom-drink-group');

  function getGender(): string {
    const checked = document.querySelector('input[name="gender"]:checked') as HTMLInputElement;
    return checked ? checked.value : 'male';
  }

  function getAlcoholGramsPerDrink(): number {
    const drinkType = drinkTypeEl.value;
    switch (drinkType) {
      case 'standard': return 14;
      case 'beer': return 12 * 29.5735 * 0.05 * 0.789;    // ~14g
      case 'wine': return 5 * 29.5735 * 0.12 * 0.789;     // ~14g
      case 'spirits': return 1.5 * 29.5735 * 0.40 * 0.789; // ~14g
      case 'custom': {
        const oz = parseFloat(customOzEl.value) || 0;
        const abv = parseFloat(customAbvEl.value) || 0;
        return oz * 29.5735 * (abv / 100) * 0.789;
      }
      default: return 14;
    }
  }

  function calculate() {
    let weightLbs = parseFloat(bodyWeightEl.value) || 0;
    const unit = weightUnitEl.value;
    if (unit === 'kg') {
      weightLbs = weightLbs * 2.20462;
    }
    const weightGrams = weightLbs * 453.592;

    const gender = getGender();
    const r = gender === 'male' ? 0.68 : 0.55;

    const numDrinks = parseFloat(numDrinksEl.value) || 0;
    const alcoholPerDrink = getAlcoholGramsPerDrink();
    const totalAlcoholGrams = numDrinks * alcoholPerDrink;

    const hours = parseFloat(hoursDrinkingEl.value) || 0;

    let bac = 0;
    if (weightGrams > 0) {
      bac = (totalAlcoholGrams / (weightGrams * r)) - (0.015 * hours);
    }
    if (bac < 0) bac = 0;

    // Determine level
    let level = 'sober';
    let levelLabel = 'Sober';
    let impairment = 'None';
    let legalStatus = 'Under Limit';
    let statusColor = '#22c55e';

    if (bac >= 0.30) {
      level = 'dangerous'; levelLabel = 'Dangerous'; impairment = 'Life-threatening';
      legalStatus = 'Far Over Limit'; statusColor = '#7c3aed';
    } else if (bac >= 0.15) {
      level = 'severe'; levelLabel = 'Severely Impaired'; impairment = 'Major loss of coordination';
      legalStatus = 'Over Limit'; statusColor = '#991b1b';
    } else if (bac >= 0.08) {
      level = 'impaired'; levelLabel = 'Legally Impaired'; impairment = 'Significant impairment';
      legalStatus = 'Over Limit'; statusColor = '#ef4444';
    } else if (bac >= 0.04) {
      level = 'buzzed'; levelLabel = 'Buzzed / Impaired'; impairment = 'Reduced coordination';
      legalStatus = 'Under Limit'; statusColor = '#eab308';
    } else if (bac >= 0.02) {
      level = 'mild'; levelLabel = 'Mildly Relaxed'; impairment = 'Subtle impairment';
      legalStatus = 'Under Limit'; statusColor = '#84cc16';
    } else {
      level = 'sober'; levelLabel = 'Sober'; impairment = 'None';
      legalStatus = 'Under Limit'; statusColor = '#22c55e';
    }

    // Time to sober
    const hoursToSober = bac > 0 ? bac / 0.015 : 0;
    const soberH = Math.floor(hoursToSober);
    const soberM = Math.round((hoursToSober - soberH) * 60);

    // Update DOM
    document.getElementById('bacValue')!.textContent = bac.toFixed(3) + '%';
    document.getElementById('bacStatus')!.textContent = levelLabel;
    document.getElementById('impairmentLevel')!.textContent = impairment;
    document.getElementById('timeToSober')!.textContent = soberH + 'h ' + soberM + 'm';
    document.getElementById('legalStatus')!.textContent = legalStatus;
    (document.getElementById('legalStatus') as HTMLElement).style.color = bac >= 0.08 ? '#ef4444' : '#22c55e';

    // Card styling
    const card = document.getElementById('bacCard')!;
    card.className = 'result-card bac-card level-' + level;

    // Bar marker
    const barPercent = Math.min((bac / 0.35) * 100, 100);
    (document.getElementById('bacBarMarker') as HTMLElement).style.left = barPercent + '%';
    document.getElementById('bacBarLabel')!.textContent = bac.toFixed(3);
  }

  // Toggle custom drink fields
  drinkTypeEl.addEventListener('change', () => {
    const isCustom = drinkTypeEl.value === 'custom';
    customDrinkGroups.forEach(el => {
      (el as HTMLElement).classList.toggle('hidden', !isCustom);
    });
    calculate();
  });

  // Listen for changes on all inputs
  [bodyWeightEl, weightUnitEl, numDrinksEl, drinkTypeEl, customOzEl, customAbvEl, hoursDrinkingEl].forEach(el => {
    el.addEventListener('input', calculate);
    el.addEventListener('change', calculate);
  });

  // Listen for gender radio changes
  document.querySelectorAll('input[name="gender"]').forEach(el => {
    el.addEventListener('change', calculate);
  });

  calculate();
</script>
