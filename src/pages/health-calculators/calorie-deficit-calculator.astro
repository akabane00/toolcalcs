---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import '../../styles/calculator.css';
import RelatedCalculators from '../../components/RelatedCalculators.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import ReviewedBy from '../../components/ReviewedBy.astro';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolcalcs.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Health Calculators",
        "item": "https://toolcalcs.com/health-calculators/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Calorie Deficit Calculator"
      }
    ]
  },
  {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How many calories should I cut to lose weight?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A deficit of 500 calories per day below your TDEE leads to approximately 1 pound of weight loss per week. A 250-calorie deficit results in about 0.5 pounds per week. Most health professionals recommend a deficit between 500 and 1,000 calories per day for safe and sustainable weight loss.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the minimum safe calorie intake?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Women should not consume fewer than 1,200 calories per day and men should not go below 1,500 calories per day without medical supervision. Eating below these thresholds increases the risk of nutrient deficiencies, muscle loss, metabolic slowdown, and other health complications.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is a calorie deficit?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A calorie deficit occurs when you consume fewer calories than your body burns in a day. Your body makes up the energy difference by using stored body fat, which leads to weight loss over time. The size of the deficit determines how quickly you lose weight.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why am I not losing weight in a calorie deficit?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Common reasons include underestimating calorie intake, overestimating exercise calories, water retention masking fat loss, metabolic adaptation from prolonged dieting, or an inaccurate TDEE estimate. Try weighing your food precisely, comparing weekly weight averages instead of daily fluctuations, and recalculating your TDEE.',
      },
    },
    {
      '@type': 'Question',
      name: 'Should I create my calorie deficit through diet or exercise?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A combination of both is most effective. Diet changes are typically easier for creating a large deficit since cutting 500 calories from food is simpler than burning 500 extra calories through exercise. However, exercise preserves muscle mass, boosts metabolism, and improves overall health during a deficit.',
      },
    },
  ],
},
];
---

<BaseLayout
  title="Calorie Deficit Calculator - How Many Calories to Lose Weight | ToolCalcs"
  description="Free calorie deficit calculator. Find your exact daily calorie target for weight loss based on your TDEE, activity level, and weight loss goals."
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/health-calculators/">Health Calculators</a> &rsaquo;
    <span>Calorie Deficit Calculator</span>
  </nav>
  <p class="last-updated">Last updated March 2026</p>
  <h1>Calorie Deficit Calculator</h1>
  <p class="page-desc">Calculate your exact daily calorie target for weight loss based on your body stats, activity level, and goal pace.</p>

  <ReviewedBy />

  <div class="calculator-box">
    <div class="unit-toggle">
      <button class="toggle-btn active" data-unit="imperial">Imperial</button>
      <button class="toggle-btn" data-unit="metric">Metric</button>
    </div>

    <div class="calc-inputs">
      <div class="input-group">
        <label>Gender</label>
        <div class="radio-group">
          <label class="radio-label"><input type="radio" name="gender" value="male" checked /> Male</label>
          <label class="radio-label"><input type="radio" name="gender" value="female" /> Female</label>
        </div>
      </div>
      <div class="input-group">
        <label for="age">Age</label>
        <input type="number" id="age" value="30" min="15" max="100" />
      </div>
      <div id="imperialFields">
        <div class="input-row">
          <div class="input-group">
            <label for="weightLbs">Weight (lbs)</label>
            <input type="number" id="weightLbs" value="170" min="50" />
          </div>
          <div class="input-group">
            <label for="feet">Height (ft)</label>
            <input type="number" id="feet" value="5" min="3" max="8" />
          </div>
          <div class="input-group">
            <label for="inches">in</label>
            <input type="number" id="inches" value="9" min="0" max="11" />
          </div>
        </div>
      </div>
      <div id="metricFields" class="hidden">
        <div class="input-row">
          <div class="input-group">
            <label for="weightKg">Weight (kg)</label>
            <input type="number" id="weightKg" value="77" min="30" />
          </div>
          <div class="input-group">
            <label for="heightCm">Height (cm)</label>
            <input type="number" id="heightCm" value="175" min="100" max="250" />
          </div>
        </div>
      </div>
      <div class="input-group full-width">
        <label for="activity">Activity Level</label>
        <select id="activity">
          <option value="1.2">Sedentary (office job, little exercise)</option>
          <option value="1.375">Lightly Active (light exercise 1-3 days/week)</option>
          <option value="1.55" selected>Moderately Active (moderate exercise 3-5 days/week)</option>
          <option value="1.725">Very Active (hard exercise 6-7 days/week)</option>
          <option value="1.9">Extra Active (very hard exercise, physical job)</option>
        </select>
      </div>
      <div class="input-group full-width">
        <label for="goalRate">Weight Loss Goal</label>
        <select id="goalRate">
          <option value="250">0.5 lb/week (mild)</option>
          <option value="500" selected>1 lb/week (moderate)</option>
          <option value="750">1.5 lb/week (aggressive)</option>
          <option value="1000">2 lb/week (very aggressive)</option>
        </select>
      </div>
      <button class="calc-btn" id="calculateBtn">Calculate Deficit</button>
    </div>

    <div class="calc-results" id="results">
      <div class="result-cards">
        <div class="result-card primary">
          <span class="result-label">Daily Calorie Target</span>
          <span class="result-value" id="targetValue">0</span>
          <span class="result-unit">calories/day</span>
        </div>
        <div class="result-card primary">
          <span class="result-label">Your TDEE (Maintenance)</span>
          <span class="result-value" id="tdeeValue">0</span>
          <span class="result-unit">calories/day</span>
        </div>
        <div class="result-card">
          <span class="result-label">Daily Deficit</span>
          <span class="result-value" id="dailyDeficit">0</span>
          <span class="result-unit">calories/day</span>
        </div>
        <div class="result-card">
          <span class="result-label">Weekly Deficit</span>
          <span class="result-value" id="weeklyDeficit">0</span>
          <span class="result-unit">calories/week</span>
        </div>
        <div class="result-card">
          <span class="result-label">Time to Lose 10 lbs</span>
          <span class="result-value" id="timeTo10">0</span>
          <span class="result-unit">weeks</span>
        </div>
        <div class="result-card">
          <span class="result-label">Minimum Safe Intake</span>
          <span class="result-value" id="minSafe">0</span>
          <span class="result-unit">calories/day</span>
        </div>
      </div>
      <div id="safetyWarning" class="safety-warning hidden">
        <strong>Warning:</strong> Your calorie target is below the recommended minimum safe intake. Consider a smaller deficit or consult a healthcare professional before proceeding.
      </div>
    </div>
  </div>

  <AdUnit slot="calc-mid" format="rectangle" />

  <article class="content-section">
    <h2>What Is a Calorie Deficit?</h2>
    <p>A calorie deficit occurs when you consume fewer calories than your body burns throughout the day. Your body requires a certain number of calories to maintain its current weight, known as your Total Daily Energy Expenditure (TDEE). When you eat less than your TDEE, your body turns to stored energy reserves, primarily body fat, to make up the difference. This process is the fundamental mechanism behind all weight loss, regardless of the specific diet approach you follow.</p>
    <p>The size of your calorie deficit determines how quickly you lose weight. A larger deficit leads to faster weight loss, but going too far below your body's needs can cause muscle loss, nutrient deficiencies, hormonal disruptions, and metabolic adaptation that ultimately slows your progress. Finding the right balance between meaningful progress and long-term sustainability is the key to successful weight management.</p>
    <p>One pound of body fat contains approximately 3,500 calories of stored energy. This means a daily deficit of 500 calories should produce roughly one pound of weight loss per week (500 &times; 7 = 3,500). While this math is not perfectly linear in practice due to metabolic adjustments and water weight fluctuations, it remains a useful guideline for estimating weight loss timelines.</p>

    <h2>How This Calculator Works: The Mifflin-St Jeor Equation</h2>
    <p>This calorie deficit calculator uses the <strong>Mifflin-St Jeor equation</strong>, considered the gold standard for estimating Basal Metabolic Rate (BMR). Published in 1990, this formula has been validated by numerous studies and is recommended by the American Dietetic Association as the most accurate predictive equation for healthy individuals.</p>
    <div class="formula-box">
      <code>Male BMR = 10 &times; weight(kg) + 6.25 &times; height(cm) - 5 &times; age - 5</code><br/>
      <code>Female BMR = 10 &times; weight(kg) + 6.25 &times; height(cm) - 5 &times; age - 161</code>
    </div>
    <p>Your BMR represents the calories your body burns at complete rest, just to keep your organs functioning, your blood circulating, and your cells regenerating. It typically accounts for 60-70% of your total daily calorie burn. The calculator then multiplies your BMR by an activity factor to estimate your TDEE:</p>
    <ul>
      <li><strong>Sedentary (1.2):</strong> Office job with minimal walking, under 5,000 steps per day</li>
      <li><strong>Lightly Active (1.375):</strong> Light exercise 1-3 days per week, 5,000-7,500 steps per day</li>
      <li><strong>Moderately Active (1.55):</strong> Moderate exercise 3-5 days per week, 7,500-10,000 steps per day</li>
      <li><strong>Very Active (1.725):</strong> Hard exercise 6-7 days per week, over 12,500 steps per day</li>
      <li><strong>Extra Active (1.9):</strong> Very intense training or physical labor combined with exercise</li>
    </ul>
    <p><strong>Example:</strong> A 30-year-old male weighing 170 lbs (77.1 kg) at 5'9" (175.3 cm) with moderate activity would have a BMR of 10(77.1) + 6.25(175.3) - 5(30) - 5 = 771 + 1,096 - 150 - 5 = <strong>1,712 calories/day</strong>. His TDEE at moderate activity (1.55) would be 1,712 &times; 1.55 = <strong>2,654 calories/day</strong>. To lose 1 lb/week, he would eat 2,654 - 500 = <strong>2,154 calories/day</strong>.</p>

    <h2>Safe Calorie Deficit Ranges</h2>
    <p>Not all calorie deficits are created equal. The deficit you choose should balance your desire for fast results with your body's need for adequate nutrition and energy. Here are the general guidelines used by nutrition professionals:</p>
    <ul>
      <li><strong>Mild deficit (250 cal/day, ~0.5 lb/week):</strong> The most sustainable approach. Minimal hunger, easy to maintain long-term, preserves the most muscle mass. Best for people who are already lean or only need to lose a small amount of weight.</li>
      <li><strong>Moderate deficit (500 cal/day, ~1 lb/week):</strong> The most commonly recommended approach. Provides noticeable results while remaining sustainable for most people. This is the sweet spot for the majority of dieters.</li>
      <li><strong>Aggressive deficit (750 cal/day, ~1.5 lb/week):</strong> Suitable for people with significant weight to lose. Requires more discipline and careful attention to nutrition. May lead to increased hunger and fatigue.</li>
      <li><strong>Very aggressive deficit (1,000 cal/day, ~2 lb/week):</strong> The maximum recommended deficit for most people. Only appropriate for individuals with a high starting weight. Risk of muscle loss and metabolic adaptation increases significantly at this level.</li>
    </ul>

    <h2>Why You Should Never Go Too Low</h2>
    <p>It might seem logical that eating as little as possible would produce the fastest results, but extremely low calorie diets (often called "crash diets") frequently backfire. Here is what happens when you drop calories too low:</p>
    <ul>
      <li><strong>Metabolic adaptation:</strong> Your body reduces its metabolic rate to conserve energy, sometimes by as much as 15-20%. This means you burn fewer calories even at rest, making further weight loss increasingly difficult.</li>
      <li><strong>Muscle loss:</strong> When the deficit is too severe, your body breaks down muscle tissue for energy in addition to fat. Since muscle tissue burns more calories at rest than fat, losing muscle further reduces your metabolism.</li>
      <li><strong>Nutrient deficiencies:</strong> Very low calorie diets make it nearly impossible to get adequate vitamins, minerals, and essential fatty acids from food alone. Deficiencies can affect everything from bone health to immune function.</li>
      <li><strong>Hormonal disruption:</strong> Severe calorie restriction can lower thyroid hormones, testosterone, and leptin levels while increasing cortisol. These hormonal changes promote fat storage and make weight loss harder.</li>
      <li><strong>Binge eating:</strong> Extreme hunger from overly aggressive dieting often leads to episodes of binge eating, which can undo weeks of progress in a single day.</li>
    </ul>
    <p>The minimum safe calorie intake is generally considered to be <strong>1,200 calories per day for women</strong> and <strong>1,500 calories per day for men</strong>. Below these thresholds, medical supervision is strongly recommended.</p>

    <h2>Protein Needs During a Calorie Deficit</h2>
    <p>Protein intake becomes even more important when you are eating in a deficit. Adequate protein helps preserve lean muscle mass, keeps you feeling full longer, and has a higher thermic effect than carbohydrates or fats, meaning your body burns more calories digesting protein.</p>
    <p>During a calorie deficit, aim for <strong>0.8 to 1.2 grams of protein per pound of body weight per day</strong>. For a 170-pound person, that means 136-204 grams of protein daily. If you exercise regularly, especially with resistance training, aim for the higher end of this range. Good protein sources include lean meats, fish, eggs, dairy, legumes, and protein supplements when needed.</p>
    <p>Research consistently shows that higher protein intake during a deficit leads to greater fat loss and better muscle retention compared to lower protein diets with the same total calories. In one study, participants consuming 1.2 grams of protein per pound of body weight retained significantly more muscle mass during an aggressive deficit than those consuming 0.5 grams per pound.</p>

    <h2>Exercise vs. Diet: Creating Your Deficit</h2>
    <p>You can create a calorie deficit through diet alone, exercise alone, or a combination of both. Each approach has advantages:</p>
    <ul>
      <li><strong>Diet only:</strong> The simplest approach. Cutting 500 calories from your daily food intake is straightforward, requiring no extra time or equipment. However, relying solely on diet means missing the health and muscle-preserving benefits of exercise.</li>
      <li><strong>Exercise only:</strong> Burning an extra 500 calories through exercise requires significant effort, typically 45-60 minutes of vigorous activity per day. Most people find it impractical to create a large deficit through exercise alone, and many overestimate how many calories they actually burn.</li>
      <li><strong>Combined approach (recommended):</strong> A 250-calorie reduction from food plus 250 calories burned through exercise achieves the same 500-calorie deficit with less sacrifice on either side. This approach preserves muscle, boosts metabolism, improves cardiovascular health, and is the most sustainable long-term strategy.</li>
    </ul>
    <p>Resistance training (weight lifting, bodyweight exercises) is particularly important during a deficit. While cardio burns more calories per session, resistance training sends signals to your body that it needs to keep its muscle. Studies show that combining a calorie deficit with resistance training can produce body recomposition, where you lose fat while maintaining or even slightly gaining muscle.</p>

    <h2>Understanding and Overcoming Plateaus</h2>
    <p>Weight loss plateaus are a normal and expected part of any diet. After several weeks of consistent weight loss, your progress may stall even though you are still eating in a deficit. Several factors cause plateaus:</p>
    <ul>
      <li><strong>Metabolic adaptation:</strong> As you lose weight, your body becomes smaller and requires fewer calories. Your original deficit shrinks because your TDEE has decreased.</li>
      <li><strong>Water retention:</strong> Increased cortisol from dieting stress, changes in sodium intake, new exercise routines, and hormonal cycles can all cause temporary water retention that masks ongoing fat loss.</li>
      <li><strong>Calorie creep:</strong> Over time, portions tend to gradually increase and tracking becomes less precise. Small additions of sauces, oils, and snacks can unknowingly eliminate your deficit.</li>
    </ul>
    <p>To break through a plateau, try these strategies: recalculate your TDEE at your current weight, take a 1-2 week diet break eating at maintenance, increase your daily step count by 2,000-3,000 steps, add or change your exercise routine, or tighten your food tracking by weighing everything for a week. Avoid the temptation to drastically cut calories further, as this often makes the problem worse.</p>

    <h2>Tips for Tracking Your Calorie Deficit</h2>
    <p>Consistent and accurate tracking is the most important factor in maintaining a calorie deficit. Here are practical tips for success:</p>
    <ol>
      <li><strong>Use a food scale:</strong> Eyeballing portions is notoriously inaccurate. Studies show that people underestimate calorie intake by 20-50% when not measuring. A simple kitchen scale costs under $15 and dramatically improves accuracy.</li>
      <li><strong>Track everything:</strong> Cooking oils, sauces, condiments, beverages, and "just a bite" of something all contain calories. Log everything, including the handful of nuts you grabbed while cooking.</li>
      <li><strong>Weigh yourself consistently:</strong> Weigh yourself daily at the same time (morning, after using the bathroom) and compare weekly averages. Daily weight can fluctuate by 2-5 pounds due to water, sodium, and food volume.</li>
      <li><strong>Plan meals in advance:</strong> Pre-logging your meals for the next day makes it much easier to hit your calorie target. You can adjust portions before eating rather than trying to make up for overages later.</li>
      <li><strong>Be patient:</strong> Weight loss is not linear. You might lose 3 pounds one week, nothing the next, and 2 pounds the following week. Focus on the monthly trend rather than weekly fluctuations.</li>
      <li><strong>Take measurements and photos:</strong> The scale does not tell the whole story. Body measurements and progress photos reveal changes in body composition that weight alone misses, especially if you are exercising.</li>
    </ol>

    <h2>Frequently Asked Questions</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary>How many calories should I cut to lose weight?</summary>
        <p>A daily deficit of 500 calories below your TDEE leads to approximately 1 pound of weight loss per week. For slower, more sustainable loss, aim for a 250-calorie deficit (0.5 lb/week). The maximum recommended deficit for most people is 1,000 calories per day (2 lbs/week). Choose based on how much weight you need to lose and your ability to sustain the deficit.</p>
      </details>
      <details class="faq-item">
        <summary>What is the minimum safe calorie intake?</summary>
        <p>Women should not consume fewer than 1,200 calories per day and men should not go below 1,500 calories per day without medical supervision. These minimums ensure adequate nutrition for basic bodily functions. If your calculated calorie target falls below these thresholds, choose a smaller deficit or consult a healthcare professional.</p>
      </details>
      <details class="faq-item">
        <summary>Why am I not losing weight in a calorie deficit?</summary>
        <p>The most common reasons are underestimating calorie intake (not weighing food, forgetting cooking oils and snacks), overestimating exercise calories, water retention masking fat loss, or metabolic adaptation from prolonged dieting. Try weighing all food for two weeks, compare weekly average weights rather than daily numbers, and recalculate your TDEE at your current weight.</p>
      </details>
      <details class="faq-item">
        <summary>Should I eat more on exercise days?</summary>
        <p>If your TDEE calculation already includes your exercise through the activity multiplier, you do not need to eat extra on workout days. If you use a sedentary TDEE and track exercise separately, you may add back 50-75% of your estimated exercise calories. Keep in mind that most fitness trackers overestimate calorie burn by 20-40%.</p>
      </details>
      <details class="faq-item">
        <summary>How long does it take to see results from a calorie deficit?</summary>
        <p>Most people notice initial weight loss within the first week, though much of this is water weight. Visible changes in body composition typically appear after 3-4 weeks of a consistent deficit. For significant visual changes, expect 8-12 weeks of sustained effort. Take progress photos monthly for the best comparison.</p>
      </details>
    </div>
    <h2>Related Calculators</h2>
    <ul>
      <li><a href="/health-calculators/tdee-calculator/">TDEE Calculator</a> - Calculate your Total Daily Energy Expenditure.</li>
      <li><a href="/health-calculators/calorie-calculator/">Calorie Calculator</a> - Get daily calorie and macro targets for your goals.</li>
      <li><a href="/health-calculators/bmi-calculator/">BMI Calculator</a> - Check your Body Mass Index.</li>
      <li><a href="/health-calculators/macro-calculator/">Macro Calculator</a> - Find your ideal protein, carb, and fat targets.</li>
    </ul>
  </article>

  <AdUnit slot="calc-bottom" format="horizontal" />
  <RelatedArticles calculatorSlug="calorie-deficit-calculator" />

  <RelatedCalculators currentSlug="calorie-deficit-calculator" />
</BaseLayout>

<style>
.unit-toggle { display: flex; gap: 4px; margin-bottom: 20px; background: var(--color-bg); border-radius: var(--radius); padding: 4px; width: fit-content; }
  .toggle-btn { padding: 8px 16px; border: none; border-radius: 6px; background: transparent; font-size: 0.85rem; font-weight: 500; cursor: pointer; color: var(--color-text-muted); }
  .toggle-btn.active { background: var(--color-surface); color: var(--color-primary); box-shadow: var(--shadow-sm); }
  .calc-inputs { display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px; }
  .input-row { display: flex; gap: 16px; flex-wrap: wrap; }
  .input-group.full-width { flex: 100%; }
  .radio-group { display: flex; gap: 16px; padding-top: 4px; }
  .radio-label { display: flex; align-items: center; gap: 4px; font-size: 0.95rem; cursor: pointer; }
  .hidden { display: none; }
  .result-value { display: block; font-size: 1.8rem; font-weight: 800; }
  .result-unit { display: block; font-size: 0.75rem; color: var(--color-text-muted); }
  .safety-warning { background: #fef2f2; border: 1px solid #fecaca; border-radius: var(--radius); padding: 12px 16px; margin-top: 16px; color: #991b1b; font-size: 0.9rem; }
  .content-section ul { margin: 0 0 16px 24px; }
  @media (max-width: 640px) { .input-row { flex-direction: column; } .result-cards { grid-template-columns: 1fr; } }
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script is:inline>
  var unit = 'imperial';

  document.querySelectorAll('.toggle-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.toggle-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      unit = btn.dataset.unit;
      document.getElementById('imperialFields').classList.toggle('hidden', unit !== 'imperial');
      document.getElementById('metricFields').classList.toggle('hidden', unit !== 'metric');
    });
  });

  function calculate() {
    var age = parseInt(document.getElementById('age').value) || 30;
    var gender = (document.querySelector('input[name="gender"]:checked') || {}).value || 'male';
    var activityFactor = parseFloat(document.getElementById('activity').value);
    var deficitPerDay = parseInt(document.getElementById('goalRate').value);

    var weightKg, heightCm;

    if (unit === 'imperial') {
      var feet = parseFloat(document.getElementById('feet').value) || 0;
      var inches = parseFloat(document.getElementById('inches').value) || 0;
      var lbs = parseFloat(document.getElementById('weightLbs').value) || 0;
      heightCm = (feet * 12 + inches) * 2.54;
      weightKg = lbs * 0.453592;
    } else {
      heightCm = parseFloat(document.getElementById('heightCm').value) || 0;
      weightKg = parseFloat(document.getElementById('weightKg').value) || 0;
    }

    // Mifflin-St Jeor equation
    var bmr;
    if (gender === 'male') {
      bmr = 10 * weightKg + 6.25 * heightCm - 5 * age - 5;
    } else {
      bmr = 10 * weightKg + 6.25 * heightCm - 5 * age - 161;
    }

    var tdee = bmr * activityFactor;
    var target = Math.round(tdee - deficitPerDay);
    var weeklyDef = deficitPerDay * 7;

    // Time to lose 10 lbs (3500 cal per lb)
    var weeksTo10 = Math.round((10 * 3500) / weeklyDef * 10) / 10;

    // Minimum safe intake
    var minSafe = gender === 'male' ? 1500 : 1200;

    document.getElementById('targetValue').textContent = Math.round(target).toLocaleString();
    document.getElementById('tdeeValue').textContent = Math.round(tdee).toLocaleString();
    document.getElementById('dailyDeficit').textContent = deficitPerDay.toLocaleString();
    document.getElementById('weeklyDeficit').textContent = weeklyDef.toLocaleString();
    document.getElementById('timeTo10').textContent = weeksTo10;
    document.getElementById('minSafe').textContent = minSafe.toLocaleString();

    // Show warning if target is below minimum safe intake
    var warningEl = document.getElementById('safetyWarning');
    if (target < minSafe) {
      warningEl.classList.remove('hidden');
    } else {
      warningEl.classList.add('hidden');
    }
  }

  document.getElementById('calculateBtn').addEventListener('click', calculate);
  calculate();
</script>
