<script>
  // IOM 2009 Guidelines data
  const guidelines: Record<string, { single: [number, number]; twins: [number, number]; rateLow: number; rateHigh: number }> = {
    underweight: { single: [28, 40], twins: [50, 62], rateLow: 1.0, rateHigh: 1.3 },
    normal:      { single: [25, 35], twins: [37, 54], rateLow: 0.8, rateHigh: 1.0 },
    overweight:  { single: [15, 25], twins: [31, 50], rateLow: 0.5, rateHigh: 0.7 },
    obese:       { single: [11, 20], twins: [25, 42], rateLow: 0.4, rateHigh: 0.6 },
  };

  // First trimester gain (weeks 1-13): 1 to 4.4 lbs total regardless of category
  const firstTrimesterGainLow = 1.0;
  const firstTrimesterGainHigh = 4.4;
  const firstTrimesterEnd = 13;

  function getBmiCategory(bmi: number): string {
    if (bmi < 18.5) return 'underweight';
    if (bmi < 25) return 'normal';
    if (bmi < 30) return 'overweight';
    return 'obese';
  }

  function getCategoryLabel(cat: string): string {
    const labels: Record<string, string> = {
      underweight: 'Underweight',
      normal: 'Normal',
      overweight: 'Overweight',
      obese: 'Obese',
    };
    return labels[cat] || cat;
  }

  function calculateExpectedGain(week: number, cat: string, isTwins: boolean): [number, number] {
    const guide = guidelines[cat];
    if (!guide) return [0, 0];

    if (week <= 0) return [0, 0];

    // First trimester: linear ramp to 1-4.4 lbs by week 13
    if (week <= firstTrimesterEnd) {
      const fraction = week / firstTrimesterEnd;
      return [
        Math.round(firstTrimesterGainLow * fraction * 10) / 10,
        Math.round(firstTrimesterGainHigh * fraction * 10) / 10,
      ];
    }

    // Second and third trimesters: first trimester gain + weekly rate for remaining weeks
    const weeksAfterFirst = week - firstTrimesterEnd;
    const totalRange = isTwins ? guide.twins : guide.single;

    // Calculate based on weekly rate from the IOM
    const lowGain = firstTrimesterGainLow + guide.rateLow * weeksAfterFirst;
    const highGain = firstTrimesterGainHigh + guide.rateHigh * weeksAfterFirst;

    // Clamp to total recommended range
    return [
      Math.round(Math.min(lowGain, totalRange[1]) * 10) / 10,
      Math.round(Math.min(highGain, totalRange[1]) * 10) / 10,
    ];
  }

  function calculate() {
    const weightLbs = parseFloat((document.getElementById('preWeight') as HTMLInputElement).value) || 0;
    const feet = parseFloat((document.getElementById('heightFeet') as HTMLInputElement).value) || 0;
    const inches = parseFloat((document.getElementById('heightInches') as HTMLInputElement).value) || 0;
    const week = parseInt((document.getElementById('currentWeek') as HTMLInputElement).value) || 0;
    const numBabies = (document.getElementById('numBabies') as HTMLSelectElement).value;

    const totalInches = feet * 12 + inches;
    if (totalInches === 0 || weightLbs === 0 || week < 1 || week > 42) return;

    // Calculate BMI
    const bmi = (703 * weightLbs) / (totalInches * totalInches);
    const bmiCategory = getBmiCategory(bmi);
    const guide = guidelines[bmiCategory];
    const isTwins = numBabies === 'twins';

    // Total recommended range
    const totalRange = isTwins ? guide.twins : guide.single;

    // Expected gain at current week
    const [gainLow, gainHigh] = calculateExpectedGain(week, bmiCategory, isTwins);

    // Weekly rate text
    let rateText = '';
    if (week <= firstTrimesterEnd) {
      rateText = '1st trimester: 1 - 4.4 lbs total';
    } else {
      rateText = guide.rateLow + ' - ' + guide.rateHigh + ' lbs/week';
    }

    // Update DOM
    document.getElementById('totalGainRange')!.textContent = totalRange[0] + ' - ' + totalRange[1] + ' lbs';
    document.getElementById('bmiValue')!.textContent = bmi.toFixed(1);
    document.getElementById('bmiCategory')!.textContent = getCategoryLabel(bmiCategory);
    document.getElementById('gainSoFar')!.textContent = gainLow + ' - ' + gainHigh + ' lbs';
    document.getElementById('weekDisplay')!.textContent = 'Week ' + week;
    document.getElementById('weekRate')!.textContent = rateText;
  }

  // Event listeners
  document.getElementById('calculateBtn')?.addEventListener('click', calculate);

  // Auto-recalculate on input change
  ['preWeight', 'heightFeet', 'heightInches', 'currentWeek', 'numBabies'].forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.addEventListener('input', calculate);
      el.addEventListener('change', calculate);
    }
  });

  // Calculate on load with defaults
  calculate();
</script>
