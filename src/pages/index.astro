      <div class="quick-tool-group">
        <h3><a href="/math/">Math Reference</a></h3>
        <div class="quick-links">
          <a href="/math/gcf-of-12-and-18/">GCF of 12 and 18</a>
          <a href="/math/square-root-of-144/">Square Root of 144</a>
          <a href="/math/is-91-prime/">Is 91 Prime?</a>
          <a href="/math/15-squared/">15 Squared</a>
          <a href="/math/5-cubed/">5 Cubed</a>
          <a href="/times-tables/7/">7 Times Table</a>
          <a href="/math/">View all math pages &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/roman-numerals/">Roman Numerals</a></h3>
