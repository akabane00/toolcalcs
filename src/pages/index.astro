---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';
import { categories, calculators } from '../data/calculators';
import { getAllRomanNumeralPages } from '../data/roman-numerals';
import { getAllPercentagePages } from '../data/percentage-pages';
import { getAllSalaryPages } from '../data/salary-conversions';
import { getAllTipPages } from '../data/tip-calculations';
import { getAllFractionPages } from '../data/fractions';
import { getAllPercentOffPages } from '../data/percent-off';
import { getAllGradeScorePages } from '../data/grade-scores';
import { getAllDecimalToFractionPages } from '../data/decimal-to-fraction';
import { getAllTemperaturePages } from '../data/temperature-conversions';
import { getAllFactorsPages } from '../data/factors';
import { getAllWhatPercentPages } from '../data/what-percent';
import { getAllDaysCalcPages } from '../data/days-calculator';
import { getAllRandomGenPages } from '../data/random-generators';
import { getAllCookingPages } from '../data/cooking-conversions';
import { getAllCompoundInterestPages } from '../data/compound-interest';

const romanCount = getAllRomanNumeralPages().length;
const pctCount = getAllPercentagePages().length;
const salaryCount = getAllSalaryPages().length;
const tipCount = getAllTipPages().length;
const fractionCount = getAllFractionPages().length;
const percentOffCount = getAllPercentOffPages().length;
const gradeCount = getAllGradeScorePages().length;
const d2fCount = getAllDecimalToFractionPages().length;
const tempCount = getAllTemperaturePages().length;
const factorsCount = getAllFactorsPages().length;
const whatPctCount = getAllWhatPercentPages().length;
const daysCount = getAllDaysCalcPages().length;
const randomCount = getAllRandomGenPages().length;
const cookingCount = getAllCookingPages().length;
const ciCount = getAllCompoundInterestPages().length;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ToolCalcs',
  url: 'https://toolcalcs.com',
  description: 'Free online calculators for finance, health, and math. Simple, fast, and accurate tools.',
};
---

<BaseLayout
  title="Free Online Calculators - Financial, Health & Math Tools | ToolCalcs"
  description="Free online calculators for finance, health, and everyday math. Compound interest, BMI, percentage calculators and more. Simple, fast, and accurate."
  structuredData={structuredData}
>
  <section class="hero">
    <h1>Free Online Calculators</h1>
    <p>Simple, fast, and accurate tools for finance, health, and everyday math.</p>
  </section>

  <AdUnit slot="home-top" format="horizontal" />

  {categories.map(cat => {
    const catCalcs = calculators.filter(c => c.categorySlug === cat.slug);
    return (
      <section class="category-section">
        <div class="category-header">
          <h2>
            <span class="category-icon">{cat.icon}</span>
            <a href={`/${cat.slug}/`}>{cat.name}</a>
          </h2>
          <a href={`/${cat.slug}/`} class="view-all">View all &rarr;</a>
        </div>
        <div class="calc-grid">
          {catCalcs.map(calc => (
            <a href={`/${calc.categorySlug}/${calc.slug}/`} class="calc-card">
              <span class="calc-icon">{calc.icon}</span>
              <h3>{calc.title}</h3>
              <p>{calc.description}</p>
            </a>
          ))}
        </div>
      </section>
    );
  })}

  <!-- Quick Tools Section -->
  <section class="quick-tools-section">
    <div class="category-header">
      <h2><span class="category-icon">🔍</span> Quick Answers & Converters</h2>
    </div>
    <div class="quick-tools-grid">
      <div class="quick-tool-group">
        <h3><a href="/convert/">Unit Conversions</a></h3>
        <div class="quick-links">
          <a href="/convert/inches-to-centimeters/">Inches to cm</a>
          <a href="/convert/pounds-to-kilograms/">Pounds to kg</a>
          <a href="/convert/celsius-to-fahrenheit/">Celsius to Fahrenheit</a>
          <a href="/convert/miles-to-kilometers/">Miles to km</a>
          <a href="/convert/gallons-to-liters/">Gallons to liters</a>
          <a href="/convert/feet-to-meters/">Feet to meters</a>
          <a href="/convert/ounces-to-grams/">Ounces to grams</a>
          <a href="/convert/">View all 90+ conversions &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/percentage/">Percentage Calculator</a></h3>
        <div class="quick-links">
          <a href="/percentage/10-percent-of-100/">10% of 100</a>
          <a href="/percentage/20-percent-of-200/">20% of 200</a>
          <a href="/percentage/15-percent-of-500/">15% of 500</a>
          <a href="/percentage/25-percent-of-1000/">25% of 1000</a>
          <a href="/percentage/50-percent-of-200/">50% of 200</a>
          <a href="/percentage/5-percent-of-10000/">5% of 10000</a>
          <a href="/percentage/">View all {pctCount} calculations &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/how-many/">How Many?</a></h3>
        <div class="quick-links">
          <a href="/how-many/cups-in-a-gallon/">Cups in a gallon</a>
          <a href="/how-many/ounces-in-a-pound/">Ounces in a pound</a>
          <a href="/how-many/feet-in-a-mile/">Feet in a mile</a>
          <a href="/how-many/grams-in-an-ounce/">Grams in an ounce</a>
          <a href="/how-many/tablespoons-in-a-cup/">Tbsp in a cup</a>
          <a href="/how-many/">View all 31 answers &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/days-until/">Countdown Timers</a></h3>
        <div class="quick-links">
          <a href="/days-until/christmas/">Days until Christmas</a>
          <a href="/days-until/new-year/">Days until New Year</a>
          <a href="/days-until/thanksgiving/">Days until Thanksgiving</a>
          <a href="/days-until/halloween/">Days until Halloween</a>
          <a href="/days-until/independence-day/">Days until July 4th</a>
          <a href="/days-until/">View all 39 countdowns &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/currency/">Currency Exchange</a></h3>
        <div class="quick-links">
          <a href="/currency/usd-to-eur/">USD to EUR</a>
          <a href="/currency/usd-to-gbp/">USD to GBP</a>
          <a href="/currency/usd-to-jpy/">USD to JPY</a>
          <a href="/currency/eur-to-gbp/">EUR to GBP</a>
          <a href="/currency/usd-to-cad/">USD to CAD</a>
          <a href="/currency/">View all 54 pairs &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/salary/">Salary Conversions</a></h3>
        <div class="quick-links">
          <a href="/salary/15-an-hour/">$15 an Hour</a>
          <a href="/salary/20-an-hour/">$20 an Hour</a>
          <a href="/salary/25-an-hour/">$25 an Hour</a>
          <a href="/salary/30-an-hour/">$30 an Hour</a>
          <a href="/salary/50000-a-year/">$50,000 a Year</a>
          <a href="/salary/100000-a-year/">$100,000 a Year</a>
          <a href="/salary/">View all {salaryCount} conversions &rarr;</a>
        </div>
