        <div class="quick-links">
          <a href="/tip/15-percent-on-50/">15% Tip on $50</a>
          <a href="/tip/20-percent-on-100/">20% Tip on $100</a>
          <a href="/tip/18-percent-on-75/">18% Tip on $75</a>
          <a href="/tip/15-percent-on-30/">15% Tip on $30</a>
          <a href="/tip/20-percent-on-50/">20% Tip on $50</a>
          <a href="/tip/">View all {tipCount} calculations &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/fraction/">Fractions</a></h3>
        <div class="quick-links">
          <a href="/fraction/1-2/">1/2 as Decimal</a>
          <a href="/fraction/3-4/">3/4 as Decimal</a>
          <a href="/fraction/1-3/">1/3 as Decimal</a>
          <a href="/fraction/2-5/">2/5 as Decimal</a>
          <a href="/fraction/5-8/">5/8 as Decimal</a>
          <a href="/fraction/">View all {fractionCount} fractions &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/percent-off/">Percent Off Calculator</a></h3>
        <div class="quick-links">
          <a href="/percent-off/20-percent-off-50/">20% off $50</a>
          <a href="/percent-off/25-percent-off-100/">25% off $100</a>
          <a href="/percent-off/30-percent-off-80/">30% off $80</a>
          <a href="/percent-off/10-percent-off-200/">10% off $200</a>
          <a href="/percent-off/50-percent-off-100/">50% off $100</a>
          <a href="/percent-off/">View all {percentOffCount} calculations &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/grade/">Grade Calculator</a></h3>
        <div class="quick-links">
          <a href="/grade/18-out-of-20/">18 out of 20</a>
          <a href="/grade/15-out-of-20/">15 out of 20</a>
          <a href="/grade/90-out-of-100/">90 out of 100</a>
          <a href="/grade/8-out-of-10/">8 out of 10</a>
          <a href="/grade/75-out-of-100/">75 out of 100</a>
          <a href="/grade/">View all {gradeCount} scores &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/decimal-to-fraction/">Decimal to Fraction</a></h3>
        <div class="quick-links">
          <a href="/decimal-to-fraction/0.5/">0.5 as a Fraction</a>
          <a href="/decimal-to-fraction/0.75/">0.75 as a Fraction</a>
          <a href="/decimal-to-fraction/0.25/">0.25 as a Fraction</a>
          <a href="/decimal-to-fraction/0.333/">0.333 as a Fraction</a>
          <a href="/decimal-to-fraction/0.625/">0.625 as a Fraction</a>
          <a href="/decimal-to-fraction/">View all {d2fCount} conversions &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/temperature/">Temperature Converter</a></h3>
        <div class="quick-links">
          <a href="/temperature/100-fahrenheit-to-celsius/">100°F to °C</a>
          <a href="/temperature/72-fahrenheit-to-celsius/">72°F to °C</a>
          <a href="/temperature/0-celsius-to-fahrenheit/">0°C to °F</a>
          <a href="/temperature/37-celsius-to-fahrenheit/">37°C to °F</a>
          <a href="/temperature/350-fahrenheit-to-celsius/">350°F to °C</a>
          <a href="/temperature/">View all {tempCount} conversions &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/factors-of/">Factors Of</a></h3>
        <div class="quick-links">
          <a href="/factors-of/12/">Factors of 12</a>
          <a href="/factors-of/24/">Factors of 24</a>
          <a href="/factors-of/36/">Factors of 36</a>
          <a href="/factors-of/48/">Factors of 48</a>
          <a href="/factors-of/100/">Factors of 100</a>
          <a href="/factors-of/">View all {factorsCount} numbers &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/days-from-now/">Days From Today</a></h3>
        <div class="quick-links">
          <a href="/days-from-now/30/">30 Days From Today</a>
          <a href="/days-from-now/60/">60 Days From Today</a>
          <a href="/days-from-now/90/">90 Days From Today</a>
          <a href="/days-from-now/180/">180 Days From Today</a>
          <a href="/days-from-now/365/">365 Days From Today</a>
          <a href="/days-from-now/">View all {daysCount} calculations &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/random/">Random Generators</a></h3>
        <div class="quick-links">
          <a href="/random/number-between-1-and-100/">Random 1-100</a>
          <a href="/random/number-between-1-and-10/">Random 1-10</a>
          <a href="/random/dice-roll/">Dice Roller</a>
          <a href="/random/coin-flip/">Coin Flip</a>
          <a href="/random/random-color/">Random Color</a>
          <a href="/random/">View all {randomCount} generators &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/cooking/">Cooking Conversions</a></h3>
        <div class="quick-links">
          <a href="/cooking/100-grams-flour-to-cups/">100g Flour to Cups</a>
          <a href="/cooking/200-grams-sugar-to-cups/">200g Sugar to Cups</a>
          <a href="/cooking/1-cup-butter-in-grams/">1 Cup Butter in Grams</a>
          <a href="/cooking/half-cup-flour-in-grams/">1/2 Cup Flour in Grams</a>
          <a href="/cooking/100-grams-rice-to-cups/">100g Rice to Cups</a>
          <a href="/cooking/">View all {cookingCount} conversions &rarr;</a>
        </div>
      </div>
      <div class="quick-tool-group">
        <h3><a href="/compound-interest/">Compound Interest</a></h3>
        <div class="quick-links">
          <a href="/compound-interest/10000-at-5-percent-for-10-years/">$10K at 5% / 10yr</a>
          <a href="/compound-interest/10000-at-7-percent-for-20-years/">$10K at 7% / 20yr</a>
          <a href="/compound-interest/50000-at-5-percent-for-15-years/">$50K at 5% / 15yr</a>
          <a href="/compound-interest/100000-at-7-percent-for-20-years/">$100K at 7% / 20yr</a>
          <a href="/compound-interest/25000-at-6-percent-for-10-years/">$25K at 6% / 10yr</a>
