---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';
import { categories, calculators } from '../data/calculators';
import { getRecentArticles } from '../data/blog-articles';

const recentArticles = getRecentArticles(8);

function formatDate(iso: string): string {
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ToolCalcs',
  url: 'https://toolcalcs.com',
  description: 'Free online calculators for finance, health, and math. Simple, fast, and accurate tools.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://toolcalcs.com/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout
  title="150+ Free Online Calculators (2026) - Finance, Health & Math | ToolCalcs"
  description="150+ free calculators, 200+ expert articles, and 43 interactive tests. CPA-reviewed finance tools, science-based health calculators. No sign-up, 100% private."
  structuredData={structuredData}
>
  <section class="hero">
    <h1>Free Online Calculators</h1>
    <p>Simple, fast, and accurate tools for finance, health, and everyday math.</p>
  </section>

  <section class="editorial-intro">
    <p>ToolCalcs provides <strong>150+ free calculators</strong> across 14 categories, <strong>200+ in-depth articles</strong>, and <strong>43 interactive tests</strong> — all built by our editorial team of finance writers and reviewed by CPAs. Every formula is verified against authoritative sources including the <strong>IRS</strong>, <strong>Federal Reserve</strong>, <strong>Bureau of Labor Statistics</strong>, and <strong>WHO</strong>. All calculations run privately in your browser — your data never leaves your device. <a href="/about/">Learn more about our team</a> or read our <a href="/editorial-standards/">editorial standards</a>.</p>
  </section>

  <!-- Recently Used (populated client-side) -->
  <section class="recent-section" id="recent-section" style="display:none;">
    <div class="category-header">
      <h2><span class="category-icon">🕐</span> Recently Used</h2>
    </div>
    <div class="recent-grid" id="recent-grid"></div>
  </section>

  <AdUnit slot="home-top" format="horizontal" />

  {categories.map(cat => {
    const catCalcs = calculators.filter(c => c.categorySlug === cat.slug);
    return (
      <section class="category-section">
        <div class="category-header">
          <h2>
            <span class="category-icon">{cat.icon}</span>
            <a href={`/${cat.slug}/`}>{cat.name}</a>
          </h2>
          <a href={`/${cat.slug}/`} class="view-all">View all &rarr;</a>
        </div>
        <div class="calc-grid">
          {catCalcs.map(calc => (
            <a href={`/${calc.categorySlug}/${calc.slug}/`} class="calc-card">
              <span class="calc-icon">{calc.icon}</span>
              <h3>{calc.title}</h3>
              <p>{calc.description}</p>
            </a>
          ))}
        </div>
      </section>
    );
  })}

  <!-- More from ToolCalcs -->
  <section class="new-sections">
    <div class="category-header">
      <h2><span class="category-icon">🎯</span> More from ToolCalcs</h2>
    </div>
    <div class="sections-grid">
      <a href="/test/" class="section-card tests">
        <div class="section-icon">🎮</div>
        <h3>Tests & Games</h3>
        <p>Reaction time, CPS, typing speed, number memory, color blindness, visual memory, and more. Challenge yourself and track your scores.</p>
        <span class="section-count">43 tests</span>
      </a>
      <a href="/tools/" class="section-card tools">
        <div class="section-icon">🛠️</div>
        <h3>Web Tools</h3>
        <p>JSON formatter, password generator, Base64 encoder, color converter, hash generator, QR code generator, and more.</p>
        <span class="section-count">25 tools</span>
      </a>
      <a href="/worksheets/" class="section-card worksheets">
        <div class="section-icon">📝</div>
        <h3>Printable Worksheets</h3>
        <p>Free math, reading, language arts, and seasonal worksheets for Pre-K through 10th grade. Print unlimited copies.</p>
        <span class="section-count">95+ worksheets</span>
      </a>
    </div>
  </section>

  <!-- Popular Tests -->
  <section class="popular-tests-section">
    <div class="category-header">
      <h2><span class="category-icon">🧠</span> Popular Tests & Quizzes</h2>
      <a href="/test/" class="view-all">View all tests &rarr;</a>
    </div>
    <div class="calc-grid">
      <a href="/test/iq-test/" class="calc-card">
        <span class="calc-icon">🧠</span>
        <h3>Quick IQ Test</h3>
        <p>Test your cognitive ability with 20 timed questions. Get your estimated IQ score instantly.</p>
      </a>
      <a href="/test/mental-age-test/" class="calc-card">
        <span class="calc-icon">🧒</span>
        <h3>Mental Age Test</h3>
        <p>Discover your psychological age based on personality, habits, and preferences.</p>
      </a>
      <a href="/test/disc-personality-test/" class="calc-card">
        <span class="calc-icon">🎯</span>
        <h3>DISC Personality Test</h3>
        <p>Find your DISC type — Dominance, Influence, Steadiness, or Conscientiousness.</p>
      </a>
      <a href="/test/anxiety-test/" class="calc-card">
        <span class="calc-icon">😰</span>
        <h3>Anxiety Test (GAD-7)</h3>
        <p>Clinically validated screening tool to assess your anxiety severity level.</p>
      </a>
      <a href="/test/memory-age-test/" class="calc-card">
        <span class="calc-icon">🧩</span>
        <h3>Memory Age Test</h3>
        <p>Test your visual memory and find out your brain's memory age.</p>
      </a>
      <a href="/test/dark-triad-test/" class="calc-card">
        <span class="calc-icon">🌑</span>
        <h3>Dark Triad Test</h3>
        <p>Measure Machiavellianism, narcissism, and psychopathy traits with this psychology quiz.</p>
      </a>
    </div>
  </section>

  <!-- Latest from the Blog -->
  <section class="blog-preview">
    <div class="category-header">
      <h2><span class="category-icon">📖</span> Latest from the Blog</h2>
      <a href="/blog/" class="view-all-link">View all articles &rarr;</a>
    </div>
    <div class="blog-preview-grid">
      {recentArticles.map(article => (
        <a href={`/blog/${article.slug}/`} class="blog-preview-card">
          <span class="bp-category">{article.category}</span>
          <h3>{article.title}</h3>
          <p>{article.description}</p>
          <span class="bp-date">{formatDate(article.datePublished)}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Why ToolCalcs -->
  <section class="trust-section">
    <div class="category-header">
      <h2><span class="category-icon">🔒</span> Why ToolCalcs?</h2>
    </div>
    <div class="trust-grid">
      <div class="trust-item">
        <strong>100% Private</strong>
        <p>All calculations run in your browser. Your data never leaves your device.</p>
      </div>
      <div class="trust-item">
        <strong>No Sign-Up Required</strong>
        <p>Use any tool instantly. No accounts, no paywalls, no premium tiers.</p>
      </div>
      <div class="trust-item">
        <strong>Verified Formulas</strong>
        <p>Every calculator uses industry-standard formulas from authoritative sources like IRS, WHO, and BLS.</p>
      </div>
      <div class="trust-item">
        <strong>Open & Transparent</strong>
        <p>We show step-by-step breakdowns so you can understand and verify every result.</p>
      </div>
    </div>
  </section>

  <!-- Popular Games -->
  <section class="quick-ref-section">
    <div class="category-header">
      <h2><span class="category-icon">🎮</span> Popular Games</h2>
      <a href="/test/" class="view-all">View all &rarr;</a>
    </div>
    <div class="quick-ref-grid">
      <a href="/test/2048-game/" class="qr-link">2048 Game</a>
      <a href="/test/wordle-game/" class="qr-link">Wordle</a>
      <a href="/test/snake-game/" class="qr-link">Snake Game</a>
      <a href="/test/sudoku/" class="qr-link">Sudoku</a>
      <a href="/test/minesweeper/" class="qr-link">Minesweeper</a>
      <a href="/test/typing-speed-test/" class="qr-link">Typing Speed Test</a>
      <a href="/test/reaction-time-test/" class="qr-link">Reaction Time</a>
      <a href="/test/aim-trainer/" class="qr-link">Aim Trainer</a>
      <a href="/test/cps-test/" class="qr-link">CPS Test</a>
      <a href="/test/chimp-test/" class="qr-link">Chimp Test</a>
    </div>
  </section>

  <AdUnit slot="home-bottom" format="horizontal" />

  <script>
    // Render recently used calculators on homepage
    try {
      const list = JSON.parse(localStorage.getItem('tc_recent') || '[]');
      if (list.length > 0) {
        const section = document.getElementById('recent-section');
        const grid = document.getElementById('recent-grid');
        if (section && grid) {
          list.slice(0, 6).forEach((item: {url: string; title: string}) => {
            const a = document.createElement('a');
            a.href = item.url;
            a.className = 'recent-item';
            a.textContent = item.title;
            grid.appendChild(a);
          });
          section.style.display = 'block';
        }
      }
    } catch(e) {}
  </script>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 40px 0 32px;
  }
  .hero h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .editorial-intro {
    max-width: 800px;
    margin: 0 auto 32px;
    padding: 16px 24px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    text-align: center;
  }
  .editorial-intro strong {
    color: var(--color-text);
  }
  .editorial-intro a {
    color: var(--color-primary);
    font-weight: 500;
  }

  .category-section {
    margin-bottom: 40px;
  }
  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-border);
  }
  .category-header h2 {
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .category-header h2 a {
    color: var(--color-text);
    text-decoration: none;
  }
  .category-header h2 a:hover {
    color: var(--color-primary);
  }
  .category-icon {
    font-size: 1.4rem;
  }
  .view-all {
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .calc-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 20px;
    transition: box-shadow 0.15s, border-color 0.15s;
    text-decoration: none;
    color: var(--color-text);
  }
  .calc-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .calc-icon {
    font-size: 1.6rem;
    display: block;
    margin-bottom: 8px;
  }
  .calc-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--color-text);
  }
  .calc-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Trust Section */
  .trust-section {
    margin-bottom: 40px;
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }
  .trust-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 20px;
  }
  .trust-item strong {
    display: block;
    font-size: 1rem;
    margin-bottom: 6px;
  }
  .trust-item p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Quick Reference (compact) */
  .quick-ref-section {
    margin-bottom: 40px;
  }
  .quick-ref-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .qr-link {
    display: inline-block;
    padding: 8px 16px;
    font-size: 0.85rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .qr-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
  }

  /* New Sections Grid */
  .new-sections {
    margin-bottom: 40px;
  }
  .sections-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .section-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 28px 20px;
    transition: box-shadow 0.15s, border-color 0.15s;
    text-decoration: none;
    color: var(--color-text);
  }
  .section-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .section-icon {
    font-size: 2rem;
    margin-bottom: 12px;
  }
  .section-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .section-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .section-count {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
    background: #eff6ff;
    padding: 3px 12px;
    border-radius: 12px;
  }
  [data-theme="dark"] .section-count { background: #1e3a5f; }

  /* Recently Used */
  .recent-section { margin-bottom: 32px; }
  .recent-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .recent-item {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.88rem;
    color: var(--color-text);
    background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
    text-decoration: none;
  }
  .recent-item:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
  }

  /* Popular Tests */
  .popular-tests-section {
    margin-bottom: 40px;
  }

  .blog-preview { margin-top: 2rem; }
  .blog-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }
  .blog-preview-card {
    display: block;
    padding: 16px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .blog-preview-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }
  .bp-category {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-primary);
    margin-bottom: 6px;
  }
  .blog-preview-card h3 {
    font-size: 0.95rem;
    margin: 0 0 6px;
    line-height: 1.4;
  }
  .blog-preview-card p {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0 0 8px;
  }
  .bp-date {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .hero h1 { font-size: 1.5rem; }
    .calc-grid { grid-template-columns: 1fr; }
    .quick-ref-grid { flex-direction: column; }
    .sections-grid { grid-template-columns: 1fr; }
    .blog-preview-grid { grid-template-columns: 1fr; }
  }
</style>
