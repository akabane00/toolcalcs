      </div>
    </div>
  </section>

  <!-- New Sections -->
  <section class="new-sections">
    <div class="category-header">
      <h2><span class="category-icon">🎯</span> More from ToolCalcs</h2>
    </div>
    <div class="sections-grid">
      <a href="/test/" class="section-card tests">
        <div class="section-icon">🎮</div>
        <h3>Tests & Games</h3>
        <p>Reaction time, CPS, typing speed, number memory, color blindness, visual memory, and more. Challenge yourself and track your scores.</p>
        <span class="section-count">10 tests</span>
      </a>
      <a href="/tools/" class="section-card tools">
        <div class="section-icon">🛠️</div>
        <h3>Web Tools</h3>
        <p>JSON formatter, password generator, Base64 encoder, color converter, hash generator, QR code generator, and more.</p>
        <span class="section-count">10 tools</span>
      </a>
      <a href="/worksheets/" class="section-card worksheets">
        <div class="section-icon">📝</div>
        <h3>Printable Worksheets</h3>
        <p>Free math worksheets for Pre-K through 5th grade. Generate unlimited problems, print, and practice.</p>
        <span class="section-count">8 worksheets</span>
      </a>
    </div>
  </section>

  <AdUnit slot="home-bottom" format="horizontal" />
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 40px 0 32px;
  }
  .hero h1 {
    font-size: 2rem;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .hero p {
    font-size: 1.1rem;
    color: var(--color-text-muted);
  }

  .category-section {
    margin-bottom: 40px;
  }
  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-border);
  }
  .category-header h2 {
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .category-header h2 a {
    color: var(--color-text);
    text-decoration: none;
  }
  .category-header h2 a:hover {
    color: var(--color-primary);
  }
  .category-icon {
    font-size: 1.4rem;
  }
  .view-all {
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
  }

  .calc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .calc-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 20px;
    transition: box-shadow 0.15s, border-color 0.15s;
    text-decoration: none;
    color: var(--color-text);
  }
  .calc-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .calc-icon {
    font-size: 1.6rem;
    display: block;
    margin-bottom: 8px;
  }
  .calc-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--color-text);
  }
  .calc-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Quick Tools Section */
  .quick-tools-section {
    margin-bottom: 40px;
  }
  .quick-tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }
  .quick-tool-group {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 20px;
  }
  .quick-tool-group h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .quick-tool-group h3 a {
    color: var(--color-text);
    text-decoration: none;
  }
  .quick-tool-group h3 a:hover { color: var(--color-primary); }
  .quick-links {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .quick-links a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding: 4px 0;
  }
  .quick-links a:hover { color: var(--color-primary); }
  .quick-links a:last-child {
    margin-top: 4px;
    font-weight: 500;
    color: var(--color-primary);
  }

  /* New Sections Grid */
  .new-sections {
    margin-bottom: 40px;
  }
  .sections-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .section-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 28px 20px;
    transition: box-shadow 0.15s, border-color 0.15s;
    text-decoration: none;
    color: var(--color-text);
  }
  .section-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .section-icon {
    font-size: 2rem;
    margin-bottom: 12px;
  }
  .section-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .section-card p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .section-count {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
    background: #eff6ff;
    padding: 3px 12px;
    border-radius: 12px;
  }

  @media (max-width: 640px) {
    .hero h1 { font-size: 1.5rem; }
    .calc-grid { grid-template-columns: 1fr; }
    .quick-tools-grid { grid-template-columns: 1fr; }
    .sections-grid { grid-template-columns: 1fr; }
  }
</style>
