---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('insurance-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Insurance Calculators"
    }
  ]
};
---

<BaseLayout
  title="Insurance Calculators - Life, Auto, Home & Renters Tools"
  description="Free insurance calculators: estimate life insurance needs, auto insurance premiums, home insurance costs, and renters insurance coverage. Make informed coverage decisions."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Insurance Calculators</span>
  </nav>

  <h1>Insurance Calculators</h1>
  <p class="page-desc">Free tools to estimate insurance coverage needs and premiums for life, auto, home, and renters insurance.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/insurance-calculators/life-insurance-calculator/" class="popular-chip">Life Insurance Needs</a>
      <a href="/insurance-calculators/auto-insurance-calculator/" class="popular-chip">Auto Insurance</a>
      <a href="/insurance-calculators/home-insurance-calculator/" class="popular-chip">Home Insurance</a>
      <a href="/insurance-calculators/term-vs-whole-life-calculator/" class="popular-chip">Term vs Whole Life</a>
      <a href="/insurance-calculators/renters-insurance-calculator/" class="popular-chip">Renters Insurance</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/insurance-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Related Guides</h2>
    <p class="quick-ref-desc">Learn how to choose the right insurance coverage for your situation:</p>
    <div class="quick-ref-grid">
      <a href="/blog/understanding-insurance-deductibles/" class="quick-ref-card"><span>📖</span> Insurance Deductibles Explained</a>
      <a href="/blog/what-is-an-hsa-health-savings-account/" class="quick-ref-card"><span>🏥</span> What Is an HSA?</a>
      <a href="/blog/how-to-start-investing/" class="quick-ref-card"><span>💹</span> How to Start Investing</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="insurance-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
