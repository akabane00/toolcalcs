  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/insurance-calculators/">Insurance Calculators</a> &rsaquo;
    <span>Renters Insurance Calculator</span>
