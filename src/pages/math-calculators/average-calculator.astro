<style>
  .data-textarea {
    width: 100%;
    padding: 12px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 1rem;
    font-family: inherit;
    background: var(--color-bg);
    color: var(--color-text);
    resize: vertical;
    box-sizing: border-box;
    line-height: 1.6;
  }
  .data-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .result-cards {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .sorted-data {
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--color-bg);
    border-radius: var(--radius);
    text-align: center;
  }
  .sorted-title {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 6px;
  }
  .sorted-data code {
    font-size: 0.95rem;
    color: var(--color-text);
    word-break: break-all;
  }

  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script is:inline>
  function calculate() {
    var rawInput = document.getElementById('numbersInput').value;
    var nums = rawInput.split(/[\s,\n]+/).map(function(s) { return parseFloat(s.trim()); }).filter(function(n) { return !isNaN(n); });
    var cards = document.getElementById('resultCards');
    var sortedDiv = document.getElementById('sortedData');

    if (nums.length === 0) {
      cards.style.display = 'none';
      sortedDiv.style.display = 'none';
      return;
    }

    // Mean
    var sum = nums.reduce(function(a, b) { return a + b; }, 0);
    var mean = sum / nums.length;

    // Median
    var sorted = nums.slice().sort(function(a, b) { return a - b; });
    var median;
    var mid = Math.floor(sorted.length / 2);
    if (sorted.length % 2 === 0) {
      median = (sorted[mid - 1] + sorted[mid]) / 2;
    } else {
      median = sorted[mid];
    }

    // Mode
    var freq = {};
    var maxFreq = 0;
    nums.forEach(function(n) {
      freq[n] = (freq[n] || 0) + 1;
      if (freq[n] > maxFreq) maxFreq = freq[n];
    });
    var modes = Object.keys(freq).filter(function(k) { return freq[k] === maxFreq; });
    var modeStr;
    if (maxFreq === 1) {
      modeStr = 'No mode';
    } else if (modes.length === Object.keys(freq).length) {
      modeStr = 'No mode';
    } else {
      modeStr = modes.join(', ');
    }

    // Range
    var range = sorted[sorted.length - 1] - sorted[0];

    // Display results
    var fmt = function(n) {
      return parseFloat(n.toFixed(6)).toLocaleString('en-US', { maximumFractionDigits: 6 });
    };

    document.getElementById('resMean').textContent = fmt(mean);
    document.getElementById('resMedian').textContent = fmt(median);
    document.getElementById('resMode').textContent = modeStr;
    document.getElementById('resRange').textContent = fmt(range);
    document.getElementById('resCount').textContent = nums.length.toString();
    document.getElementById('resSum').textContent = fmt(sum);

    cards.style.display = 'grid';

    // Sorted data display
    document.getElementById('sortedList').textContent = sorted.map(function(n) { return fmt(n); }).join(', ');
    sortedDiv.style.display = 'block';
  }

  document.getElementById('calculateBtn').addEventListener('click', calculate);
  calculate();
</script>
