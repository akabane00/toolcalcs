<script is:inline>
  var numCount = 2;

  document.getElementById('addBtn').addEventListener('click', function() {
    numCount++;
    var container = document.getElementById('inputContainer');
    var inputs = container.querySelector('.calc-inputs');
    var div = document.createElement('div');
    div.className = 'input-group';
    div.innerHTML = '<label for="num' + numCount + '">Number ' + numCount + '</label><input type="number" id="num' + numCount + '" value="" min="1" step="1" placeholder="Enter a number" />';
    inputs.appendChild(div);
  });

  function gcd(a, b) {
    a = Math.abs(a);
    b = Math.abs(b);
    while (b) {
      var t = b;
      b = a % b;
      a = t;
    }
    return a;
  }

  function lcm(a, b) {
    return Math.abs(a * b) / gcd(a, b);
  }

  function gcdMultiple(nums) {
    return nums.reduce(function(a, b) { return gcd(a, b); });
  }

  function lcmMultiple(nums) {
    return nums.reduce(function(a, b) { return lcm(a, b); });
  }

  function getPrimeFactors(n) {
    var factors = [];
    var d = 2;
    n = Math.abs(n);
    while (d * d <= n) {
      while (n % d === 0) {
        factors.push(d);
        n /= d;
      }
      d++;
    }
    if (n > 1) factors.push(n);
    return factors;
  }

  function formatFactors(factors) {
    if (factors.length === 0) return '1';
    return factors.join(' \u00D7 ');
  }

  function formatFactorsExponent(factors) {
    if (factors.length === 0) return '1';
    var counts = {};
    factors.forEach(function(f) {
      counts[f] = (counts[f] || 0) + 1;
    });
    var primes = Object.keys(counts).sort(function(a, b) { return Number(a) - Number(b); });
    var parts = primes.map(function(p) {
      var exp = counts[p];
      if (exp === 1) return p;
      var superscripts = { '0': '\u2070', '1': '\u00B9', '2': '\u00B2', '3': '\u00B3', '4': '\u2074', '5': '\u2075', '6': '\u2076', '7': '\u2077', '8': '\u2078', '9': '\u2079' };
      var expStr = String(exp).split('').map(function(c) { return superscripts[c] || c; }).join('');
      return p + expStr;
    });
    return parts.join(' \u00D7 ');
  }

  function calculate() {
    var nums = [];
    for (var i = 1; i <= numCount; i++) {
      var el = document.getElementById('num' + i);
      if (!el) continue;
      var val = parseInt(el.value);
      if (!isNaN(val) && val > 0) nums.push(val);
    }

    var errorEl = document.getElementById('errorMsg');
    var cards = document.getElementById('resultCards');
    var factSection = document.getElementById('factorizationSection');
    var stepsSection = document.getElementById('stepsSection');

    if (nums.length < 2) {
      errorEl.textContent = 'Please enter at least two positive whole numbers.';
      errorEl.style.display = 'block';
      cards.style.display = 'none';
      factSection.style.display = 'none';
      stepsSection.style.display = 'none';
      return;
    }

    errorEl.style.display = 'none';

    var resultGCF = gcdMultiple(nums);
    var resultLCM = lcmMultiple(nums);

    document.getElementById('resGCF').textContent = resultGCF.toLocaleString('en-US');
    document.getElementById('resLCM').textContent = resultLCM.toLocaleString('en-US');
    cards.style.display = 'grid';

    // Prime factorizations
    var factList = document.getElementById('factorizationList');
    factList.innerHTML = '';
    nums.forEach(function(n) {
      var factors = getPrimeFactors(n);
      var div = document.createElement('div');
      div.className = 'factor-line';
      var expanded = formatFactors(factors);
      var exponential = formatFactorsExponent(factors);
      if (expanded === exponential) {
        div.textContent = n + ' = ' + expanded;
      } else {
        div.textContent = n + ' = ' + expanded + ' = ' + exponential;
      }
      factList.appendChild(div);
    });
    factSection.style.display = 'block';

    // Step-by-step
    var stepsList = document.getElementById('stepsList');
    stepsList.innerHTML = '';

    // GCF steps
    var gcfStep = document.createElement('div');
    gcfStep.className = 'step-line';
    if (nums.length === 2) {
      gcfStep.textContent = 'GCF(' + nums[0] + ', ' + nums[1] + '): Using Euclidean algorithm:';
      stepsList.appendChild(gcfStep);

      var a = nums[0], b = nums[1];
      if (a < b) { var tmp = a; a = b; b = tmp; }
      while (b > 0) {
        var q = Math.floor(a / b);
        var r = a % b;
        var line = document.createElement('div');
        line.className = 'step-line';
        line.textContent = '  ' + a + ' = ' + q + ' \u00D7 ' + b + ' + ' + r;
        stepsList.appendChild(line);
        a = b;
        b = r;
      }
      var finalGcf = document.createElement('div');
      finalGcf.className = 'step-line';
      finalGcf.textContent = '  GCF = ' + a;
      stepsList.appendChild(finalGcf);
    } else {
      gcfStep.textContent = 'GCF(' + nums.join(', ') + '):';
      stepsList.appendChild(gcfStep);
      var running = nums[0];
      for (var i = 1; i < nums.length; i++) {
        running = gcd(running, nums[i]);
        var line = document.createElement('div');
        line.className = 'step-line';
        line.textContent = '  GCF so far after including ' + nums[i] + ': ' + running;
        stepsList.appendChild(line);
      }
    }

    // LCM steps
    var lcmHeader = document.createElement('div');
    lcmHeader.className = 'step-line';
    lcmHeader.style.marginTop = '10px';
    if (nums.length === 2) {
      lcmHeader.textContent = 'LCM(' + nums[0] + ', ' + nums[1] + ') = (' + nums[0] + ' \u00D7 ' + nums[1] + ') / GCF = ' + (nums[0] * nums[1]) + ' / ' + resultGCF + ' = ' + resultLCM;
    } else {
      lcmHeader.textContent = 'LCM(' + nums.join(', ') + '):';
      stepsList.appendChild(lcmHeader);
      var runLcm = nums[0];
      for (var i = 1; i < nums.length; i++) {
        runLcm = lcm(runLcm, nums[i]);
        var line = document.createElement('div');
        line.className = 'step-line';
        line.textContent = '  LCM so far after including ' + nums[i] + ': ' + runLcm;
        stepsList.appendChild(line);
      }
      lcmHeader = null;
    }
    if (lcmHeader) stepsList.appendChild(lcmHeader);

    stepsSection.style.display = 'block';
  }

  document.getElementById('calculateBtn').addEventListener('click', calculate);
  calculate();
</script>
