<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
  .prime-badge {
    display: inline-block;
    padding: 4px 14px;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 1rem;
  }
  .prime-yes { background: #dcfce7; color: #166534; }
  .prime-no { background: #fee2e2; color: #991b1b; }
  .result-value { word-break: break-all; }
</style>

<script is:inline>
  function isPrime(n) {
    if (n < 2) return false;
    if (n < 4) return true;
    if (n % 2 === 0 || n % 3 === 0) return false;
    for (var i = 5; i * i <= n; i += 6) {
      if (n % i === 0 || n % (i + 2) === 0) return false;
    }
    return true;
  }

  function getPrimeFactors(n) {
    var factors = [];
    var d = 2;
    while (d * d <= n) {
      while (n % d === 0) { factors.push(d); n /= d; }
      d++;
    }
    if (n > 1) factors.push(n);
    return factors;
  }

  function getAllFactors(n) {
    var factors = [];
    for (var i = 1; i <= Math.sqrt(n); i++) {
      if (n % i === 0) {
        factors.push(i);
        if (i !== n / i) factors.push(n / i);
      }
    }
    return factors.sort(function(a, b) { return a - b; });
  }

  function nextPrime(n) {
    var p = n + 1;
    while (!isPrime(p)) p++;
    return p;
  }

  function prevPrime(n) {
    if (n <= 2) return null;
    var p = n - 1;
    while (p > 1 && !isPrime(p)) p--;
    return p > 1 ? p : null;
  }

  function formatFactorization(factors) {
    if (factors.length === 0) return 'N/A';
    var counts = {};
    for (var i = 0; i < factors.length; i++) {
      counts[factors[i]] = (counts[factors[i]] || 0) + 1;
    }
    var parts = [];
    var keys = Object.keys(counts).sort(function(a, b) { return Number(a) - Number(b); });
    for (var j = 0; j < keys.length; j++) {
      var base = keys[j];
      var exp = counts[base];
      if (exp === 1) {
        parts.push(base);
      } else {
        parts.push(base + '^' + exp);
      }
    }
    return parts.join(' \u00d7 ');
  }

  function calculate() {
    var input = document.getElementById('numberInput');
    var warning = document.getElementById('warningMsg');
    var n = parseInt(input.value);

    if (isNaN(n) || n < 0 || n > 10000000 || input.value.indexOf('.') !== -1) {
      warning.style.display = 'block';
      document.getElementById('primeResult').innerHTML = '--';
      document.getElementById('factorization').textContent = '--';
      document.getElementById('allFactors').textContent = '--';
      document.getElementById('prevPrime').textContent = '--';
      document.getElementById('nextPrime').textContent = '--';
      return;
    }
    warning.style.display = 'none';

    var prime = isPrime(n);

    if (prime) {
      document.getElementById('primeResult').innerHTML = '<span class="prime-badge prime-yes">Yes \u2014 Prime</span>';
    } else {
      document.getElementById('primeResult').innerHTML = '<span class="prime-badge prime-no">No \u2014 Not Prime</span>';
    }

    if (n < 2) {
      document.getElementById('factorization').textContent = 'N/A';
      document.getElementById('allFactors').textContent = n === 0 ? 'N/A' : '1';
      document.getElementById('prevPrime').textContent = 'N/A';
      document.getElementById('nextPrime').textContent = n < 2 ? '2' : String(nextPrime(n));
      return;
    }

    var pf = getPrimeFactors(n);
    document.getElementById('factorization').textContent = prime ? n + ' (prime)' : formatFactorization(pf);

    var af = getAllFactors(n);
    document.getElementById('allFactors').textContent = af.join(', ');

    var pp = prevPrime(n);
    document.getElementById('prevPrime').textContent = pp !== null ? String(pp) : 'N/A';
    document.getElementById('nextPrime').textContent = String(nextPrime(n));
  }

  document.getElementById('checkBtn').addEventListener('click', calculate);
  document.getElementById('numberInput').addEventListener('input', calculate);

  calculate();
</script>
