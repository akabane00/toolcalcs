    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://toolcalcs.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Math Calculators",
        "item": "https://toolcalcs.com/math-calculators/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Quadratic Formula Calculator"
      }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the quadratic formula?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The quadratic formula is x = (-b plus or minus the square root of (b squared minus 4ac)) divided by 2a. It solves any equation in the form ax squared plus bx plus c equals 0, where a is not zero. The formula gives you the x-values (roots) where the parabola crosses the x-axis.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the discriminant and what does it tell you?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The discriminant is the expression b squared minus 4ac, found under the square root in the quadratic formula. If the discriminant is positive, the equation has two distinct real roots. If it equals zero, there is exactly one repeated real root. If it is negative, the equation has two complex (imaginary) roots.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can the quadratic formula give complex or imaginary roots?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. When the discriminant (b squared minus 4ac) is negative, the square root produces an imaginary number. The two roots are complex conjugates of the form (-b/2a) plus or minus (square root of the absolute value of the discriminant / 2a) times i, where i is the imaginary unit equal to the square root of -1.',
        },
      },
    ],
  },
];
