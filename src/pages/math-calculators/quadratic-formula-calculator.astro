    </ul>
  </article>

  <AdUnit slot="calc-bottom" format="horizontal" />
  <RelatedArticles calculatorSlug="quadratic-formula-calculator" />
  <RelatedCalculators currentSlug="quadratic-formula-calculator" />
</BaseLayout>

<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
  .equation-display {
    background: var(--color-bg);
    border-radius: var(--radius);
    padding: 14px 18px;
    margin-bottom: 20px;
    text-align: center;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
    font-family: 'Georgia', serif;
    letter-spacing: 0.5px;
  }
</style>

<script is:inline>
  function fmt(n) {
    if (Math.abs(n) < 1e-10) return '0';
    if (n === Math.round(n)) return n.toString();
    return n.toFixed(6).replace(/0+$/, '').replace(/\.$/, '');
  }

  function updateEquation() {
    var a = parseFloat(document.getElementById('inputA').value) || 0;
    var b = parseFloat(document.getElementById('inputB').value) || 0;
    var c = parseFloat(document.getElementById('inputC').value) || 0;

    var parts = [];
    if (a !== 0) {
      if (a === 1) parts.push('x\u00B2');
      else if (a === -1) parts.push('-x\u00B2');
      else parts.push(a + 'x\u00B2');
    }
    if (b !== 0) {
      if (parts.length > 0) {
        if (b > 0) parts.push('+ ' + (b === 1 ? '' : b) + 'x');
        else parts.push('- ' + (b === -1 ? '' : Math.abs(b)) + 'x');
      } else {
        if (b === 1) parts.push('x');
        else if (b === -1) parts.push('-x');
        else parts.push(b + 'x');
      }
    }
    if (c !== 0) {
      if (parts.length > 0) {
        if (c > 0) parts.push('+ ' + c);
        else parts.push('- ' + Math.abs(c));
      } else {
        parts.push(c.toString());
      }
    }
    if (parts.length === 0) parts.push('0');
    document.getElementById('eqText').textContent = parts.join(' ') + ' = 0';
  }

  function solve() {
    var a = parseFloat(document.getElementById('inputA').value);
    var b = parseFloat(document.getElementById('inputB').value);
    var c = parseFloat(document.getElementById('inputC').value);

    if (isNaN(a)) a = 0;
    if (isNaN(b)) b = 0;
    if (isNaN(c)) c = 0;

    updateEquation();

    if (a === 0) {
      if (b === 0) {
        document.getElementById('discriminant').textContent = 'N/A';
        document.getElementById('rootType').textContent = c === 0 ? 'All real numbers' : 'No solution';
        document.getElementById('x1Label').textContent = 'x';
        document.getElementById('x1Value').textContent = c === 0 ? 'All x' : 'No solution';
        document.getElementById('x2Label').textContent = '';
        document.getElementById('x2Value').textContent = '';
        document.getElementById('vertex').textContent = 'N/A (linear)';
        document.getElementById('axisSymmetry').textContent = 'N/A (linear)';
        return;
      }
      var xLin = -c / b;
      document.getElementById('discriminant').textContent = 'N/A (linear equation)';
      document.getElementById('rootType').textContent = 'Linear \u2014 one root';
      document.getElementById('x1Label').textContent = 'x';
      document.getElementById('x1Value').textContent = fmt(xLin);
      document.getElementById('x2Label').textContent = '';
      document.getElementById('x2Value').textContent = '';
      document.getElementById('vertex').textContent = 'N/A (linear)';
      document.getElementById('axisSymmetry').textContent = 'N/A (linear)';
      return;
    }

    var disc = b * b - 4 * a * c;
    var vertexX = -b / (2 * a);
    var vertexY = a * vertexX * vertexX + b * vertexX + c;

    document.getElementById('discriminant').textContent = fmt(disc);
    document.getElementById('vertex').textContent = '(' + fmt(vertexX) + ', ' + fmt(vertexY) + ')';
    document.getElementById('axisSymmetry').textContent = 'x = ' + fmt(vertexX);
    document.getElementById('x1Label').textContent = 'x\u2081';
    document.getElementById('x2Label').textContent = 'x\u2082';

    if (disc > 0) {
      var x1 = (-b + Math.sqrt(disc)) / (2 * a);
      var x2 = (-b - Math.sqrt(disc)) / (2 * a);
      document.getElementById('rootType').textContent = 'Two distinct real roots';
      document.getElementById('x1Value').textContent = fmt(x1);
      document.getElementById('x2Value').textContent = fmt(x2);
    } else if (disc === 0) {
      var x = -b / (2 * a);
      document.getElementById('rootType').textContent = 'One repeated real root';
      document.getElementById('x1Value').textContent = fmt(x);
      document.getElementById('x2Value').textContent = fmt(x) + ' (repeated)';
    } else {
      var realPart = -b / (2 * a);
      var imagPart = Math.sqrt(-disc) / (2 * a);
      document.getElementById('rootType').textContent = 'Two complex roots';
      document.getElementById('x1Value').textContent = fmt(realPart) + ' + ' + fmt(Math.abs(imagPart)) + 'i';
      document.getElementById('x2Value').textContent = fmt(realPart) + ' \u2212 ' + fmt(Math.abs(imagPart)) + 'i';
    }
  }

  document.getElementById('solveBtn').addEventListener('click', solve);
  document.getElementById('inputA').addEventListener('input', solve);
  document.getElementById('inputB').addEventListener('input', solve);
  document.getElementById('inputC').addEventListener('input', solve);

  solve();
</script>
