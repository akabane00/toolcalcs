const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Math Calculators", "item": "https://toolcalcs.com/math-calculators/" },
      { "@type": "ListItem", "position": 3, "name": "Scientific Calculator" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I switch between degrees and radians on this scientific calculator?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Click the DEG/RAD button in the bottom-left corner of the calculator to toggle between degree mode and radian mode. When DEG is displayed, trigonometric functions like sin, cos, and tan interpret input as degrees. When RAD is displayed, they interpret input as radians. Most everyday angle problems use degrees, while calculus and physics often require radians.",
        },
      },
      {
        "@type": "Question",
        "name": "What is the difference between log and ln on a scientific calculator?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The log button calculates the common logarithm (base 10), while ln calculates the natural logarithm (base e, approximately 2.71828). For example, log(100) = 2 because 10 squared is 100, and ln(e) = 1 because e to the first power is e. Common logarithms are used in engineering and chemistry (like pH calculations), while natural logarithms appear frequently in calculus, compound interest, and population growth models.",
        },
      },
      {
        "@type": "Question",
        "name": "Does this calculator follow the standard order of operations?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. This scientific calculator follows the standard mathematical order of operations (PEMDAS/BODMAS): parentheses first, then exponents, followed by multiplication and division from left to right, and finally addition and subtraction from left to right. You can use parentheses to override the default order when needed.",
        },
      },
    ],
  },
];
