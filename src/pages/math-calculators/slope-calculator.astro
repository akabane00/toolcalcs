      <li><a href="/math-calculators/quadratic-formula-calculator/">Quadratic Formula Calculator</a> - Solve quadratic equations and find roots, vertex, and axis of symmetry.</li>
    </ul>
  </article>

  <AdUnit slot="calc-bottom" format="horizontal" />
  <RelatedArticles calculatorSlug="slope-calculator" />
  <RelatedCalculators currentSlug="slope-calculator" />
</BaseLayout>

<style>
  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script is:inline>
  document.getElementById('calculateBtn').addEventListener('click', function() {
    var x1 = parseFloat(document.getElementById('x1').value);
    var y1 = parseFloat(document.getElementById('y1').value);
    var x2 = parseFloat(document.getElementById('x2').value);
    var y2 = parseFloat(document.getElementById('y2').value);

    if (isNaN(x1) || isNaN(y1) || isNaN(x2) || isNaN(y2)) {
      alert('Please enter valid numbers for all four coordinate values.');
      return;
    }

    var rise = y2 - y1;
    var run = x2 - x1;

    document.getElementById('resultRise').textContent = rise % 1 === 0 ? rise : rise.toFixed(4);
    document.getElementById('resultRun').textContent = run % 1 === 0 ? run : run.toFixed(4);

    if (run === 0) {
      document.getElementById('resultSlope').textContent = 'Undefined (vertical line)';
      document.getElementById('resultEquation').textContent = 'x = ' + x1;
      document.getElementById('resultAngle').textContent = '90\u00B0';
    } else {
      var slope = rise / run;
      var slopeDisplay = slope % 1 === 0 ? slope.toString() : slope.toFixed(4);
      document.getElementById('resultSlope').textContent = slopeDisplay;

      var b = y1 - slope * x1;
      var bDisplay = b % 1 === 0 ? b : parseFloat(b.toFixed(4));
      var equation = 'y = ' + slopeDisplay + 'x';
      if (b > 0) {
        equation += ' + ' + bDisplay;
      } else if (b < 0) {
        equation += ' - ' + Math.abs(bDisplay);
      }
      document.getElementById('resultEquation').textContent = equation;

      var angleRad = Math.atan(slope);
      var angleDeg = angleRad * (180 / Math.PI);
      document.getElementById('resultAngle').textContent = angleDeg.toFixed(2) + '\u00B0';
    }

    var distance = Math.sqrt(Math.pow(run, 2) + Math.pow(rise, 2));
    document.getElementById('resultDistance').textContent = distance.toFixed(4);

    document.getElementById('resultsSection').style.display = '';
  });
</script>
