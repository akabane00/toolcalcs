        </div>
        <div class="input-group">
          <label for="rt-b">Side b (leg)</label>
          <input type="number" id="rt-b" value="4" min="0" step="any" />
        </div>
      </div>
    </div>

    <button class="calc-btn" id="calculateBtn">Calculate Triangle</button>

    <div id="errorMsg" class="error-msg" style="display:none;"></div>

    <div class="result-cards" id="resultCards" style="display:none;">
      <div class="result-card">
        <span class="result-label">Side a</span>
        <span class="result-value" id="resSideA">&mdash;</span>
      </div>
      <div class="result-card">
        <span class="result-label">Side b</span>
        <span class="result-value" id="resSideB">&mdash;</span>
      </div>
      <div class="result-card">
        <span class="result-label">Side c</span>
        <span class="result-value" id="resSideC">&mdash;</span>
      </div>
      <div class="result-card">
        <span class="result-label">Angle A</span>
        <span class="result-value" id="resAngleA">&mdash;</span>
      </div>
      <div class="result-card">
        <span class="result-label">Angle B</span>
        <span class="result-value" id="resAngleB">&mdash;</span>
      </div>
      <div class="result-card">
        <span class="result-label">Angle C</span>
        <span class="result-value" id="resAngleC">&mdash;</span>
      </div>
      <div class="result-card primary">
        <span class="result-label">Area</span>
        <span class="result-value" id="resArea">&mdash;</span>
        <span class="result-unit">sq units</span>
      </div>
      <div class="result-card primary">
        <span class="result-label">Perimeter</span>
        <span class="result-value" id="resPerimeter">&mdash;</span>
