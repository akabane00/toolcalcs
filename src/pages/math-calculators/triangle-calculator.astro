        </div>
        <div class="input-group">
          <label for="sss-b">Side b</label>
          <input type="number" id="sss-b" value="7" min="0" step="any" />
        </div>
        <div class="input-group">
          <label for="sss-c">Side c</label>
          <input type="number" id="sss-c" value="9" min="0" step="any" />
        </div>
      </div>
    </div>

    <!-- SAS Inputs -->
    <div class="tab-panel hidden" id="sas-panel">
      <div class="calc-inputs">
        <div class="input-group">
          <label for="sas-a">Side a</label>
          <input type="number" id="sas-a" value="6" min="0" step="any" />
        </div>
        <div class="input-group">
          <label for="sas-b">Side b</label>
          <input type="number" id="sas-b" value="8" min="0" step="any" />
