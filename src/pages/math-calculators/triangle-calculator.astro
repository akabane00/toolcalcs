import RelatedCalculators from '../../components/RelatedCalculators.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import '../../styles/calculator.css';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Math Calculators", "item": "https://toolcalcs.com/math-calculators/" },
      { "@type": "ListItem", "position": 3, "name": "Triangle Calculator" }
    ]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'How do you calculate the area of a triangle when you know all three sides?', acceptedAnswer: { '@type': 'Answer', text: 'Use Heron\'s formula. First calculate the semi-perimeter s = (a + b + c) / 2, then the area equals the square root of s times (s minus a) times (s minus b) times (s minus c). This works for any triangle as long as the three sides satisfy the triangle inequality.' } },
      { '@type': 'Question', name: 'What is the Law of Cosines and when is it used?', acceptedAnswer: { '@type': 'Answer', text: 'The Law of Cosines states that c squared equals a squared plus b squared minus 2ab times the cosine of angle C. It is used to find an unknown side when two sides and the included angle are known (SAS), or to find an unknown angle when all three sides are known (SSS). It generalizes the Pythagorean theorem to non-right triangles.' } },
      { '@type': 'Question', name: 'How do you check if three sides can form a valid triangle?', acceptedAnswer: { '@type': 'Answer', text: 'Apply the triangle inequality theorem: the sum of any two sides must be greater than the third side. You need to check all three combinations: a + b > c, a + c > b, and b + c > a. If any of these conditions fails, the three lengths cannot form a triangle.' } },
    ],
  },
];
