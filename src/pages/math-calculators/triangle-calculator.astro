<BaseLayout
  title="Triangle Calculator - Sides, Angles & Area | ToolCalcs"
  description="Free triangle calculator. Calculate sides, angles, area, and perimeter using SSS, SAS, or right triangle mode. Law of Cosines and Heron's formula built in."
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/math-calculators/">Math Calculators</a> &rsaquo;
    <span>Triangle Calculator</span>
  </nav>
  <p class="last-updated">Last updated March 2026</p>
  <h1>Triangle Calculator</h1>
  <p class="page-desc">Calculate all sides, angles, area, and perimeter of a triangle. Choose from three modes: SSS, SAS, or Right Triangle.</p>

  <div class="calculator-box">
    <div class="tab-buttons">
      <button class="tab-btn active" data-tab="sss">SSS (3 Sides)</button>
      <button class="tab-btn" data-tab="sas">SAS (2 Sides + Angle)</button>
      <button class="tab-btn" data-tab="right">Right Triangle</button>
    </div>

    <!-- SSS Inputs -->
