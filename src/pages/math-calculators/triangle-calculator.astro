    </ul>
  </article>

  <AdUnit slot="calc-bottom" format="horizontal" />
  <RelatedArticles calculatorSlug="triangle-calculator" />
  <RelatedCalculators currentSlug="triangle-calculator" />
</BaseLayout>

<style>
  .tab-buttons {
    display: flex;
    gap: 4px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .tab-btn {
    padding: 8px 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: transparent;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--color-text);
    transition: all 0.15s;
  }
  .tab-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .tab-btn.active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .tab-panel.hidden { display: none; }

  .error-msg {
    margin-top: 16px;
    padding: 12px 16px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: var(--radius);
    color: #dc2626;
    font-size: 0.9rem;
  }
  [data-theme="dark"] .error-msg {
    background: #451a1a;
    border-color: #7f1d1d;
    color: #fca5a5;
  }

  .result-cards {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .result-unit {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .formula-display {
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--color-bg);
    border-radius: var(--radius);
    text-align: center;
  }
  .formula-title {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 6px;
  }
  .formula-display code {
    font-size: 0.95rem;
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .tab-buttons { justify-content: center; }
    .tab-btn { padding: 6px 12px; font-size: 0.85rem; }
  }

  .last-updated { font-size: 0.75rem; color: var(--color-text-muted); margin: 4px 0 0; }
</style>

<script is:inline>
  var currentTab = 'sss';

  // Tab switching
  var tabBtns = document.querySelectorAll('.tab-btn');
  for (var i = 0; i < tabBtns.length; i++) {
    tabBtns[i].addEventListener('click', function() {
      for (var j = 0; j < tabBtns.length; j++) {
        tabBtns[j].classList.remove('active');
      }
      this.classList.add('active');
      currentTab = this.getAttribute('data-tab');

      var panels = document.querySelectorAll('.tab-panel');
      for (var k = 0; k < panels.length; k++) {
        panels[k].classList.add('hidden');
      }
      document.getElementById(currentTab + '-panel').classList.remove('hidden');

      hideResults();
    });
  }

  function getVal(id) {
    return parseFloat(document.getElementById(id).value) || 0;
  }

  function fmt(n) {
    return parseFloat(n.toFixed(4)).toLocaleString('en-US', { maximumFractionDigits: 4 });
  }

  function fmtDeg(n) {
    return fmt(n) + '\u00B0';
  }

  function hideResults() {
    document.getElementById('resultCards').style.display = 'none';
    document.getElementById('formulaDisplay').style.display = 'none';
    document.getElementById('errorMsg').style.display = 'none';
  }

  function showError(msg) {
    var el = document.getElementById('errorMsg');
    el.textContent = msg;
    el.style.display = 'block';
    document.getElementById('resultCards').style.display = 'none';
    document.getElementById('formulaDisplay').style.display = 'none';
  }

  function showResults(a, b, c, A, B, C, area, perimeter, method) {
    document.getElementById('errorMsg').style.display = 'none';
    document.getElementById('resSideA').textContent = fmt(a);
    document.getElementById('resSideB').textContent = fmt(b);
    document.getElementById('resSideC').textContent = fmt(c);
    document.getElementById('resAngleA').textContent = fmtDeg(A);
    document.getElementById('resAngleB').textContent = fmtDeg(B);
    document.getElementById('resAngleC').textContent = fmtDeg(C);
    document.getElementById('resArea').textContent = fmt(area);
    document.getElementById('resPerimeter').textContent = fmt(perimeter);
    document.getElementById('resultCards').style.display = 'grid';
    document.getElementById('formulaText').textContent = method;
    document.getElementById('formulaDisplay').style.display = 'block';
  }

  function calculate() {
    var DEG = Math.PI / 180;
    var RAD = 180 / Math.PI;

    if (currentTab === 'sss') {
      var a = getVal('sss-a');
      var b = getVal('sss-b');
      var c = getVal('sss-c');
      if (a <= 0 || b <= 0 || c <= 0) { showError('All sides must be positive numbers.'); return; }
      if (a + b <= c || a + c <= b || b + c <= a) { showError('Invalid triangle: the sum of any two sides must be greater than the third side.'); return; }

      // Law of Cosines for angles
      var A = Math.acos((b * b + c * c - a * a) / (2 * b * c)) * RAD;
      var B = Math.acos((a * a + c * c - b * b) / (2 * a * c)) * RAD;
      var C = 180 - A - B;

      // Heron's formula for area
      var s = (a + b + c) / 2;
      var area = Math.sqrt(s * (s - a) * (s - b) * (s - c));
      var perimeter = a + b + c;

      showResults(a, b, c, A, B, C, area, perimeter, "SSS: Law of Cosines for angles, Heron's formula for area");

    } else if (currentTab === 'sas') {
      var a = getVal('sas-a');
      var b = getVal('sas-b');
      var Cdeg = getVal('sas-C');
      if (a <= 0 || b <= 0) { showError('Both sides must be positive numbers.'); return; }
      if (Cdeg <= 0 || Cdeg >= 180) { showError('Angle C must be between 0 and 180 degrees (exclusive).'); return; }

      var Crad = Cdeg * DEG;
      // Law of Cosines for missing side
      var c = Math.sqrt(a * a + b * b - 2 * a * b * Math.cos(Crad));

      // Law of Cosines for remaining angles
      var A = Math.acos((b * b + c * c - a * a) / (2 * b * c)) * RAD;
      var B = 180 - A - Cdeg;

      // Area using SAS formula
      var area = 0.5 * a * b * Math.sin(Crad);
      var perimeter = a + b + c;

      showResults(a, b, c, A, B, Cdeg, area, perimeter, "SAS: Law of Cosines for side c, then angles via Law of Cosines");

    } else if (currentTab === 'right') {
      var a = getVal('rt-a');
      var b = getVal('rt-b');
      if (a <= 0 || b <= 0) { showError('Both legs must be positive numbers.'); return; }

      // Pythagorean theorem
      var c = Math.sqrt(a * a + b * b);
      var A = Math.atan(a / b) * RAD;
      var B = 90 - A;
      var C = 90;
      var area = 0.5 * a * b;
      var perimeter = a + b + c;

      showResults(a, b, c, A, B, C, area, perimeter, "Right triangle: Pythagorean theorem, c = \u221A(a\u00B2 + b\u00B2)");
    }
  }

  document.getElementById('calculateBtn').addEventListener('click', calculate);
  calculate();
</script>
