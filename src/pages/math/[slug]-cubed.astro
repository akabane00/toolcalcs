---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import CrossLinks from '../../components/CrossLinks.astro';
import '../../styles/calculator.css';
import { getAllCubedPages, type PowerPage } from '../../data/powers';

export function getStaticPaths() {
  return getAllCubedPages().map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: PowerPage };
const { base, result, resultFormatted, isPerfectSquare, squareRoot } = page;

// Related cubed pages
const allPages = getAllCubedPages();
const nearbyOffsets = [-3, -2, -1, 1, 2, 3];
const relatedPages = nearbyOffsets
  .map((offset) => allPages.find((p) => p.base === base + offset))
  .filter((p): p is PowerPage => !!p);

// Cross-links
const crossLinks: { href: string; label: string; icon: string }[] = [
  { href: `/math/${base}-squared/`, label: `${base} Squared`, icon: '²' },
];
if (result <= 141) {
  crossLinks.push({ href: `/factors-of/${result}/`, label: `Factors of ${resultFormatted}`, icon: '🔢' });
}
if (base <= 200) {
  crossLinks.push({ href: `/math/is-${base}-prime/`, label: `Is ${base} Prime?`, icon: '🔍' });
}

// SEO
const title = `${base} Cubed - ${base}³ = ${resultFormatted} | ToolCalcs`;
const description = `${base} cubed (${base}³) equals ${resultFormatted}. Learn what ${base} cubed means, see the step-by-step calculation, and explore related cubes and cube roots.`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Math Reference", "item": "https://toolcalcs.com/math/" },
      { "@type": "ListItem", "position": 3, "name": `${base} Cubed` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": `What is ${base} cubed?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `${base} cubed (${base}³) equals ${resultFormatted}. This is calculated by multiplying ${base} by itself three times: ${base} × ${base} × ${base} = ${resultFormatted}.`,
        },
      },
      {
        "@type": "Question",
        "name": `What is the cube root of ${resultFormatted}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `The cube root of ${resultFormatted} is ${base}. Since ${base} × ${base} × ${base} = ${resultFormatted}, we know that ³√${resultFormatted} = ${base}.`,
        },
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} type="article" structuredData={structuredData}>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/math/">Math Reference</a> &rsaquo;
    <span>{base} Cubed</span>
  </nav>

  <h1>{base} Cubed</h1>
  <p class="page-desc">Calculate {base} cubed ({base}³) with step-by-step explanation, volume interpretation, and related powers.</p>

  <div class="quick-fact">
    <span class="quick-fact-label">Quick Answer:</span>
    <strong>{base}³ = {base} × {base} × {base} = {resultFormatted}</strong>
  </div>

  <!-- Result Cards -->
  <div class="result-cards">
    <div class="result-card primary">
      <span class="result-label">{base}³</span>
      <span class="result-value">{resultFormatted}</span>
    </div>
    <div class="result-card">
      <span class="result-label">{base}²</span>
      <span class="result-value">{(base * base).toLocaleString('en-US')}</span>
    </div>
    <div class="result-card">
      <span class="result-label">Cube Root of {resultFormatted}</span>
      <span class="result-value">{base}</span>
    </div>
    {isPerfectSquare && squareRoot !== null && (
      <div class="result-card">
        <span class="result-label">Square Root of {resultFormatted}</span>
        <span class="result-value">{squareRoot}</span>
      </div>
    )}
    <div class="result-card">
      <span class="result-label">{base}⁴</span>
      <span class="result-value">{(base ** 4).toLocaleString('en-US')}</span>
    </div>
  </div>

  <!-- Calculation Steps -->
  <h2 class="section-heading">Step-by-Step Calculation</h2>
  <div class="calculator-box">
    <div class="steps-list">
      <div class="step-row">
        <span class="step-num">Step 1:</span>
        <span>Write the expression: {base}³</span>
      </div>
      <div class="step-row">
        <span class="step-num">Step 2:</span>
        <span>"Cubed" means multiply three times: {base} × {base} × {base}</span>
      </div>
      <div class="step-row">
        <span class="step-num">Step 3:</span>
        <span>First: {base} × {base} = {(base * base).toLocaleString('en-US')}</span>
      </div>
      <div class="step-row result">
        <span class="step-num">Step 4:</span>
        <span>Then: {(base * base).toLocaleString('en-US')} × {base} = <strong>{resultFormatted}</strong></span>
      </div>
    </div>
  </div>

  <!-- Interactive Power Calculator -->
  <h2 class="section-heading">Power Calculator</h2>
  <div class="calculator-box">
    <p class="calc-desc">Enter a base and exponent to calculate any power.</p>
    <div class="finder-row">
      <div class="input-group">
        <label for="baseInput">Base</label>
        <input type="number" id="baseInput" value={base} min="-10000" max="10000" />
      </div>
      <div class="input-group">
        <label for="expInput">Exponent</label>
        <input type="number" id="expInput" value="3" min="0" max="20" />
      </div>
      <button class="calc-btn" id="powerBtn">Calculate</button>
    </div>
    <div id="powerResult" class="finder-result"></div>
  </div>

  <!-- Perfect Cubes Reference -->
  <h2 class="section-heading">Perfect Cubes 1³ to 15³</h2>
  <div class="table-container">
    <table class="data-table">
      <thead>
        <tr><th>n</th><th>n³</th><th>n</th><th>n³</th></tr>
      </thead>
      <tbody>
        {Array.from({ length: 8 }, (_, i) => (
          <tr>
            <td class={i + 1 === base ? 'highlight' : ''}>{i + 1}</td>
            <td class={i + 1 === base ? 'highlight' : ''}>{((i + 1) ** 3).toLocaleString('en-US')}</td>
            <td class={i + 9 === base ? 'highlight' : ''}>{i + 9}</td>
            <td class={i + 9 === base ? 'highlight' : ''}>{((i + 9) ** 3).toLocaleString('en-US')}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <AdUnit slot="cubed-mid" format="rectangle" />

  <!-- SEO Content -->
  <article class="content-section">
    <h2>What Does "Cubed" Mean?</h2>
    <p>
      When a number is "cubed," it is raised to the third power — multiplied by itself three times. The expression {base}³ means {base} × {base} × {base}, which equals {resultFormatted}. The term "cubed" comes from geometry: a cube with edge length {base} has a volume of {base}³ = {resultFormatted} cubic units. Just as "squared" relates to two-dimensional area, "cubed" relates to three-dimensional volume.
    </p>
    <p>
      Cubing is a fundamental operation in mathematics and science. It appears in volume calculations (V = s³ for a cube), in physics formulas (such as gravitational force being proportional to the cube of distance in certain problems), in chemistry (crystal lattice structures), and in computer science (cubic time complexity algorithms). Understanding cubes and cube roots is important for advanced math topics including polynomial equations and number theory.
    </p>

    <h2>Calculating {base} Cubed</h2>
    <p>
      To calculate {base}³, multiply {base} by itself three times. First compute {base} × {base} = {(base * base).toLocaleString('en-US')}, then multiply by {base} again: {(base * base).toLocaleString('en-US')} × {base} = {resultFormatted}. This two-step approach makes mental calculation easier for larger numbers. You can also verify: the cube root of {resultFormatted} should equal {base}, and indeed ³√{resultFormatted} = {base}.
    </p>

    <h2>Cube Root Connection</h2>
    <p>
      Cubing and taking the cube root are inverse operations. Since {base}³ = {resultFormatted}, the cube root of {resultFormatted} is {base}: ³√{resultFormatted} = {base}. Unlike square roots, cube roots can be taken of negative numbers: since (-{base})³ = -{resultFormatted}, the cube root of -{resultFormatted} is -{base}. This makes cube roots simpler than square roots in some respects, as every real number has exactly one real cube root.
    </p>

    <h2>Volume Interpretation</h2>
    <p>
      Geometrically, {base}³ represents the volume of a cube with edge length {base}. If each edge of a cube measures {base} units, the cube contains {resultFormatted} cubic units of space. This connection between cubing and volume is practical: if you need to fill a cubic container with side length {base} inches, you need {resultFormatted} cubic inches of material. Volume calculations using cubes are common in construction, packaging, shipping, and manufacturing.
    </p>

    <h2>Frequently Asked Questions</h2>
    <h3>What is {base} cubed?</h3>
    <p>
      {base} cubed ({base}³) equals {resultFormatted}. This is {base} multiplied by itself three times: {base} × {base} × {base} = {resultFormatted}. It represents the volume of a cube with side length {base}.
    </p>

    <h3>What is the cube root of {resultFormatted}?</h3>
    <p>
      The cube root of {resultFormatted} is {base}. Since {base} × {base} × {base} = {resultFormatted}, the cube root ³√{resultFormatted} = {base}.
    </p>

    <h2>Nearby Cubes</h2>
    <ul>
      {relatedPages.map((p) => (
        <li>
          <a href={`/math/${p.slug}-cubed/`}>{p.base} Cubed = {p.resultFormatted}</a>
        </li>
      ))}
    </ul>

    <p><a href="/math/">&larr; Math Reference</a> | <a href="/math-calculators/">Math Calculators</a></p>

    <CrossLinks links={crossLinks} />
  </article>

  <AdUnit slot="cubed-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-fact { background: #eff6ff; border-radius: var(--radius); padding: 16px 24px; margin-bottom: 24px; font-size: 1.1rem; }
  .quick-fact-label { font-size: 0.85rem; color: var(--color-text-muted); display: block; margin-bottom: 4px; }
  .quick-fact strong { color: var(--color-primary); font-size: 1.15rem; }
  .section-heading { font-size: 1.2rem; margin: 32px 0 12px; }
  .calc-desc { font-size: 0.9rem; color: var(--color-text-muted); margin-bottom: 16px; }
  .finder-row { display: flex; gap: 16px; align-items: end; flex-wrap: wrap; }
  .finder-row .input-group { flex: 1; min-width: 100px; }
  .finder-result { margin-top: 16px; padding: 14px 16px; background: var(--color-bg); border-radius: var(--radius); font-size: 0.95rem; line-height: 1.7; min-height: 44px; }
  .steps-list { display: flex; flex-direction: column; gap: 8px; }
  .step-row { display: flex; gap: 10px; align-items: baseline; padding: 6px 0; }
  .step-row.result { margin-top: 8px; padding-top: 12px; border-top: 2px solid var(--color-primary); color: var(--color-primary); font-weight: 600; }
  .step-num { font-weight: 700; min-width: 60px; color: var(--color-text-muted); font-size: 0.85rem; }
  .highlight { background: #dbeafe; font-weight: 700; color: var(--color-primary); }
  @media (max-width: 640px) { .finder-row { flex-direction: column; } }
</style>

<script>
  var baseInput = document.getElementById('baseInput') as HTMLInputElement;
  var expInput = document.getElementById('expInput') as HTMLInputElement;
  var powerBtn = document.getElementById('powerBtn') as HTMLButtonElement;
  var resultDiv = document.getElementById('powerResult') as HTMLDivElement;

  function calculate() {
    var b = parseFloat(baseInput.value);
    var e = parseInt(expInput.value, 10);
    if (isNaN(b) || isNaN(e) || e < 0 || e > 20 || Math.abs(b) > 10000) {
      resultDiv.textContent = 'Please enter a valid base (-10000 to 10000) and exponent (0 to 20).';
      return;
    }
    var result = Math.pow(b, e);
    var html = '<strong>' + b + '<sup>' + e + '</sup> = ' + result.toLocaleString('en-US') + '</strong>';
    resultDiv.innerHTML = html;
  }

  powerBtn.addEventListener('click', calculate);
  baseInput.addEventListener('keydown', function(e) { if ((e as KeyboardEvent).key === 'Enter') calculate(); });
  expInput.addEventListener('keydown', function(e) { if ((e as KeyboardEvent).key === 'Enter') calculate(); });
  calculate();
</script>
