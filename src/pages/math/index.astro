---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import '../../styles/category.css';
import { getAllGcfLcmPages } from '../../data/gcf-lcm';
import { getAllSquareRootPages } from '../../data/square-roots';
import { getAllSquaredPages, getAllCubedPages, getAllFourthPowerPages } from '../../data/powers';
import { getAllPrimeCheckPages } from '../../data/prime-check';
import { getAllDividedByPages } from '../../data/divided-by';

const gcfCount = getAllGcfLcmPages().length;
const sqrtCount = getAllSquareRootPages().length;
const squaredCount = getAllSquaredPages().length;
const cubedCount = getAllCubedPages().length;
const fourthCount = getAllFourthPowerPages().length;
const primeCount = getAllPrimeCheckPages().length;
const divCount = getAllDividedByPages().length;
const lcmCount = gcfCount; // LCM uses same data pairs as GCF

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Math Reference" },
  ],
};

// Popular samples for each section
const gcfSamples = [
  { slug: '12-and-18', label: 'GCF of 12 & 18' },
  { slug: '8-and-12', label: 'GCF of 8 & 12' },
  { slug: '15-and-20', label: 'GCF of 15 & 20' },
  { slug: '6-and-9', label: 'GCF of 6 & 9' },
  { slug: '14-and-21', label: 'GCF of 14 & 21' },
  { slug: '10-and-15', label: 'GCF of 10 & 15' },
  { slug: '4-and-6', label: 'GCF of 4 & 6' },
  { slug: '16-and-24', label: 'GCF of 16 & 24' },
];

const sqrtSamples = [
  { slug: '2', label: '√2' }, { slug: '3', label: '√3' },
  { slug: '4', label: '√4' }, { slug: '5', label: '√5' },
  { slug: '16', label: '√16' }, { slug: '25', label: '√25' },
  { slug: '49', label: '√49' }, { slug: '64', label: '√64' },
  { slug: '100', label: '√100' }, { slug: '144', label: '√144' },
  { slug: '169', label: '√169' }, { slug: '200', label: '√200' },
];

const squaredSamples = [
  { slug: '5', label: '5²' }, { slug: '7', label: '7²' },
  { slug: '9', label: '9²' }, { slug: '12', label: '12²' },
  { slug: '15', label: '15²' }, { slug: '20', label: '20²' },
  { slug: '25', label: '25²' }, { slug: '30', label: '30²' },
];

const cubedSamples = [
  { slug: '2', label: '2³' }, { slug: '3', label: '3³' },
  { slug: '4', label: '4³' }, { slug: '5', label: '5³' },
  { slug: '7', label: '7³' }, { slug: '10', label: '10³' },
];

const primeSamples = [
  { slug: '7', label: 'Is 7 prime?' }, { slug: '13', label: 'Is 13 prime?' },
  { slug: '51', label: 'Is 51 prime?' }, { slug: '57', label: 'Is 57 prime?' },
  { slug: '91', label: 'Is 91 prime?' }, { slug: '97', label: 'Is 97 prime?' },
  { slug: '100', label: 'Is 100 prime?' }, { slug: '127', label: 'Is 127 prime?' },
];

const divSamples = [
  { dividend: 100, divisor: 3, label: '100 ÷ 3' },
  { dividend: 100, divisor: 7, label: '100 ÷ 7' },
  { dividend: 72, divisor: 8, label: '72 ÷ 8' },
  { dividend: 144, divisor: 12, label: '144 ÷ 12' },
  { dividend: 200, divisor: 6, label: '200 ÷ 6' },
  { dividend: 1000, divisor: 7, label: '1000 ÷ 7' },
  { dividend: 500, divisor: 9, label: '500 ÷ 9' },
  { dividend: 360, divisor: 11, label: '360 ÷ 11' },
];

const lcmSamples = [
  { slug: '12-and-18', label: 'LCM of 12 & 18' },
  { slug: '8-and-12', label: 'LCM of 8 & 12' },
  { slug: '15-and-20', label: 'LCM of 15 & 20' },
  { slug: '6-and-9', label: 'LCM of 6 & 9' },
  { slug: '4-and-6', label: 'LCM of 4 & 6' },
  { slug: '3-and-5', label: 'LCM of 3 & 5' },
  { slug: '10-and-15', label: 'LCM of 10 & 15' },
  { slug: '14-and-21', label: 'LCM of 14 & 21' },
];
---

<BaseLayout
  title="Math Reference - GCF, LCM, Square Roots, Primes & More | ToolCalcs"
  description={`Instant math answers: GCF (${gcfCount} pages), LCM (${lcmCount} pages), square roots (${sqrtCount} pages), powers (${squaredCount + cubedCount + fourthCount} pages), primes (${primeCount} pages), division (${divCount} pages), and times tables.`}
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Math Reference</span>
  </nav>

  <h1>Math Reference</h1>
  <p class="page-desc">Instant answers for GCF, LCM, square roots, powers, prime numbers, division, and times tables. Browse {gcfCount + lcmCount + sqrtCount + squaredCount + cubedCount + fourthCount + primeCount + divCount + 156} reference pages.</p>

  <AdUnit slot="math-idx-top" format="horizontal" />

  <!-- GCF & LCM -->
  <section class="factors-section">
    <h2 class="factors-heading">GCF & LCM Calculator ({gcfCount} pages)</h2>
    <p class="section-desc">Find the Greatest Common Factor and Least Common Multiple of any two numbers.</p>
    <div class="number-grid">
      {gcfSamples.map((s) => (
        <a href={`/math/gcf-of-${s.slug}/`} class="number-card">
          <span class="number-val">{s.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- LCM -->
  <section class="factors-section">
    <h2 class="factors-heading">LCM - Least Common Multiple ({lcmCount} pages)</h2>
    <p class="section-desc">Find the Least Common Multiple of any two numbers with step-by-step methods.</p>
    <div class="number-grid">
      {lcmSamples.map((s) => (
        <a href={`/math/lcm-of-${s.slug}/`} class="number-card">
          <span class="number-val">{s.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Square Roots -->
  <section class="factors-section">
    <h2 class="factors-heading">Square Roots ({sqrtCount} pages)</h2>
    <p class="section-desc">Find the square root of any number with simplified radical form and step-by-step solutions.</p>
    <div class="number-grid">
      {sqrtSamples.map((s) => (
        <a href={`/math/square-root-of-${s.slug}/`} class="number-card">
          <span class="number-val">{s.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Powers & Exponents -->
  <section class="factors-section">
    <h2 class="factors-heading">Powers & Exponents ({squaredCount + cubedCount + fourthCount} pages)</h2>
    <p class="section-desc">Calculate squares and cubes with step-by-step explanations.</p>
    <h3 class="subsection-heading">Squares (n²)</h3>
    <div class="number-grid">
      {squaredSamples.map((s) => (
        <a href={`/math/${s.slug}-squared/`} class="number-card">
          <span class="number-val">{s.label}</span>
        </a>
      ))}
    </div>
    <h3 class="subsection-heading">Cubes (n³)</h3>
    <div class="number-grid">
      {cubedSamples.map((s) => (
        <a href={`/math/${s.slug}-cubed/`} class="number-card">
          <span class="number-val">{s.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Prime Numbers -->
  <section class="factors-section">
    <h2 class="factors-heading">Is It Prime? ({primeCount} pages)</h2>
    <p class="section-desc">Check whether any number is prime or composite, with factors and prime factorization.</p>
    <div class="number-grid">
      {primeSamples.map((s) => (
        <a href={`/math/is-${s.slug}-prime/`} class="number-card">
          <span class="number-val">{s.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Division -->
  <section class="factors-section">
    <h2 class="factors-heading">Division ({divCount} pages)</h2>
    <p class="section-desc">Find quotients, remainders, and decimal results for common division problems.</p>
    <div class="number-grid">
      {divSamples.map((s) => (
        <a href={`/math/${s.dividend}-divided-by-${s.divisor}/`} class="number-card">
          <span class="number-val">{s.label}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Times Tables -->
  <section class="factors-section">
    <h2 class="factors-heading">Times Tables (156 pages)</h2>
    <p class="section-desc">Complete multiplication tables from 1× to 12× with interactive quizzes and 144 individual fact pages.</p>
    <div class="number-grid">
      {Array.from({ length: 12 }, (_, i) => i + 1).map((n) => (
        <a href={`/times-tables/${n}/`} class="number-card">
          <span class="number-val">{n}×</span>
          <span class="number-count">Table</span>
        </a>
      ))}
    </div>
    <p style="margin-top: 12px;"><a href="/times-tables/">View all times tables &rarr;</a></p>
  </section>

  <!-- Related -->
  <section class="factors-section">
    <h2 class="factors-heading">Related Tools</h2>
    <div class="number-grid">
      <a href="/factors-of/" class="number-card">
        <span class="number-val">Factors</span>
        <span class="number-count">Calculator</span>
      </a>
      <a href="/fraction/" class="number-card">
        <span class="number-val">Fractions</span>
        <span class="number-count">Reference</span>
      </a>
      <a href="/percentage/" class="number-card">
        <span class="number-val">Percentages</span>
        <span class="number-count">Calculator</span>
      </a>
      <a href="/math-calculators/" class="number-card">
        <span class="number-val">Math</span>
        <span class="number-count">Calculators</span>
      </a>
    </div>
  </section>

  <AdUnit slot="math-idx-bottom" format="horizontal" />
</BaseLayout>

<style>
  .factors-section { margin-bottom: 32px; }
  .factors-heading { font-size: 1.2rem; font-weight: 700; margin-bottom: 8px; padding-bottom: 8px; border-bottom: 2px solid var(--color-border); }
  .section-desc { font-size: 0.9rem; color: var(--color-text-muted); margin-bottom: 14px; }
  .subsection-heading { font-size: 1rem; font-weight: 600; margin: 16px 0 8px; color: var(--color-text-muted); }
  .number-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px; }
  .number-card { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 14px 10px; background: var(--color-bg-alt); border: 1px solid var(--color-border); border-radius: var(--radius); text-decoration: none; color: var(--color-text); transition: border-color 0.15s, box-shadow 0.15s; }
  .number-card:hover { border-color: var(--color-primary); box-shadow: 0 2px 8px rgba(37, 99, 235, 0.1); }
  .number-val { font-size: 1.1rem; font-weight: 800; color: var(--color-primary); }
  .number-count { font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); }
  @media (max-width: 640px) { .number-grid { grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); } }
</style>
