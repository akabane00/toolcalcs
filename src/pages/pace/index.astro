---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import '../../styles/calculator.css';
import { getAllPacePages } from '../../data/running-pace';
import type { PacePage } from '../../data/running-pace';

const allPages = getAllPacePages();
const pacePages = allPages.filter(function (p) { return p.pageType === 'pace'; });
const raceTargetPages = allPages.filter(function (p) { return p.pageType === 'race-target'; });
const count = allPages.length;

// Group pace pages by category in display order
const categoryOrder = ['Elite', 'Advanced', 'Intermediate', 'Recreational', 'Beginner'];
function getPagesForCategory(cat: string): PacePage[] {
  return pacePages
    .filter(function (p) { return p.category === cat; })
    .sort(function (a, b) { return a.paceMinPerMile - b.paceMinPerMile; });
}

// Group race targets by race name
const raceNames = ['5K', '10K', 'Half Marathon', 'Marathon'];
function getTargetsForRace(raceName: string): PacePage[] {
  return raceTargetPages
    .filter(function (p) { return p.title.includes(raceName); })
    .sort(function (a, b) { return a.paceMinPerMile - b.paceMinPerMile; });
}

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Running Pace Calculator"
    }
  ]
};
---

<BaseLayout
  title="Running Pace Calculator - Pace Conversion & Race Times | ToolCalcs"
  description={`Convert running paces between min/mile, min/km, and mph. See estimated 5K, 10K, half marathon, and marathon finish times for ${count} different paces and race goals.`}
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Running Pace Calculator</span>
  </nav>

  <h1>Running Pace Calculator</h1>
  <p class="page-desc">Convert running paces between miles and kilometers, calculate your speed, and see estimated finish times for 5K, 10K, half marathon, and marathon. Browse {count} pace conversions and race time goals below.</p>

  <AdUnit slot="pace-idx-top" format="horizontal" />

  {categoryOrder.map(function (cat, idx) {
    var pages = getPagesForCategory(cat);
    if (pages.length === 0) return null;
    return (
      <>
        <section class="pace-category-section">
          <h2 class="pace-category-heading">{cat} Pace</h2>
          <div class="table-container">
            <table class="data-table pace-idx-table">
              <thead>
                <tr>
                  <th>Pace (min/mile)</th>
                  <th>Pace (min/km)</th>
                  <th>Speed (mph)</th>
                  <th>5K Time</th>
                </tr>
              </thead>
              <tbody>
                {pages.map(function (p) {
                  return (
                    <tr>
                      <td><a href={'/pace/' + p.slug + '/'}>{p.paceDisplay}</a></td>
                      <td>{p.paceKmDisplay}</td>
                      <td>{p.speedMph}</td>
                      <td class="pace-time">{p.race5k}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>
        {idx === 2 && <AdUnit slot="pace-idx-mid" format="rectangle" />}
      </>
    );
  })}

  <!-- Race Target Times -->
  <h2 class="section-heading">Race Time Goals</h2>
  <p class="page-desc" style="margin-top: 0;">Find the exact pace you need to hit your target race time.</p>

  {raceNames.map(function (raceName) {
    var targets = getTargetsForRace(raceName);
    if (targets.length === 0) return null;
    return (
      <section class="pace-category-section">
        <h3 class="pace-category-heading">{raceName} Goals</h3>
        <div class="table-container">
          <table class="data-table pace-idx-table">
            <thead>
              <tr>
                <th>Goal</th>
                <th>Required Pace</th>
                <th>Speed (mph)</th>
              </tr>
            </thead>
            <tbody>
              {targets.map(function (p) {
                return (
                  <tr>
                    <td><a href={'/pace/' + p.slug + '/'}>{p.title}</a></td>
                    <td>{p.paceDisplay}</td>
                    <td>{p.speedMph}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    );
  })}

  <!-- SEO Content -->
  <article class="content-section">
    <h2>How to Use This Running Pace Guide</h2>
    <p>
      This page lists {count} pre-calculated running pace conversions organized by skill level. Each row shows the pace per mile, equivalent pace per kilometer, speed in mph, and estimated 5K finish time. Click any pace to see a detailed breakdown including race time predictions for 5K, 10K, half marathon, and marathon distances, plus training tips tailored to that pace level.
    </p>
    <p>
      The Race Time Goals section helps you work backwards from a target finish time to find the exact pace per mile and per kilometer you need to maintain throughout your race.
    </p>

    <h2>Understanding Running Pace</h2>
    <p>
      Running pace is the time it takes to cover a specific distance, typically expressed as minutes per mile or minutes per kilometer. Pace is the inverse of speed — a faster pace means a lower number (fewer minutes per mile). For example, a 7:00 min/mile pace is faster than a 10:00 min/mile pace.
    </p>
    <p>
      To convert between pace and speed: <strong>Speed (mph) = 60 / Pace (min/mile)</strong>. To convert pace from min/mile to min/km, divide by 1.609. These conversions are essential for runners who train with GPS watches that may display either unit, or who race in countries using the metric system.
    </p>
    <p>
      Race time estimates on this page assume even pacing from start to finish. In practice, most runners experience some pace variation due to terrain, weather, and fatigue. For longer distances like the marathon, many coaches recommend starting slightly slower than goal pace and running negative splits (getting faster in the second half) for the best results.
    </p>

    <h2>Choosing the Right Pace for Your Goals</h2>
    <p>
      Your ideal training pace depends on your goals. For building aerobic fitness, most runs should be at a conversational pace — typically 1-2 minutes per mile slower than your race pace. Speed work and tempo runs should be done at or slightly faster than race pace, but these should make up only about 20% of your weekly mileage.
    </p>
    <p>
      For race day, knowing your goal pace is essential. Use the Race Time Goals section to find the pace you need, then practice running at that pace during training. A GPS watch or running app can help you stay on target. Consider using a pacing strategy appropriate to your experience level and the race distance.
    </p>
    <p>
      Explore each pace page for detailed conversions, race time predictions, and personalized training advice for your level.
    </p>

    <p><a href="/">Back to ToolCalcs Home &rarr;</a></p>
  </article>

  <AdUnit slot="pace-idx-bottom" format="horizontal" />
</BaseLayout>

<style>
  .pace-category-section {
    margin-bottom: 36px;
  }
  .pace-category-heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
  }
  .section-heading {
    font-size: 1.4rem;
    margin: 40px 0 12px;
  }
  .pace-idx-table a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }
  .pace-idx-table a:hover {
    text-decoration: underline;
  }
  .pace-time {
    font-weight: 700;
    color: #1d4ed8;
  }
  .pace-idx-table td:first-child {
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .pace-idx-table {
      font-size: 0.82rem;
    }
    .pace-idx-table th,
    .pace-idx-table td {
      padding: 6px 8px;
    }
    .pace-idx-table td:first-child {
      white-space: normal;
    }
  }
</style>
