---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import CrossLinks from '../../components/CrossLinks.astro';
import '../../styles/calculator.css';
import { getAllPaycheckPages, STATES, SALARIES, type PaycheckPage } from '../../data/paycheck';

export function getStaticPaths() {
  return getAllPaycheckPages().map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: PaycheckPage };
const {
  slug, state, stateAbbr, annualSalary, salaryDisplay, stateTaxRate,
  federalTax, stateTax, ficaTax, totalTax, annualTakeHome,
  monthlyTakeHome, biweeklyTakeHome, weeklyTakeHome, hourlyEquivalent, marginalRate,
} = page;

function fmt(n: number): string {
  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function fmtWhole(n: number): string {
  return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}

function pct(n: number): string {
  return (n * 100).toFixed(1) + '%';
}

// Pre-compute dollar strings for JSX (avoid ${} in templates)
const salaryDollar = '$' + salaryDisplay;
const takeHomeDollar = fmt(annualTakeHome);

// All pages for cross-references
const allPages = getAllPaycheckPages();

// Same salary, other states
const sameSlaryOtherStates = allPages
  .filter((p) => p.annualSalary === annualSalary && p.state !== state)
  .sort((a, b) => b.annualTakeHome - a.annualTakeHome);

// Same state, other salaries
const sameStateOtherSalaries = allPages
  .filter((p) => p.state === state && p.annualSalary !== annualSalary)
  .sort((a, b) => a.annualSalary - b.annualSalary);

// Tax percentages for visual bars
const federalPct = Math.round((federalTax / annualSalary) * 100);
const statePct = Math.round((stateTax / annualSalary) * 100);
const ficaPct = Math.round((ficaTax / annualSalary) * 100);
const takeHomePct = Math.round((annualTakeHome / annualSalary) * 100);

// State info
const stateInfo = STATES.find((s) => s.name === state);
const stateDesc = stateInfo ? stateInfo.description : '';
const isNoTaxState = stateTaxRate === 0;

// SEO
const title = salaryDollar + ' Salary in ' + state + ' - Take-Home Pay After Taxes | ToolCalcs';
const h1Text = salaryDollar + ' Salary in ' + state + ': Take-Home Pay After Taxes';
const description = 'How much is ' + salaryDollar + ' after taxes in ' + state + '? Take-home pay is ' + takeHomeDollar + '/year, ' + fmt(monthlyTakeHome) + '/month, ' + fmt(biweeklyTakeHome) + ' biweekly. Full tax breakdown.';
const breadcrumbShort = salaryDollar + ' in ' + stateAbbr;

// FAQ content
const faq1Q = 'How much is ' + salaryDollar + ' after taxes in ' + state + '?';
const faq1A = 'On a ' + salaryDollar + ' salary in ' + state + ', your estimated take-home pay is ' + takeHomeDollar + ' per year after federal taxes, state taxes, and FICA deductions. That works out to ' + fmt(monthlyTakeHome) + ' per month or ' + fmt(biweeklyTakeHome) + ' per biweekly paycheck.';

const faq2Q = 'What is the tax rate on a ' + salaryDollar + ' salary in ' + state + '?';
const faq2A = isNoTaxState
  ? state + ' has no state income tax, so you only pay federal income tax (' + fmt(federalTax) + ') and FICA taxes (' + fmt(ficaTax) + '). Your combined effective tax rate is ' + pct(totalTax / annualSalary) + ', and your marginal tax rate is ' + pct(marginalRate) + '.'
  : 'In ' + state + ', you pay federal income tax (' + fmt(federalTax) + '), state income tax (' + fmt(stateTax) + ' at an effective rate of ' + pct(stateTaxRate) + '), and FICA taxes (' + fmt(ficaTax) + '). Your combined effective tax rate is ' + pct(totalTax / annualSalary) + '.';

const faq3Q = 'How much is ' + salaryDollar + ' a year per hour after taxes in ' + state + '?';
const faq3A = 'After taxes in ' + state + ', a ' + salaryDollar + ' annual salary equals approximately ' + fmt(hourlyEquivalent) + ' per hour in take-home pay, based on 2,080 working hours per year (40 hours per week for 52 weeks).';

const faq4Q = 'Is ' + salaryDollar + ' a good salary in ' + state + '?';
const faq4A = annualSalary < 40000
  ? 'A ' + salaryDollar + ' salary in ' + state + ' is below the national median income. Budgeting carefully is important at this income level, especially in higher cost-of-living areas. Your take-home pay of ' + fmt(monthlyTakeHome) + ' per month needs to cover rent, utilities, food, and transportation.'
  : annualSalary < 60000
    ? 'A ' + salaryDollar + ' salary in ' + state + ' is near the national median household income. This provides a comfortable living in many areas, though major metro areas may be more challenging. Your monthly take-home of ' + fmt(monthlyTakeHome) + ' should cover most essential expenses with room for savings.'
    : 'A ' + salaryDollar + ' salary in ' + state + ' is above the national median and provides a comfortable standard of living in most areas. With ' + fmt(monthlyTakeHome) + ' per month in take-home pay, you have room for savings, investments, and discretionary spending.';

// Structured Data
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Financial Calculators", "item": "https://toolcalcs.com/financial-calculators/" },
      { "@type": "ListItem", "position": 3, "name": "Paycheck Calculator", "item": "https://toolcalcs.com/paycheck/" },
      { "@type": "ListItem", "position": 4, "name": breadcrumbShort },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": faq1Q, "acceptedAnswer": { "@type": "Answer", "text": faq1A } },
      { "@type": "Question", "name": faq2Q, "acceptedAnswer": { "@type": "Answer", "text": faq2A } },
      { "@type": "Question", "name": faq3Q, "acceptedAnswer": { "@type": "Answer", "text": faq3A } },
      { "@type": "Question", "name": faq4Q, "acceptedAnswer": { "@type": "Answer", "text": faq4A } },
    ],
  },
];

// Salary context paragraph
function getSalaryContext(): string {
  if (isNoTaxState) {
    return 'Living in ' + state + ' gives you a significant advantage because there is no state income tax. This means more of your ' + salaryDollar + ' salary stays in your pocket compared to states with income taxes. For example, a worker earning the same salary in California would take home ' + fmt(annualTakeHome - (sameSlaryOtherStates.find(function(p) { return p.state === 'California'; })?.annualTakeHome || 0) > '$0.00' ? 'significantly less' : 'a different amount') + ' due to state income taxes. However, ' + state + ' may have higher sales taxes or property taxes to make up for the lack of income tax revenue.';
  }
  return state + ' levies a state income tax that reduces your take-home pay by ' + fmt(stateTax) + ' on a ' + salaryDollar + ' salary. The effective state tax rate of ' + pct(stateTaxRate) + ' is ' + (stateTaxRate > 0.045 ? 'above' : stateTaxRate > 0.035 ? 'near' : 'below') + ' the national average. When combined with federal taxes and FICA, your total effective tax rate is ' + pct(totalTax / annualSalary) + '. Understanding these deductions helps you plan your budget and make informed decisions about where to live and work.';
}

// Find the no-tax state advantage
const bestNoTaxState = sameSlaryOtherStates.find((p) => p.stateTaxRate === 0);
const taxStateSavings = bestNoTaxState ? round2(bestNoTaxState.annualTakeHome - annualTakeHome) : 0;

function round2(n: number): number {
  return Math.round(n * 100) / 100;
}
---

<BaseLayout
  title={title} description={description} type="article" noindex={true} structuredData={structuredData}>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/financial-calculators/">Financial Calculators</a> &rsaquo;
    <a href="/paycheck/">Paycheck Calculator</a> &rsaquo;
    <span>{breadcrumbShort}</span>
  </nav>

  <h1>{h1Text}</h1>
  <p class="page-desc">
    See exactly how much of your {salaryDollar} salary you keep in {state} after federal taxes, state taxes, and FICA deductions.
  </p>

  <!-- Quick Fact -->
  <div class="quick-fact">
    <span class="quick-fact-label">Quick Fact:</span>
    <strong>{salaryDollar} in {state} = {takeHomeDollar} take-home pay per year</strong>
  </div>

  <!-- Result Cards -->
  <div class="result-cards paycheck-cards">
    <div class="result-card primary">
      <span class="result-label">Annual Take-Home</span>
      <span class="result-value">{fmt(annualTakeHome)}</span>
    </div>
    <div class="result-card success">
      <span class="result-label">Monthly Take-Home</span>
      <span class="result-value">{fmt(monthlyTakeHome)}</span>
    </div>
    <div class="result-card">
      <span class="result-label">Biweekly Paycheck</span>
      <span class="result-value">{fmt(biweeklyTakeHome)}</span>
    </div>
    <div class="result-card">
      <span class="result-label">Weekly Take-Home</span>
      <span class="result-value">{fmt(weeklyTakeHome)}</span>
    </div>
    <div class="result-card">
      <span class="result-label">Hourly Equivalent</span>
      <span class="result-value">{fmt(hourlyEquivalent)}</span>
    </div>
    <div class="result-card">
      <span class="result-label">Total Taxes</span>
      <span class="result-value tax-red">{fmt(totalTax)}</span>
    </div>
  </div>

  <!-- Tax Breakdown -->
  <h2 class="section-heading">Tax Breakdown for {salaryDollar} in {state}</h2>
  <div class="calculator-box">
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Tax Type</th>
            <th>Amount</th>
            <th>Rate</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Federal Income Tax</td>
            <td class="tax-red">{fmt(federalTax)}</td>
            <td>{pct(federalTax / annualSalary)}</td>
          </tr>
          <tr>
            <td>{state} State Tax</td>
            <td class="tax-red">{isNoTaxState ? '$0.00' : fmt(stateTax)}</td>
            <td>{isNoTaxState ? '0% (No State Tax)' : pct(stateTaxRate)}</td>
          </tr>
          <tr>
            <td>Social Security (6.2%)</td>
            <td class="tax-red">{fmt(round2(Math.min(annualSalary, 168600) * 0.062))}</td>
            <td>6.2%</td>
          </tr>
          <tr>
            <td>Medicare (1.45%)</td>
            <td class="tax-red">{fmt(round2(annualSalary * 0.0145))}</td>
            <td>1.45%</td>
          </tr>
          <tr class="total-row">
            <td><strong>Total Taxes</strong></td>
            <td class="tax-red"><strong>{fmt(totalTax)}</strong></td>
            <td><strong>{pct(totalTax / annualSalary)}</strong></td>
          </tr>
          <tr class="take-home-row">
            <td><strong>Take-Home Pay</strong></td>
            <td class="take-home-green"><strong>{fmt(annualTakeHome)}</strong></td>
            <td><strong>{pct(annualTakeHome / annualSalary)}</strong></td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="disclaimer">
      Estimates based on 2025 federal tax brackets (single filer, standard deduction of $14,600) and FICA. Actual taxes vary by filing status, deductions, credits, and local taxes.
    </p>
  </div>

  <!-- Visual Breakdown Bars -->
  <h2 class="section-heading">Where Your Money Goes</h2>
  <div class="bar-breakdown">
    <div class="bar-item">
      <div class="bar-label">
        <span>Take-Home Pay</span>
        <span class="bar-pct">{takeHomePct}%</span>
      </div>
      <div class="bar-track">
        <div class="bar-fill bar-green" style={'width:' + takeHomePct + '%'}></div>
      </div>
    </div>
    <div class="bar-item">
      <div class="bar-label">
        <span>Federal Tax</span>
        <span class="bar-pct">{federalPct}%</span>
      </div>
      <div class="bar-track">
        <div class="bar-fill bar-red" style={'width:' + federalPct + '%'}></div>
      </div>
    </div>
    <div class="bar-item">
      <div class="bar-label">
        <span>State Tax</span>
        <span class="bar-pct">{statePct}%</span>
      </div>
      <div class="bar-track">
        <div class="bar-fill bar-orange" style={'width:' + (statePct > 0 ? statePct : 0) + '%'}></div>
      </div>
    </div>
    <div class="bar-item">
      <div class="bar-label">
        <span>FICA (SS + Medicare)</span>
        <span class="bar-pct">{ficaPct}%</span>
      </div>
      <div class="bar-track">
        <div class="bar-fill bar-yellow" style={'width:' + ficaPct + '%'}></div>
      </div>
    </div>
  </div>

  <AdUnit slot="paycheck-mid" format="rectangle" />

  <!-- Same Salary in Other States -->
  {sameSlaryOtherStates.length > 0 && (
    <h2 class="section-heading">{salaryDollar} Salary: Compare Take-Home Pay by State</h2>
    <p class="compare-desc">See how your take-home pay on a {salaryDollar} salary compares across different states.</p>
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>State</th>
            <th>State Tax</th>
            <th>Total Taxes</th>
            <th>Annual Take-Home</th>
            <th>Monthly</th>
          </tr>
        </thead>
        <tbody>
          <tr class="highlight-row">
            <td><strong>{state} ({stateAbbr})</strong></td>
            <td>{isNoTaxState ? '$0' : fmt(stateTax)}</td>
            <td>{fmt(totalTax)}</td>
            <td class="take-home-green"><strong>{fmt(annualTakeHome)}</strong></td>
            <td>{fmt(monthlyTakeHome)}</td>
          </tr>
          {sameSlaryOtherStates.map((p) => (
            <tr>
              <td><a href={'/paycheck/' + p.slug + '/'}>{p.state} ({p.stateAbbr})</a></td>
              <td>{p.stateTaxRate === 0 ? '$0' : fmt(p.stateTax)}</td>
              <td>{fmt(p.totalTax)}</td>
              <td>{fmt(p.annualTakeHome)}</td>
              <td>{fmt(p.monthlyTakeHome)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <!-- Same State, Different Salaries -->
  {sameStateOtherSalaries.length > 0 && (
    <h2 class="section-heading">Other Salaries in {state}</h2>
    <p class="compare-desc">Compare take-home pay for different salary levels in {state}.</p>
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Salary</th>
            <th>Federal Tax</th>
            <th>State Tax</th>
            <th>Annual Take-Home</th>
            <th>Monthly</th>
          </tr>
        </thead>
        <tbody>
          {sameStateOtherSalaries.map((p) => {
            var pSalaryDollar = '$' + p.salaryDisplay;
            return (
              <tr>
                <td><a href={'/paycheck/' + p.slug + '/'}>{pSalaryDollar}</a></td>
                <td>{fmt(p.federalTax)}</td>
                <td>{p.stateTaxRate === 0 ? '$0' : fmt(p.stateTax)}</td>
                <td>{fmt(p.annualTakeHome)}</td>
                <td>{fmt(p.monthlyTakeHome)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}

  <!-- SEO Content -->
  <article class="content-section">
    <h2>{salaryDollar} Salary in {state}: What You Actually Take Home</h2>
    <p>
      If you earn {salaryDollar} per year in {state}, your estimated take-home pay after all taxes is <strong>{takeHomeDollar}</strong> annually. That means you keep about <strong>{takeHomePct}%</strong> of your gross salary. Your biweekly paycheck would be approximately {fmt(biweeklyTakeHome)}, and your monthly take-home pay is {fmt(monthlyTakeHome)}.
    </p>
    <p>
      {stateDesc}
    </p>

    <h2>Understanding Your Tax Deductions</h2>
    <p>
      Your {salaryDollar} gross salary is reduced by three main categories of taxes before it reaches your bank account. Federal income tax takes {fmt(federalTax)} based on the 2025 tax brackets for a single filer with the standard deduction of $14,600. FICA taxes (Social Security at 6.2% and Medicare at 1.45%) account for {fmt(ficaTax)}.
      {isNoTaxState
        ? ' Since ' + state + ' has no state income tax, you avoid that deduction entirely, keeping more of your earnings.'
        : ' ' + state + ' state income tax adds ' + fmt(stateTax) + ' to your tax bill at an effective rate of ' + pct(stateTaxRate) + '.'
      }
    </p>
    <p>
      Your combined marginal tax rate is {pct(marginalRate)}, meaning each additional dollar you earn is taxed at that rate. This is important for evaluating raises, overtime, and side income. Your effective tax rate (total taxes as a percentage of gross income) is {pct(totalTax / annualSalary)}, which is a more accurate measure of your overall tax burden.
    </p>

    <h2>How to Increase Your Take-Home Pay</h2>
    <p>
      There are several strategies to keep more of your {salaryDollar} salary. Contributing to a pre-tax 401(k) or traditional IRA reduces your taxable income, lowering your federal tax bill. Health insurance premiums paid through an employer plan are typically pre-tax as well. If you have significant medical expenses, you may benefit from a Health Savings Account (HSA) which offers triple tax advantages.
    </p>
    <p>
      Adjusting your W-4 withholdings can also help match your actual tax liability more closely, avoiding large refunds (which are essentially interest-free loans to the government) or unexpected tax bills. If your employer offers a Flexible Spending Account (FSA) for dependent care or medical expenses, these also reduce your taxable income.
    </p>

    <h2>Frequently Asked Questions</h2>

    <h3>{faq1Q}</h3>
    <p>{faq1A}</p>

    <h3>{faq2Q}</h3>
    <p>{faq2A}</p>

    <h3>{faq3Q}</h3>
    <p>{faq3A}</p>

    <h3>{faq4Q}</h3>
    <p>{faq4A}</p>

    <h2>Related Paycheck Calculations</h2>
    <ul>
      {sameSlaryOtherStates.slice(0, 4).map((p) => {
        var linkSalary = '$' + p.salaryDisplay;
        return (
          <li>
            <a href={'/paycheck/' + p.slug + '/'}>
              {linkSalary + ' in ' + p.state + ' \u2192 ' + fmt(p.annualTakeHome) + '/year take-home'}
            </a>
          </li>
        );
      })}
      {sameStateOtherSalaries.slice(0, 3).map((p) => {
        var linkSalary = '$' + p.salaryDisplay;
        return (
          <li>
            <a href={'/paycheck/' + p.slug + '/'}>
              {linkSalary + ' in ' + state + ' \u2192 ' + fmt(p.annualTakeHome) + '/year take-home'}
            </a>
          </li>
        );
      })}
    </ul>

    <p><a href="/paycheck/">&larr; View All Paycheck Calculations</a> | <a href="/financial-calculators/">Financial Calculators</a></p>

    <CrossLinks links={[
      { href: '/salary/', label: 'Salary Calculator', icon: '\uD83D\uDCB0' },
      { href: '/financial-calculators/', label: 'Financial Calculators', icon: '\uD83D\uDCC8' },
      { href: '/mortgage/', label: 'Mortgage Calculator', icon: '\uD83C\uDFE0' },
      { href: '/loan/', label: 'Loan Calculator', icon: '\uD83C\uDFE6' },
    ]} />
  </article>

  <AdUnit slot="paycheck-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-fact {
    background: #eff6ff;
    border-radius: var(--radius);
    padding: 16px 24px;
    margin-bottom: 24px;
    font-size: 1.1rem;
  }
  .quick-fact-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 4px;
  }
  .quick-fact strong {
    color: var(--color-primary);
    font-size: 1.15rem;
  }
  .section-heading {
    font-size: 1.2rem;
    margin: 32px 0 12px;
  }
  .paycheck-cards {
    grid-template-columns: repeat(3, 1fr);
  }
  .tax-red {
    color: #dc2626;
    font-weight: 600;
  }
  .take-home-green {
    color: #16a34a;
    font-weight: 700;
  }
  .total-row td {
    border-top: 2px solid var(--color-border);
    background: #fef2f2;
  }
  .take-home-row td {
    background: #f0fdf4;
  }
  .highlight-row {
    background: #eff6ff;
  }
  .disclaimer {
    background: #fef3c7;
    border-radius: var(--radius);
    padding: 10px 16px;
    font-size: 0.85rem;
    color: #92400e;
    margin-top: 16px;
    line-height: 1.5;
  }
  .compare-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 12px;
  }

  /* Visual Breakdown Bars */
  .bar-breakdown {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }
  .bar-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    font-weight: 600;
  }
  .bar-pct {
    color: var(--color-text-muted);
    font-weight: 500;
  }
  .bar-track {
    height: 24px;
    background: #f1f5f9;
    border-radius: 6px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 6px;
    transition: width 0.3s ease;
    min-width: 2px;
  }
  .bar-green { background: #22c55e; }
  .bar-red { background: #ef4444; }
  .bar-orange { background: #f97316; }
  .bar-yellow { background: #eab308; }

  @media (max-width: 768px) {
    .paycheck-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .paycheck-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
