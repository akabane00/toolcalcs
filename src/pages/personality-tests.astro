---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Free Personality Tests & Psychology Guides",
  "description": "Take free personality tests (MBTI, DISC, Enneagram, Big Five) and read expert guides on personality types, emotional intelligence, and attachment styles.",
  "url": "https://toolcalcs.com/personality-tests/"
};
---

<BaseLayout
  title="Free Personality Tests & Psychology Guides (2026) | ToolCalcs"
  description="Take free personality tests: MBTI, DISC, Big Five, Enneagram, Dark Triad, EQ, and more. Plus expert guides on 16 personality types, attachment styles, and emotional intelligence."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <span>Personality Tests</span>
  </nav>

  <h1>Free Personality Tests & Guides</h1>
  <p class="hub-desc">Discover your personality type with scientifically-validated assessments. Take a test below, then read our in-depth guides to understand your results and what they mean for your career, relationships, and personal growth.</p>

  <AdUnit slot="hub-top" format="horizontal" />

  <section class="hub-section">
    <h2>Take a Free Personality Test</h2>
    <p class="section-desc">Each test takes 5-15 minutes. Your results are instant, private, and free.</p>
    <div class="hub-grid">
      <a href="/test/personality-type-test/" class="hub-card featured">
        <span class="hub-icon">🧠</span>
        <h3>16 Types Personality Test (MBTI)</h3>
        <p>Find your 4-letter type: INTJ, ENFP, ISTP, and more. The world's most popular personality framework.</p>
        <span class="hub-badge">Most Popular</span>
      </a>
      <a href="/test/disc-personality-test/" class="hub-card">
        <span class="hub-icon">🎯</span>
        <h3>DISC Personality Test</h3>
        <p>Discover your Dominance, Influence, Steadiness, or Conscientiousness profile.</p>
      </a>
      <a href="/test/big-five-personality-test/" class="hub-card">
        <span class="hub-icon">📊</span>
        <h3>Big Five (OCEAN) Test</h3>
        <p>Measure Openness, Conscientiousness, Extraversion, Agreeableness, and Neuroticism.</p>
      </a>
      <a href="/test/enneagram-test/" class="hub-card">
        <span class="hub-icon">🔢</span>
        <h3>Enneagram Test</h3>
        <p>Find your core number among the 9 Enneagram types and understand your motivations.</p>
      </a>
      <a href="/test/dark-triad-test/" class="hub-card">
        <span class="hub-icon">🌑</span>
        <h3>Dark Triad Test</h3>
        <p>Measure Machiavellianism, narcissism, and psychopathy traits in this psychology assessment.</p>
      </a>
      <a href="/test/emotional-intelligence-test/" class="hub-card">
        <span class="hub-icon">❤️</span>
        <h3>Emotional Intelligence (EQ)</h3>
        <p>Assess your ability to recognize, understand, and manage emotions effectively.</p>
      </a>
      <a href="/test/attachment-style-quiz/" class="hub-card">
        <span class="hub-icon">🔗</span>
        <h3>Attachment Style Quiz</h3>
        <p>Discover if you are secure, anxious, avoidant, or fearful-avoidant in relationships.</p>
      </a>
      <a href="/test/introvert-extrovert-test/" class="hub-card">
        <span class="hub-icon">🔄</span>
        <h3>Introvert-Extrovert Test</h3>
        <p>Find where you fall on the introversion-extraversion spectrum.</p>
      </a>
      <a href="/test/love-language-test/" class="hub-card">
        <span class="hub-icon">💕</span>
        <h3>Love Language Test</h3>
        <p>Discover how you give and receive love: words, acts, gifts, time, or touch.</p>
      </a>
    </div>
  </section>

  <AdUnit slot="hub-mid" format="horizontal" />

  <section class="hub-section">
    <h2>Personality Type Guides</h2>
    <p class="section-desc">Expert articles explaining personality frameworks, research, and practical applications.</p>
    <div class="guide-grid">
      <a href="/blog/understanding-16-personality-types/" class="guide-card">
        <h3>The 16 Personality Types Explained: Complete MBTI Guide</h3>
        <p>Understand all 16 types, the four dimensions, and what your type reveals about career and relationships.</p>
      </a>
      <a href="/blog/best-personality-tests-online/" class="guide-card">
        <h3>10 Best Free Personality Tests Online (2026)</h3>
        <p>Compare the top free personality tests: MBTI, DISC, Enneagram, Big Five, and more.</p>
      </a>
      <a href="/blog/big-five-vs-mbti/" class="guide-card">
        <h3>Big Five vs MBTI: Which Is More Accurate?</h3>
        <p>Scientific comparison of the two most popular personality models.</p>
      </a>
      <a href="/blog/mbti-vs-disc-vs-enneagram/" class="guide-card">
        <h3>MBTI vs DISC vs Enneagram: Which Test Is Right for You?</h3>
        <p>Side-by-side comparison of three personality frameworks.</p>
      </a>
      <a href="/blog/dark-triad-personality-explained/" class="guide-card">
        <h3>What Is the Dark Triad Personality?</h3>
        <p>Explore the traits, research, and psychology behind the Dark Triad.</p>
      </a>
      <a href="/blog/what-is-disc-assessment/" class="guide-card">
        <h3>What Is DISC Assessment?</h3>
        <p>Complete guide to the 4 DISC personality types and how they interact.</p>
      </a>
      <a href="/blog/enneagram-types-guide/" class="guide-card">
        <h3>The 9 Enneagram Types: Find Your Number</h3>
        <p>Deep dive into each Enneagram type, wings, and growth paths.</p>
      </a>
      <a href="/blog/attachment-styles-in-relationships/" class="guide-card">
        <h3>4 Attachment Styles in Relationships</h3>
        <p>How attachment theory affects your romantic relationships.</p>
      </a>
      <a href="/blog/what-is-emotional-intelligence/" class="guide-card">
        <h3>What Is Emotional Intelligence (EQ)?</h3>
        <p>Why EQ matters more than IQ for success and how to improve it.</p>
      </a>
      <a href="/blog/introvert-vs-extrovert-science/" class="guide-card">
        <h3>Introvert vs Extrovert: What Science Says</h3>
        <p>The neuroscience behind introversion and extraversion.</p>
      </a>
      <a href="/blog/5-love-languages-explained/" class="guide-card">
        <h3>The 5 Love Languages Explained</h3>
        <p>How you give and receive love, and why it matters in every relationship.</p>
      </a>
    </div>
  </section>

  <AdUnit slot="hub-bottom" format="horizontal" />
</BaseLayout>

<style>
  .hub-desc {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 28px;
    max-width: 700px;
  }
  .hub-section { margin-bottom: 48px; }
  .hub-section h2 { font-size: 1.4rem; margin-bottom: 6px; }
  .section-desc { color: var(--color-text-muted); font-size: 0.92rem; margin-bottom: 20px; }
  .hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }
  .hub-card {
    display: block;
    padding: 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, box-shadow 0.15s;
    position: relative;
  }
  .hub-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }
  .hub-card.featured { border-color: var(--color-primary); }
  .hub-icon { font-size: 1.8rem; display: block; margin-bottom: 10px; }
  .hub-card h3 { font-size: 1.05rem; margin-bottom: 6px; }
  .hub-card p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.5; margin: 0; }
  .hub-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 10px;
    background: var(--color-primary);
    color: #fff;
  }
  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 14px;
  }
  .guide-card {
    display: block;
    padding: 16px 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s;
  }
  .guide-card:hover {
    border-color: var(--color-primary);
    text-decoration: none;
  }
  .guide-card h3 { font-size: 0.98rem; margin-bottom: 4px; }
  .guide-card p { font-size: 0.82rem; color: var(--color-text-muted); margin: 0; line-height: 1.4; }
  @media (max-width: 640px) {
    .hub-grid { grid-template-columns: 1fr; }
    .guide-grid { grid-template-columns: 1fr; }
  }
</style>
