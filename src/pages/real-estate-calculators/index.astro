---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('real-estate-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Real Estate Calculators" }
  ]
};
---

<BaseLayout
  title="Real Estate Calculators - Rental Property, Cap Rate, Refinance & More"
  description="Free real estate calculators: analyze rental property cash flow, cap rate, mortgage refinance break-even, home affordability, closing costs, and investment ROI."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Real Estate Calculators</span>
  </nav>

  <h1>Real Estate Calculators</h1>
  <p class="page-desc">Free tools to analyze rental properties, refinancing decisions, home affordability, and investment returns. Make smarter real estate decisions with data.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/real-estate-calculators/rental-property-calculator/" class="popular-chip">Rental Property</a>
      <a href="/real-estate-calculators/cap-rate-calculator/" class="popular-chip">Cap Rate</a>
      <a href="/real-estate-calculators/mortgage-refinance-calculator/" class="popular-chip">Mortgage Refinance</a>
      <a href="/real-estate-calculators/home-affordability-calculator/" class="popular-chip">Home Affordability</a>
      <a href="/real-estate-calculators/closing-cost-calculator/" class="popular-chip">Closing Costs</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/real-estate-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Real Estate Guides & Articles</h2>
    <p class="quick-ref-desc">Learn how to evaluate deals, analyze cash flow, and invest smarter:</p>
    <div class="quick-ref-grid">
      <a href="/blog/how-to-analyze-rental-property/" class="quick-ref-card"><span>🏘️</span> How to Analyze a Rental Property</a>
      <a href="/blog/what-is-a-good-cap-rate/" class="quick-ref-card"><span>📊</span> What Is a Good Cap Rate?</a>
      <a href="/blog/real-estate-investing-beginners-guide/" class="quick-ref-card"><span>📖</span> Real Estate Investing for Beginners</a>
      <a href="/blog/1031-exchange-explained/" class="quick-ref-card"><span>💼</span> 1031 Exchange Explained</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="real-estate-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
