---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import '../../styles/calculator.css';
import { getAllSavingsPages, DEPOSITS, formatMoney } from '../../data/savings';
import type { SavingsPage } from '../../data/savings';

const fmt = (n: number): string => '$' + formatMoney(n);
const allPages = getAllSavingsPages();
const count = allPages.length;

const depositLabels: { value: number; display: string }[] = [
  { value: 1000, display: '$1,000' },
  { value: 5000, display: '$5,000' },
  { value: 10000, display: '$10,000' },
  { value: 25000, display: '$25,000' },
  { value: 50000, display: '$50,000' },
  { value: 100000, display: '$100,000' },
];

function getPagesForDeposit(depositVal: number): SavingsPage[] {
  var results: SavingsPage[] = [];
  for (var i = 0; i < allPages.length; i++) {
    if (allPages[i].initialDeposit === depositVal) {
      results.push(allPages[i]);
    }
  }
  // Sort by term then rate
  results.sort(function (a, b) {
    if (a.termYears !== b.termYears) return a.termYears - b.termYears;
    return a.rate - b.rate;
  });
  return results;
}

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Financial Calculators",
      "item": "https://toolcalcs.com/financial-calculators/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Savings Calculator"
    }
  ]
};
---

<BaseLayout
  title="Savings Growth Calculator - See How Your Money Grows | ToolCalcs"
  description={`Browse ${count} pre-calculated savings growth scenarios. See how deposits from $1,000 to $100,000 grow at 3% to 7% APY over 1 to 30 years with compound interest.`}
  structuredData={structuredData}
  canonical="https://toolcalcs.com/financial-calculators/savings-goal-calculator/"
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/financial-calculators/">Financial Calculators</a> &rsaquo;
    <span>Savings Calculator</span>
  </nav>

  <h1>Savings Growth Calculator</h1>
  <p class="page-desc">Explore {count} pre-calculated savings growth scenarios below. See exactly how much your money will grow at different APY rates and time periods using the power of compound interest.</p>

  <AdUnit slot="sav-idx-top" format="horizontal" />

  {depositLabels.map(function (dl) {
    var pages = getPagesForDeposit(dl.value);
    if (pages.length === 0) return null;
    return (
      <section class="sav-deposit-section">
        <h2 class="sav-deposit-heading">{dl.display} Savings Growth</h2>
        <div class="table-container">
          <table class="data-table sav-idx-table">
            <thead>
              <tr>
                <th>Term</th>
                <th>APY</th>
                <th>Future Value</th>
                <th>Interest Earned</th>
              </tr>
            </thead>
            <tbody>
              {pages.map(function (p) {
                return (
                  <tr>
                    <td>{p.termYears} {p.termYears === 1 ? 'year' : 'years'}</td>
                    <td>{p.rate}%</td>
                    <td>
                      <a href={`/savings/${p.slug}/`}>{fmt(p.futureValue)}</a>
                    </td>
                    <td class="sav-idx-interest">{fmt(p.totalInterest)}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    );
  })}

  <p class="sav-interactive-link">
    Want to try custom values? Use our <a href="/financial-calculators/compound-interest-calculator/">interactive compound interest calculator</a> to model any savings scenario with your own deposit amount, rate, and time period.
  </p>

  <!-- SEO Content -->
  <article class="content-section">
    <h2>How to Use This Guide</h2>
    <p>
      This page contains {count} pre-calculated savings growth scenarios organized by initial deposit amount. Each table shows how a specific deposit grows over different time periods and APY rates. Click any future value to see the full year-by-year breakdown, rate comparisons, and detailed explanation for that scenario.
    </p>
    <p>
      The scenarios cover deposits from $1,000 to $100,000 at APY rates ranging from 3% to 7%, with terms from 1 to 30 years. These represent the most commonly searched savings scenarios and the rates typically available from high-yield savings accounts and certificates of deposit (CDs).
    </p>
    <p>
      Each individual page includes a year-by-year growth table showing exactly how your balance increases each year, comparison tables showing the same deposit at different rates and terms, and detailed explanations of how compound interest works for that specific scenario. Use these pages to plan your savings strategy, compare different account options, or understand how time and interest rates affect your money.
    </p>

    <h2>Understanding Compound Interest</h2>
    <p>
      All calculations on these pages use the compound interest formula: FV = P(1 + r)<sup>t</sup>, where P is your initial deposit, r is the annual interest rate as a decimal, and t is the number of years. This formula assumes annual compounding, which means interest is calculated and added to your balance once per year.
    </p>
    <p>
      Compound interest differs from simple interest in one crucial way: with simple interest, you earn returns only on your original deposit. With compound interest, you earn returns on your deposit plus all previously earned interest. Over short periods, the difference is modest. Over long periods, it becomes dramatic. For example, $10,000 at 5% simple interest earns $500 per year, totaling $5,000 after 10 years. With compound interest, the same deposit earns $6,288.95 after 10 years, which is $1,288.95 more, because each year's interest earns its own interest in subsequent years.
    </p>
    <p>
      The three factors that determine your savings growth are the amount you deposit, the interest rate (APY), and time. Of these three, time is the most powerful. Doubling your deposit doubles your interest. Doubling your rate roughly doubles your interest. But doubling the time more than doubles your interest, because the compounding effect accelerates with each passing year. This is why financial advisors consistently emphasize starting to save as early as possible.
    </p>
    <p>
      When comparing savings accounts, always look at the APY (Annual Percentage Yield) rather than the nominal interest rate. APY accounts for the effect of compounding and gives you the true annual return. An account advertising 4.95% interest compounded daily has a different APY than one offering 5.00% compounded annually. The APY provides an apples-to-apples comparison between accounts with different compounding frequencies.
    </p>

    <p><a href="/">Back to ToolCalcs Home &rarr;</a></p>
  </article>

  <AdUnit slot="sav-idx-bottom" format="horizontal" />
</BaseLayout>

<style>
  .sav-deposit-section {
    margin-bottom: 36px;
  }
  .sav-deposit-heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
  }
  .sav-idx-table {
    margin-bottom: 8px;
  }
  .sav-idx-table a {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
  }
  .sav-idx-table a:hover {
    text-decoration: underline;
  }
  .sav-idx-interest {
    color: var(--color-success, #16a34a);
    font-weight: 500;
  }
  .sav-interactive-link {
    margin: 24px 0;
    padding: 16px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.95rem;
    text-align: center;
  }
  .sav-interactive-link a {
    color: var(--color-primary);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .sav-idx-table th,
    .sav-idx-table td {
      font-size: 0.85rem;
      padding: 8px 6px;
    }
  }
</style>
