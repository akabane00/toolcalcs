---
import BaseLayout from '../layouts/BaseLayout.astro';
import { categories, calculators } from '../data/calculators';
import { games } from '../data/games';
import { tools } from '../data/tools';
import { worksheets } from '../data/worksheets';
---

<BaseLayout
  title="Sitemap - All Tools & Calculators"
  description="Browse all free online calculators, tests, web tools, and worksheets on ToolCalcs. Find the tool you need by category."
  noindex={true}
>
  <h1>Sitemap</h1>
  <p class="page-desc">All tools and pages on ToolCalcs, organized by category.</p>

  <div class="sitemap">
    {categories.map(cat => {
      const catCalcs = calculators.filter(c => c.categorySlug === cat.slug);
      return (
        <section class="sitemap-section">
          <h2><a href={`/${cat.slug}/`}>{cat.name}</a></h2>
          <ul>
            {catCalcs.map(calc => (
              <li><a href={`/${calc.categorySlug}/${calc.slug}/`}>{calc.title}</a></li>
            ))}
          </ul>
        </section>
      );
    })}

    <section class="sitemap-section">
      <h2><a href="/test/">Tests & Games</a></h2>
      <ul>
        {games.map(g => (
          <li><a href={`/test/${g.slug}/`}>{g.title}</a></li>
        ))}
      </ul>
    </section>

    <section class="sitemap-section">
      <h2><a href="/tools/">Web Tools</a></h2>
      <ul>
        {tools.map(t => (
          <li><a href={`/tools/${t.slug}/`}>{t.title}</a></li>
        ))}
      </ul>
    </section>

    <section class="sitemap-section">
      <h2><a href="/worksheets/">Printable Worksheets</a></h2>
      <ul>
        {worksheets.map(w => (
          <li><a href={`/worksheets/${w.slug}/`}>{w.title}</a></li>
        ))}
      </ul>
    </section>

    <section class="sitemap-section">
      <h2>Quick Reference Pages</h2>
      <ul class="sitemap-links">
        <li><a href="/convert/">Unit Conversions</a> (90+ pairs)</li>
        <li><a href="/currency/">Currency Exchange</a> (54 pairs)</li>
        <li><a href="/percentage/">Percentage Calculator</a></li>
        <li><a href="/salary/">Salary Conversions</a></li>
        <li><a href="/tip/">Tip Calculator</a></li>
        <li><a href="/fraction/">Fractions to Decimals</a></li>
        <li><a href="/decimal-to-fraction/">Decimal to Fraction</a></li>
        <li><a href="/percent-off/">Percent Off Calculator</a></li>
        <li><a href="/grade/">Grade Calculator</a></li>
        <li><a href="/roman-numerals/">Roman Numerals</a></li>
        <li><a href="/number-to-words/">Numbers in Words</a></li>
        <li><a href="/factors-of/">Factors Of</a></li>
        <li><a href="/temperature/">Temperature Converter</a></li>
        <li><a href="/cooking/">Cooking Conversions</a></li>
        <li><a href="/compound-interest/">Compound Interest Tables</a></li>
        <li><a href="/auto-loan/">Auto Loan Tables</a></li>
        <li><a href="/time-convert/">Time Conversions</a></li>
        <li><a href="/days-until/">Countdown Timers</a></li>
        <li><a href="/days-from-now/">Days From Today</a></li>
        <li><a href="/born-in/">Born In Year</a></li>
        <li><a href="/random/">Random Generators</a></li>
        <li><a href="/how-many/">How Many?</a></li>
        <li><a href="/math/">Math Reference</a></li>
        <li><a href="/times-tables/">Times Tables</a></li>
        <li><a href="/time-zone/">Time Zone Converter</a></li>
        <li><a href="/what-percent/">What Percent Calculator</a></li>
      </ul>
    </section>

    <section class="sitemap-section">
      <h2>About</h2>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about/">About ToolCalcs</a></li>
        <li><a href="/contact/">Contact</a></li>
        <li><a href="/privacy-policy/">Privacy Policy</a></li>
        <li><a href="/terms-of-service/">Terms of Service</a></li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  h1 { margin-bottom: 4px; }
  .page-desc {
    color: var(--color-text-muted);
    margin-bottom: 32px;
  }
  .sitemap {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 32px;
  }
  .sitemap-section h2 {
    font-size: 1.15rem;
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--color-border);
  }
  .sitemap-section h2 a {
    color: var(--color-text);
    text-decoration: none;
  }
  .sitemap-section h2 a:hover {
    color: var(--color-primary);
  }
  .sitemap-section ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .sitemap-section li {
    font-size: 0.9rem;
  }
  .sitemap-section li a {
    color: var(--color-text-muted);
  }
  .sitemap-section li a:hover {
    color: var(--color-primary);
  }
  @media (max-width: 640px) {
    .sitemap { grid-template-columns: 1fr; }
  }
</style>
