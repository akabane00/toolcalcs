---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { getCalculatorsByCategory } from '../../data/calculators';
import '../../styles/category.css';

const calcs = getCalculatorsByCategory('tax-calculators');

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Tax Calculators"
    }
  ]
};
---

<BaseLayout
  title="Tax Calculators - Income Tax, Capital Gains, Sales Tax & More"
  description="Free tax calculators: estimate federal income tax, self-employment tax, capital gains tax, withholding, sales tax, and property tax. Plan smarter for tax season."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Tax Calculators</span>
  </nav>

  <h1>Tax Calculators</h1>
  <p class="page-desc">Free tools to estimate federal income tax, self-employment tax, capital gains, withholding, and more. Plan ahead for tax season.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <div class="popular-calcs">
    <h2>Most Popular</h2>
    <div class="popular-chips">
      <a href="/tax-calculators/federal-income-tax-calculator/" class="popular-chip">Federal Income Tax</a>
      <a href="/tax-calculators/self-employment-tax-calculator/" class="popular-chip">Self-Employment Tax</a>
      <a href="/tax-calculators/capital-gains-tax-calculator/" class="popular-chip">Capital Gains Tax</a>
      <a href="/tax-calculators/tax-withholding-calculator/" class="popular-chip">Tax Withholding</a>
      <a href="/tax-calculators/sales-tax-calculator/" class="popular-chip">Sales Tax</a>
    </div>
  </div>

  <div class="calc-grid">
    {calcs.map(calc => (
      <a href={`/tax-calculators/${calc.slug}/`} class="calc-card">
        <span class="calc-icon">{calc.icon}</span>
        <h2>{calc.title}</h2>
        <p>{calc.description}</p>
      </a>
    ))}
  </div>

  <section class="quick-ref">
    <h2>Tax Guides & Articles</h2>
    <p class="quick-ref-desc">Learn how to reduce your tax bill and file with confidence:</p>
    <div class="quick-ref-grid">
      <a href="/blog/tax-filing-guide-beginners/" class="quick-ref-card"><span>📖</span> Tax Filing Guide for Beginners</a>
      <a href="/blog/how-to-file-taxes-first-time/" class="quick-ref-card"><span>🧾</span> Filing Taxes for the First Time</a>
      <a href="/blog/capital-gains-tax-guide/" class="quick-ref-card"><span>📈</span> Capital Gains Tax Guide</a>
      <a href="/blog/self-employment-tax-guide/" class="quick-ref-card"><span>💼</span> Self-Employment Tax Guide</a>
    </div>
  </section>

  <ExploreMore currentCategorySlug="tax-calculators" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-ref { margin-top: 40px; }
  .quick-ref h2 { font-size: 1.3rem; margin-bottom: 6px; }
  .quick-ref-desc { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 16px; }
  .quick-ref-grid { display: flex; flex-wrap: wrap; gap: 10px; }
  .quick-ref-card {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 10px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.9rem;
    color: var(--color-text); background: var(--color-surface);
    transition: border-color 0.15s, color 0.15s;
  }
  .quick-ref-card:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
  .quick-ref-card span { font-size: 1.1rem; }
</style>
