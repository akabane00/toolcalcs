---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import CrossLinks from '../../components/CrossLinks.astro';
import '../../styles/calculator.css';
import { getAllTemperaturePages, type TemperatureConversionPage } from '../../data/temperature-conversions';

export function getStaticPaths() {
  return getAllTemperaturePages().map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: TemperatureConversionPage };
const { value, fromUnit, toUnit, result, resultRounded, fromSymbol, toSymbol, kelvinValue, formula, category, description } = page;

const unitNames: Record<string, string> = { fahrenheit: 'Fahrenheit', celsius: 'Celsius', kelvin: 'Kelvin' };
const fromName = unitNames[fromUnit];
const toName = unitNames[toUnit];

// Compute all three temperature values for the converter
function toFahrenheit(v: number, unit: string): number {
  if (unit === 'fahrenheit') return v;
  if (unit === 'celsius') return Math.round((v * 9 / 5 + 32) * 100) / 100;
  return Math.round(((v - 273.15) * 9 / 5 + 32) * 100) / 100;
}
function toCelsius(v: number, unit: string): number {
  if (unit === 'celsius') return v;
  if (unit === 'fahrenheit') return Math.round(((v - 32) * 5 / 9) * 100) / 100;
  return Math.round((v - 273.15) * 100) / 100;
}
function toKelvin(v: number, unit: string): number {
  if (unit === 'kelvin') return v;
  if (unit === 'celsius') return Math.round((v + 273.15) * 100) / 100;
  return Math.round(((v - 32) * 5 / 9 + 273.15) * 100) / 100;
}

const fahrenheitValue = toFahrenheit(value, fromUnit);
const celsiusValue = toCelsius(value, fromUnit);
const kelvinValueCalc = toKelvin(value, fromUnit);

// Format value for display
function fmtVal(n: number): string {
  if (Number.isInteger(n)) return n.toLocaleString('en-US');
  return n.toLocaleString('en-US', { maximumFractionDigits: 2 });
}

// Step-by-step calculation data
interface Step { label: string; expression: string; }
const steps: Step[] = [];

if (fromUnit === 'fahrenheit' && toUnit === 'celsius') {
  steps.push({ label: 'Start with the formula', expression: '\u00B0C = (\u00B0F \u2212 32) \u00D7 5/9' });
  steps.push({ label: 'Substitute the value', expression: `\u00B0C = (${fmtVal(value)} \u2212 32) \u00D7 5/9` });
  const sub = Math.round((value - 32) * 100) / 100;
  steps.push({ label: 'Subtract 32', expression: `\u00B0C = ${fmtVal(sub)} \u00D7 5/9` });
  steps.push({ label: 'Multiply by 5/9', expression: `\u00B0C = ${resultRounded}` });
} else if (fromUnit === 'celsius' && toUnit === 'fahrenheit') {
  steps.push({ label: 'Start with the formula', expression: '\u00B0F = (\u00B0C \u00D7 9/5) + 32' });
  steps.push({ label: 'Substitute the value', expression: `\u00B0F = (${fmtVal(value)} \u00D7 9/5) + 32` });
  const mult = Math.round((value * 9 / 5) * 100) / 100;
  steps.push({ label: 'Multiply by 9/5', expression: `\u00B0F = ${fmtVal(mult)} + 32` });
  steps.push({ label: 'Add 32', expression: `\u00B0F = ${resultRounded}` });
} else if (fromUnit === 'kelvin' && toUnit === 'celsius') {
  steps.push({ label: 'Start with the formula', expression: '\u00B0C = K \u2212 273.15' });
  steps.push({ label: 'Substitute the value', expression: `\u00B0C = ${fmtVal(value)} \u2212 273.15` });
  steps.push({ label: 'Subtract 273.15', expression: `\u00B0C = ${resultRounded}` });
} else if (fromUnit === 'kelvin' && toUnit === 'fahrenheit') {
  steps.push({ label: 'Start with the formula', expression: '\u00B0F = (K \u2212 273.15) \u00D7 9/5 + 32' });
  steps.push({ label: 'Substitute the value', expression: `\u00B0F = (${fmtVal(value)} \u2212 273.15) \u00D7 9/5 + 32` });
  const sub = Math.round((value - 273.15) * 100) / 100;
  steps.push({ label: 'Subtract 273.15', expression: `\u00B0F = ${fmtVal(sub)} \u00D7 9/5 + 32` });
  const mult = Math.round((sub * 9 / 5) * 100) / 100;
  steps.push({ label: 'Multiply by 9/5', expression: `\u00B0F = ${fmtVal(mult)} + 32` });
  steps.push({ label: 'Add 32', expression: `\u00B0F = ${resultRounded}` });
} else if (fromUnit === 'celsius' && toUnit === 'kelvin') {
  steps.push({ label: 'Start with the formula', expression: 'K = \u00B0C + 273.15' });
  steps.push({ label: 'Substitute the value', expression: `K = ${fmtVal(value)} + 273.15` });
  steps.push({ label: 'Add 273.15', expression: `K = ${resultRounded}` });
} else if (fromUnit === 'fahrenheit' && toUnit === 'kelvin') {
  steps.push({ label: 'Start with the formula', expression: 'K = (\u00B0F \u2212 32) \u00D7 5/9 + 273.15' });
  steps.push({ label: 'Substitute the value', expression: `K = (${fmtVal(value)} \u2212 32) \u00D7 5/9 + 273.15` });
  const sub = Math.round((value - 32) * 100) / 100;
  steps.push({ label: 'Subtract 32', expression: `K = ${fmtVal(sub)} \u00D7 5/9 + 273.15` });
  const mult = Math.round((sub * 5 / 9) * 100) / 100;
  steps.push({ label: 'Multiply by 5/9', expression: `K = ${fmtVal(mult)} + 273.15` });
  steps.push({ label: 'Add 273.15', expression: `K = ${resultRounded}` });
}

// Nearby temperatures table
const isBodyTemp = category === 'body';
const interval = isBodyTemp ? 1 : 5;
const nearbyRows: { fromVal: number; toVal: number; kVal: number }[] = [];
for (let i = -20; i <= 20; i += interval) {
  const v = fromUnit === 'kelvin' ? Math.round((value + i) * 100) / 100 : value + i;
  let toVal: number;
  let kVal: number;
  if (fromUnit === 'fahrenheit' && toUnit === 'celsius') {
    toVal = Math.round(((v - 32) * 5 / 9) * 100) / 100;
    kVal = Math.round(((v - 32) * 5 / 9 + 273.15) * 100) / 100;
  } else if (fromUnit === 'celsius' && toUnit === 'fahrenheit') {
    toVal = Math.round((v * 9 / 5 + 32) * 100) / 100;
    kVal = Math.round((v + 273.15) * 100) / 100;
  } else if (fromUnit === 'kelvin' && toUnit === 'celsius') {
    toVal = Math.round((v - 273.15) * 100) / 100;
    kVal = Math.round(v * 100) / 100;
  } else if (fromUnit === 'kelvin' && toUnit === 'fahrenheit') {
    toVal = Math.round(((v - 273.15) * 9 / 5 + 32) * 100) / 100;
    kVal = Math.round(v * 100) / 100;
  } else if (fromUnit === 'celsius' && toUnit === 'kelvin') {
    toVal = Math.round((v + 273.15) * 100) / 100;
    kVal = Math.round((v + 273.15) * 100) / 100;
  } else {
    toVal = Math.round(((v - 32) * 5 / 9 + 273.15) * 100) / 100;
    kVal = Math.round(((v - 32) * 5 / 9 + 273.15) * 100) / 100;
  }
  nearbyRows.push({ fromVal: v, toVal, kVal });
}

// Determine temperature feel for FAQ
function getTempFeel(fVal: number): string {
  if (fVal <= -20) return 'extremely cold and dangerous without proper protection';
  if (fVal <= 0) return 'very cold, well below the freezing point of water';
  if (fVal <= 32) return 'cold, at or below the freezing point of water';
  if (fVal <= 50) return 'cold';
  if (fVal <= 60) return 'cool';
  if (fVal <= 70) return 'mild and comfortable';
  if (fVal <= 80) return 'warm and pleasant';
  if (fVal <= 90) return 'warm to hot';
  if (fVal <= 100) return 'hot';
  if (fVal <= 120) return 'very hot';
  if (fVal <= 212) return 'extremely hot, dangerous for human exposure';
  return 'extremely hot, well above the boiling point of water';
}
const tempFeel = getTempFeel(fahrenheitValue);

// Category-specific educational content
const educationalContent: Record<string, { heading: string; text: string }> = {
  body: {
    heading: 'Understanding Body Temperature',
    text: `Normal human body temperature is widely cited as 98.6\u00B0F (37\u00B0C), though recent research suggests the average has decreased slightly to around 97.9\u00B0F (36.6\u00B0C). Body temperature varies naturally throughout the day, typically lowest in the early morning and highest in the late afternoon. Factors such as age, activity level, hormonal cycles, and the method of measurement (oral, axillary, rectal, tympanic) all influence the reading. A fever is generally defined as a body temperature of 100.4\u00B0F (38\u00B0C) or higher. Low-grade fevers between 99\u00B0F and 100.4\u00B0F are common with minor infections and usually resolve on their own. Temperatures above 103\u00B0F (39.4\u00B0C) are considered high fevers and warrant medical attention, especially in children and the elderly. Hypothermia, defined as a body temperature below 95\u00B0F (35\u00B0C), is a medical emergency that requires immediate treatment. Understanding these thresholds in both Fahrenheit and Celsius is essential for travelers, healthcare workers, and parents monitoring illness across different countries that use different temperature scales.`,
  },
  weather: {
    heading: 'Temperature and Weather',
    text: `Weather temperatures are reported in Fahrenheit in the United States and a few other countries, while most of the world uses Celsius. Understanding both scales is crucial for travelers, pilots, meteorologists, and anyone following international weather reports. Water freezes at 32\u00B0F (0\u00B0C) and boils at 212\u00B0F (100\u00B0C) at standard atmospheric pressure. Comfortable indoor room temperature is typically 68\u00B0F to 72\u00B0F (20\u00B0C to 22\u00B0C). A temperature of 50\u00B0F (10\u00B0C) feels cool, while 90\u00B0F (32\u00B0C) is considered hot. At -40\u00B0, both scales meet: -40\u00B0F equals exactly -40\u00B0C, which is the only temperature where the two scales intersect. Extreme weather temperatures on Earth have ranged from -128.6\u00B0F (-89.2\u00B0C) recorded at Vostok Station in Antarctica to 134\u00B0F (56.7\u00B0C) in Death Valley, California. Wind chill and heat index further affect how temperatures feel to the human body, making it important to consider these factors alongside the actual air temperature when planning outdoor activities.`,
  },
  cooking: {
    heading: 'Cooking Temperatures',
    text: `Accurate temperature conversion is essential in cooking, where oven temperatures, internal meat temperatures, and candy-making stages all depend on precise readings. Most American recipes use Fahrenheit, while European and international recipes use Celsius. A standard baking temperature of 350\u00B0F equals approximately 177\u00B0C, often rounded to 180\u00B0C in metric recipes. Water boils at 212\u00B0F (100\u00B0C) at sea level, a key reference point for cooking. Safe internal cooking temperatures are critical for food safety: poultry should reach 165\u00B0F (74\u00B0C), ground meats 160\u00B0F (71\u00B0C), and whole cuts of beef or pork a minimum of 145\u00B0F (63\u00B0C). In candy making, temperatures determine the stage of sugar syrup: soft ball at 235\u00B0F (113\u00B0C), hard ball at 250\u00B0F (121\u00B0C), and hard crack at 300\u00B0F (149\u00B0C). Deep frying typically occurs between 350\u00B0F and 375\u00B0F (177\u00B0C to 191\u00B0C). Pizza ovens can reach 800\u00B0F to 900\u00B0F (425\u00B0C to 480\u00B0C) for authentic Neapolitan-style pizza. Converting accurately between these scales ensures your food is cooked safely and to the desired doneness.`,
  },
  science: {
    heading: 'Temperature Scales in Science',
    text: `Three primary temperature scales are used in science and daily life: Fahrenheit, Celsius, and Kelvin. The Fahrenheit scale, developed by Daniel Gabriel Fahrenheit in 1724, sets the freezing point of water at 32\u00B0F and the boiling point at 212\u00B0F. The Celsius scale, created by Anders Celsius in 1742 (originally inverted), places these reference points at 0\u00B0C and 100\u00B0C respectively, making it a more intuitive decimal system. The Kelvin scale, proposed by Lord Kelvin in 1848, is the SI base unit for thermodynamic temperature. It uses the same degree size as Celsius but starts at absolute zero (0 K = -273.15\u00B0C = -459.67\u00B0F), the theoretical lowest possible temperature where all molecular motion ceases. Kelvin is essential in physics, chemistry, and engineering because it provides an absolute reference point. Scientists use Kelvin for calculations involving gas laws, thermodynamics, and blackbody radiation. The relationship between these scales is linear: Celsius and Kelvin differ by a fixed offset (273.15), while Fahrenheit requires both a scale factor (9/5) and an offset (32) for conversion from Celsius.`,
  },
};
const eduContent = educationalContent[category] || educationalContent.science;

// Cross-links
const crossLinks = [
  { href: '/convert/', label: 'Unit Converter', icon: '🔄' },
  { href: '/math/', label: 'Math Calculators', icon: '🔢' },
];

// SEO
const valueDisplay = value < 0 ? `\u2212${Math.abs(value)}` : String(value);
const title = `${valueDisplay}${fromSymbol} to ${toName} - ${value}${fromSymbol} = ${resultRounded}${toSymbol} | ToolCalcs`;
const metaDescription = `Convert ${valueDisplay}${fromSymbol} to ${toName}. ${value}${fromSymbol} equals ${resultRounded}${toSymbol}.${description ? ' ' + description + '.' : ''} Step-by-step formula, converter, and temperature table.`;

const canonicalUrl = `https://toolcalcs.com/temperature/${page.slug}/`;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Temperature Conversions", "item": "https://toolcalcs.com/temperature/" },
      { "@type": "ListItem", "position": 3, "name": `${valueDisplay}${fromSymbol} to ${toName}` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": `What is ${valueDisplay}${fromSymbol} in ${toName}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `${valueDisplay}${fromSymbol} is equal to ${resultRounded}${toSymbol}. ${description ? description + '.' : `This conversion uses the standard ${fromName} to ${toName} formula.`}`,
        },
      },
      {
        "@type": "Question",
        "name": `How do you convert ${fromName} to ${toName}?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `To convert ${fromName} to ${toName}, use the formula: ${formula}. ${fromUnit === 'fahrenheit' && toUnit === 'celsius' ? 'Subtract 32, then multiply by 5/9.' : fromUnit === 'celsius' && toUnit === 'fahrenheit' ? 'Multiply by 9/5, then add 32.' : fromUnit === 'kelvin' && toUnit === 'celsius' ? 'Subtract 273.15 from the Kelvin value.' : fromUnit === 'kelvin' && toUnit === 'fahrenheit' ? 'Subtract 273.15, multiply by 9/5, then add 32.' : fromUnit === 'celsius' && toUnit === 'kelvin' ? 'Add 273.15 to the Celsius value.' : 'Subtract 32, multiply by 5/9, then add 273.15.'}`,
        },
      },
      {
        "@type": "Question",
        "name": `Is ${valueDisplay}${fromSymbol} hot or cold?`,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": `${valueDisplay}${fromSymbol} (${resultRounded}${toSymbol}) is ${tempFeel}. ${description ? description + '.' : ''}`,
        },
      },
    ],
  },
];
---

<BaseLayout
  title={title} description={metaDescription} type="article" noindex={true} structuredData={structuredData}>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/temperature/">Temperature Conversions</a> &rsaquo;
    <span>{valueDisplay}{fromSymbol} to {toName}</span>
  </nav>

  <h1>{valueDisplay}{fromSymbol} to {toName}</h1>
  <p class="page-desc">Convert {valueDisplay} degrees {fromName} to {toName}. {description ? description + '.' : ''}</p>

  <!-- Quick Answer Box -->
  <div class="quick-fact">
    <span class="quick-fact-label">Quick Answer:</span>
    <strong>{valueDisplay}{fromSymbol} = {resultRounded}{toSymbol}</strong>
  </div>

  <!-- Result Cards -->
  <div class="result-cards">
    <div class="result-card primary">
      <span class="result-label">Result</span>
      <span class="result-value">{resultRounded}{toSymbol}</span>
    </div>
    <div class="result-card">
      <span class="result-label">Formula</span>
      <span class="result-value result-formula">{formula}</span>
    </div>
    <div class="result-card">
      <span class="result-label">Category</span>
      <span class="result-value">{category.charAt(0).toUpperCase() + category.slice(1)}</span>
    </div>
    <div class="result-card">
      <span class="result-label">Kelvin</span>
      <span class="result-value">{fmtVal(kelvinValue)} K</span>
    </div>
  </div>

  <!-- Step-by-Step -->
  <h2 class="section-heading">How to Convert {valueDisplay}{fromSymbol} to {toName}</h2>
  <div class="calculator-box">
    <p class="calc-desc">Follow these steps to convert {valueDisplay}{fromSymbol} to {toName}:</p>
    {steps.map((step, i) => (
      <div class="step">
        <span class="step-number">Step {i + 1}</span>
        <span class="step-label">{step.label}</span>
        <code class="step-expression">{step.expression}</code>
      </div>
    ))}
    <div class="step step-final">
      <span class="step-label">Final Answer:</span>
      <strong>{valueDisplay}{fromSymbol} = {resultRounded}{toSymbol}</strong>
    </div>
  </div>

  <AdUnit slot="temp-mid" format="rectangle" />

  <!-- Interactive Converter Widget -->
  <h2 class="section-heading">Temperature Converter</h2>
  <div class="calculator-box">
    <p class="calc-desc">Change any value to instantly convert between Fahrenheit, Celsius, and Kelvin.</p>
    <div class="converter-grid">
      <div class="input-group">
        <label for="fInput">Fahrenheit (&deg;F)</label>
        <input type="number" id="fInput" step="any" />
      </div>
      <div class="input-group">
        <label for="cInput">Celsius (&deg;C)</label>
        <input type="number" id="cInput" step="any" />
      </div>
      <div class="input-group">
        <label for="kInput">Kelvin (K)</label>
        <input type="number" id="kInput" step="any" />
      </div>
    </div>
  </div>

  <!-- Nearby Temperatures Table -->
  <h2 class="section-heading">Temperature Conversion Table</h2>
  <div class="table-container">
    <table class="data-table">
      <thead>
        <tr>
          <th>{fromName} ({fromSymbol})</th>
          <th>{toName} ({toSymbol})</th>
          <th>Kelvin (K)</th>
        </tr>
      </thead>
      <tbody>
        {nearbyRows.map((row) => (
          <tr class={row.fromVal === value ? 'highlight-row' : ''}>
            <td>{fmtVal(row.fromVal)}{fromSymbol}</td>
            <td>{fmtVal(row.toVal)}{toSymbol}</td>
            <td>{fmtVal(row.kVal)} K</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Educational Content -->
  <article class="content-section">
    <h2>{eduContent.heading}</h2>
    <p>{eduContent.text}</p>

    <h2>Frequently Asked Questions</h2>

    <h3>What is {valueDisplay}{fromSymbol} in {toName}?</h3>
    <p>
      {valueDisplay}{fromSymbol} is equal to {resultRounded}{toSymbol}. {description ? description + '. ' : ''}This conversion is calculated using the standard {fromName} to {toName} formula: {formula}. The equivalent Kelvin value is {fmtVal(kelvinValue)} K.
    </p>

    <h3>How do you convert {fromName} to {toName}?</h3>
    <p>
      {fromUnit === 'fahrenheit' && toUnit === 'celsius'
        ? `To convert Fahrenheit to Celsius, subtract 32 from the Fahrenheit value, then multiply by 5/9. The formula is: \u00B0C = (\u00B0F \u2212 32) \u00D7 5/9. For example, ${valueDisplay}\u00B0F becomes (${valueDisplay} \u2212 32) \u00D7 5/9 = ${resultRounded}\u00B0C.`
        : fromUnit === 'celsius' && toUnit === 'fahrenheit'
          ? `To convert Celsius to Fahrenheit, multiply the Celsius value by 9/5, then add 32. The formula is: \u00B0F = (\u00B0C \u00D7 9/5) + 32. For example, ${valueDisplay}\u00B0C becomes (${valueDisplay} \u00D7 9/5) + 32 = ${resultRounded}\u00B0F.`
          : fromUnit === 'kelvin' && toUnit === 'celsius'
            ? `To convert Kelvin to Celsius, simply subtract 273.15 from the Kelvin value. The formula is: \u00B0C = K \u2212 273.15. For example, ${valueDisplay} K becomes ${valueDisplay} \u2212 273.15 = ${resultRounded}\u00B0C.`
            : fromUnit === 'kelvin' && toUnit === 'fahrenheit'
              ? `To convert Kelvin to Fahrenheit, subtract 273.15, multiply by 9/5, then add 32. The formula is: \u00B0F = (K \u2212 273.15) \u00D7 9/5 + 32. For example, ${valueDisplay} K becomes ${resultRounded}\u00B0F.`
              : fromUnit === 'celsius' && toUnit === 'kelvin'
                ? `To convert Celsius to Kelvin, add 273.15 to the Celsius value. The formula is: K = \u00B0C + 273.15. For example, ${valueDisplay}\u00B0C becomes ${valueDisplay} + 273.15 = ${resultRounded} K.`
                : `To convert Fahrenheit to Kelvin, subtract 32, multiply by 5/9, then add 273.15. The formula is: K = (\u00B0F \u2212 32) \u00D7 5/9 + 273.15. For example, ${valueDisplay}\u00B0F becomes ${resultRounded} K.`
      }
    </p>

    <h3>Is {valueDisplay}{fromSymbol} hot or cold?</h3>
    <p>
      A temperature of {valueDisplay}{fromSymbol} ({resultRounded}{toSymbol}) is {tempFeel}. {category === 'body' ? 'In terms of body temperature, this reading ' + (fahrenheitValue < 97 ? 'indicates hypothermia and requires medical attention.' : fahrenheitValue < 99 ? 'falls within the normal range for a healthy adult.' : fahrenheitValue < 100.4 ? 'is slightly above normal but is not considered a fever.' : fahrenheitValue < 103 ? 'indicates a fever. Monitor symptoms and consider consulting a healthcare provider.' : 'indicates a high fever. Seek medical attention promptly.') : category === 'weather' ? 'For weather, this temperature is ' + (fahrenheitValue < 32 ? 'below freezing and winter clothing is essential.' : fahrenheitValue < 60 ? 'cool and a jacket or layers are recommended.' : fahrenheitValue < 80 ? 'comfortable for most outdoor activities.' : 'warm to hot, and staying hydrated is important.') : category === 'cooking' ? 'In cooking, this temperature is ' + (fahrenheitValue < 212 ? 'below the boiling point of water.' : fahrenheitValue < 300 ? 'suitable for slow cooking or simmering.' : fahrenheitValue < 400 ? 'a standard baking temperature.' : 'a high oven temperature used for roasting or broiling.') : 'On the Kelvin scale, this corresponds to ' + fmtVal(kelvinValue) + ' K.'}
    </p>

    <p><a href="/temperature/">&larr; View All Temperature Conversions</a></p>

    <CrossLinks links={crossLinks} />
  </article>

  <AdUnit slot="temp-bottom" format="horizontal" />
</BaseLayout>

<style>
  .quick-fact {
    background: #eff6ff;
    border-radius: var(--radius);
    padding: 16px 24px;
    margin-bottom: 24px;
    font-size: 1.1rem;
  }
  .quick-fact-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 4px;
  }
  .quick-fact strong {
    color: var(--color-primary);
    font-size: 1.3rem;
  }

  .result-formula {
    font-size: 0.85rem !important;
    word-break: break-word;
  }

  .section-heading {
    font-size: 1.2rem;
    margin: 32px 0 12px;
  }

  .calc-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 16px;
  }

  .step {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    margin-bottom: 8px;
    background: var(--color-bg);
    border-radius: var(--radius);
    font-size: 0.95rem;
  }
  .step-number {
    background: var(--color-primary);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .step-label {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
  .step-expression {
    font-weight: 700;
    color: var(--color-text);
    font-size: 1rem;
    margin-left: auto;
  }
  .step-final {
    background: #eff6ff;
    border: 1px solid var(--color-primary);
    font-size: 1.05rem;
  }
  .step-final strong {
    color: var(--color-primary);
    margin-left: auto;
  }

  .converter-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }

  .highlight-row {
    background: #eff6ff;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .converter-grid {
      grid-template-columns: 1fr;
