</style>

<script define:vars={{ initF: fahrenheitValue, initC: celsiusValue, initK: kelvinValueCalc }}>
  var fInput = document.getElementById('fInput');
  var cInput = document.getElementById('cInput');
  var kInput = document.getElementById('kInput');

  function round2(n) { return Math.round(n * 100) / 100; }

  fInput.value = initF;
  cInput.value = initC;
  kInput.value = initK;

  function fromF() {
    var f = parseFloat(fInput.value);
    if (isNaN(f)) return;
    cInput.value = round2((f - 32) * 5 / 9);
    kInput.value = round2((f - 32) * 5 / 9 + 273.15);
  }
  function fromC() {
    var c = parseFloat(cInput.value);
    if (isNaN(c)) return;
    fInput.value = round2(c * 9 / 5 + 32);
    kInput.value = round2(c + 273.15);
  }
  function fromK() {
    var k = parseFloat(kInput.value);
    if (isNaN(k)) return;
    cInput.value = round2(k - 273.15);
    fInput.value = round2((k - 273.15) * 9 / 5 + 32);
  }

  fInput.addEventListener('input', fromF);
  cInput.addEventListener('input', fromC);
  kInput.addEventListener('input', fromK);
</script>
