  <AdUnit slot="game-bottom" format="horizontal" />
</BaseLayout>

<style>
  .game-area { cursor: default; user-select: auto; -webkit-user-select: auto; }
</style>

<script define:vars={{ gameName, gameSlug, gameIcon, metricLabel, metricUnit }}>
(function () {
  'use strict';

  var questions = [
    "Feeling nervous, anxious, or on edge",
    "Not being able to stop or control worrying",
    "Worrying too much about different things",
    "Trouble relaxing",
    "Being so restless that it is hard to sit still",
    "Becoming easily annoyed or irritable",
    "Feeling afraid, as if something awful might happen"
  ];

  var optionLabels = [
    { text: "Not at all", value: 0 },
    { text: "Several days", value: 1 },
    { text: "More than half the days", value: 2 },
    { text: "Nearly every day", value: 3 }
  ];

  var severityLevels = [
    { min: 0, max: 4, label: "Minimal Anxiety", color: "#22c55e", bgColor: "#dcfce7", desc: "Your score suggests minimal anxiety. Your symptoms are within the normal range. Most people experience occasional worry, and your current level does not indicate a clinical concern. Continue practicing healthy habits like regular exercise, good sleep hygiene, and stress management to maintain your well-being." },
    { min: 5, max: 9, label: "Mild Anxiety", color: "#f59e0b", bgColor: "#fef3c7", desc: "Your score suggests mild anxiety. You are experiencing some anxiety symptoms that may be noticeable but are likely manageable. Consider incorporating relaxation techniques, regular exercise, and mindfulness practices into your routine. If symptoms persist or worsen, consider speaking with a healthcare provider." },
    { min: 10, max: 14, label: "Moderate Anxiety", color: "#f97316", bgColor: "#fff7ed", desc: "Your score suggests moderate anxiety. Your symptoms are clinically significant and may be affecting your daily life, work, or relationships. We recommend speaking with a healthcare provider or mental health professional for further evaluation. Effective treatments are available and can make a meaningful difference." },
    { min: 15, max: 21, label: "Severe Anxiety", color: "#ef4444", bgColor: "#fef2f2", desc: "Your score suggests severe anxiety. You are experiencing significant anxiety symptoms that are very likely affecting your quality of life. We strongly recommend seeking professional help as soon as possible. Effective treatments including therapy and medication can provide substantial relief. You do not have to manage this alone." }
  ];

  var STORAGE_KEY = 'toolcalcs_anxiety-test_history';
  var MAX_HISTORY = 20;

  function loadHistory() {
    try { var r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch (e) {}
    return [];
  }
  function saveHistory(h) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(h.slice(0, MAX_HISTORY))); } catch (e) {}
  }

  var instructionsView = document.getElementById('instructionsView');
  var playView = document.getElementById('playView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var tryAgainBtn = document.getElementById('tryAgainBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var scoreDisplay = document.getElementById('scoreDisplay');
  var severityBadge = document.getElementById('severityBadge');
  var resultDesc = document.getElementById('resultDesc');
  var seekHelp = document.getElementById('seekHelp');
  var attemptHistorySection = document.getElementById('attemptHistory');
  var historyList = document.getElementById('historyList');

  var currentIndex = 0;
  var totalScore = 0;

  function showView(view) {
    instructionsView.style.display = 'none';
    playView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function startTest() {
    currentIndex = 0;
    totalScore = 0;
    showView(playView);
    showQuestion();
  }

  function showQuestion() {
    var num = currentIndex + 1;
    progressText.textContent = 'Question ' + num + ' of 7';
    progressFill.style.width = Math.round((num / 7) * 100) + '%';
    questionText.textContent = questions[currentIndex];

    var html = '';
    for (var i = 0; i < optionLabels.length; i++) {
      html += '<button class="quiz-option" data-value="' + optionLabels[i].value + '" type="button">' + optionLabels[i].text + '</button>';
    }
    optionsContainer.innerHTML = html;
  }

  function handleAnswer(val) {
    totalScore += val;
    currentIndex++;
    if (currentIndex < 7) {
      showQuestion();
    } else {
      showResults();
    }
  }

  function getSeverity(score) {
    for (var i = 0; i < severityLevels.length; i++) {
      if (score >= severityLevels[i].min && score <= severityLevels[i].max) return severityLevels[i];
    }
    return severityLevels[0];
  }

  function showResults() {
    var severity = getSeverity(totalScore);

    scoreDisplay.textContent = totalScore + ' / 21';
    scoreDisplay.style.color = severity.color;

    severityBadge.textContent = severity.label;
    severityBadge.style.background = severity.bgColor;
    severityBadge.style.color = severity.color;

    resultDesc.textContent = severity.desc;

    if (totalScore >= 10) {
      seekHelp.style.display = 'block';
    } else {
      seekHelp.style.display = 'none';
    }

    showView(resultView);

    var h = loadHistory();
    h.unshift({ score: totalScore, severity: severity.label, date: new Date().toISOString() });
    saveHistory(h);
    renderHistory();

    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: totalScore + '/21',
        unit: '',
        metricLabel: metricLabel,
        ratingLabel: severity.label,
        ratingColor: severity.color
      });
    }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    var html = '';
    for (var i = 0; i < history.length; i++) {
      var e = history[i];
      html += '<div class="history-item">';
      html += '<span class="history-score">' + e.score + '/21 — ' + e.severity + '</span>';
      html += '<span class="history-time">' + formatDate(e.date) + '</span>';
      html += '</div>';
    }
    historyList.innerHTML = html;
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  optionsContainer.addEventListener('click', function (e) {
    var btn = e.target;
    if (!btn.classList.contains('quiz-option')) return;
    var val = parseInt(btn.getAttribute('data-value'), 10);
    if (isNaN(val)) return;
    btn.classList.add('selected');
    setTimeout(function () { handleAnswer(val); }, 200);
  });

  startBtn.addEventListener('click', startTest);
  tryAgainBtn.addEventListener('click', startTest);
  renderHistory();
})();
</script>
