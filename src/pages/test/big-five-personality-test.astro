    questionText.textContent = q.text;

    // Reset selected state on all buttons
    var btns = likertButtons.querySelectorAll('.quiz-option');
    for (var i = 0; i < btns.length; i++) {
      btns[i].classList.remove('selected');
    }
  }

  function handleAnswer(val) {
    var q = shuffledQuestions[currentIndex];
    var score = q.rev ? (6 - val) : val;
    rawScores[q.dim] += score;

    currentIndex++;
    if (currentIndex < 50) {
      showQuestion();
    } else {
      showResults();
    }
  }

  function getLevel(pct) {
    if (pct <= 35) return 'Low';
    if (pct <= 65) return 'Average';
    return 'High';
  }

  function showResults() {
    var scores = {};
    var dimOrder = ['O', 'C', 'E', 'A', 'N'];

    for (var i = 0; i < dimOrder.length; i++) {
      var d = dimOrder[i];
      scores[d] = Math.round(((rawScores[d] - 10) / 40) * 100);
      if (scores[d] < 0) scores[d] = 0;
      if (scores[d] > 100) scores[d] = 100;
    }

    // Build bar chart
    var chartHtml = '';
    for (var j = 0; j < dimOrder.length; j++) {
      var dim = dimOrder[j];
      var pct = scores[dim];
      var level = getLevel(pct);
      var info = dimensions[dim];
      chartHtml += '<div class="quiz-bar-item">';
      chartHtml += '<div class="quiz-bar-label"><span>' + info.short + '</span><span>' + pct + '% — ' + level + '</span></div>';
      chartHtml += '<div class="quiz-bar-track"><div class="quiz-bar-fill" style="width:' + pct + '%;background:' + dimColors[dim] + '"></div></div>';
      chartHtml += '</div>';
    }
    barChart.innerHTML = chartHtml;

    // Build dimension descriptions
    var descHtml = '';
    for (var k = 0; k < dimOrder.length; k++) {
      var dd = dimOrder[k];
      var ddPct = scores[dd];
      var ddInfo = dimensions[dd];
      var ddLevel = getLevel(ddPct);
      var desc = ddPct > 50 ? ddInfo.highDesc : ddInfo.lowDesc;
      descHtml += '<div style="text-align:left;margin-bottom:16px;">';
      descHtml += '<strong style="color:' + dimColors[dd] + '">' + ddInfo.name + ' (' + ddLevel + ')</strong>';
      descHtml += '<p style="margin:4px 0 0;font-size:0.9rem;line-height:1.6;">' + desc + '</p>';
      descHtml += '</div>';
    }
    dimensionDescriptions.innerHTML = descHtml;

    showView(resultView);
    addToHistory(scores);
    renderHistory();

    // GameShare
    var summary = 'O:' + scores.O + '% C:' + scores.C + '% E:' + scores.E + '% A:' + scores.A + '% N:' + scores.N + '%';
    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: summary,
        unit: '',
        metricLabel: metricLabel,
        ratingLabel: 'OCEAN Profile',
        ratingColor: '#8b5cf6'
      });
    }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    var html = '';
    for (var i = 0; i < history.length; i++) {
      var e = history[i];
      var s = e.scores;
      var label = 'O:' + s.O + ' C:' + s.C + ' E:' + s.E + ' A:' + s.A + ' N:' + s.N;
      html += '<div class="history-item">';
      html += '<span class="history-score">' + label + '</span>';
      html += '<span class="history-time">' + formatDate(e.date) + '</span>';
      html += '</div>';
    }
    historyList.innerHTML = html;
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  // Events
  likertButtons.addEventListener('click', function (e) {
    var btn = e.target;
    if (!btn.classList.contains('quiz-option')) return;
    var val = parseInt(btn.getAttribute('data-value'), 10);
    if (!val) return;

    // Visual feedback
    btn.classList.add('selected');

    // Small delay so user sees their selection
    setTimeout(function () {
      handleAnswer(val);
    }, 200);
  });

  startBtn.addEventListener('click', startTest);
  tryAgainBtn.addEventListener('click', startTest);
  renderHistory();
})();
</script>
