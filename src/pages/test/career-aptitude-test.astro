      title: "The Organizer",
      color: "#64748b",
      desc: "You are detail-oriented, organized, and systematic. You prefer structured environments with clear rules and procedures, and you find satisfaction in creating order and maintaining accuracy.",
      careers: ["Accountant", "Auditor", "Administrative Assistant", "Bookkeeper", "Tax Preparer", "Logistics Coordinator", "Database Admin", "Compliance Officer"],
      environment: "You thrive in structured offices, financial institutions, government agencies, or any setting where reliability and precision are valued."
    }
  };

  var STORAGE_KEY = 'toolcalcs_career-aptitude-test_history';
  var MAX_HISTORY = 20;

  function loadHistory() {
    try { var r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch (e) {}
    return [];
  }
  function saveHistory(h) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(h.slice(0, MAX_HISTORY))); } catch (e) {}
  }

  var instructionsView = document.getElementById('instructionsView');
  var playView = document.getElementById('playView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var tryAgainBtn = document.getElementById('tryAgainBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var barChart = document.getElementById('barChart');
  var hollandCode = document.getElementById('hollandCode');
  var hollandName = document.getElementById('hollandName');
  var resultDescriptions = document.getElementById('resultDescriptions');
  var attemptHistorySection = document.getElementById('attemptHistory');
  var historyList = document.getElementById('historyList');

  var shuffled = [];
  var currentIndex = 0;
  var scores = {};

  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
    }
    return a;
  }

  function showView(view) {
    instructionsView.style.display = 'none';
    playView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function startTest() {
    shuffled = shuffle(questions);
    currentIndex = 0;
    scores = { R: 0, I: 0, A: 0, S: 0, E: 0, C: 0 };
    showView(playView);
    showQuestion();
  }

  function showQuestion() {
    var q = shuffled[currentIndex];
    var num = currentIndex + 1;
    progressText.textContent = 'Question ' + num + ' of 30';
    progressFill.style.width = Math.round((num / 30) * 100) + '%';
    questionText.textContent = q.text;

    var html = '';
    var opts = Math.random() < 0.5 ? [q.options[0], q.options[1]] : [q.options[1], q.options[0]];
    for (var i = 0; i < opts.length; i++) {
      html += '<button class="quiz-option" data-dim="' + opts[i].dim + '" type="button">' + opts[i].label + '</button>';
    }
    optionsContainer.innerHTML = html;
  }

  function handleAnswer(dim) {
    scores[dim]++;
    currentIndex++;
    if (currentIndex < 30) {
      showQuestion();
    } else {
      showResults();
    }
  }

  function showResults() {
    var typeOrder = ['R', 'I', 'A', 'S', 'E', 'C'];
    var sorted = typeOrder.slice().sort(function (a, b) { return scores[b] - scores[a]; });
    var code = sorted[0] + sorted[1] + sorted[2];
    var maxScore = 10;

    hollandCode.textContent = code;
    hollandName.textContent = types[sorted[0]].name + ' - ' + types[sorted[1]].name + ' - ' + types[sorted[2]].name;

    var chartHtml = '';
    for (var i = 0; i < typeOrder.length; i++) {
      var t = typeOrder[i];
      var pct = Math.round((scores[t] / maxScore) * 100);
      if (pct > 100) pct = 100;
      var info = types[t];
      chartHtml += '<div class="quiz-bar-item">';
      chartHtml += '<div class="quiz-bar-label"><span>' + info.name + ' (' + t + ')</span><span>' + scores[t] + '/' + maxScore + '</span></div>';
      chartHtml += '<div class="quiz-bar-track"><div class="quiz-bar-fill" style="width:' + pct + '%;background:' + info.color + '"></div></div>';
      chartHtml += '</div>';
    }
    barChart.innerHTML = chartHtml;

    var descHtml = '';
    for (var j = 0; j < 3; j++) {
      var key = sorted[j];
      var info2 = types[key];
      var rank = j === 0 ? 'Primary' : j === 1 ? 'Secondary' : 'Tertiary';
      descHtml += '<div style="text-align:left;margin-bottom:20px;padding:16px;border:1px solid var(--color-border);border-radius:var(--radius);">';
      descHtml += '<strong style="color:' + info2.color + '">' + rank + ': ' + info2.name + ' — ' + info2.title + '</strong>';
      descHtml += '<p style="margin:8px 0;font-size:0.9rem;line-height:1.6;">' + info2.desc + '</p>';
      descHtml += '<p style="margin:4px 0;font-size:0.85rem;line-height:1.5;"><strong>Matching Careers:</strong> ' + info2.careers.join(', ') + '</p>';
      descHtml += '<p style="margin:4px 0;font-size:0.85rem;line-height:1.5;color:var(--color-text-muted);">' + info2.environment + '</p>';
      descHtml += '</div>';
    }
    resultDescriptions.innerHTML = descHtml;

    showView(resultView);

    var h = loadHistory();
    h.unshift({ code: code, scores: scores, date: new Date().toISOString() });
    saveHistory(h);
    renderHistory();

    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: code,
        unit: '',
        metricLabel: metricLabel,
        ratingLabel: types[sorted[0]].name + ' - ' + types[sorted[0]].title,
        ratingColor: types[sorted[0]].color
      });
    }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    var html = '';
    for (var i = 0; i < history.length; i++) {
      var e = history[i];
      html += '<div class="history-item">';
      html += '<span class="history-score">' + e.code + '</span>';
      html += '<span class="history-time">' + formatDate(e.date) + '</span>';
      html += '</div>';
    }
    historyList.innerHTML = html;
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  optionsContainer.addEventListener('click', function (e) {
    var btn = e.target;
    if (!btn.classList.contains('quiz-option')) return;
    var dim = btn.getAttribute('data-dim');
    if (!dim) return;
    btn.classList.add('selected');
    setTimeout(function () { handleAnswer(dim); }, 200);
  });

  startBtn.addEventListener('click', startTest);
  tryAgainBtn.addEventListener('click', startTest);
  renderHistory();
})();
</script>
