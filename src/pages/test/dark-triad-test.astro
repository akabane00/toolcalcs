    { text: "I like to get acquainted with important people.", trait: "N", rev: false },
    { text: "I feel embarrassed if someone compliments me.", trait: "N", rev: true },
    { text: "I have been compared to famous people.", trait: "N", rev: false },
    { text: "I am an average person.", trait: "N", rev: true },
    { text: "I insist on getting the respect I deserve.", trait: "N", rev: false },
    { text: "I like to get revenge on authorities.", trait: "P", rev: false },
    { text: "I avoid dangerous situations.", trait: "P", rev: true },
    { text: "Payback needs to be quick and nasty.", trait: "P", rev: false },
    { text: "People often say I am out of control.", trait: "P", rev: false },
    { text: "It is true that I can be mean to others.", trait: "P", rev: false },
    { text: "People who mess with me always regret it.", trait: "P", rev: false },
    { text: "I have never gotten into trouble with the law.", trait: "P", rev: true },
    { text: "I enjoy having sex with people I hardly know.", trait: "P", rev: false },
    { text: "I will say anything to get what I want.", trait: "P", rev: false }
  ];

  var likertOptions = [
    { label: "Strongly Disagree", val: 1 },
    { label: "Disagree", val: 2 },
    { label: "Neutral", val: 3 },
    { label: "Agree", val: 4 },
    { label: "Strongly Agree", val: 5 }
  ];

  var traitMeta = {
    M: { name: "Machiavellianism", icon: "\u{265F}\u{FE0F}", color: "#8b5cf6" },
    N: { name: "Narcissism", icon: "\u{1FA9E}", color: "#f59e0b" },
    P: { name: "Psychopathy", icon: "\u{1F525}", color: "#ef4444" }
  };

  var levelRanges = [
    { min: 75, label: "Very High", color: "#ef4444" },
    { min: 55, label: "High", color: "#f97316" },
    { min: 35, label: "Moderate", color: "#f59e0b" },
    { min: 15, label: "Low", color: "#22c55e" },
    { min: 0, label: "Very Low", color: "#16a34a" }
  ];

  var overallRanges = [
    { min: 75, label: "Very High Dark Triad", color: "#ef4444" },
    { min: 55, label: "High Dark Triad", color: "#f97316" },
    { min: 35, label: "Moderate Dark Triad", color: "#f59e0b" },
    { min: 15, label: "Low Dark Triad", color: "#22c55e" },
    { min: 0, label: "Very Low Dark Triad", color: "#16a34a" }
  ];

  var traitInterpretations = {
    M: {
      high: "You tend to be strategic and calculating in social interactions. You are comfortable using indirect means to achieve your goals and view relationships partly in terms of their utility. You may be skilled at negotiation and navigating complex political environments.",
      moderate: "You have a balanced approach to social strategy. You can be pragmatic when needed but generally prefer straightforward dealings with others. You understand strategic thinking without being dominated by it.",
      low: "You tend to be straightforward and trusting in your interactions. You prefer honest, direct communication and are uncomfortable with manipulation or deception, even when it might serve your interests."
    },
    N: {
      high: "You have a strong sense of self-importance and enjoy being recognized for your qualities. You are confident, charismatic, and drawn to positions of influence. You may sometimes struggle with criticism or situations where you are not the focus.",
      moderate: "You have healthy self-confidence without excessive self-focus. You appreciate recognition but do not depend on it for your self-worth. You can take leadership roles comfortably while still valuing others' contributions.",
      low: "You tend to be humble and self-effacing. You are comfortable letting others take the spotlight and may undervalue your own contributions. You might benefit from developing more confidence in your unique qualities."
    },
    P: {
      high: "You tend toward boldness, risk-taking, and emotional detachment. You are less influenced by social norms and may act impulsively. You handle high-pressure situations well but may sometimes disregard others' feelings or the consequences of your actions.",
      moderate: "You have a balanced mix of boldness and social awareness. You can take calculated risks and handle stress well while generally maintaining awareness of how your actions affect others.",
      low: "You are empathetic, cautious, and socially considerate. You carefully weigh the consequences of your actions and are sensitive to others' emotions. You may sometimes be overly cautious or avoid necessary risks."
    }
  };

  var STORAGE_KEY = 'toolcalcs_dark-triad-test_history';
  var MAX_HISTORY = 20;

  function getLevel(score, ranges) {
    for (var i = 0; i < ranges.length; i++) {
      if (score >= ranges[i].min) return { label: ranges[i].label, color: ranges[i].color };
    }
    return { label: "Very Low", color: "#16a34a" };
  }

  function loadHistory() {
    try { var r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch (e) {}
    return [];
  }
  function saveHistory(h) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(h.slice(0, MAX_HISTORY))); } catch (e) {}
  }
  function addToHistory(score) {
    var h = loadHistory();
    h.unshift({ score: score, date: new Date().toISOString(), rating: getLevel(score, overallRanges).label });
    saveHistory(h);
  }

  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
    }
    return a;
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  var instructionsView = document.getElementById('instructionsView');
  var playView = document.getElementById('playView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var tryAgainBtn = document.getElementById('tryAgainBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var finalScore = document.getElementById('finalScore');
  var ratingBadge = document.getElementById('ratingBadge');
  var traitChart = document.getElementById('traitChart');
  var traitDetails = document.getElementById('traitDetails');
  var interpretationNote = document.getElementById('interpretationNote');
  var attemptHistorySection = document.getElementById('attemptHistory');
  var historyList = document.getElementById('historyList');

  var shuffledQuestions = [];
  var currentIndex = 0;
  var answers = [];
  var isProcessing = false;

  function showView(view) {
    instructionsView.style.display = 'none';
    playView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function startGame() {
    shuffledQuestions = shuffle(questions);
    currentIndex = 0;
    answers = [];
    isProcessing = false;
    showView(playView);
    renderQuestion();
  }

  function renderQuestion() {
    var q = shuffledQuestions[currentIndex];
    var total = shuffledQuestions.length;
    var pct = Math.round((currentIndex / total) * 100);

    progressText.textContent = 'Question ' + (currentIndex + 1) + ' of ' + total;
    progressFill.style.width = pct + '%';
    questionText.textContent = '"' + q.text + '"';

    var html = '';
    for (var i = 0; i < likertOptions.length; i++) {
      html += '<button class="quiz-option" type="button" data-val="' + likertOptions[i].val + '">' + likertOptions[i].label + '</button>';
    }
    optionsContainer.innerHTML = html;
  }

  function handleOptionClick(e) {
    if (isProcessing) return;
    var btn = e.target;
    if (!btn || !btn.classList || !btn.classList.contains('quiz-option')) return;

    isProcessing = true;
    var val = parseInt(btn.getAttribute('data-val'), 10);
    btn.classList.add('selected');

    var q = shuffledQuestions[currentIndex];
    var actualVal = q.rev ? (6 - val) : val;
    answers.push({ trait: q.trait, val: actualVal });

    setTimeout(function () {
      currentIndex++;
      if (currentIndex >= shuffledQuestions.length) {
        showResults();
      } else {
        renderQuestion();
      }
      isProcessing = false;
    }, 300);
  }

  function showResults() {
    var traitScores = { M: 0, N: 0, P: 0 };
    var traitCounts = { M: 0, N: 0, P: 0 };

    for (var i = 0; i < answers.length; i++) {
      traitScores[answers[i].trait] += answers[i].val;
      traitCounts[answers[i].trait]++;
    }

    var traitPcts = {};
    var traitKeys = ['M', 'N', 'P'];
    for (var j = 0; j < traitKeys.length; j++) {
      var k = traitKeys[j];
      var maxPossible = traitCounts[k] * 5;
      var minPossible = traitCounts[k] * 1;
      traitPcts[k] = Math.round(((traitScores[k] - minPossible) / (maxPossible - minPossible)) * 100);
      if (traitPcts[k] < 0) traitPcts[k] = 0;
      if (traitPcts[k] > 100) traitPcts[k] = 100;
    }

    var overallScore = Math.round((traitPcts.M + traitPcts.N + traitPcts.P) / 3);

    showView(resultView);
    finalScore.textContent = String(overallScore);

    var overall = getLevel(overallScore, overallRanges);
    ratingBadge.textContent = overall.label;
    ratingBadge.style.background = overall.color;

    var chartHTML = '';
    for (var m = 0; m < traitKeys.length; m++) {
      var tk = traitKeys[m];
      var tm = traitMeta[tk];
      var tl = getLevel(traitPcts[tk], levelRanges);
      chartHTML += '<div class="quiz-bar-item">';
      chartHTML += '<div class="quiz-bar-label"><span>' + tm.icon + ' ' + tm.name + '</span><span>' + traitPcts[tk] + '%</span></div>';
      chartHTML += '<div class="quiz-bar-track"><div class="quiz-bar-fill" style="width:' + traitPcts[tk] + '%;background:' + tm.color + '"></div></div>';
      chartHTML += '<div style="text-align:right;font-size:0.8rem;color:var(--color-text-muted);margin-top:2px;">' + tl.label + '</div>';
      chartHTML += '</div>';
    }
    traitChart.innerHTML = chartHTML;

    var detailsHTML = '<div style="text-align:left;max-width:450px;margin:0 auto;">';
    for (var n = 0; n < traitKeys.length; n++) {
      var dtk = traitKeys[n];
      var dtm = traitMeta[dtk];
      var interpLevel = traitPcts[dtk] >= 55 ? 'high' : (traitPcts[dtk] >= 25 ? 'moderate' : 'low');
      detailsHTML += '<p><strong>' + dtm.icon + ' ' + dtm.name + ' (' + traitPcts[dtk] + '%):</strong> ' + traitInterpretations[dtk][interpLevel] + '</p>';
    }
    detailsHTML += '</div>';
    traitDetails.innerHTML = detailsHTML;

    interpretationNote.innerHTML = '<div style="text-align:left;max-width:450px;margin:16px auto 0;padding:16px;background:var(--color-bg);border-radius:var(--radius);border:1px solid var(--color-border);"><p style="margin-bottom:4px;font-size:0.85rem;color:var(--color-text-muted);"><strong>Important Note:</strong> This is a self-assessment tool for personal insight and is not a clinical diagnosis. Dark Triad traits exist on a normal spectrum of human personality. If your results concern you, consider speaking with a licensed mental health professional.</p></div>';

    addToHistory(overallScore);
    renderHistory();

    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: overallScore,
        unit: metricUnit,
        metricLabel: metricLabel,
        ratingLabel: overall.label,
        ratingColor: overall.color
      });
    }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    var html = '';
    for (var i = 0; i < history.length; i++) {
      var e = history[i];
      var r = getLevel(e.score, overallRanges);
      html += '<div class="history-item">';
      html += '<span class="history-score">' + e.score + '/100</span>';
      html += '<span class="history-rating" style="background:' + r.color + '">' + r.label + '</span>';
      html += '<span class="history-time">' + formatDate(e.date) + '</span>';
      html += '</div>';
    }
    historyList.innerHTML = html;
  }

  optionsContainer.addEventListener('click', handleOptionClick);
  startBtn.addEventListener('click', startGame);
  tryAgainBtn.addEventListener('click', startGame);
  renderHistory();
})();
</script>
