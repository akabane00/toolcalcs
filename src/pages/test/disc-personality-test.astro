        { label: "Analyze performance metrics to identify the root cause before taking action", dim: "C" }
      ]
    }
  ];

  var discTypes = {
    D: {
      name: "Dominance",
      icon: "\u{1F534}",
      color: "#ef4444",
      desc: "You are a Driver. Direct, results-oriented, and decisive, you thrive on challenge and competition. You value efficiency and bottom-line results. You are at your best when leading bold initiatives, solving tough problems, and pushing for ambitious goals.",
      strengths: "Decisiveness, determination, confidence, ability to drive results under pressure",
      challenges: "Impatience, insensitivity, dominating conversations, overlooking details",
      idealEnv: "Fast-paced, competitive environment with autonomy and clear metrics for success",
      compatible: "I (Influence) and C (Conscientiousness)"
    },
    I: {
      name: "Influence",
      icon: "\u{1F7E1}",
      color: "#eab308",
      desc: "You are an Inspirer. Enthusiastic, optimistic, and socially skilled, you thrive on interaction and collaboration. You value relationships and creative freedom. You are at your best when motivating teams, building rapport, and generating excitement for new ideas.",
      strengths: "Persuasion, creativity, enthusiasm, ability to build coalitions and motivate others",
      challenges: "Difficulty with follow-through, overpromising, disorganization, avoiding conflict",
      idealEnv: "Collaborative, fun workplace with open communication and opportunities for recognition",
      compatible: "D (Dominance) and S (Steadiness)"
    },
    S: {
      name: "Steadiness",
      icon: "\u{1F7E2}",
      color: "#22c55e",
      desc: "You are a Supporter. Patient, reliable, and team-oriented, you value harmony and stability. You prefer predictable environments and genuine relationships. You are at your best when creating cohesive teams, supporting colleagues, and delivering consistently dependable work.",
      strengths: "Dependability, patience, loyalty, ability to create harmonious team environments",
      challenges: "Resistance to change, difficulty asserting yourself, avoiding confrontation, indecision",
      idealEnv: "Stable, supportive workplace with clear processes, minimal surprises, and a cohesive team",
      compatible: "I (Influence) and C (Conscientiousness)"
    },
    C: {
      name: "Conscientiousness",
      icon: "\u{1F535}",
      color: "#3b82f6",
      desc: "You are an Analyst. Detail-oriented, quality-focused, and systematic, you value accuracy and expertise. You prefer thorough analysis before action. You are at your best when solving complex problems, maintaining high standards, and ensuring quality outcomes.",
      strengths: "Thoroughness, accuracy, expertise, ability to identify risks and ensure quality",
      challenges: "Analysis paralysis, perfectionism, overly critical, difficulty with rapid change",
      idealEnv: "Structured, quiet workspace with time for focused analysis and high-quality standards",
      compatible: "D (Dominance) and S (Steadiness)"
    }
  };

  var STORAGE_KEY = 'toolcalcs_disc-personality-test_history';
  var MAX_HISTORY = 20;

  function loadHistory() {
    try { var r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch (e) {}
    return [];
  }
  function saveHistory(h) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(h.slice(0, MAX_HISTORY))); } catch (e) {}
  }
  function addToHistory(primary, scores) {
    var h = loadHistory();
    h.unshift({ primary: primary, scores: scores, date: new Date().toISOString() });
    saveHistory(h);
  }

  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
    }
    return a;
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  var instructionsView = document.getElementById('instructionsView');
  var playView = document.getElementById('playView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var tryAgainBtn = document.getElementById('tryAgainBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var resultIcon = document.getElementById('resultIcon');
  var primaryType = document.getElementById('primaryType');
  var primaryLabel = document.getElementById('primaryLabel');
  var ratingBadge = document.getElementById('ratingBadge');
  var dimChart = document.getElementById('dimChart');
  var typeDescription = document.getElementById('typeDescription');
  var compatibleTypesEl = document.getElementById('compatibleTypes');
  var attemptHistorySection = document.getElementById('attemptHistory');
  var historyList = document.getElementById('historyList');

  var shuffledQuestions = [];
  var currentIndex = 0;
  var scores = { D: 0, I: 0, S: 0, C: 0 };
  var isProcessing = false;

  function showView(view) {
    instructionsView.style.display = 'none';
    playView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function startGame() {
    shuffledQuestions = shuffle(questions);
    currentIndex = 0;
    scores = { D: 0, I: 0, S: 0, C: 0 };
    isProcessing = false;
    showView(playView);
    renderQuestion();
  }

  function renderQuestion() {
    var q = shuffledQuestions[currentIndex];
    var total = shuffledQuestions.length;
    var pct = Math.round((currentIndex / total) * 100);

    progressText.textContent = 'Question ' + (currentIndex + 1) + ' of ' + total;
    progressFill.style.width = pct + '%';
    questionText.textContent = q.text;

    var shuffledOpts = shuffle(q.options);
    var html = '';
    for (var i = 0; i < shuffledOpts.length; i++) {
      html += '<button class="quiz-option" type="button" data-dim="' + shuffledOpts[i].dim + '">' + shuffledOpts[i].label + '</button>';
    }
    optionsContainer.innerHTML = html;
  }

  function handleOptionClick(e) {
    if (isProcessing) return;
    var btn = e.target;
    if (!btn || !btn.classList || !btn.classList.contains('quiz-option')) return;

    isProcessing = true;
    var dim = btn.getAttribute('data-dim');
    btn.classList.add('selected');
    scores[dim]++;

    setTimeout(function () {
      currentIndex++;
      if (currentIndex >= shuffledQuestions.length) {
        showResults();
      } else {
        renderQuestion();
      }
      isProcessing = false;
    }, 300);
  }

  function showResults() {
    var total = questions.length;
    var dimKeys = ['D', 'I', 'S', 'C'];
    var pcts = {};
    var primaryDim = 'D';
    var secondaryDim = 'I';
    var maxScore = 0;
    var secondMax = 0;

    for (var i = 0; i < dimKeys.length; i++) {
      var k = dimKeys[i];
      pcts[k] = Math.round((scores[k] / total) * 100);
      if (scores[k] > maxScore) {
        secondMax = maxScore;
        secondaryDim = primaryDim;
        maxScore = scores[k];
        primaryDim = k;
      } else if (scores[k] > secondMax) {
        secondMax = scores[k];
        secondaryDim = k;
      }
    }

    var type = discTypes[primaryDim];
    showView(resultView);

    resultIcon.textContent = type.icon;
    primaryType.textContent = primaryDim;
    primaryLabel.textContent = ' - ' + type.name;
    ratingBadge.textContent = type.name + ' (' + primaryDim + secondaryDim + ')';
    ratingBadge.style.background = type.color;

    var chartHTML = '';
    for (var j = 0; j < dimKeys.length; j++) {
      var dk = dimKeys[j];
      var dt = discTypes[dk];
      chartHTML += '<div class="quiz-bar-item">';
      chartHTML += '<div class="quiz-bar-label"><span>' + dt.icon + ' ' + dt.name + ' (' + dk + ')</span><span>' + pcts[dk] + '%</span></div>';
      chartHTML += '<div class="quiz-bar-track"><div class="quiz-bar-fill" style="width:' + pcts[dk] + '%;background:' + dt.color + '"></div></div>';
      chartHTML += '</div>';
    }
    dimChart.innerHTML = chartHTML;

    var descHTML = '<div style="text-align:left;max-width:450px;margin:0 auto;">';
    descHTML += '<p>' + type.desc + '</p>';
    descHTML += '<p><strong>Key Strengths:</strong> ' + type.strengths + '</p>';
    descHTML += '<p><strong>Watch Out For:</strong> ' + type.challenges + '</p>';
    descHTML += '<p><strong>Ideal Work Environment:</strong> ' + type.idealEnv + '</p>';
    descHTML += '</div>';
    typeDescription.innerHTML = descHTML;

    compatibleTypesEl.innerHTML = '<div style="text-align:left;max-width:450px;margin:16px auto 0;padding:16px;background:var(--color-bg);border-radius:var(--radius);border:1px solid var(--color-border);"><p><strong>Most Compatible Types:</strong> ' + type.compatible + '</p><p style="margin-top:8px;font-size:0.9rem;color:var(--color-text-muted);">These types complement your ' + type.name + ' style by balancing your strengths and covering areas where you may need support.</p></div>';

    addToHistory(primaryDim, pcts);
    renderHistory();

    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: type.name + ' (' + primaryDim + ')',
        unit: metricUnit,
        metricLabel: metricLabel,
        ratingLabel: primaryDim + secondaryDim + ' Profile',
        ratingColor: type.color
      });
    }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    var html = '';
    for (var i = 0; i < history.length; i++) {
      var e = history[i];
      var t = discTypes[e.primary] || discTypes.D;
      html += '<div class="history-item">';
      html += '<span class="history-score">' + t.icon + ' ' + e.primary + ' - ' + t.name + '</span>';
      html += '<span class="history-rating" style="background:' + t.color + '">' + e.primary + '</span>';
      html += '<span class="history-time">' + formatDate(e.date) + '</span>';
      html += '</div>';
    }
    historyList.innerHTML = html;
  }

  optionsContainer.addEventListener('click', handleOptionClick);
  startBtn.addEventListener('click', startGame);
  tryAgainBtn.addEventListener('click', startGame);
  renderHistory();
})();
</script>
