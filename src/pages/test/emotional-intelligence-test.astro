      options: [
        { label: "Freeze and procrastinate because everything feels impossible", val: 1 },
        { label: "Stay up all night trying to do everything at once", val: 1 },
        { label: "Prioritize tasks by urgency and importance, then tackle them one at a time", val: 4 },
        { label: "Complain to everyone about how busy you are without taking action", val: 2 }
      ]
    },
    {
      text: "You witness a colleague being unfairly criticized by a senior manager in front of others. You:",
      dim: "socialAware",
      options: [
        { label: "Enjoy the drama and tell others about it later", val: 1 },
        { label: "Check on the colleague afterward to offer support and acknowledge what happened was unfair", val: 4 },
        { label: "Pretend you did not see anything", val: 2 },
        { label: "Confront the senior manager publicly on the spot", val: 1 }
      ]
    },
    {
      text: "Your partner or close friend tells you something you did hurt their feelings. You:",
      dim: "selfAware",
      options: [
        { label: "Listen without defensiveness, try to understand their perspective, and apologize sincerely", val: 4 },
        { label: "Immediately list things they have done that hurt you", val: 1 },
        { label: "Tell them they are being too sensitive", val: 1 },
        { label: "Apologize quickly just to end the conversation", val: 2 }
      ]
    },
    {
      text: "You are about to give a presentation and feel extremely nervous. You:",
      dim: "selfAware",
      options: [
        { label: "Deny that you are nervous and try to suppress the feeling entirely", val: 1 },
        { label: "Acknowledge the nervousness as normal, use breathing techniques, and channel the energy into enthusiasm", val: 4 },
        { label: "Consider faking an illness to avoid presenting", val: 1 },
        { label: "Rush through the presentation as fast as possible to get it over with", val: 2 }
      ]
    },
    {
      text: "A new person joins your social group and seems to struggle fitting in. You:",
      dim: "socialAware",
      options: [
        { label: "Wait for them to make the effort to fit in on their own", val: 2 },
        { label: "Make an intentional effort to include them in conversations and introduce them to others", val: 4 },
        { label: "Ignore them because the group dynamics are fine as they are", val: 1 },
        { label: "Be friendly when they approach you but do not go out of your way", val: 3 }
      ]
    },
    {
      text: "You are asked to work on a project with someone you personally dislike. You:",
      dim: "relManage",
      options: [
        { label: "Focus on the shared goal, maintain professionalism, and find common ground", val: 4 },
        { label: "Request to be reassigned to a different project", val: 2 },
        { label: "Do the minimum collaboration possible and avoid them", val: 1 },
        { label: "Let your personal feelings affect the quality of your shared work", val: 1 }
      ]
    },
    {
      text: "After a disagreement with a friend, you realize that you were actually in the wrong. You:",
      dim: "selfAware",
      options: [
        { label: "Reach out, acknowledge you were wrong, and apologize without making excuses", val: 4 },
        { label: "Wait for them to reach out first because apologizing feels uncomfortable", val: 2 },
        { label: "Convince yourself you were actually right to avoid the discomfort", val: 1 },
        { label: "Apologize but add qualifiers like 'but you also...'", val: 1 }
      ]
    },
    {
      text: "You are trying to motivate a team that is exhausted and demoralized after a tough quarter. You:",
      dim: "relManage",
      options: [
        { label: "Tell them to toughen up because that is just how business works", val: 1 },
        { label: "Acknowledge the difficulty, celebrate small wins, and involve them in planning next steps", val: 4 },
        { label: "Promise bonuses or rewards you cannot guarantee", val: 1 },
        { label: "Give them a generic motivational speech without addressing their specific concerns", val: 2 }
      ]
    },
    {
      text: "Someone gives you a compliment that you feel is undeserved. You:",
      dim: "selfManage",
      options: [
        { label: "Deflect it completely by saying you did nothing special", val: 2 },
        { label: "Brag about additional accomplishments while accepting it", val: 1 },
        { label: "Accept it graciously while internally reflecting on whether it aligns with your self-perception", val: 4 },
        { label: "Assume they want something from you and become suspicious", val: 1 }
      ]
    },
    {
      text: "You overhear colleagues speaking negatively about another coworker who is not present. You:",
      dim: "socialAware",
      options: [
        { label: "Join in because it is just harmless venting", val: 1 },
        { label: "Steer the conversation in a more constructive direction or excuse yourself", val: 4 },
        { label: "Say nothing but remember the information for your own benefit", val: 1 },
        { label: "Listen silently without contributing but do not intervene", val: 2 }
      ]
    }
  ];

  var domains = {
    selfAware: {
      name: "Self-Awareness",
      icon: "\u{1FA9E}",
      desc: "The ability to recognize and understand your own emotions, strengths, weaknesses, and their impact on others."
    },
    selfManage: {
      name: "Self-Management",
      icon: "\u{1F3AF}",
      desc: "The ability to control impulsive feelings, manage emotions in healthy ways, and adapt to changing circumstances."
    },
    socialAware: {
      name: "Social Awareness",
      icon: "\u{1F465}",
      desc: "The ability to understand the emotions, needs, and concerns of others, pick up on social cues, and feel comfortable socially."
    },
    relManage: {
      name: "Relationship Management",
      icon: "\u{1F91D}",
      desc: "The ability to develop and maintain good relationships, communicate clearly, inspire and influence others, and manage conflict."
    }
  };

  var eqRanges = [
    { min: 80, label: "Exceptional", color: "#16a34a" },
    { min: 60, label: "Strong", color: "#22c55e" },
    { min: 40, label: "Moderate", color: "#f59e0b" },
    { min: 20, label: "Developing", color: "#f97316" },
    { min: 0, label: "Needs Work", color: "#ef4444" }
  ];

  var improvementTipsMap = {
    selfAware: "<strong>Tips to Improve Self-Awareness:</strong> Practice daily mindfulness meditation for 5-10 minutes. Keep an emotion journal noting triggers and reactions. Regularly ask trusted people for honest feedback about your emotional patterns.",
    selfManage: "<strong>Tips to Improve Self-Management:</strong> Use the 10-second rule before reacting to strong emotions. Build routines that reduce decision fatigue. Practice reframing negative situations by identifying what you can learn or control.",
    socialAware: "<strong>Tips to Improve Social Awareness:</strong> Practice active listening by focusing entirely on the speaker. Observe body language and tone in conversations. Read fiction to build empathy. Ask open-ended questions to understand others' perspectives.",
    relManage: "<strong>Tips to Improve Relationship Management:</strong> Address conflicts early before they escalate. Give specific, genuine appreciation regularly. Practice clear 'I' statements in difficult conversations. Invest in relationships proactively, not just when you need something."
  };

  var STORAGE_KEY = 'toolcalcs_emotional-intelligence-test_history';
  var MAX_HISTORY = 20;

  function getEQRating(score) {
    for (var i = 0; i < eqRanges.length; i++) {
      if (score >= eqRanges[i].min) return { label: eqRanges[i].label, color: eqRanges[i].color };
    }
    return { label: "Needs Work", color: "#ef4444" };
  }

  function loadHistory() {
    try { var r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch (e) {}
    return [];
  }
  function saveHistory(h) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(h.slice(0, MAX_HISTORY))); } catch (e) {}
  }
  function addToHistory(score) {
    var h = loadHistory();
    h.unshift({ score: score, date: new Date().toISOString(), rating: getEQRating(score).label });
    saveHistory(h);
  }

  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i];
      a[i] = a[j];
      a[j] = tmp;
    }
    return a;
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  // DOM
  var instructionsView = document.getElementById('instructionsView');
  var playView = document.getElementById('playView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var tryAgainBtn = document.getElementById('tryAgainBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var finalScore = document.getElementById('finalScore');
  var ratingBadge = document.getElementById('ratingBadge');
  var domainChart = document.getElementById('domainChart');
  var domainDetails = document.getElementById('domainDetails');
  var improvementTips = document.getElementById('improvementTips');
  var attemptHistorySection = document.getElementById('attemptHistory');
  var historyList = document.getElementById('historyList');

  var shuffledQuestions = [];
  var currentIndex = 0;
  var scores = { selfAware: 0, selfManage: 0, socialAware: 0, relManage: 0 };
  var domainCounts = { selfAware: 0, selfManage: 0, socialAware: 0, relManage: 0 };
  var isProcessing = false;

  function showView(view) {
    instructionsView.style.display = 'none';
    playView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function startGame() {
    shuffledQuestions = shuffle(questions);
    currentIndex = 0;
    scores = { selfAware: 0, selfManage: 0, socialAware: 0, relManage: 0 };
    domainCounts = { selfAware: 0, selfManage: 0, socialAware: 0, relManage: 0 };

    // Count questions per domain
    for (var i = 0; i < shuffledQuestions.length; i++) {
      domainCounts[shuffledQuestions[i].dim]++;
    }

    isProcessing = false;
    showView(playView);
    renderQuestion();
  }

  function renderQuestion() {
    var q = shuffledQuestions[currentIndex];
    var total = shuffledQuestions.length;
    var pct = Math.round(((currentIndex) / total) * 100);

    progressText.textContent = 'Question ' + (currentIndex + 1) + ' of ' + total;
    progressFill.style.width = pct + '%';
    questionText.textContent = q.text;

    var shuffledOpts = shuffle(q.options);
    var html = '';
    for (var i = 0; i < shuffledOpts.length; i++) {
      html += '<button class="quiz-option" type="button" data-val="' + shuffledOpts[i].val + '" data-dim="' + q.dim + '">' + shuffledOpts[i].label + '</button>';
    }
    optionsContainer.innerHTML = html;
  }

  function handleOptionClick(e) {
    if (isProcessing) return;
    var btn = e.target;
    if (!btn || !btn.classList || !btn.classList.contains('quiz-option')) return;

    isProcessing = true;
    var val = parseInt(btn.getAttribute('data-val'), 10);
    var dim = btn.getAttribute('data-dim');

    btn.classList.add('selected');
    scores[dim] += val;

    setTimeout(function () {
      currentIndex++;
      if (currentIndex >= shuffledQuestions.length) {
        showResults();
      } else {
        renderQuestion();
      }
      isProcessing = false;
    }, 300);
  }

  function showResults() {
    // Calculate total EQ score (0-100)
    var totalRaw = scores.selfAware + scores.selfManage + scores.socialAware + scores.relManage;
    var totalMax = shuffledQuestions.length * 4;  // 120
    var totalMin = shuffledQuestions.length * 1;  // 30
    var eqScore = Math.round(((totalRaw - totalMin) / (totalMax - totalMin)) * 100);
    if (eqScore < 0) eqScore = 0;
    if (eqScore > 100) eqScore = 100;

    showView(resultView);
    finalScore.textContent = String(eqScore);

    var rating = getEQRating(eqScore);
    ratingBadge.textContent = rating.label;
    ratingBadge.style.background = rating.color;

    // Domain bar chart
    var chartHTML = '';
    var lowestDim = '';
    var lowestPct = 101;
    var dimKeys = ['selfAware', 'selfManage', 'socialAware', 'relManage'];

    for (var i = 0; i < dimKeys.length; i++) {
      var key = dimKeys[i];
      var domainMax = domainCounts[key] * 4;
      var domainMin = domainCounts[key] * 1;
      var domainPct = Math.round(((scores[key] - domainMin) / (domainMax - domainMin)) * 100);
      if (domainPct < 0) domainPct = 0;
      if (domainPct > 100) domainPct = 100;

      if (domainPct < lowestPct) {
        lowestPct = domainPct;
        lowestDim = key;
      }

      var domainColor = getEQRating(domainPct).color;
      chartHTML += '<div class="quiz-bar-item">';
      chartHTML += '<div class="quiz-bar-label"><span>' + domains[key].icon + ' ' + domains[key].name + '</span><span>' + domainPct + '%</span></div>';
      chartHTML += '<div class="quiz-bar-track"><div class="quiz-bar-fill" style="width:' + domainPct + '%;background:' + domainColor + '"></div></div>';
      chartHTML += '</div>';
    }
    domainChart.innerHTML = chartHTML;

    // Domain details
    var detailsHTML = '<div style="text-align:left;max-width:450px;margin:0 auto;">';
    for (var j = 0; j < dimKeys.length; j++) {
      var dk = dimKeys[j];
      detailsHTML += '<p><strong>' + domains[dk].icon + ' ' + domains[dk].name + ':</strong> ' + domains[dk].desc + '</p>';
    }
    detailsHTML += '</div>';
    domainDetails.innerHTML = detailsHTML;

    // Improvement tips for lowest domain
    if (lowestDim && improvementTipsMap[lowestDim]) {
      improvementTips.innerHTML = '<div style="text-align:left;max-width:450px;margin:16px auto 0;padding:16px;background:var(--color-bg);border-radius:var(--radius);border:1px solid var(--color-border);"><p style="margin-bottom:4px;font-size:0.9rem;color:var(--color-text-muted);">Your biggest growth area:</p><p>' + improvementTipsMap[lowestDim] + '</p></div>';
    }

    addToHistory(eqScore);
    renderHistory();

    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: eqScore,
        unit: metricUnit,
        metricLabel: metricLabel,
        ratingLabel: rating.label,
        ratingColor: rating.color
      });
    }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    var html = '';
    for (var i = 0; i < history.length; i++) {
      var e = history[i];
      var r = getEQRating(e.score);
      html += '<div class="history-item">';
      html += '<span class="history-score">' + e.score + '/100</span>';
      html += '<span class="history-rating" style="background:' + r.color + '">' + r.label + '</span>';
      html += '<span class="history-time">' + formatDate(e.date) + '</span>';
      html += '</div>';
    }
    historyList.innerHTML = html;
  }

  // Events
  optionsContainer.addEventListener('click', handleOptionClick);
  startBtn.addEventListener('click', startGame);
  tryAgainBtn.addEventListener('click', startGame);
  renderHistory();
})();
</script>
