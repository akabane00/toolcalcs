  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i];
      a[i] = a[j];
      a[j] = tmp;
    }
    return a;
  }

  function showView(view) {
    instructionsView.style.display = 'none';
    playView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function resetScores() {
    scores = { T1: 0, T2: 0, T3: 0, T4: 0, T5: 0, T6: 0, T7: 0, T8: 0, T9: 0 };
  }

  function renderQuestion() {
    var q = shuffled[currentIndex];
    var num = currentIndex + 1;
    var total = shuffled.length;
    progressText.textContent = 'Question ' + num + ' of ' + total;
    progressFill.style.width = Math.round((num / total) * 100) + '%';
    questionText.textContent = q.text;

    likertContainer.innerHTML = '';
    for (var i = 0; i < likertOptions.length; i++) {
      var btn = document.createElement('button');
      btn.className = 'quiz-option';
      btn.type = 'button';
      btn.textContent = likertOptions[i].label;
      btn.dataset.val = String(likertOptions[i].val);
      btn.dataset.dim = q.dim;
      likertContainer.appendChild(btn);
    }
  }

  function handleLikertClick(e) {
    var target = e.target;
    if (!target || !target.classList || !target.classList.contains('quiz-option')) return;
    var val = parseInt(target.dataset.val, 10);
    var dim = target.dataset.dim;

    // Visual feedback
    target.classList.add('selected');

    scores[dim] = (scores[dim] || 0) + val;
    currentIndex++;

    if (currentIndex >= shuffled.length) {
      setTimeout(function () { showResults(); }, 250);
    } else {
      setTimeout(function () { renderQuestion(); }, 250);
    }
  }

  function getAdjacentTypes(typeKey) {
    var num = types[typeKey].num;
    var prev = num === 1 ? 9 : num - 1;
    var next = num === 9 ? 1 : num + 1;
    return { prev: 'T' + prev, next: 'T' + next };
  }

  function calculateWing(topKey) {
    var adj = getAdjacentTypes(topKey);
    var prevScore = scores[adj.prev] || 0;
    var nextScore = scores[adj.next] || 0;
    if (prevScore >= nextScore) {
      return { wingKey: adj.prev, wingNum: types[adj.prev].num };
    }
    return { wingKey: adj.next, wingNum: types[adj.next].num };
  }

  function showResults() {
    showView(resultView);

    // Find top type
    var topKey = 'T1';
    var topScore = 0;
    var allKeys = ['T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'T8', 'T9'];
    for (var i = 0; i < allKeys.length; i++) {
      if (scores[allKeys[i]] > topScore) {
        topScore = scores[allKeys[i]];
        topKey = allKeys[i];
      }
    }

    var topType = types[topKey];
    var wing = calculateWing(topKey);
    var wingLabel = 'w' + wing.wingNum;
    var fullLabel = 'Type ' + topType.num + wingLabel;

    var growthType = types['T' + topType.growth];
    var stressType = types['T' + topType.stress];

    // Max possible per type = 4 questions * 5 points = 20
    var maxScore = 20;

    // Build result HTML
    var html = '';
    html += '<div class="result-icon" aria-hidden="true">\uD83D\uDD37</div>';
    html += '<div class="quiz-result-type">' + fullLabel + '</div>';
    html += '<div class="quiz-result-name">' + topType.name + '</div>';
    html += '<div class="quiz-result-desc">' + topType.desc + '</div>';

    // Bar chart
    html += '<div class="quiz-bar-chart">';
    for (var j = 0; j < allKeys.length; j++) {
      var key = allKeys[j];
      var t = types[key];
      var s = scores[key] || 0;
      var pct = Math.round((s / maxScore) * 100);
      var isTop = key === topKey;
      html += '<div class="quiz-bar-item">';
      html += '<div class="quiz-bar-label"><span>Type ' + t.num + ' - ' + t.name + '</span><span>' + s + '/' + maxScore + '</span></div>';
      html += '<div class="quiz-bar-track"><div class="quiz-bar-fill" style="width:' + pct + '%;' + (isTop ? 'background:#6366f1;' : '') + '"></div></div>';
      html += '</div>';
    }
    html += '</div>';

    // Core fear and desire
    html += '<div class="quiz-traits strengths"><h3>Core Desire</h3><ul><li>' + topType.desire + '</li></ul></div>';
    html += '<div class="quiz-traits weaknesses"><h3>Core Fear</h3><ul><li>' + topType.fear + '</li></ul></div>';

    // Growth and stress arrows
    html += '<div class="quiz-traits careers"><h3>Growth Direction</h3><ul><li>In growth, you move toward Type ' + growthType.num + ' (' + growthType.name + ')</li></ul></div>';
    html += '<div class="quiz-traits careers"><h3>Stress Direction</h3><ul><li>Under stress, you move toward Type ' + stressType.num + ' (' + stressType.name + ')</li></ul></div>';

    // Strengths
    html += '<div class="quiz-traits strengths"><h3>Key Strengths</h3><ul>';
    for (var k = 0; k < topType.strengths.length; k++) {
      html += '<li>' + topType.strengths[k] + '</li>';
    }
    html += '</ul></div>';

    // Weaknesses
    html += '<div class="quiz-traits weaknesses"><h3>Growth Areas</h3><ul>';
    for (var m = 0; m < topType.weaknesses.length; m++) {
      html += '<li>' + topType.weaknesses[m] + '</li>';
    }
    html += '</ul></div>';

    // Try again button
    html += '<button class="game-btn primary" id="tryAgainBtn" type="button" style="margin-top:16px;">Take Test Again</button>';

    resultContent.innerHTML = html;

    // Bind try again
    var tryAgainBtn = document.getElementById('tryAgainBtn');
    if (tryAgainBtn) {
      tryAgainBtn.addEventListener('click', startGame);
    }

    // Save history
    addToHistory(fullLabel);
    renderHistory();

    // Show share
    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: 'Type ' + topType.num,
        unit: topType.name,
        metricLabel: metricLabel,
        ratingLabel: 'Type ' + topType.num + wingLabel,
        ratingColor: '#6366f1'
      });
    }
  }

  function startGame() {
    resetScores();
    shuffled = shuffle(questions);
    currentIndex = 0;
    showView(playView);
    renderQuestion();

    if (window.GameShare) {
      window.GameShare.hide();
    }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    var items = '';
    for (var i = 0; i < history.length; i++) {
      var e = history[i];
      items += '<div class="history-item">';
      items += '<span class="history-score">' + e.score + '</span>';
      items += '<span class="history-rating" style="background:#6366f1">' + e.score + '</span>';
      items += '<span class="history-time">' + formatDate(e.date) + '</span>';
      items += '</div>';
    }
    historyList.innerHTML = items;
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  // Events
  likertContainer.addEventListener('click', handleLikertClick);
  startBtn.addEventListener('click', startGame);
  renderHistory();
})();
</script>
