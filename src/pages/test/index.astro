---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { games } from '../../data/games';
import '../../styles/category.css';

const personalityTests = [
  { slug: 'personality-type-test', icon: '🧠', title: '16 Personalities Test', description: 'Discover your MBTI personality type through 40 carefully crafted questions. Find out if you are INFJ, ENTP, or one of 14 other types.' },
  { slug: 'love-language-test', icon: '💝', title: 'Love Language Test', description: 'Discover how you prefer to give and receive love. Based on Dr. Gary Chapman\'s 5 Love Languages framework.' },
  { slug: 'enneagram-test', icon: '🔷', title: 'Enneagram Test', description: 'Find your Enneagram type, wing, and growth path. Understand your core motivations and fears through 36 questions.' },
  { slug: 'big-five-personality-test', icon: '📊', title: 'Big Five Personality Test', description: 'Measure your Openness, Conscientiousness, Extraversion, Agreeableness, and Neuroticism with 50 research-based questions.' },
  { slug: 'attachment-style-quiz', icon: '🔗', title: 'Attachment Style Quiz', description: 'Discover your attachment style: Secure, Anxious, Avoidant, or Fearful-Avoidant. Understand your relationship patterns.' },
  { slug: 'emotional-intelligence-test', icon: '🧠', title: 'Emotional Intelligence (EQ) Test', description: 'Measure your EQ across 4 domains: Self-Awareness, Self-Management, Social Awareness, and Relationship Management.' },
  { slug: 'disc-personality-test', icon: '📋', title: 'DISC Personality Test', description: 'Discover your workplace personality type: Dominance, Influence, Steadiness, or Conscientiousness. 28 scenario-based questions.' },
  { slug: 'dark-triad-test', icon: '🖤', title: 'Dark Triad Personality Test', description: 'Measure your Narcissism, Machiavellianism, and Psychopathy traits with the Short Dark Triad (SD3) scale.' },
  { slug: 'introvert-extrovert-test', icon: '🔄', title: 'Introvert vs Extrovert Test', description: 'Discover where you fall on the introversion-extraversion spectrum. Are you an ambivert?' },
  { slug: 'career-aptitude-test', icon: '💼', title: 'Career Aptitude Test', description: 'Find your ideal career path based on Holland\'s RIASEC model. 30 questions to discover your work personality.' },
];

const healthScreenings = [
  { slug: 'anxiety-test', icon: '💭', title: 'Anxiety Test (GAD-7)', description: 'Free anxiety self-assessment based on the GAD-7 clinical screening tool. Measure generalized anxiety severity.' },
  { slug: 'depression-test', icon: '🌧️', title: 'Depression Test (PHQ-9)', description: 'Free depression self-assessment based on the PHQ-9 clinical screening tool. Includes crisis resources.' },
];

const viralQuizzes = [
  { slug: 'mental-age-test', icon: '🧒', title: 'Mental Age Test', description: 'How old is your mind? Answer 25 fun questions to discover your mental age. Share your results!' },
  { slug: 'left-brain-right-brain-test', icon: '🧠', title: 'Left Brain Right Brain Test', description: 'Are you logical and analytical (left) or creative and intuitive (right)? 20 questions to find out.' },
  { slug: 'iq-test', icon: '💡', title: 'Quick IQ Test', description: 'Estimate your IQ with 20 questions covering pattern recognition, logic, spatial thinking, and numerical ability.' },
  { slug: 'memory-age-test', icon: '🧠', title: 'Memory Age Test', description: 'How old is your memory? 5 quick challenges testing short-term, visual, and working memory.' },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Tests & Games" }
  ]
};
---

<BaseLayout
  title="Free Online Tests & Games - Personality, IQ, Memory, Reaction Time | ToolCalcs"
  description="32 free online tests: personality quizzes (MBTI, DISC, Enneagram), IQ test, mental age, anxiety & depression screenings, reaction time, memory games, and more. Share your results!"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Tests & Games</span>
  </nav>

  <h1>Tests & Games</h1>
  <p class="page-desc">32 free interactive tests: discover your personality, estimate your IQ, check your mental age, screen for anxiety and depression, challenge your reflexes, and train your memory. Share your results with friends.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <h2 class="section-title">Personality & Psychology Tests</h2>
  <div class="calc-grid">
    {personalityTests.map(test => (
      <a href={`/test/${test.slug}/`} class="calc-card">
        <span class="calc-icon">{test.icon}</span>
        <h3>{test.title}</h3>
        <p>{test.description}</p>
      </a>
    ))}
  </div>

  <h2 class="section-title">Mental Health Screenings</h2>
  <div class="calc-grid">
    {healthScreenings.map(test => (
      <a href={`/test/${test.slug}/`} class="calc-card">
        <span class="calc-icon">{test.icon}</span>
        <h3>{test.title}</h3>
        <p>{test.description}</p>
      </a>
    ))}
  </div>

  <h2 class="section-title">Fun & Viral Quizzes</h2>
  <div class="calc-grid">
    {viralQuizzes.map(test => (
      <a href={`/test/${test.slug}/`} class="calc-card">
        <span class="calc-icon">{test.icon}</span>
        <h3>{test.title}</h3>
        <p>{test.description}</p>
      </a>
    ))}
  </div>

  <h2 class="section-title">Cognitive & Reflex Tests</h2>
  <div class="calc-grid">
    {games.map(game => (
      <a href={`/test/${game.slug}/`} class="calc-card">
        <span class="calc-icon">{game.icon}</span>
        <h3>{game.title}</h3>
        <p>{game.description}</p>
      </a>
    ))}
  </div>

  <ExploreMore currentCategorySlug="test" />

  <AdUnit slot="cat-bottom" format="horizontal" />

  <section class="cross-section">
    <h2>Explore More on ToolCalcs</h2>
    <div class="cross-links">
      <a href="/tools/">Web Tools</a>
      <a href="/financial-calculators/">Financial Calculators</a>
      <a href="/health-calculators/">Health Calculators</a>
      <a href="/math-calculators/">Math Calculators</a>
      <a href="/worksheets/">Math Worksheets</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section-title {
    font-size: 1.2rem;
    margin: 32px 0 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-primary);
    color: var(--color-text);
  }
  .section-title:first-of-type {
    margin-top: 0;
  }
  .cross-section {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .cross-section h2 {
    font-size: 1.1rem;
    margin-bottom: 12px;
  }
  .cross-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .cross-links a {
    padding: 6px 14px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.85rem;
    color: var(--color-text);
    transition: border-color 0.15s;
  }
  .cross-links a:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
  }
</style>
