---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { games } from '../../data/games';
import '../../styles/category.css';

const personalityTests = [
  { slug: 'personality-type-test', icon: '🧠', title: '16 Personalities Test', description: 'Discover your MBTI personality type through 40 carefully crafted questions. Find out if you are INFJ, ENTP, or one of 14 other types.' },
  { slug: 'love-language-test', icon: '💝', title: 'Love Language Test', description: 'Discover how you prefer to give and receive love. Based on Dr. Gary Chapman\'s 5 Love Languages framework.' },
  { slug: 'enneagram-test', icon: '🔷', title: 'Enneagram Test', description: 'Find your Enneagram type, wing, and growth path. Understand your core motivations and fears through 36 questions.' },
  { slug: 'big-five-personality-test', icon: '📊', title: 'Big Five Personality Test', description: 'Measure your Openness, Conscientiousness, Extraversion, Agreeableness, and Neuroticism with 50 research-based questions.' },
  { slug: 'attachment-style-quiz', icon: '🔗', title: 'Attachment Style Quiz', description: 'Discover your attachment style: Secure, Anxious, Avoidant, or Fearful-Avoidant. Understand your relationship patterns.' },
  { slug: 'emotional-intelligence-test', icon: '🧠', title: 'Emotional Intelligence (EQ) Test', description: 'Measure your EQ across 4 domains: Self-Awareness, Self-Management, Social Awareness, and Relationship Management.' },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Tests & Games" }
  ]
};
---

<BaseLayout
  title="Online Tests & Games - Personality, IQ, Reaction Time & More | ToolCalcs"
  description="Free online personality tests, cognitive challenges, and reflex games. Discover your MBTI type, love language, attachment style, and test your reaction time, typing speed, and memory."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Tests & Games</span>
  </nav>

  <h1>Tests & Games</h1>
  <p class="page-desc">Discover your personality, test your cognitive abilities, and challenge your reflexes with free interactive tests. Share your results with friends.</p>

  <AdUnit slot="cat-top" format="horizontal" />

  <h2 class="section-title">Personality & Psychology Tests</h2>
  <div class="calc-grid">
    {personalityTests.map(test => (
      <a href={`/test/${test.slug}/`} class="calc-card">
        <span class="calc-icon">{test.icon}</span>
        <h3>{test.title}</h3>
        <p>{test.description}</p>
      </a>
    ))}
  </div>

  <h2 class="section-title">Cognitive & Reflex Tests</h2>
  <div class="calc-grid">
    {games.map(game => (
      <a href={`/test/${game.slug}/`} class="calc-card">
        <span class="calc-icon">{game.icon}</span>
        <h3>{game.title}</h3>
        <p>{game.description}</p>
      </a>
    ))}
  </div>

  <ExploreMore currentCategorySlug="test" />

  <AdUnit slot="cat-bottom" format="horizontal" />

  <section class="cross-section">
    <h2>Explore More on ToolCalcs</h2>
    <div class="cross-links">
      <a href="/tools/">Web Tools</a>
      <a href="/financial-calculators/">Financial Calculators</a>
      <a href="/health-calculators/">Health Calculators</a>
      <a href="/math-calculators/">Math Calculators</a>
      <a href="/worksheets/">Math Worksheets</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section-title {
    font-size: 1.2rem;
    margin: 32px 0 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-primary);
    color: var(--color-text);
  }
  .section-title:first-of-type {
    margin-top: 0;
  }
  .cross-section {
    margin-top: 40px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }
  .cross-section h2 {
    font-size: 1.1rem;
    margin-bottom: 12px;
  }
  .cross-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .cross-links a {
    padding: 6px 14px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.85rem;
    color: var(--color-text);
    transition: border-color 0.15s;
  }
  .cross-links a:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    text-decoration: none;
  }
</style>
