      icon: "\u{2600}\u{FE0F}",
      color: "#f97316",
      desc: "You are a strong extrovert. People are your fuel, and you come alive in social settings. You love meeting new people, being the center of attention, and working collaboratively. Solitude feels uncomfortable and you seek out interaction naturally and frequently. You are likely a natural connector who builds large social networks and brings energy to every room you enter.",
      tips: "While your social energy is a tremendous strength, make sure to develop your capacity for solitary focus and reflection. Not every problem is best solved through discussion. Practice being comfortable with silence. Be mindful that not everyone shares your energy level, and give quieter people the space they need. Your enthusiasm and warmth make the world a more connected place."
    }
  };

  var STORAGE_KEY = 'toolcalcs_introvert-extrovert-test_history';
  var MAX_HISTORY = 20;

  function getType(score) {
    if (score <= 20) return typeProfiles.strongIntrovert;
    if (score <= 40) return typeProfiles.introvert;
    if (score <= 60) return typeProfiles.ambivert;
    if (score <= 80) return typeProfiles.extrovert;
    return typeProfiles.strongExtrovert;
  }

  function loadHistory() {
    try { var r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch (e) {}
    return [];
  }
  function saveHistory(h) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(h.slice(0, MAX_HISTORY))); } catch (e) {}
  }
  function addToHistory(score) {
    var h = loadHistory();
    h.unshift({ score: score, date: new Date().toISOString(), label: getType(score).label });
    saveHistory(h);
  }

  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
    }
    return a;
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  var instructionsView = document.getElementById('instructionsView');
  var playView = document.getElementById('playView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var tryAgainBtn = document.getElementById('tryAgainBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var resultIcon = document.getElementById('resultIcon');
  var finalScore = document.getElementById('finalScore');
  var ratingBadge = document.getElementById('ratingBadge');
  var spectrumBar = document.getElementById('spectrumBar');
  var typeDescription = document.getElementById('typeDescription');
  var typeTips = document.getElementById('typeTips');
  var attemptHistorySection = document.getElementById('attemptHistory');
  var historyList = document.getElementById('historyList');

  var shuffledQuestions = [];
  var currentIndex = 0;
  var extrovertPoints = 0;
  var isProcessing = false;

  function showView(view) {
    instructionsView.style.display = 'none';
    playView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function startGame() {
    shuffledQuestions = shuffle(questions);
    currentIndex = 0;
    extrovertPoints = 0;
    isProcessing = false;
    showView(playView);
    renderQuestion();
  }

  function renderQuestion() {
    var q = shuffledQuestions[currentIndex];
    var total = shuffledQuestions.length;
    var pct = Math.round((currentIndex / total) * 100);

    progressText.textContent = 'Question ' + (currentIndex + 1) + ' of ' + total;
    progressFill.style.width = pct + '%';
    questionText.textContent = q.text;

    var shuffledOpts = shuffle(q.options);
    var html = '';
    for (var i = 0; i < shuffledOpts.length; i++) {
      html += '<button class="quiz-option" type="button" data-side="' + shuffledOpts[i].side + '">' + shuffledOpts[i].label + '</button>';
    }
    optionsContainer.innerHTML = html;
  }

  function handleOptionClick(e) {
    if (isProcessing) return;
    var btn = e.target;
    if (!btn || !btn.classList || !btn.classList.contains('quiz-option')) return;

    isProcessing = true;
    var side = btn.getAttribute('data-side');
    btn.classList.add('selected');

    if (side === 'E') {
      extrovertPoints++;
    }

    setTimeout(function () {
      currentIndex++;
      if (currentIndex >= shuffledQuestions.length) {
        showResults();
      } else {
        renderQuestion();
      }
      isProcessing = false;
    }, 300);
  }

  function showResults() {
    var total = questions.length;
    var spectrumScore = Math.round((extrovertPoints / total) * 100);

    var type = getType(spectrumScore);

    showView(resultView);
    resultIcon.textContent = type.icon;
    finalScore.textContent = String(spectrumScore);
    ratingBadge.textContent = type.label;
    ratingBadge.style.background = type.color;

    var specHTML = '<div class="spectrum-container">';
    specHTML += '<div class="spectrum-track">';
    specHTML += '<div class="spectrum-marker" style="left:' + spectrumScore + '%"></div>';
    specHTML += '</div>';
    specHTML += '<div class="spectrum-labels"><span>Introvert</span><span>Ambivert</span><span>Extrovert</span></div>';
    specHTML += '</div>';
    spectrumBar.innerHTML = specHTML;

    typeDescription.innerHTML = '<div style="text-align:left;max-width:450px;margin:0 auto;"><p>' + type.desc + '</p></div>';

    typeTips.innerHTML = '<div style="text-align:left;max-width:450px;margin:16px auto 0;padding:16px;background:var(--color-bg);border-radius:var(--radius);border:1px solid var(--color-border);"><p style="margin-bottom:4px;font-size:0.9rem;color:var(--color-text-muted);">Tips for thriving as a ' + type.label + ':</p><p>' + type.tips + '</p></div>';

    addToHistory(spectrumScore);
    renderHistory();

    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: spectrumScore,
        unit: metricUnit,
        metricLabel: metricLabel,
        ratingLabel: type.label,
        ratingColor: type.color
      });
    }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    var html = '';
    for (var i = 0; i < history.length; i++) {
      var e = history[i];
      var t = getType(e.score);
      html += '<div class="history-item">';
      html += '<span class="history-score">' + e.score + '/100</span>';
      html += '<span class="history-rating" style="background:' + t.color + '">' + t.label + '</span>';
      html += '<span class="history-time">' + formatDate(e.date) + '</span>';
      html += '</div>';
    }
    historyList.innerHTML = html;
  }

  optionsContainer.addEventListener('click', handleOptionClick);
  startBtn.addEventListener('click', startGame);
  tryAgainBtn.addEventListener('click', startGame);
  renderHistory();
})();
</script>
