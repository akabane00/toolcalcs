<script define:vars={{ gameName: "Quick IQ Test", gameSlug: "iq-test", gameIcon: "\uD83D\uDCA1", metricLabel: "Estimated IQ", metricUnit: "" }}>
(function () {
  'use strict';

  // Questions: 5 per category, each with 4 options, answer index, and difficulty points
  var questions = [
    // === Pattern Recognition (5) ===
    { cat: "Pattern Recognition", text: "What comes next in the sequence: 2, 6, 18, 54, ?", options: ["108", "162", "72", "148"], answer: 1, pts: 1 },
    { cat: "Pattern Recognition", text: "What comes next: 1, 1, 2, 3, 5, 8, ?", options: ["10", "11", "13", "15"], answer: 2, pts: 1 },
    { cat: "Pattern Recognition", text: "What comes next: 3, 6, 11, 18, 27, ?", options: ["36", "38", "34", "40"], answer: 1, pts: 2 },
    { cat: "Pattern Recognition", text: "What comes next: 1, 4, 9, 16, 25, ?", options: ["30", "36", "49", "32"], answer: 1, pts: 2 },
    { cat: "Pattern Recognition", text: "What comes next: 2, 3, 5, 7, 11, 13, ?", options: ["15", "17", "19", "16"], answer: 1, pts: 3 },

    // === Logical Reasoning (5) ===
    { cat: "Logical Reasoning", text: "All Bloops are Razzies. All Razzies are Loogies. Are all Bloops Loogies?", options: ["Yes", "No", "Cannot be determined", "Only some"], answer: 0, pts: 1 },
    { cat: "Logical Reasoning", text: "If it rains, the grass gets wet. The grass is wet. Did it rain?", options: ["Yes, definitely", "No", "Not necessarily - something else could have made it wet", "Only if there was no sprinkler"], answer: 2, pts: 2 },
    { cat: "Logical Reasoning", text: "Some cats are black. Some black things are hats. Which must be true?", options: ["Some cats are hats", "No cats are hats", "Neither conclusion can be drawn", "All hats are cats"], answer: 2, pts: 2 },
    { cat: "Logical Reasoning", text: "If A is taller than B, and B is taller than C, and C is taller than D, who is the shortest?", options: ["A", "B", "C", "D"], answer: 3, pts: 1 },
    { cat: "Logical Reasoning", text: "Only one of these statements is true: (1) Statement 2 is true. (2) Statement 1 is false. Which is true?", options: ["Statement 1", "Statement 2", "Both", "Neither"], answer: 1, pts: 3 },

    // === Spatial Thinking (5) ===
    { cat: "Spatial Thinking", text: "If you fold a square piece of paper in half diagonally, what shape do you get?", options: ["Rectangle", "Triangle", "Pentagon", "Smaller square"], answer: 1, pts: 1 },
    { cat: "Spatial Thinking", text: "A cube has 6 faces, 12 edges, and how many corners (vertices)?", options: ["6", "8", "10", "4"], answer: 1, pts: 1 },
    { cat: "Spatial Thinking", text: "If you look at a clock in a mirror showing 3:00, what time does the mirror image appear to show?", options: ["9:00", "3:00", "6:00", "12:00"], answer: 0, pts: 2 },
    { cat: "Spatial Thinking", text: "How many squares (of any size) can you count on a standard 2x2 grid?", options: ["4", "5", "6", "8"], answer: 1, pts: 2 },
    { cat: "Spatial Thinking", text: "If you unfold a cube, which shape is NOT a valid net of the cube?", options: ["A cross/plus shape", "A T-shape", "A straight line of 6 squares", "An L-shape with 3 + 3 squares"], answer: 2, pts: 3 },

    // === Numerical Ability (5) ===
    { cat: "Numerical Ability", text: "What is 15% of 240?", options: ["32", "36", "38", "34"], answer: 1, pts: 1 },
    { cat: "Numerical Ability", text: "If a shirt costs $40 after a 20% discount, what was the original price?", options: ["$48", "$50", "$52", "$56"], answer: 1, pts: 2 },
    { cat: "Numerical Ability", text: "A train travels 120 miles in 2.5 hours. What is its average speed?", options: ["42 mph", "48 mph", "52 mph", "60 mph"], answer: 1, pts: 1 },
    { cat: "Numerical Ability", text: "If you invest $1,000 at 10% annual interest (compounded), how much do you have after 2 years?", options: ["$1,200", "$1,210", "$1,100", "$1,220"], answer: 1, pts: 2 },
    { cat: "Numerical Ability", text: "Three people can paint 3 fences in 3 hours. How many fences can 9 people paint in 9 hours?", options: ["9", "18", "27", "81"], answer: 2, pts: 3 }
  ];

  var IQ_RANGES = [
    { min: 0,  max: 5,  iq: [75, 85],   label: "Below Average", color: "#ef4444" },
    { min: 6,  max: 12, iq: [85, 100],  label: "Average", color: "#f59e0b" },
    { min: 13, max: 20, iq: [100, 115], label: "Above Average", color: "#22c55e" },
    { min: 21, max: 28, iq: [115, 130], label: "Superior", color: "#3b82f6" },
    { min: 29, max: 36, iq: [130, 145], label: "Gifted", color: "#8b5cf6" },
    { min: 37, max: 99, iq: [145, 160], label: "Exceptional", color: "#ec4899" }
  ];

  var CAT_COLORS = {
    "Pattern Recognition": "#3b82f6",
    "Logical Reasoning": "#22c55e",
    "Spatial Thinking": "#f59e0b",
    "Numerical Ability": "#ec4899"
  };

  // DOM
  var instructionsView = document.getElementById('instructionsView');
  var quizView = document.getElementById('quizView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var retakeBtn = document.getElementById('retakeBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var categoryBadge = document.getElementById('categoryBadge');
  var resultIcon = document.getElementById('resultIcon');
  var resultIQ = document.getElementById('resultIQ');
  var resultLabel = document.getElementById('resultLabel');
  var resultDesc = document.getElementById('resultDesc');
  var categoryChart = document.getElementById('categoryChart');
  var bellCurveContainer = document.getElementById('bellCurveContainer');
  var disclaimerText = document.getElementById('disclaimerText');

  var currentIndex = 0;
  var shuffled = [];
  var totalScore = 0;
  var catScores = {};
  var catMaxes = {};
  var isProcessing = false;

  function shuffleArr(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
    }
    return a;
  }

  function showView(view) {
    instructionsView.style.display = 'none';
    quizView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function renderQuestion() {
    var q = shuffled[currentIndex];
    progressText.textContent = 'Question ' + (currentIndex + 1) + ' of 20';
    progressFill.style.width = Math.round((currentIndex / 20) * 100) + '%';
    questionText.textContent = q.text;
    categoryBadge.innerHTML = '<span class="iq-cat-badge" style="background:' + (CAT_COLORS[q.cat] || '#6b7280') + ';">' + q.cat + '</span>';

    optionsContainer.innerHTML = '';
    for (var i = 0; i < q.options.length; i++) {
      var btn = document.createElement('button');
      btn.className = 'quiz-option';
      btn.type = 'button';
      btn.textContent = q.options[i];
      btn.setAttribute('data-idx', String(i));
      optionsContainer.appendChild(btn);
    }
  }

  function handleOptionClick(e) {
    if (isProcessing) return;
    var target = e.target;
    if (!target || !target.classList || !target.classList.contains('quiz-option')) return;

    isProcessing = true;
    var idx = parseInt(target.getAttribute('data-idx'), 10);
    var q = shuffled[currentIndex];
    var correct = idx === q.answer;

    if (correct) {
      totalScore += q.pts;
      catScores[q.cat] = (catScores[q.cat] || 0) + q.pts;
      target.style.borderColor = '#22c55e';
      target.style.background = '#22c55e';
      target.style.color = '#fff';
    } else {
      target.style.borderColor = '#ef4444';
      target.style.background = '#ef4444';
      target.style.color = '#fff';
      // Highlight correct answer
      var btns = optionsContainer.querySelectorAll('.quiz-option');
      for (var b = 0; b < btns.length; b++) {
        if (parseInt(btns[b].getAttribute('data-idx'), 10) === q.answer) {
          btns[b].style.borderColor = '#22c55e';
          btns[b].style.background = '#22c55e';
          btns[b].style.color = '#fff';
        }
      }
    }

    setTimeout(function () {
      currentIndex++;
      if (currentIndex >= 20) {
        showResults();
      } else {
        renderQuestion();
      }
      isProcessing = false;
    }, 800);
  }

  function showResults() {
    showView(resultView);
    progressFill.style.width = '100%';

    // Find IQ range
    var range = IQ_RANGES[1];
    for (var r = 0; r < IQ_RANGES.length; r++) {
      if (totalScore >= IQ_RANGES[r].min && totalScore <= IQ_RANGES[r].max) {
        range = IQ_RANGES[r];
        break;
      }
    }

    // Interpolate IQ within range
    var rangeSpan = range.max - range.min;
    var scoreInRange = totalScore - range.min;
    var pct = rangeSpan > 0 ? scoreInRange / rangeSpan : 0.5;
    var estimatedIQ = Math.round(range.iq[0] + pct * (range.iq[1] - range.iq[0]));

    resultIcon.textContent = gameIcon;
    resultIQ.innerHTML = '<span class="iq-score-big">' + estimatedIQ + '</span>';
    resultLabel.innerHTML = '<span class="iq-range-text">Estimated IQ: ' + range.iq[0] + ' - ' + range.iq[1] + '</span>';

    // Descriptions
    var descriptions = {
      "Below Average": "Your score suggests room for growth in these cognitive areas. Remember that IQ tests measure only specific types of intelligence, and many successful people score in this range. Practice with logic puzzles, math problems, and pattern games can help sharpen these skills.",
      "Average": "Your score falls within the average range, where the majority of people score. This indicates solid cognitive abilities across the tested domains. You have a balanced foundation of analytical skills that serves you well in everyday life.",
      "Above Average": "Your score indicates above-average cognitive abilities. You demonstrate strong skills in reasoning, pattern recognition, and problem-solving. This level of cognitive function is associated with success in academic and professional environments.",
      "Superior": "Excellent! Your score indicates superior cognitive abilities. You demonstrate exceptional skills in analytical thinking, pattern recognition, and logical reasoning. You likely excel in complex problem-solving and abstract thinking tasks.",
      "Gifted": "Outstanding! Your score places you in the gifted range, representing the top 2% of the population. You show remarkable abilities in abstract reasoning, pattern recognition, and cognitive flexibility.",
      "Exceptional": "Remarkable! Your score suggests exceptional cognitive abilities, placing you among a very small percentage of the population. You demonstrate extraordinary pattern recognition, logical reasoning, and problem-solving capabilities."
    };
    resultDesc.textContent = descriptions[range.label] || descriptions["Average"];

    // Bell curve SVG
    var markerX = 20 + ((estimatedIQ - 55) / (145 - 55)) * 360;
    if (markerX < 20) markerX = 20;
    if (markerX > 380) markerX = 380;

    bellCurveContainer.innerHTML = '<div class="iq-bell-wrap">' +
      '<svg class="iq-bell-svg" viewBox="0 0 400 120">' +
      '<path class="iq-bell-fill" d="M20,110 Q60,108 100,100 Q150,70 200,20 Q250,70 300,100 Q340,108 380,110 Z"/>' +
      '<path class="iq-bell-curve" d="M20,110 Q60,108 100,100 Q150,70 200,20 Q250,70 300,100 Q340,108 380,110"/>' +
      '<line class="iq-bell-marker" x1="' + markerX + '" y1="10" x2="' + markerX + '" y2="115"/>' +
      '<circle cx="' + markerX + '" cy="10" r="4" fill="var(--color-primary)"/>' +
      '</svg>' +
      '<div class="iq-bell-labels"><span>70</span><span>85</span><span>100</span><span>115</span><span>130</span><span>145</span></div>' +
      '</div>';

    // Category breakdown
    var cats = ["Pattern Recognition", "Logical Reasoning", "Spatial Thinking", "Numerical Ability"];
    var chartHTML = '';
    for (var c = 0; c < cats.length; c++) {
      var cat = cats[c];
      var scored = catScores[cat] || 0;
      var maxPts = catMaxes[cat] || 1;
      var catPct = Math.round((scored / maxPts) * 100);
      var color = CAT_COLORS[cat] || 'var(--color-primary)';
      chartHTML += '<div class="quiz-bar-item">';
      chartHTML += '<div class="quiz-bar-label"><span>' + cat + '</span><span>' + catPct + '%</span></div>';
      chartHTML += '<div class="quiz-bar-track"><div class="quiz-bar-fill" style="width:' + catPct + '%;background:' + color + ';"></div></div>';
      chartHTML += '</div>';
    }
    categoryChart.innerHTML = chartHTML;

    disclaimerText.textContent = 'Disclaimer: This is a quick estimation for entertainment purposes. For an accurate IQ assessment, consult a licensed psychologist who can administer a standardized test like the WAIS-IV or Stanford-Binet in a clinical setting.';

    // GameShare
    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: estimatedIQ,
        unit: 'IQ',
        metricLabel: metricLabel,
        ratingLabel: range.label,
        ratingColor: range.color
      });
    }
  }

  function startQuiz() {
    currentIndex = 0;
    totalScore = 0;
    catScores = {};
    catMaxes = {};
    isProcessing = false;

    // Calculate max possible per category
    for (var i = 0; i < questions.length; i++) {
      var cat = questions[i].cat;
      catMaxes[cat] = (catMaxes[cat] || 0) + questions[i].pts;
    }

    shuffled = shuffleArr(questions);
    showView(quizView);
    renderQuestion();
    if (window.GameShare) window.GameShare.hide();
  }

  startBtn.addEventListener('click', startQuiz);
  retakeBtn.addEventListener('click', startQuiz);
  optionsContainer.addEventListener('click', handleOptionClick);
})();
</script>
