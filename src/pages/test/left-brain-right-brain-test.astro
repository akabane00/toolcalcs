      { label: "Math and science", side: "L" },
      { label: "Art and music", side: "R" }
    ]},
    { text: "When watching a movie, you tend to focus on:", options: [
      { label: "The plot logic, continuity, and whether the story makes sense", side: "L" },
      { label: "The visuals, music, emotional impact, and artistic style", side: "R" }
    ]},
    { text: "How do you usually remember people?", options: [
      { label: "By their name and the facts they shared about themselves", side: "L" },
      { label: "By their face, voice, and the feeling of the interaction", side: "R" }
    ]},
    { text: "When you have free time, you prefer:", options: [
      { label: "Doing a puzzle, playing strategy games, or reading", side: "L" },
      { label: "Drawing, playing music, daydreaming, or exploring nature", side: "R" }
    ]},
    { text: "How do you feel about strict deadlines?", options: [
      { label: "I work best with clear deadlines and structure", side: "L" },
      { label: "I feel constrained by deadlines and prefer flexibility", side: "R" }
    ]},
    { text: "When explaining a concept to someone, you:", options: [
      { label: "Use precise language, definitions, and logical examples", side: "L" },
      { label: "Use analogies, metaphors, and visual comparisons", side: "R" }
    ]},
    { text: "What type of music do you prefer?", options: [
      { label: "Music with clever lyrics and complex composition", side: "L" },
      { label: "Music that creates a mood, feeling, or atmosphere", side: "R" }
    ]},
    { text: "When shopping for a product, you typically:", options: [
      { label: "Compare specs, read reviews, and make a spreadsheet", side: "L" },
      { label: "Choose based on how it looks, feels, and appeals to you", side: "R" }
    ]},
    { text: "In a debate, you are more likely to:", options: [
      { label: "Present logical arguments backed by evidence and data", side: "L" },
      { label: "Appeal to emotions, values, and personal stories", side: "R" }
    ]},
    { text: "When you daydream, you usually think about:", options: [
      { label: "Plans, goals, and strategies for the future", side: "L" },
      { label: "Imaginary scenarios, creative ideas, or past experiences", side: "R" }
    ]},
    { text: "Which describes your approach to rules?", options: [
      { label: "Rules exist for good reasons and should be followed", side: "L" },
      { label: "Rules are guidelines that can be bent when needed", side: "R" }
    ]},
    { text: "When faced with ambiguity, you:", options: [
      { label: "Feel uncomfortable and want to clarify things immediately", side: "L" },
      { label: "Feel comfortable with uncertainty and explore possibilities", side: "R" }
    ]}
  ];

  var leftTraits = ["Logical thinking", "Detail-oriented", "Analytical", "Sequential processing", "Mathematical ability", "Language skills", "Fact-based decisions", "Rule-following"];
  var rightTraits = ["Creative thinking", "Big-picture view", "Intuitive", "Holistic processing", "Artistic ability", "Spatial awareness", "Emotion-based decisions", "Imaginative"];

  // DOM refs
  var instructionsView = document.getElementById('instructionsView');
  var quizView = document.getElementById('quizView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var retakeBtn = document.getElementById('retakeBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var resultType = document.getElementById('resultType');
  var resultName = document.getElementById('resultName');
  var resultDesc = document.getElementById('resultDesc');
  var donutContainer = document.getElementById('donutContainer');
  var traitsComparison = document.getElementById('traitsComparison');
  var resultLearning = document.getElementById('resultLearning');

  var currentIndex = 0;
  var shuffled = [];
  var leftScore = 0;
  var rightScore = 0;
  var isProcessing = false;

  function shuffleArr(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
    }
    return a;
  }

  function showView(view) {
    instructionsView.style.display = 'none';
    quizView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function renderQuestion() {
    var q = shuffled[currentIndex];
    progressText.textContent = 'Question ' + (currentIndex + 1) + ' of 20';
    progressFill.style.width = Math.round((currentIndex / 20) * 100) + '%';
    questionText.textContent = q.text;

    optionsContainer.innerHTML = '';
    var opts = shuffleArr(q.options);
    for (var i = 0; i < opts.length; i++) {
      var btn = document.createElement('button');
      btn.className = 'quiz-option';
      btn.type = 'button';
      btn.textContent = opts[i].label;
      btn.setAttribute('data-side', opts[i].side);
      optionsContainer.appendChild(btn);
    }
  }

  function handleOptionClick(e) {
    if (isProcessing) return;
    var target = e.target;
    if (!target || !target.classList || !target.classList.contains('quiz-option')) return;

    isProcessing = true;
    var side = target.getAttribute('data-side');
    if (side === 'L') leftScore++;
    else rightScore++;

    target.classList.add('selected');

    setTimeout(function () {
      currentIndex++;
      if (currentIndex >= 20) {
        showResults();
      } else {
        renderQuestion();
      }
      isProcessing = false;
    }, 300);
  }

  function showResults() {
    showView(resultView);
    progressFill.style.width = '100%';

    var total = leftScore + rightScore;
    var leftPct = Math.round((leftScore / total) * 100);
    var rightPct = 100 - leftPct;

    // Determine dominance
    var dominance, dominanceDesc, learningTip;
    if (leftPct >= 65) {
      dominance = "Left Brain Dominant";
      dominanceDesc = "You are a strongly analytical and logical thinker. You excel at breaking down complex problems into manageable steps, organizing information systematically, and making decisions based on facts and evidence. Your structured approach to life makes you reliable, detail-oriented, and methodical. You thrive in environments that value precision and clear reasoning.";
      learningTip = "You learn best through structured formats: outlines, step-by-step guides, written instructions, and logical sequences. Consider using spreadsheets, timelines, and categorization systems to organize new information.";
    } else if (rightPct >= 65) {
      dominance = "Right Brain Dominant";
      dominanceDesc = "You are a strongly creative and intuitive thinker. You excel at seeing the big picture, recognizing patterns, and generating innovative ideas. Your holistic approach to life makes you imaginative, emotionally intelligent, and adaptable. You thrive in environments that value originality and allow creative freedom.";
      learningTip = "You learn best through visual and experiential formats: diagrams, mind maps, color coding, hands-on activities, and real-world applications. Consider using metaphors, stories, and visual aids to connect with new information.";
    } else {
      dominance = "Balanced Brain";
      dominanceDesc = "You have an excellent balance between analytical and creative thinking. You can switch between logical analysis and creative brainstorming depending on what the situation demands. This cognitive flexibility is a significant strength, allowing you to approach problems from multiple angles and adapt to diverse challenges.";
      learningTip = "You can adapt your learning approach to match the material. Use structured methods for technical subjects and creative approaches for abstract concepts. Your versatility is your greatest learning advantage.";
    }

    // Render donut chart
    var circumference = 2 * Math.PI * 70; // radius 70
    var leftDash = (leftPct / 100) * circumference;
    var rightDash = (rightPct / 100) * circumference;

    donutContainer.innerHTML = '<div class="lb-donut-wrap">' +
      '<svg class="lb-donut-svg" viewBox="0 0 180 180">' +
      '<circle class="lb-donut-bg" cx="90" cy="90" r="70"/>' +
      '<circle class="lb-donut-left" cx="90" cy="90" r="70" stroke-dasharray="' + leftDash + ' ' + circumference + '" stroke-dashoffset="0"/>' +
      '<circle class="lb-donut-right" cx="90" cy="90" r="70" stroke-dasharray="' + rightDash + ' ' + circumference + '" stroke-dashoffset="-' + leftDash + '"/>' +
      '</svg>' +
      '<div class="lb-donut-center"><div class="lb-donut-pct">' + leftPct + '/' + rightPct + '</div><div class="lb-donut-label">L / R</div></div>' +
      '</div>' +
      '<div class="lb-legend">' +
      '<span><span class="lb-legend-dot" style="background:#3b82f6;"></span>Left ' + leftPct + '%</span>' +
      '<span><span class="lb-legend-dot" style="background:#ec4899;"></span>Right ' + rightPct + '%</span>' +
      '</div>';

    resultType.textContent = dominance;
    resultName.textContent = leftPct + '% Left Brain / ' + rightPct + '% Right Brain';
    resultDesc.textContent = dominanceDesc;

    // Traits comparison grid
    var traitsHTML = '<div class="lb-traits-grid">';
    traitsHTML += '<div class="lb-traits-col"><h4 style="color:#3b82f6;">Left Brain Traits</h4><ul>';
    for (var i = 0; i < leftTraits.length; i++) {
      traitsHTML += '<li>' + (leftPct >= 50 ? '\u2705 ' : '\u25CB ') + leftTraits[i] + '</li>';
    }
    traitsHTML += '</ul></div>';
    traitsHTML += '<div class="lb-traits-col"><h4 style="color:#ec4899;">Right Brain Traits</h4><ul>';
    for (var j = 0; j < rightTraits.length; j++) {
      traitsHTML += '<li>' + (rightPct >= 50 ? '\u2705 ' : '\u25CB ') + rightTraits[j] + '</li>';
    }
    traitsHTML += '</ul></div></div>';
    traitsComparison.innerHTML = traitsHTML;

    resultLearning.innerHTML = '<strong>Your Learning Style:</strong> ' + learningTip;

    // GameShare
    if (window.GameShare) {
      var ratingColor = leftPct >= 65 ? '#3b82f6' : rightPct >= 65 ? '#ec4899' : '#8b5cf6';
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: leftPct + '% L / ' + rightPct + '% R',
        unit: '',
        metricLabel: metricLabel,
        ratingLabel: dominance,
        ratingColor: ratingColor
      });
    }
  }

  function startQuiz() {
    currentIndex = 0;
    leftScore = 0;
    rightScore = 0;
    shuffled = shuffleArr(questions);
    isProcessing = false;
    showView(quizView);
    renderQuestion();
    if (window.GameShare) window.GameShare.hide();
  }

  startBtn.addEventListener('click', startQuiz);
  retakeBtn.addEventListener('click', startQuiz);
  optionsContainer.addEventListener('click', handleOptionClick);
})();
</script>
