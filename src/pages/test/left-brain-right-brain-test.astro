<script define:vars={{ gameName: "Left Brain Right Brain Test", gameSlug: "left-brain-right-brain-test", gameIcon: "\uD83E\uDDE0", metricLabel: "Brain Dominance", metricUnit: "" }}>
(function () {
  'use strict';

  var questions = [
    { text: "When making an important decision, you tend to:", options: [
      { label: "Analyze all the facts and data before choosing", side: "L" },
      { label: "Go with your gut feeling and intuition", side: "R" }
    ]},
    { text: "When organizing a project, you prefer to:", options: [
      { label: "Create a detailed plan with timelines and milestones", side: "L" },
      { label: "Start with a rough vision and figure it out as you go", side: "R" }
    ]},
    { text: "Which type of book do you enjoy more?", options: [
      { label: "Non-fiction: science, history, or self-improvement", side: "L" },
      { label: "Fiction: novels, fantasy, or poetry", side: "R" }
    ]},
    { text: "When solving a problem, your first instinct is to:", options: [
      { label: "Break it down into smaller, logical steps", side: "L" },
      { label: "Look at the big picture and brainstorm creative solutions", side: "R" }
