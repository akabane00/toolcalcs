      icon: "\uD83E\uDD1D",
      desc: "Actions speak louder than words for you. You feel most loved when your partner shows care through helpful actions \u2014 cooking a meal, running errands, fixing something around the house, or taking tasks off your plate.",
      tips: ["Help with chores without being asked", "Take care of tasks your partner finds stressful", "Follow through on commitments and promises", "Anticipate needs before being told"]
    },
    gifts: {
      name: "Receiving Gifts",
      icon: "\uD83C\uDF81",
      desc: "You cherish thoughtful gifts that show your partner was thinking about you. It is not about materialism \u2014 it is the thought, effort, and symbolism behind each gift that makes you feel truly loved and remembered.",
      tips: ["Give small, thoughtful gifts regularly", "Remember significant dates and milestones", "Pick up small items that remind you of them", "Put thought into the presentation and meaning"]
    },
    time: {
      name: "Quality Time",
      icon: "\u23F0",
      desc: "Nothing says 'I love you' like undivided attention. You feel most loved when your partner is fully present \u2014 no phones, no distractions \u2014 just genuine, focused togetherness and meaningful conversation.",
      tips: ["Put away devices during conversations", "Plan regular one-on-one activities", "Make eye contact and actively listen", "Create rituals of connection like morning coffee or evening walks"]
    },
    touch: {
      name: "Physical Touch",
      icon: "\uD83E\uDD17",
      desc: "Physical closeness and affection make you feel secure and loved. Hugs, hand-holding, cuddling, and other forms of physical connection are your primary way of feeling bonded to your partner.",
      tips: ["Hold hands when walking together", "Give hugs when greeting and saying goodbye", "Sit close during conversations", "Offer comfort through physical presence during tough times"]
    }
  };

  var LANG_COLORS = {
    words: '#e91e63',
    acts: '#ff9800',
    gifts: '#9c27b0',
    time: '#2196f3',
    touch: '#4caf50'
  };

  // DOM references
  var instructionsView = document.getElementById('instructionsView');
  var quizView = document.getElementById('quizView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var retakeBtn = document.getElementById('retakeBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var resultIcon = document.getElementById('resultIcon');
  var resultType = document.getElementById('resultType');
  var resultName = document.getElementById('resultName');
  var resultDesc = document.getElementById('resultDesc');
  var dimensionChart = document.getElementById('dimensionChart');
  var resultTips = document.getElementById('resultTips');

  var currentIndex = 0;
  var shuffled = [];
  var scores = { words: 0, acts: 0, gifts: 0, time: 0, touch: 0 };
  var isProcessing = false;

  // Fisher-Yates shuffle
  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i];
      a[i] = a[j];
      a[j] = tmp;
    }
    return a;
  }

  function showView(view) {
    instructionsView.style.display = 'none';
    quizView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function renderQuestion() {
    var q = shuffled[currentIndex];
    progressText.textContent = 'Question ' + (currentIndex + 1) + ' of 30';
    progressFill.style.width = Math.round(((currentIndex) / 30) * 100) + '%';
    questionText.textContent = q.text;

    optionsContainer.innerHTML = '';
    for (var i = 0; i < q.options.length; i++) {
      var btn = document.createElement('button');
      btn.className = 'quiz-option';
      btn.type = 'button';
      btn.textContent = q.options[i].label;
      btn.setAttribute('data-dim', q.options[i].dim);
      optionsContainer.appendChild(btn);
    }
  }

  function handleOptionClick(e) {
    if (isProcessing) return;
    var target = e.target;
    if (!target || !target.classList || !target.classList.contains('quiz-option')) return;

    isProcessing = true;
    var dim = target.getAttribute('data-dim');
    scores[dim] = (scores[dim] || 0) + 1;

    target.classList.add('selected');

    setTimeout(function () {
      currentIndex++;
      if (currentIndex >= 30) {
        showResults();
      } else {
        renderQuestion();
      }
      isProcessing = false;
    }, 300);
  }

  function showResults() {
    showView(resultView);
    progressFill.style.width = '100%';

    // Find top language
    var topDim = 'words';
    var topScore = 0;
    var dims = ['words', 'acts', 'gifts', 'time', 'touch'];
    for (var i = 0; i < dims.length; i++) {
      if (scores[dims[i]] > topScore) {
        topScore = scores[dims[i]];
        topDim = dims[i];
      }
    }

    var topLang = languages[topDim];
    resultIcon.textContent = topLang.icon;
    resultType.textContent = topLang.name;
    resultName.textContent = 'Your Primary Love Language';
    resultDesc.textContent = topLang.desc;

    // Build sorted bar chart
    var sorted = dims.slice().sort(function (a, b) { return scores[b] - scores[a]; });
    var totalPoints = 30;
    var chartHTML = '';
    for (var j = 0; j < sorted.length; j++) {
      var key = sorted[j];
      var pct = Math.round((scores[key] / totalPoints) * 100);
      var color = LANG_COLORS[key] || 'var(--color-primary)';
      chartHTML += '<div class="quiz-bar-item">';
      chartHTML += '<div class="quiz-bar-label"><span>' + languages[key].icon + ' ' + languages[key].name + '</span><span>' + pct + '%</span></div>';
      chartHTML += '<div class="quiz-bar-track"><div class="quiz-bar-fill" style="width:' + pct + '%;background:' + color + ';"></div></div>';
      chartHTML += '</div>';
    }
    dimensionChart.innerHTML = chartHTML;

    // Show tips for top language
    var tipsHTML = '<h3>Tips for ' + topLang.name + '</h3><ul>';
    for (var t = 0; t < topLang.tips.length; t++) {
      tipsHTML += '<li>' + topLang.tips[t] + '</li>';
    }
    tipsHTML += '</ul>';
    resultTips.innerHTML = tipsHTML;

    // GameShare
    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: topLang.icon,
        score: topLang.name,
        unit: Math.round((topScore / 30) * 100) + '%',
        metricLabel: metricLabel,
        ratingLabel: topLang.name,
        ratingColor: '#e91e63'
      });
    }
  }

  function startQuiz() {
    currentIndex = 0;
    scores = { words: 0, acts: 0, gifts: 0, time: 0, touch: 0 };
    shuffled = shuffle(questions);
    isProcessing = false;
    showView(quizView);
    renderQuestion();

    if (window.GameShare) {
      window.GameShare.hide();
    }
  }

  // Event listeners
  startBtn.addEventListener('click', startQuiz);
  retakeBtn.addEventListener('click', startQuiz);
  optionsContainer.addEventListener('click', handleOptionClick);
})();
</script>
