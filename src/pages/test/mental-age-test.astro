  ];

  var ageBrackets = [
    { min: 10, max: 19, label: "Teen Spirit", icon: "\uD83D\uDE1C",
      desc: "Your mind is bursting with youthful energy, spontaneity, and enthusiasm! You live in the moment, embrace trends, and approach life with a carefree attitude. Your curiosity about the world is infectious, and you are not afraid to try new things or make mistakes.",
      traits: ["Spontaneous", "Energetic", "Trend-savvy", "Social butterfly", "Risk-taking", "Optimistic"] },
    { min: 20, max: 29, label: "Young Explorer", icon: "\uD83C\uDF1F",
      desc: "Your mental age reflects a perfect balance of youthful energy and emerging maturity. You are adventurous and open-minded, but you are also starting to develop long-term goals and meaningful relationships. The world feels full of possibilities.",
      traits: ["Adventurous", "Adaptable", "Ambitious", "Open-minded", "Tech-savvy", "Socially active"] },
    { min: 30, max: 39, label: "Balanced Adult", icon: "\uD83C\uDFAF",
      desc: "Your mind strikes an excellent balance between fun and responsibility. You know what you want, you are confident in your choices, and you have developed strong emotional intelligence. You enjoy both social time and quiet moments of reflection.",
      traits: ["Confident", "Emotionally mature", "Goal-oriented", "Balanced", "Self-aware", "Reliable"] },
    { min: 40, max: 49, label: "Wise Realist", icon: "\uD83E\uDDD0",
      desc: "Your mental age reflects deep wisdom, patience, and a clear sense of priorities. You value quality over quantity in all aspects of life. You have learned from experience and approach challenges with calm confidence. Stability and meaningful connections matter most to you.",
      traits: ["Patient", "Wise", "Pragmatic", "Calm under pressure", "Selective", "Experienced"] },
    { min: 50, max: 70, label: "Old Soul", icon: "\uD83E\uDDD3",
      desc: "You carry the wisdom and serenity of an old soul. Your mind values peace, reflection, and deep human connection above all else. You have a philosophical outlook on life and prefer substance over superficiality. Your emotional depth and patience are remarkable.",
      traits: ["Philosophical", "Serene", "Deeply empathetic", "Reflective", "Traditional", "Content"] }
  ];

  // DOM references
  var instructionsView = document.getElementById('instructionsView');
  var quizView = document.getElementById('quizView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var retakeBtn = document.getElementById('retakeBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var resultIcon = document.getElementById('resultIcon');
  var resultAge = document.getElementById('resultAge');
  var resultLabel = document.getElementById('resultLabel');
  var resultDesc = document.getElementById('resultDesc');
  var resultTraitsChart = document.getElementById('resultTraitsChart');
  var resultTraits = document.getElementById('resultTraits');

  var currentIndex = 0;
  var shuffled = [];
  var totalWeight = 0;
  var isProcessing = false;

  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
    }
    return a;
  }

  function showView(view) {
    instructionsView.style.display = 'none';
    quizView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function renderQuestion() {
    var q = shuffled[currentIndex];
    progressText.textContent = 'Question ' + (currentIndex + 1) + ' of 25';
    progressFill.style.width = Math.round((currentIndex / 25) * 100) + '%';
    questionText.textContent = q.text;

    optionsContainer.innerHTML = '';
    var opts = shuffle(q.options);
    for (var i = 0; i < opts.length; i++) {
      var btn = document.createElement('button');
      btn.className = 'quiz-option';
      btn.type = 'button';
      btn.textContent = opts[i].label;
      btn.setAttribute('data-weight', String(opts[i].weight));
      optionsContainer.appendChild(btn);
    }
  }

  function handleOptionClick(e) {
    if (isProcessing) return;
    var target = e.target;
    if (!target || !target.classList || !target.classList.contains('quiz-option')) return;

    isProcessing = true;
    var w = parseInt(target.getAttribute('data-weight'), 10);
    totalWeight += w;
    target.classList.add('selected');

    setTimeout(function () {
      currentIndex++;
      if (currentIndex >= 25) {
        showResults();
      } else {
        renderQuestion();
      }
      isProcessing = false;
    }, 300);
  }

  function showResults() {
    showView(resultView);
    progressFill.style.width = '100%';

    // Calculate mental age: average of weights, roughly 10-56 range mapped
    var avg = totalWeight / 25;
    // Map average weight to mental age (15-65 range)
    var mentalAge = Math.round(avg * 1.05);
    if (mentalAge < 12) mentalAge = 12;
    if (mentalAge > 68) mentalAge = 68;

    // Find bracket
    var bracket = ageBrackets[2]; // default to balanced
    for (var i = 0; i < ageBrackets.length; i++) {
      if (mentalAge >= ageBrackets[i].min && mentalAge <= ageBrackets[i].max) {
        bracket = ageBrackets[i];
        break;
      }
    }

    resultIcon.textContent = bracket.icon;
    resultAge.innerHTML = '<span class="ma-age-display">' + mentalAge + '</span> <span class="ma-age-unit">years old</span>';
    resultLabel.innerHTML = '<span class="ma-bracket-title">' + bracket.label + '</span>';
    resultDesc.textContent = bracket.desc;

    // Comparison text
    var comparisonHTML = '<p class="ma-comparison">The average mental age for test takers is 32. ';
    if (mentalAge < 28) {
      comparisonHTML += 'Your mind is younger than most!</p>';
    } else if (mentalAge > 36) {
      comparisonHTML += 'Your mind is more mature than most!</p>';
    } else {
      comparisonHTML += 'You are right around the average!</p>';
    }
    resultTraitsChart.innerHTML = comparisonHTML;

    // Show traits
    var pillsHTML = '<div class="ma-trait-pills">';
    for (var t = 0; t < bracket.traits.length; t++) {
      pillsHTML += '<span class="ma-trait-pill">' + bracket.traits[t] + '</span>';
    }
    pillsHTML += '</div>';
    resultTraits.innerHTML = pillsHTML;

    // GameShare
    if (window.GameShare) {
      var ratingColor = mentalAge < 25 ? '#22c55e' : mentalAge < 35 ? '#2563eb' : mentalAge < 45 ? '#f59e0b' : '#e91e63';
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: bracket.icon,
        score: mentalAge,
        unit: metricUnit,
        metricLabel: metricLabel,
        ratingLabel: bracket.label,
        ratingColor: ratingColor
      });
    }
  }

  function startQuiz() {
    currentIndex = 0;
    totalWeight = 0;
    shuffled = shuffle(questions);
    isProcessing = false;
    showView(quizView);
    renderQuestion();
    if (window.GameShare) window.GameShare.hide();
  }

  startBtn.addEventListener('click', startQuiz);
  retakeBtn.addEventListener('click', startQuiz);
  optionsContainer.addEventListener('click', handleOptionClick);
})();
</script>
