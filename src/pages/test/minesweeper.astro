</style>

<script is:inline>
(function() {
  var DIFFICULTIES = {
    beginner:     { rows: 9,  cols: 9,  mines: 10 },
    intermediate: { rows: 16, cols: 16, mines: 40 },
    expert:       { rows: 16, cols: 30, mines: 99 }
  };

  var ratingScale = [
    { max: 30,       label: 'Speed Demon!',   color: '#16a34a' },
    { max: 60,       label: 'Fast!',          color: '#22c55e' },
    { max: 120,      label: 'Good',           color: '#2563eb' },
    { max: 300,      label: 'Average',        color: '#f59e0b' },
    { max: Infinity, label: 'Careful Player',  color: '#ef4444' }
  ];

  var currentDiff = 'beginner';
  var board = [];       // 2D array of cell objects
  var rows = 9;
  var cols = 9;
  var totalMines = 10;
  var minesLeft = 10;
  var revealedCount = 0;
  var gameState = 'idle'; // idle | playing | won | lost
  var timerVal = 0;
  var timerInterval = null;
  var firstClick = true;
  var attempts = [];
  var longPressTimer = null;
  var longPressTriggered = false;

  var boardEl = document.getElementById('board');
  var mineCountEl = document.getElementById('mineCount');
  var timerEl = document.getElementById('timer');
  var smileyBtn = document.getElementById('smileyBtn');
  var scoreDisplay = document.getElementById('score-display');
  var scoreValue = document.getElementById('score-value');
  var ratingBadge = document.getElementById('rating-badge');
  var btnRetry = document.getElementById('btn-retry');
  var historyDiv = document.getElementById('attempt-history');
  var historyList = document.getElementById('history-list');
  var diffBtns = document.querySelectorAll('.ms-diff-btn');

  // Load history
  try {
    var saved = localStorage.getItem('ms_history');
    if (saved) attempts = JSON.parse(saved);
  } catch(e) {}

  function padNum(n, len) {
    var s = String(n);
    while (s.length < len) s = '0' + s;
    return s;
  }

  function getRatingForTime(t) {
    for (var i = 0; i < ratingScale.length; i++) {
      if (t <= ratingScale[i].max) return ratingScale[i];
    }
    return ratingScale[ratingScale.length - 1];
  }

  function updateMineCount() {
    var val = Math.max(-99, Math.min(999, minesLeft));
    mineCountEl.textContent = val < 0 ? '-' + padNum(Math.abs(val), 2) : padNum(val, 3);
  }

  function updateTimer() {
    timerEl.textContent = padNum(Math.min(timerVal, 999), 3);
  }

  function startTimer() {
    if (timerInterval) return;
    timerVal = 0;
    updateTimer();
    timerInterval = setInterval(function() {
      timerVal++;
      updateTimer();
    }, 1000);
  }

  function stopTimer() {
    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }
  }

  function initBoard() {
    stopTimer();
    var diff = DIFFICULTIES[currentDiff];
    rows = diff.rows;
    cols = diff.cols;
    totalMines = diff.mines;
    minesLeft = totalMines;
    revealedCount = 0;
    gameState = 'idle';
    firstClick = true;
    timerVal = 0;

    board = [];
    for (var r = 0; r < rows; r++) {
      board[r] = [];
      for (var c = 0; c < cols; c++) {
        board[r][c] = {
          isMine: false,
          isRevealed: false,
          isFlagged: false,
          adjacentMines: 0
        };
      }
    }

    updateMineCount();
    updateTimer();
    smileyBtn.innerHTML = '&#128578;';
    scoreDisplay.style.display = 'none';
    btnRetry.style.display = 'none';
    if (window.GameShare) window.GameShare.hide();

    renderBoard();
  }

  function placeMines(safeRow, safeCol) {
    var placed = 0;
    while (placed < totalMines) {
      var r = Math.floor(Math.random() * rows);
      var c = Math.floor(Math.random() * cols);
      // Ensure not on safe cell or its neighbors
      if (Math.abs(r - safeRow) <= 1 && Math.abs(c - safeCol) <= 1) continue;
      if (board[r][c].isMine) continue;
      board[r][c].isMine = true;
      placed++;
    }
    // Calculate adjacent mine counts
    for (var r = 0; r < rows; r++) {
      for (var c = 0; c < cols; c++) {
        if (board[r][c].isMine) continue;
        var count = 0;
        forNeighbors(r, c, function(nr, nc) {
          if (board[nr][nc].isMine) count++;
        });
        board[r][c].adjacentMines = count;
      }
    }
  }

  function forNeighbors(r, c, fn) {
    for (var dr = -1; dr <= 1; dr++) {
      for (var dc = -1; dc <= 1; dc++) {
        if (dr === 0 && dc === 0) continue;
        var nr = r + dr;
        var nc = c + dc;
        if (nr >= 0 && nr < rows && nc >= 0 && nc < cols) {
          fn(nr, nc);
        }
      }
    }
  }

  function renderBoard() {
    boardEl.style.gridTemplateColumns = 'repeat(' + cols + ', auto)';
    boardEl.innerHTML = '';

    for (var r = 0; r < rows; r++) {
      for (var c = 0; c < cols; c++) {
        var cell = document.createElement('div');
        cell.className = 'ms-cell';
        cell.dataset.r = r;
        cell.dataset.c = c;
        updateCellEl(cell, r, c);
        boardEl.appendChild(cell);
      }
    }
  }

  function getCellEl(r, c) {
    return boardEl.children[r * cols + c];
  }

  function updateCellEl(el, r, c) {
    var cell = board[r][c];
    el.innerHTML = '';
    el.className = 'ms-cell';

    if (cell.isRevealed) {
      el.classList.add('revealed');
      if (cell.isMine) {
        el.innerHTML = '<span class="mine">💣</span>';
      } else if (cell.adjacentMines > 0) {
        el.classList.add('n' + cell.adjacentMines);
        el.textContent = cell.adjacentMines;
      }
    } else if (cell.isFlagged) {
      el.innerHTML = '<span class="flag">🚩</span>';
    }
  }

  function revealCell(r, c) {
    var cell = board[r][c];
    if (cell.isRevealed || cell.isFlagged) return;

    cell.isRevealed = true;
    revealedCount++;

    if (cell.isMine) {
      gameOver(r, c);
      return;
    }

    var el = getCellEl(r, c);
    updateCellEl(el, r, c);

    // Flood fill if zero adjacent mines
    if (cell.adjacentMines === 0) {
      forNeighbors(r, c, function(nr, nc) {
        if (!board[nr][nc].isRevealed && !board[nr][nc].isFlagged) {
          revealCell(nr, nc);
        }
      });
    }

    // Check win
    if (revealedCount === rows * cols - totalMines) {
      winGame();
    }
  }

  function toggleFlag(r, c) {
    if (gameState === 'won' || gameState === 'lost') return;
    var cell = board[r][c];
    if (cell.isRevealed) return;

    if (gameState === 'idle') {
      gameState = 'playing';
      startTimer();
    }

    cell.isFlagged = !cell.isFlagged;
    minesLeft += cell.isFlagged ? -1 : 1;
    updateMineCount();

    var el = getCellEl(r, c);
    updateCellEl(el, r, c);
  }

  function handleCellClick(r, c) {
    if (gameState === 'won' || gameState === 'lost') return;
    var cell = board[r][c];
    if (cell.isFlagged || cell.isRevealed) return;

    if (firstClick) {
      firstClick = false;
      gameState = 'playing';
      placeMines(r, c);
      startTimer();
    }

    revealCell(r, c);
  }

  function gameOver(hitR, hitC) {
    gameState = 'lost';
    stopTimer();
    smileyBtn.innerHTML = '&#128565;';

    // Reveal all mines and mark wrong flags
    for (var r = 0; r < rows; r++) {
      for (var c = 0; c < cols; c++) {
        var cell = board[r][c];
        var el = getCellEl(r, c);
        if (cell.isMine && !cell.isFlagged) {
          cell.isRevealed = true;
          updateCellEl(el, r, c);
          if (r === hitR && c === hitC) {
            el.classList.add('mine-hit');
          }
        } else if (!cell.isMine && cell.isFlagged) {
          cell.isRevealed = true;
          el.classList.add('revealed', 'wrong-flag');
          el.innerHTML = '<span class="mine">💣</span>';
          el.style.textDecoration = 'line-through';
        }
      }
    }

    btnRetry.style.display = '';
  }

  function winGame() {
    gameState = 'won';
    stopTimer();
    smileyBtn.innerHTML = '&#128526;';

    // Flag all remaining mines
    for (var r = 0; r < rows; r++) {
      for (var c = 0; c < cols; c++) {
        var cell = board[r][c];
        if (cell.isMine && !cell.isFlagged) {
          cell.isFlagged = true;
          var el = getCellEl(r, c);
          updateCellEl(el, r, c);
        }
      }
    }
    minesLeft = 0;
    updateMineCount();

    var time = timerVal;
    var rating = getRatingForTime(time);

    scoreDisplay.style.display = '';
    scoreValue.textContent = time;
    ratingBadge.textContent = rating.label;
    ratingBadge.style.background = rating.color;
    ratingBadge.style.color = '#fff';
    btnRetry.style.display = '';

    // Save attempt
    attempts.unshift({
      diff: currentDiff,
      time: time,
      label: rating.label,
      date: new Date().toLocaleDateString()
    });
    if (attempts.length > 20) attempts = attempts.slice(0, 20);
    try {
      localStorage.setItem('ms_history', JSON.stringify(attempts));
    } catch(e) {}
    renderHistory();

    // GameShare
    if (window.GameShare) {
      window.GameShare.show({
        gameName: 'Minesweeper (' + currentDiff.charAt(0).toUpperCase() + currentDiff.slice(1) + ')',
        gameSlug: 'minesweeper',
        gameIcon: '💣',
        score: time,
        unit: 'sec',
        metricLabel: 'Completion Time',
        ratingLabel: rating.label,
        ratingColor: rating.color
      });
    }
  }

  function renderHistory() {
    if (attempts.length === 0) {
      historyDiv.style.display = 'none';
      return;
    }
    historyDiv.style.display = '';
    var html = '';
    for (var i = 0; i < attempts.length; i++) {
      var a = attempts[i];
      var diffLabel = a.diff.charAt(0).toUpperCase() + a.diff.slice(1);
      html += '<div class="history-row">' +
        '<span class="history-num">#' + (i + 1) + '</span>' +
        '<span class="history-score">' + a.time + ' sec</span>' +
        '<span class="history-label">' + diffLabel + '</span>' +
        '<span class="history-rating" style="color:' + (getRatingForTime(a.time).color) + '">' + a.label + '</span>' +
        '<span class="history-date">' + a.date + '</span>' +
        '</div>';
    }
    historyList.innerHTML = html;
  }

  // --- Event Listeners ---

  // Difficulty buttons
  for (var i = 0; i < diffBtns.length; i++) {
    diffBtns[i].addEventListener('click', function() {
      for (var j = 0; j < diffBtns.length; j++) {
        diffBtns[j].classList.remove('active');
      }
      this.classList.add('active');
      currentDiff = this.dataset.diff;
      initBoard();
    });
  }

  // Smiley / new game
  smileyBtn.addEventListener('click', function() {
    initBoard();
  });

  // Retry button
  btnRetry.addEventListener('click', function() {
    initBoard();
  });

  // Prevent context menu on the board
  boardEl.addEventListener('contextmenu', function(e) {
    e.preventDefault();
  });

  // Click handler
  boardEl.addEventListener('mousedown', function(e) {
    if (e.button === 2) {
      // Right click = flag
      var cell = e.target.closest('.ms-cell');
      if (!cell) return;
      var r = parseInt(cell.dataset.r, 10);
      var c = parseInt(cell.dataset.c, 10);
      toggleFlag(r, c);
    }
  });

  boardEl.addEventListener('click', function(e) {
    var cell = e.target.closest('.ms-cell');
    if (!cell) return;
    if (longPressTriggered) {
      longPressTriggered = false;
      return;
    }
    var r = parseInt(cell.dataset.r, 10);
    var c = parseInt(cell.dataset.c, 10);
    handleCellClick(r, c);
  });

  // Long press for mobile flagging
  boardEl.addEventListener('touchstart', function(e) {
    var cell = e.target.closest('.ms-cell');
    if (!cell) return;
    longPressTriggered = false;
    var r = parseInt(cell.dataset.r, 10);
    var c = parseInt(cell.dataset.c, 10);
    longPressTimer = setTimeout(function() {
      longPressTriggered = true;
      toggleFlag(r, c);
    }, 400);
  }, { passive: true });

  boardEl.addEventListener('touchend', function(e) {
    if (longPressTimer) {
      clearTimeout(longPressTimer);
      longPressTimer = null;
    }
  });

  boardEl.addEventListener('touchmove', function(e) {
    if (longPressTimer) {
      clearTimeout(longPressTimer);
      longPressTimer = null;
    }
  });

  // Prevent double-tap zoom on mobile
  boardEl.addEventListener('touchend', function(e) {
    e.preventDefault();
    if (longPressTriggered) {
      longPressTriggered = false;
      return;
    }
    var cell = e.target.closest('.ms-cell');
    if (!cell) return;
    var r = parseInt(cell.dataset.r, 10);
    var c = parseInt(cell.dataset.c, 10);
    handleCellClick(r, c);
  });

  // Init
  renderHistory();
  initBoard();
})();
</script>
