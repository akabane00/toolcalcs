  var STORAGE_KEY = 'toolcalcs_personality-type-test_history';
  var MAX_HISTORY = 20;

  var scores = { EI: 0, SN: 0, TF: 0, JP: 0 };
  var currentQ = 0;
  var shuffled = [];

  var instructionsView = document.getElementById('instructionsView');
  var quizView = document.getElementById('quizView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var retakeBtn = document.getElementById('retakeBtn');
  var progressText = document.getElementById('progressText');
  var progressFill = document.getElementById('progressFill');
  var questionText = document.getElementById('questionText');
  var optionsContainer = document.getElementById('optionsContainer');
  var resultType = document.getElementById('resultType');
  var resultName = document.getElementById('resultName');
  var resultDesc = document.getElementById('resultDesc');
  var dimensionChart = document.getElementById('dimensionChart');
  var strengthsUl = document.getElementById('strengthsUl');
  var weaknessesUl = document.getElementById('weaknessesUl');
  var careersUl = document.getElementById('careersUl');
  var attemptHistorySection = document.getElementById('attemptHistory');
  var historyList = document.getElementById('historyList');

  function shuffle(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i];
      a[i] = a[j];
      a[j] = tmp;
    }
    return a;
  }

  function showView(view) {
    instructionsView.style.display = 'none';
    quizView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function loadHistory() {
    try { var r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch (e) {}
    return [];
  }

  function saveHistory(h) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(h.slice(0, MAX_HISTORY))); } catch (e) {}
  }

  function addToHistory(typeCode) {
    var h = loadHistory();
    var t = types[typeCode];
    h.unshift({ score: typeCode, name: t ? t.name : '', date: new Date().toISOString() });
    saveHistory(h);
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    historyList.innerHTML = history.map(function (e) {
      return '<div class="history-item">' +
        '<span class="history-score">' + e.score + '</span>' +
        '<span class="history-rating" style="background:#2563eb">' + (e.name || '') + '</span>' +
        '<span class="history-time">' + formatDate(e.date) + '</span>' +
      '</div>';
    }).join('');
  }

  function startQuiz() {
    scores = { EI: 0, SN: 0, TF: 0, JP: 0 };
    currentQ = 0;
    shuffled = shuffle(questions);
    showView(quizView);
    renderQuestion();
  }

  function renderQuestion() {
    var q = shuffled[currentQ];
    progressText.textContent = 'Question ' + (currentQ + 1) + ' of ' + shuffled.length;
    progressFill.style.width = Math.round(((currentQ) / shuffled.length) * 100) + '%';
    questionText.textContent = q.text;

    optionsContainer.innerHTML = '';
    var opts = Math.random() < 0.5 ? [q.options[0], q.options[1]] : [q.options[1], q.options[0]];
    for (var i = 0; i < opts.length; i++) {
      (function (opt) {
        var btn = document.createElement('button');
        btn.className = 'quiz-option';
        btn.type = 'button';
        btn.textContent = opt.label;
        btn.addEventListener('click', function () {
          handleAnswer(opt);
        });
        optionsContainer.appendChild(btn);
      })(opts[i]);
    }
  }

  function handleAnswer(opt) {
    scores[opt.dim] += opt.val;

    var btns = optionsContainer.querySelectorAll('.quiz-option');
    for (var i = 0; i < btns.length; i++) {
      if (btns[i].textContent === opt.label) {
        btns[i].classList.add('selected');
      }
      btns[i].style.pointerEvents = 'none';
    }

    currentQ++;
    if (currentQ >= shuffled.length) {
      setTimeout(function () { showResult(); }, 350);
    } else {
      setTimeout(function () { renderQuestion(); }, 350);
    }
  }

  function determineType() {
    var e = scores.EI >= 0 ? 'E' : 'I';
    var n = scores.SN >= 0 ? 'N' : 'S';
    var t = scores.TF >= 0 ? 'T' : 'F';
    var j = scores.JP >= 0 ? 'J' : 'P';
    return e + n + t + j;
  }

  function showResult() {
    var typeCode = determineType();
    var typeData = types[typeCode];
    if (!typeData) { typeData = types['INFJ']; }

    showView(resultView);
    resultType.textContent = typeCode;
    resultName.textContent = typeData.name;
    resultDesc.textContent = typeData.desc;

    var maxScore = 10;
    var dims = [
      { left: 'E', right: 'I', key: 'EI', leftLabel: 'Extraversion', rightLabel: 'Introversion' },
      { left: 'S', right: 'N', key: 'SN', leftLabel: 'Sensing', rightLabel: 'Intuition' },
      { left: 'T', right: 'F', key: 'TF', leftLabel: 'Thinking', rightLabel: 'Feeling' },
      { left: 'J', right: 'P', key: 'JP', leftLabel: 'Judging', rightLabel: 'Perceiving' }
    ];

    dimensionChart.innerHTML = '';
    for (var i = 0; i < dims.length; i++) {
      var d = dims[i];
      var raw = scores[d.key];
      var leftPct = Math.round(50 + (raw / maxScore) * 50);
      if (leftPct > 100) leftPct = 100;
      if (leftPct < 0) leftPct = 0;
      var rightPct = 100 - leftPct;

      var item = document.createElement('div');
      item.className = 'quiz-bar-item';
      item.innerHTML =
        '<div class="quiz-bar-label">' +
          '<span>' + d.leftLabel + ' ' + leftPct + '%</span>' +
          '<span>' + d.rightLabel + ' ' + rightPct + '%</span>' +
        '</div>' +
        '<div class="quiz-bar-track">' +
          '<div class="quiz-bar-fill" style="width:' + leftPct + '%"></div>' +
        '</div>';
      dimensionChart.appendChild(item);
    }

    strengthsUl.innerHTML = '';
    for (var s = 0; s < typeData.strengths.length; s++) {
      var li = document.createElement('li');
      li.textContent = typeData.strengths[s];
      strengthsUl.appendChild(li);
    }

    weaknessesUl.innerHTML = '';
    for (var w = 0; w < typeData.weaknesses.length; w++) {
      var li2 = document.createElement('li');
      li2.textContent = typeData.weaknesses[w];
      weaknessesUl.appendChild(li2);
    }

    careersUl.innerHTML = '';
    for (var c = 0; c < typeData.careers.length; c++) {
      var li3 = document.createElement('li');
      li3.textContent = typeData.careers[c];
      careersUl.appendChild(li3);
    }

    progressFill.style.width = '100%';

    addToHistory(typeCode);
    renderHistory();

    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: typeCode,
        unit: metricUnit,
        metricLabel: metricLabel,
        ratingLabel: typeData.name,
        ratingColor: '#2563eb'
      });
    }
  }

  startBtn.addEventListener('click', startQuiz);
  retakeBtn.addEventListener('click', startQuiz);
  renderHistory();
})();
</script>
