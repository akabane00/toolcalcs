<script is:inline>
(function() {
  var canvas = document.getElementById('snakeCanvas');
  var ctx = canvas.getContext('2d');
  var scoreEl = document.getElementById('snakeScore');
  var highScoreEl = document.getElementById('snakeHighScore');
  var startOverlay = document.getElementById('snakeStartOverlay');
  var gameOverOverlay = document.getElementById('snakeGameOverOverlay');
  var finalScoreEl = document.getElementById('snakeFinalScore');
  var startBtn = document.getElementById('snakeStartBtn');
  var pauseBtn = document.getElementById('snakePauseBtn');
  var retryBtn = document.getElementById('snakeRetryBtn');
  var scoreDisplay = document.getElementById('snakeScoreDisplay');
  var scoreValue = document.getElementById('snakeScoreValue');
  var ratingBadge = document.getElementById('snakeRating');
  var historyWrap = document.getElementById('snakeHistory');
  var historyList = document.getElementById('snakeHistoryList');

  // D-pad
  var dpadUp = document.getElementById('dpadUp');
  var dpadDown = document.getElementById('dpadDown');
  var dpadLeft = document.getElementById('dpadLeft');
  var dpadRight = document.getElementById('dpadRight');

  var GRID = 20;
  var CELL = 20;
  var BASE_SPEED = 150;
  var MIN_SPEED = 60;
  var SPEED_DEC = 2;

  var snake, food, direction, nextDirection, score, highScore, speed, gameLoop, paused, running;

  // Rating scale (matches games.ts)
  var ratingScale = [
    { max: 5, label: 'Beginner', color: '#ef4444' },
    { max: 15, label: 'Average', color: '#f59e0b' },
    { max: 30, label: 'Good', color: '#2563eb' },
    { max: 50, label: 'Great!', color: '#22c55e' },
    { max: Infinity, label: 'Master!', color: '#16a34a' }
  ];

  function getRatingForScore(s) {
    for (var i = ratingScale.length - 1; i >= 0; i--) {
      if (i === 0) return ratingScale[0];
      var prev = ratingScale[i - 1];
      if (s >= prev.max) return ratingScale[i];
    }
    return ratingScale[0];
  }

  // Load high score
  highScore = parseInt(localStorage.getItem('snake-high-score') || '0', 10);
  highScoreEl.textContent = highScore;

  function init() {
    snake = [
      { x: 12, y: 10 },
      { x: 11, y: 10 },
      { x: 10, y: 10 }
    ];
    direction = 'right';
    nextDirection = 'right';
    score = 0;
    speed = BASE_SPEED;
    paused = false;
    running = true;
    scoreEl.textContent = '0';
    scoreDisplay.hidden = true;
    placeFood();
    draw();
  }

  function placeFood() {
    var empty = [];
    for (var x = 0; x < GRID; x++) {
      for (var y = 0; y < GRID; y++) {
        var onSnake = false;
        for (var i = 0; i < snake.length; i++) {
          if (snake[i].x === x && snake[i].y === y) {
            onSnake = true;
            break;
          }
        }
        if (!onSnake) empty.push({ x: x, y: y });
      }
    }
    if (empty.length === 0) {
      // Snake fills entire grid — you win
      gameOver();
      return;
    }
    food = empty[Math.floor(Math.random() * empty.length)];
  }

  function draw() {
    // Get actual canvas pixel dimensions
    var cw = canvas.width;
    var ch = canvas.height;
    var cellW = cw / GRID;
    var cellH = ch / GRID;

    // Background
    ctx.fillStyle = '#111';
    ctx.fillRect(0, 0, cw, ch);

    // Grid lines (subtle)
    ctx.strokeStyle = 'rgba(255,255,255,0.04)';
    ctx.lineWidth = 1;
    for (var i = 1; i < GRID; i++) {
      ctx.beginPath();
      ctx.moveTo(i * cellW, 0);
      ctx.lineTo(i * cellW, ch);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(0, i * cellH);
      ctx.lineTo(cw, i * cellH);
      ctx.stroke();
    }

    // Food
    if (food) {
      ctx.fillStyle = '#ef4444';
      ctx.beginPath();
      ctx.arc(
        food.x * cellW + cellW / 2,
        food.y * cellH + cellH / 2,
        cellW * 0.4,
        0,
        Math.PI * 2
      );
      ctx.fill();
    }

    // Snake
    for (var i = 0; i < snake.length; i++) {
      var seg = snake[i];
      if (i === 0) {
        // Head
        ctx.fillStyle = '#22c55e';
      } else {
        ctx.fillStyle = '#16a34a';
      }
      ctx.beginPath();
      ctx.roundRect(
        seg.x * cellW + 1,
        seg.y * cellH + 1,
        cellW - 2,
        cellH - 2,
        4
      );
      ctx.fill();
    }
  }

  function update() {
    if (paused || !running) return;

    direction = nextDirection;

    var head = { x: snake[0].x, y: snake[0].y };

    if (direction === 'up') head.y--;
    else if (direction === 'down') head.y++;
    else if (direction === 'left') head.x--;
    else if (direction === 'right') head.x++;

    // Wall collision
    if (head.x < 0 || head.x >= GRID || head.y < 0 || head.y >= GRID) {
      gameOver();
      return;
    }

    // Self collision
    for (var i = 0; i < snake.length; i++) {
      if (snake[i].x === head.x && snake[i].y === head.y) {
        gameOver();
        return;
      }
    }

    snake.unshift(head);

    // Eat food
    if (food && head.x === food.x && head.y === food.y) {
      score++;
      scoreEl.textContent = score;
      if (score > highScore) {
        highScore = score;
        highScoreEl.textContent = highScore;
        localStorage.setItem('snake-high-score', String(highScore));
      }
      // Speed up
      speed = Math.max(MIN_SPEED, BASE_SPEED - score * SPEED_DEC);
      clearInterval(gameLoop);
      gameLoop = setInterval(update, speed);
      placeFood();
    } else {
      snake.pop();
    }

    draw();
  }

  function gameOver() {
    running = false;
    clearInterval(gameLoop);
    gameLoop = null;

    finalScoreEl.textContent = score;
    gameOverOverlay.style.display = '';
    startBtn.textContent = 'Play Again';
    startBtn.style.display = '';
    pauseBtn.style.display = 'none';

    // Show score display and rating
    var rating = getRatingForScore(score);
    scoreValue.textContent = score;
    ratingBadge.textContent = rating.label;
    ratingBadge.style.background = rating.color;
    scoreDisplay.hidden = false;

    // GameShare
    if (window.GameShare) {
      window.GameShare.show({
        gameName: 'Snake Game',
        gameSlug: 'snake-game',
        gameIcon: '\uD83D\uDC0D',
        score: score,
        unit: 'pts',
        metricLabel: 'Score',
        ratingLabel: rating.label,
        ratingColor: rating.color
      });
    }

    // Save to history
    saveHistory(score, rating);
  }

  function saveHistory(s, rating) {
    var key = 'snake-history';
    var history = [];
    try { history = JSON.parse(localStorage.getItem(key) || '[]'); } catch(e) {}
    history.unshift({
      score: s,
      rating: rating.label,
      color: rating.color,
      time: new Date().toLocaleTimeString()
    });
    if (history.length > 10) history = history.slice(0, 10);
    localStorage.setItem(key, JSON.stringify(history));
    renderHistory(history);
  }

  function renderHistory(history) {
    if (!history || history.length === 0) {
      historyWrap.hidden = true;
      return;
    }
    historyWrap.hidden = false;
    var html = '';
    for (var i = 0; i < history.length; i++) {
      var h = history[i];
      html += '<div class="history-item">' +
        '<span class="history-score">' + h.score + ' pts</span>' +
        '<span class="history-rating" style="background:' + h.color + '">' + h.rating + '</span>' +
        '<span class="history-time">' + h.time + '</span>' +
        '</div>';
    }
    historyList.innerHTML = html;
  }

  // Load history on page load
  try {
    var saved = JSON.parse(localStorage.getItem('snake-history') || '[]');
    if (saved.length > 0) renderHistory(saved);
  } catch(e) {}

  function startGame() {
    startOverlay.style.display = 'none';
    gameOverOverlay.style.display = 'none';
    startBtn.style.display = 'none';
    pauseBtn.style.display = '';
    pauseBtn.textContent = 'Pause';

    if (window.GameShare) window.GameShare.hide();

    init();
    gameLoop = setInterval(update, speed);
  }

  function togglePause() {
    if (!running) return;
    paused = !paused;
    pauseBtn.textContent = paused ? 'Resume' : 'Pause';
  }

  // Direction helpers
  var opposites = { up: 'down', down: 'up', left: 'right', right: 'left' };

  function setDirection(dir) {
    if (opposites[dir] === direction) return;
    nextDirection = dir;
  }

  // Keyboard
  document.addEventListener('keydown', function(e) {
    var key = e.key;
    if (key === 'ArrowUp' || key === 'w' || key === 'W') {
      e.preventDefault();
      if (!running && !gameLoop) { startGame(); return; }
      setDirection('up');
    } else if (key === 'ArrowDown' || key === 's' || key === 'S') {
      e.preventDefault();
      if (!running && !gameLoop) { startGame(); return; }
      setDirection('down');
    } else if (key === 'ArrowLeft' || key === 'a' || key === 'A') {
      e.preventDefault();
      if (!running && !gameLoop) { startGame(); return; }
      setDirection('left');
    } else if (key === 'ArrowRight' || key === 'd' || key === 'D') {
      e.preventDefault();
      if (!running && !gameLoop) { startGame(); return; }
      setDirection('right');
    } else if (key === ' ' || key === 'Escape') {
      e.preventDefault();
      if (running) togglePause();
    }
  });

  // Buttons
  startBtn.addEventListener('click', startGame);
  pauseBtn.addEventListener('click', togglePause);
  retryBtn.addEventListener('click', startGame);

  // D-pad
  function dpadHandler(dir) {
    return function(e) {
      e.preventDefault();
      if (!running && !gameLoop) { startGame(); return; }
      setDirection(dir);
    };
  }
  dpadUp.addEventListener('touchstart', dpadHandler('up'), { passive: false });
  dpadDown.addEventListener('touchstart', dpadHandler('down'), { passive: false });
  dpadLeft.addEventListener('touchstart', dpadHandler('left'), { passive: false });
  dpadRight.addEventListener('touchstart', dpadHandler('right'), { passive: false });
  dpadUp.addEventListener('click', dpadHandler('up'));
  dpadDown.addEventListener('click', dpadHandler('down'));
  dpadLeft.addEventListener('click', dpadHandler('left'));
  dpadRight.addEventListener('click', dpadHandler('right'));

  // Prevent scrolling on arrow keys when game is active
  canvas.setAttribute('tabindex', '0');

  // Initial draw
  init();
  running = false;
  draw();
})();
</script>
</BaseLayout>
