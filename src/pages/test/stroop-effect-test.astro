  <AdUnit slot="game-bottom" format="horizontal" />
</BaseLayout>

<style>
  .game-area { cursor: default; user-select: auto; -webkit-user-select: auto; }

  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    margin-bottom: 4px;
  }
  .level-info { font-weight: 700; font-size: 1rem; color: var(--color-text); }
  .lives-info { font-size: 1rem; font-weight: 700; color: var(--color-primary); }

  .stroop-word-area {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 16px 16px;
    min-height: 120px;
  }

  .stroop-word {
    font-size: 3.5rem;
    font-weight: 900;
    letter-spacing: 2px;
    text-transform: uppercase;
    user-select: none;
    -webkit-user-select: none;
    transition: color 0.1s;
  }

  .stroop-options {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    padding: 12px 16px;
    max-width: 500px;
    margin: 0 auto;
  }

  :global(.stroop-color-btn) {
    padding: 12px 20px;
    border-radius: 8px;
    border: 2px solid var(--color-border);
    background: var(--color-surface);
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    min-width: 80px;
    text-transform: uppercase;
    transition: background 0.15s, border-color 0.15s, transform 0.1s;
  }
  :global(.stroop-color-btn:hover) {
    border-color: var(--color-primary);
    transform: scale(0.97);
  }
  :global(.stroop-color-btn.correct) {
    background: #22c55e;
    border-color: #22c55e;
    color: #fff;
  }
  :global(.stroop-color-btn.wrong) {
    background: #fecaca;
    border-color: #ef4444;
  }

  .stroop-results-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding: 16px;
    margin-top: 8px;
    max-width: 320px;
    width: 100%;
  }
  :global(.stroop-stat) {
    text-align: center;
    padding: 8px;
  }
  :global(.stroop-stat-val) {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--color-text);
    display: block;
  }
  :global(.stroop-stat-label) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    display: block;
    margin-top: 2px;
  }

  .play-view {
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .result-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 280px;
    padding: 24px;
  }
  .result-icon { font-size: 3rem; margin-bottom: 8px; }
  .result-label {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 12px;
  }

  @media (max-width: 640px) {
    .stroop-word { font-size: 2.5rem; }
    .stroop-options { gap: 6px; padding: 8px 12px; }
    :global(.stroop-color-btn) { font-size: 0.85rem; padding: 10px 14px; min-width: 64px; }
  }
</style>

<script define:vars={{ gameName: "Stroop Effect Test", gameSlug: "stroop-effect-test", gameIcon: "\u{1F9EA}", metricLabel: "Avg Time", metricUnit: "ms" }}>
(function () {
  'use strict';

  var COLORS = [
    { name: 'RED',    hex: '#ef4444' },
    { name: 'BLUE',   hex: '#2563eb' },
    { name: 'GREEN',  hex: '#16a34a' },
    { name: 'YELLOW', hex: '#ca8a04' },
    { name: 'PURPLE', hex: '#9333ea' },
    { name: 'ORANGE', hex: '#ea580c' }
  ];

  var TOTAL_TRIALS = 20;

  var RATING_SCALE = [
    { maxTime: 500,  label: 'Exceptional', color: '#16a34a' },
    { maxTime: 700,  label: 'Fast', color: '#22c55e' },
    { maxTime: 900,  label: 'Average', color: '#2563eb' },
    { maxTime: 1200, label: 'Slow', color: '#f59e0b' },
    { maxTime: Infinity, label: 'Very Slow', color: '#ef4444' }
  ];

  function getRating(avgTime) {
    for (var i = 0; i < RATING_SCALE.length; i++) {
      if (avgTime < RATING_SCALE[i].maxTime) return RATING_SCALE[i];
    }
    return RATING_SCALE[RATING_SCALE.length - 1];
  }

  var STORAGE_KEY = 'toolcalcs_stroop-effect-test_history';
  var MAX_HISTORY = 20;

  function loadHistory() {
    try { var r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch (e) {}
    return [];
  }
  function saveHistory(h) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(h.slice(0, MAX_HISTORY))); } catch (e) {}
  }
  function addToHistory(entry) {
    var h = loadHistory();
    h.unshift(entry);
    saveHistory(h);
  }

  var instructionsView = document.getElementById('instructionsView');
  var playView = document.getElementById('playView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var tryAgainBtn = document.getElementById('tryAgainBtn');
  var trialInfo = document.getElementById('trialInfo');
  var scoreInfo = document.getElementById('scoreInfo');
  var stroopWord = document.getElementById('stroopWord');
  var optionsWrap = document.getElementById('optionsWrap');
  var feedbackArea = document.getElementById('feedbackArea');
  var finalAccuracy = document.getElementById('finalAccuracy');
  var resultsGrid = document.getElementById('resultsGrid');
  var ratingBadge = document.getElementById('ratingBadge');
  var attemptHistorySection = document.getElementById('attemptHistory');
  var historyList = document.getElementById('historyList');

  var currentTrial = 0;
  var correctCount = 0;
  var isWaiting = false;
  var trialStartTime = 0;
  var reactionTimes = [];
  var trials = [];

  // Current trial data
  var currentWordIndex = -1;
  var currentColorIndex = -1;

  function showView(view) {
    instructionsView.style.display = 'none';
    playView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function shuffleArray(arr) {
    var a = arr.slice();
    for (var i = a.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
    }
    return a;
  }

  function generateTrials() {
    trials = [];
    for (var t = 0; t < TOTAL_TRIALS; t++) {
      var wordIdx = Math.floor(Math.random() * COLORS.length);
      var colorIdx;
      // Ensure incongruent (word != ink color)
      do {
        colorIdx = Math.floor(Math.random() * COLORS.length);
      } while (colorIdx === wordIdx);
      trials.push({ wordIndex: wordIdx, colorIndex: colorIdx });
    }
  }

  function showTrial(index) {
    var trial = trials[index];
    currentWordIndex = trial.wordIndex;
    currentColorIndex = trial.colorIndex;

    trialInfo.textContent = 'Trial ' + (index + 1) + ' of ' + TOTAL_TRIALS;
    scoreInfo.textContent = correctCount + ' correct';
    feedbackArea.textContent = '';
    feedbackArea.style.color = '';

    // Display word in ink color
    stroopWord.textContent = COLORS[currentWordIndex].name;
    stroopWord.style.color = COLORS[currentColorIndex].hex;

    // Create color buttons (all 6 colors, shuffled)
    var indices = [];
    for (var i = 0; i < COLORS.length; i++) indices.push(i);
    indices = shuffleArray(indices);

    optionsWrap.innerHTML = '';
    for (var j = 0; j < indices.length; j++) {
      var btn = document.createElement('button');
      btn.className = 'stroop-color-btn';
      btn.type = 'button';
      btn.textContent = COLORS[indices[j]].name;
      btn.setAttribute('data-idx', String(indices[j]));
      btn.style.borderBottomColor = COLORS[indices[j]].hex;
      btn.style.borderBottomWidth = '4px';
      optionsWrap.appendChild(btn);
    }

    trialStartTime = Date.now();
  }

  function handleOptionClick(e) {
    var btn = e.target.closest('.stroop-color-btn');
    if (!btn || isWaiting) return;

    isWaiting = true;
    var idx = parseInt(btn.getAttribute('data-idx'));
    var rt = Date.now() - trialStartTime;
    reactionTimes.push(rt);

    if (idx === currentColorIndex) {
      correctCount++;
      btn.classList.add('correct');
      feedbackArea.textContent = 'Correct! ' + rt + 'ms';
      feedbackArea.style.color = '#16a34a';
    } else {
      btn.classList.add('wrong');
      feedbackArea.textContent = 'Wrong! The ink color was ' + COLORS[currentColorIndex].name;
      feedbackArea.style.color = '#ef4444';
      // Highlight correct
      var btns = optionsWrap.querySelectorAll('.stroop-color-btn');
      for (var i = 0; i < btns.length; i++) {
        if (parseInt(btns[i].getAttribute('data-idx')) === currentColorIndex) {
          btns[i].classList.add('correct');
        }
      }
    }

    scoreInfo.textContent = correctCount + ' correct';

    setTimeout(function () {
      isWaiting = false;
      currentTrial++;
      if (currentTrial >= TOTAL_TRIALS) {
        endGame();
      } else {
        showTrial(currentTrial);
      }
    }, 1000);
  }

  function startGame() {
    currentTrial = 0;
    correctCount = 0;
    isWaiting = false;
    reactionTimes = [];
    generateTrials();
    showView(playView);
    showTrial(0);
  }

  function endGame() {
    showView(resultView);

    var accuracy = Math.round((correctCount / TOTAL_TRIALS) * 100);
    var avgTime = 0;
    if (reactionTimes.length > 0) {
      var sum = 0;
      for (var i = 0; i < reactionTimes.length; i++) sum += reactionTimes[i];
      avgTime = Math.round(sum / reactionTimes.length);
    }

    var fastest = reactionTimes.length > 0 ? Math.min.apply(null, reactionTimes) : 0;
    var slowest = reactionTimes.length > 0 ? Math.max.apply(null, reactionTimes) : 0;

    finalAccuracy.textContent = accuracy + '%';

    var rating = getRating(avgTime);
    ratingBadge.textContent = rating.label;
    ratingBadge.style.background = rating.color;

    resultsGrid.innerHTML =
      '<div class="stroop-stat"><span class="stroop-stat-val">' + avgTime + 'ms</span><span class="stroop-stat-label">Avg Reaction Time</span></div>' +
      '<div class="stroop-stat"><span class="stroop-stat-val">' + correctCount + '/' + TOTAL_TRIALS + '</span><span class="stroop-stat-label">Correct Answers</span></div>' +
      '<div class="stroop-stat"><span class="stroop-stat-val">' + fastest + 'ms</span><span class="stroop-stat-label">Fastest Response</span></div>' +
      '<div class="stroop-stat"><span class="stroop-stat-val">' + slowest + 'ms</span><span class="stroop-stat-label">Slowest Response</span></div>';

    addToHistory({
      score: avgTime,
      accuracy: accuracy,
      correct: correctCount,
      date: new Date().toISOString(),
      rating: rating.label
    });
    renderHistory();

    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: avgTime,
        unit: metricUnit,
        metricLabel: metricLabel,
        ratingLabel: rating.label + ' (' + accuracy + '% accuracy)',
        ratingColor: rating.color
      });
    }
  }

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    historyList.innerHTML = history.map(function (e) {
      var r = getRating(e.score);
      return '<div class="history-item">' +
        '<span class="history-score">' + e.score + 'ms / ' + (e.accuracy || '?') + '%</span>' +
        '<span class="history-rating" style="background:' + r.color + '">' + r.label + '</span>' +
        '<span class="history-time">' + formatDate(e.date) + '</span>' +
        '</div>';
    }).join('');
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  optionsWrap.addEventListener('click', handleOptionClick);
  startBtn.addEventListener('click', startGame);
  tryAgainBtn.addEventListener('click', startGame);
  renderHistory();
})();
</script>
