---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import GameShare from '../../components/GameShare.astro';
import CrossLinks from '../../components/CrossLinks.astro';
import { getGameBySlug, getRating } from '../../data/games';
import '../../styles/game.css';

const game = getGameBySlug('sudoku')!;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tests & Games", "item": "https://toolcalcs.com/test/" },
      { "@type": "ListItem", "position": 3, "name": "Sudoku" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Sudoku",
    "url": "https://toolcalcs.com/test/sudoku/",
    "applicationCategory": "GameApplication",
    "operatingSystem": "All",
    "browserRequirements": "Requires JavaScript",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "description": "Play free Sudoku puzzles online. Choose Easy, Medium, or Hard difficulty. Fill the 9x9 grid so every row, column, and 3x3 box contains 1-9."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the rules of Sudoku?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sudoku is played on a 9x9 grid divided into nine 3x3 boxes. The goal is to fill every empty cell with a digit from 1 to 9 so that each row, each column, and each 3x3 box contains all digits from 1 to 9 exactly once. No digit may repeat within any row, column, or box."
        }
      },
      {
        "@type": "Question",
        "name": "How do I solve a Sudoku puzzle?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Start by scanning each row, column, and 3x3 box for missing numbers. Use the naked singles technique: if a cell can only contain one possible number, fill it in. Use hidden singles: if a number can only go in one cell within a row, column, or box, place it there. For harder puzzles, use pencil marks to track candidates and apply advanced techniques like pointing pairs and box-line reduction."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between Easy, Medium, and Hard Sudoku?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Difficulty is determined by how many clues (pre-filled numbers) are given. Easy puzzles have around 40 clues and can be solved with basic techniques. Medium puzzles have about 32 clues and require some intermediate strategies. Hard puzzles have approximately 25 clues and demand advanced solving techniques like pointing pairs and hidden pairs."
        }
      },
      {
        "@type": "Question",
        "name": "Is every Sudoku puzzle solvable?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A properly constructed Sudoku puzzle has exactly one unique solution. Our generator creates a fully solved board first, then removes cells to create the puzzle. This guarantees that every puzzle you play has a valid solution. If a puzzle had multiple solutions or no solution, it would not be a valid Sudoku."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="Sudoku - Free Online Puzzle Game | ToolCalcs"
  description="Play free Sudoku puzzles online. Choose Easy, Medium, or Hard difficulty. 9x9 grid with timer, hints, notes mode, and mistake tracking. Train your brain with the world's most popular number puzzle."
  type="article"
  noindex={true}
  structuredData={structuredData}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/test/">Tests & Games</a> &rsaquo;
    <span>Sudoku</span>
  </nav>

  <h1>Sudoku</h1>
  <p class="page-desc">Fill the 9&times;9 grid so every row, column, and 3&times;3 box contains digits 1 through 9.</p>

  <div class="game-box">
    <div class="game-area sudoku-area" id="gameArea" role="region" aria-label="Sudoku puzzle" aria-live="polite">
      <div class="game-instructions" id="instructionsView">
        <h2>Sudoku Puzzle</h2>
        <p>Select a difficulty and start playing. Fill every cell so that each row, column, and 3&times;3 box contains all digits from 1 to 9. You have 3 mistakes allowed and 3 hints available.</p>
        <p style="font-size:0.85rem;color:var(--color-text-muted);">Timer starts when you click your first cell.</p>
        <div class="sudoku-difficulty-select" id="difficultySelect">
          <button class="game-btn difficulty-btn active" data-diff="easy" type="button">Easy</button>
          <button class="game-btn difficulty-btn" data-diff="medium" type="button">Medium</button>
          <button class="game-btn difficulty-btn" data-diff="hard" type="button">Hard</button>
        </div>
        <button class="game-btn primary" id="startBtn" type="button" style="margin-top:16px;">New Game</button>
      </div>

      <div class="play-view" id="playView" style="display:none;">
        <div class="sudoku-controls-bar">
          <span class="sudoku-stat" id="timerDisplay">00:00</span>
          <span class="sudoku-stat" id="difficultyLabel">Easy</span>
          <span class="sudoku-stat" id="mistakeDisplay">Mistakes: 0/3</span>
        </div>
        <div class="sudoku-board-wrap">
          <table class="sudoku-board" id="sudokuBoard" role="grid" aria-label="Sudoku grid"></table>
        </div>
        <div class="sudoku-actions">
          <button class="sudoku-action-btn" id="undoBtn" type="button" title="Undo">&#x21A9; Undo</button>
          <button class="sudoku-action-btn" id="eraseBtn" type="button" title="Erase">&#x232B; Erase</button>
          <button class="sudoku-action-btn" id="notesBtn" type="button" title="Toggle Notes">&#x270E; Notes</button>
          <button class="sudoku-action-btn" id="hintBtn" type="button" title="Hint">&#x1F4A1; Hint <span id="hintCount">3</span></button>
        </div>
        <div class="sudoku-numpad" id="numpad">
          <button class="numpad-btn" data-num="1" type="button">1</button>
          <button class="numpad-btn" data-num="2" type="button">2</button>
          <button class="numpad-btn" data-num="3" type="button">3</button>
          <button class="numpad-btn" data-num="4" type="button">4</button>
          <button class="numpad-btn" data-num="5" type="button">5</button>
          <button class="numpad-btn" data-num="6" type="button">6</button>
          <button class="numpad-btn" data-num="7" type="button">7</button>
          <button class="numpad-btn" data-num="8" type="button">8</button>
          <button class="numpad-btn" data-num="9" type="button">9</button>
        </div>
        <button class="game-btn" id="newGameBtn" type="button" style="margin-top:12px;">New Game</button>
      </div>

      <div class="result-view" id="resultView" style="display:none;">
        <div class="result-icon" aria-hidden="true">&#x1F3C6;</div>
        <div class="result-label" id="resultLabel">Puzzle Complete!</div>
        <div class="score-display">
          <span class="score-value" id="finalTime">0:00</span>
          <span class="score-unit">time</span>
        </div>
        <div class="sudoku-result-details" id="resultDetails"></div>
        <div class="rating-badge" id="ratingBadge">&mdash;</div>
        <button class="game-btn primary" id="playAgainBtn" type="button" style="margin-top:16px;">Play Again</button>
      </div>

      <div class="result-view" id="gameOverView" style="display:none;">
        <div class="result-icon" aria-hidden="true">&#x274C;</div>
        <div class="result-label">Game Over</div>
        <p style="color:var(--color-text-muted);margin-bottom:16px;">You made 3 mistakes. Better luck next time!</p>
        <button class="game-btn primary" id="retryBtn" type="button">Try Again</button>
      </div>
    </div>

    <GameShare />

    <div class="attempt-history" id="attemptHistory" hidden>
      <h3>Recent Games</h3>
      <div class="history-list" id="historyList"></div>
    </div>
  </div>

  <AdUnit slot="game-mid" format="horizontal" />

  <article class="content-section">
    <h2>What Is Sudoku?</h2>
    <p>Sudoku is a logic-based number placement puzzle played on a 9 by 9 grid that is subdivided into nine 3 by 3 boxes. The objective is straightforward: fill every empty cell with a digit from 1 to 9 so that each row, each column, and each 3 by 3 box contains all nine digits exactly once. No mathematics is required beyond counting. The puzzle relies entirely on logical deduction, pattern recognition, and systematic elimination of candidates.</p>
    <p>Each Sudoku puzzle begins with a partially completed grid. The number of pre-filled cells, called clues or givens, determines the difficulty of the puzzle. An easy puzzle might provide 40 or more clues, leaving relatively few cells to fill and requiring only basic techniques. A hard puzzle might provide as few as 22 to 25 clues, demanding advanced strategies and careful bookkeeping of candidate numbers. The minimum number of clues required for a puzzle to have a unique solution has been mathematically proven to be 17, though such puzzles are extremely difficult and rare.</p>
    <p>Sudoku puzzles are designed to have exactly one solution. A well-constructed puzzle guides the solver through a logical chain of deductions, with each solved cell revealing new information that makes subsequent cells solvable. If a puzzle has more than one solution, it is considered flawed and does not meet the standard definition of a valid Sudoku puzzle.</p>

    <h2>The History of Sudoku</h2>
    <p>The roots of Sudoku trace back to the 18th century and the mathematical concept of Latin squares, studied by Swiss mathematician Leonhard Euler in 1783. A Latin square is an n by n array filled with n different symbols, each occurring exactly once in each row and column. Sudoku extends this concept by adding the constraint that each 3 by 3 sub-grid must also contain all symbols.</p>
    <p>The modern form of Sudoku was created in 1979 by Howard Garns, a retired architect from Indianapolis, Indiana. He published the puzzle under the name "Number Place" in Dell Pencil Puzzles and Word Games magazine. The puzzle gained moderate popularity in the United States but did not become a worldwide phenomenon until it reached Japan.</p>
    <p>In 1984, the Japanese puzzle company Nikoli introduced Number Place to Japan under the name "Suuji wa dokushin ni kagiru," meaning "the digits must remain single." This was later abbreviated to "Sudoku." Nikoli made two key improvements that helped popularize the puzzle: they required that the pattern of givens be rotationally symmetric, and they limited the number of givens to no more than 32. These constraints created more elegant and aesthetically pleasing puzzles.</p>
    <p>The global Sudoku craze began in 2004 when Wayne Gould, a retired Hong Kong judge from New Zealand, developed a computer program to generate Sudoku puzzles and convinced The Times of London to publish them. Within months, Sudoku spread to newspapers around the world. By 2005, it had become one of the most popular puzzle games in history, appearing in hundreds of newspapers, books, websites, and mobile applications. The first World Sudoku Championship was held in Lucca, Italy, in 2006, and the competition continues annually, attracting elite puzzle solvers from dozens of countries.</p>

    <h2>How to Solve Sudoku: Basic Strategies</h2>
    <p>Solving Sudoku efficiently requires a systematic approach. Beginners should master the fundamental techniques before moving on to advanced strategies. The two most important basic techniques are naked singles and hidden singles.</p>
    <p><strong>Naked Singles:</strong> A naked single occurs when a cell has only one possible candidate number. To find naked singles, examine each empty cell and determine which numbers are already present in its row, column, and 3 by 3 box. If eight of the nine digits are accounted for, the remaining digit must go in that cell. This is the simplest and most commonly used technique, and many easy puzzles can be solved using naked singles alone.</p>
    <p><strong>Hidden Singles:</strong> A hidden single occurs when a particular number can only go in one cell within a row, column, or box, even though that cell might have multiple candidates overall. For example, if the number 7 can only be placed in one cell within a specific row (because it already appears elsewhere in the row, or because its other possible cells are blocked by column or box constraints), then 7 must go in that cell regardless of what other numbers might also be candidates for the same cell.</p>
    <p><strong>Scanning:</strong> Scanning is the practice of systematically checking each row, column, and box for places where a specific number can be placed. Cross-hatching is a visual scanning technique where you mentally extend the lines of existing instances of a number across the grid to eliminate cells in other boxes. This method is especially effective for numbers that appear frequently in the puzzle and have limited remaining placement options.</p>

    <h2>Advanced Sudoku Solving Techniques</h2>
    <p>When basic techniques are not sufficient to progress, advanced strategies become necessary. These techniques involve analyzing the relationships between candidate numbers across multiple cells, rows, columns, and boxes.</p>
    <p><strong>Pointing Pairs and Pointing Triples:</strong> When all instances of a candidate number within a box are confined to a single row or column, that number can be eliminated as a candidate from all other cells in that row or column outside the box. For example, if the number 5 can only appear in cells in row 2 within box 1, then 5 cannot appear anywhere else in row 2. This technique is called a pointing pair when two cells are involved and a pointing triple when three cells are involved.</p>
    <p><strong>Box-Line Reduction:</strong> This is the reverse of pointing pairs. When all instances of a candidate number within a row or column are confined to a single box, that number can be eliminated from all other cells in that box. If the number 3 in row 4 can only appear within box 4, then 3 can be removed as a candidate from all other cells in box 4 that are not in row 4.</p>
    <p><strong>Naked Pairs, Triples, and Quads:</strong> A naked pair occurs when two cells in the same row, column, or box contain exactly the same two candidates and no other candidates. Since those two numbers must occupy those two cells, they can be eliminated as candidates from all other cells in the same row, column, or box. The same logic extends to naked triples (three cells sharing three candidates) and naked quads (four cells sharing four candidates).</p>
    <p><strong>Hidden Pairs, Triples, and Quads:</strong> A hidden pair occurs when two candidates appear only in two cells within a row, column, or box. Even if those cells contain other candidates, the other candidates can be eliminated because the two hidden candidates must occupy those two cells. Hidden triples and quads follow the same logic with three or four candidates respectively.</p>
    <p><strong>X-Wing:</strong> The X-Wing pattern occurs when a candidate number appears in exactly two cells in each of two different rows, and those cells align in the same two columns. The number can then be eliminated from all other cells in those two columns. The X-Wing is named for the cross pattern formed by the four cells involved.</p>

    <h2>Understanding Sudoku Difficulty Levels</h2>
    <p>Sudoku difficulty is not solely determined by the number of clues, although that is the most significant factor. The techniques required to solve the puzzle play an equally important role in determining how challenging it feels to the solver.</p>
    <p><strong>Easy puzzles</strong> typically provide 36 to 45 clues and can be solved entirely with naked singles and hidden singles. The solving path is relatively linear, meaning that each solved cell immediately reveals another solvable cell. Easy puzzles are ideal for beginners learning the mechanics of Sudoku and for experienced solvers who want a quick, relaxing game.</p>
    <p><strong>Medium puzzles</strong> usually have 28 to 35 clues and require some intermediate techniques beyond basic singles. Solvers may need to use pencil marks (candidate notation) to track possible numbers and apply techniques like pointing pairs or naked pairs. Medium puzzles often have moments where the solver must pause and think more carefully rather than simply filling cells in sequence.</p>
    <p><strong>Hard puzzles</strong> typically feature 22 to 27 clues and demand a full arsenal of advanced solving techniques. These puzzles frequently require extensive use of pencil marks, pattern recognition across multiple units, and techniques like X-Wing or hidden triples. Hard puzzles may have long chains of dependent deductions where a single misstep can lead to contradictions that are difficult to trace back to the source.</p>

    <h2>Mental Health Benefits of Sudoku</h2>
    <p>Research suggests that engaging in logic puzzles like Sudoku offers several cognitive and mental health benefits. A 2019 study published in the International Journal of Geriatric Psychiatry found that adults over 50 who regularly engaged in number puzzles had cognitive function equivalent to people 10 years younger, particularly in measures of attention, reasoning, and memory.</p>
    <p>Sudoku requires sustained concentration, which can serve as a form of mindfulness practice. When deeply engaged in solving a puzzle, the mind is fully focused on the task at hand, providing a break from rumination and everyday worries. This flow state, described by psychologist Mihaly Csikszentmihalyi, is associated with reduced anxiety and improved mood.</p>
    <p>The puzzle also exercises working memory, the cognitive system responsible for temporarily holding and manipulating information. Solving Sudoku requires keeping track of multiple constraints simultaneously: which numbers are present in a row, column, and box, and which candidates remain for each empty cell. Regular practice may help maintain and strengthen working memory capacity, which naturally declines with age.</p>
    <p>Sudoku promotes logical thinking and systematic problem-solving skills that transfer to other domains. The process of forming hypotheses, testing them against constraints, and revising conclusions mirrors the scientific method and analytical thinking used in professional and academic contexts. Parents and educators often recommend Sudoku for children as a way to develop these critical thinking skills in an engaging, game-like format.</p>

    <h2>Competitive Sudoku</h2>
    <p>Competitive Sudoku has grown into a structured international sport since the first World Sudoku Championship in 2006. The championship is organized by the World Puzzle Federation and attracts teams from over 30 countries. Competitors solve a series of Sudoku puzzles of varying difficulty under strict time constraints, and scores are based on speed and accuracy.</p>
    <p>Elite competitive solvers can complete easy puzzles in under 30 seconds and hard puzzles in two to four minutes. The top performers develop pattern recognition skills that allow them to identify solving techniques almost instantly, bypassing the step-by-step process that recreational solvers use. Many champions have backgrounds in mathematics, computer science, or puzzle design, though the skill set for competitive Sudoku is distinct from traditional academic mathematics.</p>
    <p>Beyond the world championship, numerous national and regional Sudoku competitions exist. Online platforms host daily and weekly contests where players compete for the fastest completion times. Speed solving communities have developed their own ranking systems and leaderboards, creating a vibrant ecosystem of competitive puzzle solving that welcomes newcomers and veterans alike.</p>

    <h2>Tips for Using This Sudoku Game</h2>
    <ul>
      <li><strong>Use Notes mode:</strong> Toggle Notes mode to write small pencil marks in cells. This helps track which numbers are possible for each empty cell, especially in medium and hard puzzles where you cannot immediately determine the correct number.</li>
      <li><strong>Watch the highlights:</strong> When you select a cell, all cells containing the same number are highlighted. Use this visual cue to spot patterns and identify where that number is missing in rows, columns, or boxes.</li>
      <li><strong>Save your hints:</strong> You have three hints per game. Use them strategically when you are truly stuck, rather than spending them on cells you could figure out with a bit more thought. Each hint reveals the correct number for one cell.</li>
      <li><strong>Manage mistakes carefully:</strong> Three mistakes end the game. If you are unsure about a number, use Notes mode to record candidates rather than guessing. A wrong answer costs you one of your limited mistakes and can disrupt your solving flow.</li>
      <li><strong>Start with Easy:</strong> If you are new to Sudoku, begin with Easy difficulty to learn the interface and basic techniques. Progress to Medium once you can solve Easy puzzles consistently, and move to Hard when Medium puzzles feel comfortable.</li>
      <li><strong>Keyboard shortcuts:</strong> Use number keys 1 through 9 to enter digits. Press Delete or Backspace to erase. Press N to toggle Notes mode. Use arrow keys to navigate between cells for faster gameplay.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>

    <h3>What are the rules of Sudoku?</h3>
    <p>Sudoku is played on a 9 by 9 grid divided into nine 3 by 3 boxes. The goal is to fill every empty cell with a digit from 1 to 9 so that each row, each column, and each 3 by 3 box contains all digits from 1 to 9 exactly once. No digit may repeat within any row, column, or box.</p>

    <h3>How do I solve a Sudoku puzzle?</h3>
    <p>Start by scanning each row, column, and 3 by 3 box for missing numbers. Use the naked singles technique to find cells that can only contain one number. Use hidden singles to find numbers that can only go in one cell within a unit. For harder puzzles, use pencil marks and apply advanced techniques like pointing pairs, naked pairs, and X-Wing patterns.</p>

    <h3>What is the difference between Easy, Medium, and Hard Sudoku?</h3>
    <p>Difficulty is determined by the number of clues provided. Easy puzzles have around 40 clues and can be solved with basic techniques. Medium puzzles have about 32 clues and require intermediate strategies. Hard puzzles have approximately 25 clues and demand advanced solving techniques and careful candidate tracking.</p>

    <h3>Is every Sudoku puzzle solvable?</h3>
    <p>A properly constructed Sudoku puzzle has exactly one unique solution. Our generator creates a fully solved board first, then removes cells to create the puzzle. This guarantees that every puzzle you play has a valid solution.</p>
  </article>

