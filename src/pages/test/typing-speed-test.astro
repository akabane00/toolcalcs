---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import GameShare from '../../components/GameShare.astro';
import CrossLinks from '../../components/CrossLinks.astro';
import '../../styles/game.css';

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tests & Games", "item": "https://toolcalcs.com/test/" },
      { "@type": "ListItem", "position": 3, "name": "Typing Speed Test" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Typing Speed Test",
    "url": "https://toolcalcs.com/test/typing-speed-test/",
    "applicationCategory": "GameApplication",
    "operatingSystem": "All",
    "browserRequirements": "Requires JavaScript",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "description": "Measure your typing speed in words per minute (WPM) and accuracy. Type a passage as fast and accurately as you can within 60 seconds."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a good typing speed?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The average typing speed is around 40 WPM. A speed of 50-70 WPM is considered good for most purposes. Professional typists and programmers often type at 70-100 WPM, while competitive typists can exceed 150 WPM."
        }
      },
      {
        "@type": "Question",
        "name": "How is WPM calculated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Words per minute (WPM) is calculated by dividing the total number of characters typed by 5 (the standard word length) and then dividing by the elapsed time in minutes. This standardized formula ensures fair comparison regardless of the actual word lengths in the passage."
        }
      },
      {
        "@type": "Question",
        "name": "How can I improve my typing speed?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Practice touch typing by keeping your fingers on the home row (ASDF JKL;) and not looking at the keyboard. Start slowly with a focus on accuracy, and speed will increase naturally over time. Daily practice of 15-30 minutes is more effective than occasional long sessions."
        }
      },
      {
        "@type": "Question",
        "name": "Does typing speed matter for programming?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While programming involves more thinking than typing, a reasonable typing speed (50+ WPM) helps maintain flow and reduces the friction between thought and code. Fast typists spend less cognitive effort on the mechanical act of typing, freeing mental resources for problem-solving."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="Typing Speed Test - Check Your WPM Online Free | ToolCalcs"
  description="Test your typing speed and accuracy. Type a passage as fast as you can in 60 seconds. Measure WPM, accuracy, and get a detailed assessment. Free online typing test."
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/test/">Tests & Games</a> &rsaquo;
    <span>Typing Speed Test</span>
  </nav>

  <h1>Typing Speed Test</h1>
  <p class="page-desc">Type the passage below as quickly and accurately as you can. You have 60 seconds.</p>

  <div class="game-box">
    <div class="game-area" id="gameArea" role="region" aria-label="Typing speed test area" aria-live="polite">
      <div class="game-instructions" id="instructionsView">
        <h2>Typing Speed Test</h2>
        <p>A passage will appear on screen. Type it as fast and accurately as you can. The timer starts when you begin typing. The test ends after 60 seconds.</p>
        <p style="font-size:0.85rem;color:var(--color-text-muted);">Your WPM, accuracy, and total characters are measured in real time.</p>
        <button class="game-btn primary" id="startBtn" type="button" style="margin-top:16px;">Start Test</button>
      </div>

      <div class="play-view" id="playView" style="display:none;">
        <div class="status-bar">
          <span class="level-info" id="wpmInfo">WPM: 0</span>
          <span class="level-info" id="accInfo">Accuracy: 100%</span>
          <span class="lives-info" id="timerInfo">60s</span>
        </div>
        <div class="typing-passage" id="passageDisplay"></div>
        <textarea class="typing-input" id="typingInput" rows="4" placeholder="Start typing here..." autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"></textarea>
      </div>

      <div class="result-view" id="resultView" style="display:none;">
        <div class="result-icon" aria-hidden="true">&#9000;</div>
        <div class="result-label">Test Complete</div>
        <div class="score-display">
          <span class="score-value" id="finalWpm">0</span>
          <span class="score-unit">WPM</span>
        </div>
        <div class="typing-result-details" id="resultDetails"></div>
        <div class="rating-badge" id="ratingBadge">&mdash;</div>
        <button class="game-btn primary" id="tryAgainBtn" type="button" style="margin-top:16px;">Try Again</button>
      </div>
    </div>

    <GameShare />

    <div class="attempt-history" id="attemptHistory" hidden>
      <h3>Attempt History</h3>
      <div class="history-list" id="historyList"></div>
    </div>
  </div>

  <AdUnit slot="game-mid" format="horizontal" />

  <article class="content-section">
    <h2>What Is the Typing Speed Test?</h2>
    <p>The Typing Speed Test is an interactive assessment that measures how quickly and accurately you can type. A passage of text is displayed on screen, and you type it as fast as you can within a 60-second time limit. The test calculates your words per minute (WPM), accuracy percentage, and total characters typed, giving you a comprehensive snapshot of your typing ability.</p>
    <p>Words per minute is the standard metric for typing speed. It is calculated by dividing the total number of characters typed (including spaces) by five, which represents a standardized word length, and then dividing by the elapsed time in minutes. This approach ensures that results are comparable across different passages, regardless of whether the text contains short or long words.</p>
    <p>Accuracy is equally important. Typing fast but making frequent errors is less productive than typing at a moderate pace with high accuracy. Most employers and typing certification programs consider both speed and accuracy when evaluating typing proficiency. A combination of 60 WPM with 95 percent accuracy or higher is generally considered professional-grade typing.</p>

    <h2>The History and Science of Touch Typing</h2>
    <p>Touch typing, the ability to type without looking at the keyboard, was developed alongside the typewriter itself. Christopher Latham Sholes patented the first practical typewriter in 1868, and the QWERTY layout was designed to prevent mechanical jamming by separating commonly paired letters. Despite numerous alternative layouts like Dvorak and Colemak that claim ergonomic advantages, QWERTY remains the dominant keyboard layout worldwide.</p>
    <p>Frank Edward McGurrin is often credited as the first person to memorize the keyboard layout and type without looking at the keys, winning a typing competition in 1888 that demonstrated the clear advantage of touch typing over hunt-and-peck methods. Since then, touch typing has been taught in schools and training programs as an essential skill for office work and, more recently, for general computer literacy.</p>
    <p>The motor learning principles behind touch typing are well understood. When you first learn to type, each keystroke requires conscious attention and deliberate finger movement. With practice, these movements become automated through a process called procedural memory formation. The basal ganglia and cerebellum play key roles in storing and executing these motor sequences. Eventually, experienced typists can type common words as single motor chunks rather than individual keystrokes, which is why familiar words flow effortlessly while unusual character combinations slow you down.</p>

    <h2>Factors That Affect Typing Speed</h2>
    <p>Several factors influence how fast you can type. Physical factors include finger dexterity, hand size, and the quality of your keyboard. Mechanical keyboards with tactile feedback often allow faster typing because they provide clear confirmation of each keystroke, reducing the need to bottom out keys. Ergonomic factors like desk height, chair posture, and wrist position also matter. Poor ergonomics can cause fatigue and repetitive strain injuries that limit both speed and endurance.</p>
    <p>Cognitive factors play an equally important role. Reading speed affects typing speed because you need to process the source text before your fingers can reproduce it. Working memory capacity determines how many words you can buffer ahead while typing. Skilled typists typically read several words ahead of their current typing position, maintaining a mental queue that allows their fingers to move continuously without pausing to read the next word.</p>
    <p>Language familiarity significantly impacts performance. You type faster in your native language because word patterns and letter combinations are deeply ingrained in your motor memory. Uncommon words, technical jargon, or text in a foreign language disrupts the automatic motor sequences and forces you back into a more deliberate, letter-by-letter typing mode. This is why typing tests use common English prose rather than specialized vocabulary.</p>

    <h2>Typing Speed Benchmarks</h2>
    <p>Understanding where your typing speed falls relative to others can help set realistic improvement goals. Beginners who use hunt-and-peck methods typically type at 15 to 30 WPM. The average adult types at approximately 40 WPM, though this varies by age, profession, and experience. Office workers who type daily usually range from 40 to 60 WPM, while professional typists and transcriptionists often exceed 70 WPM.</p>
    <p>Competitive typing is a niche but active community. The Guinness World Record for typing speed on a standard keyboard is 216 WPM, set by Stella Pajunas in 1946 on an electric typewriter. In modern online typing competitions, top performers regularly exceed 180 WPM on short bursts and maintain 120 to 150 WPM over longer passages. These elite speeds require years of dedicated practice and optimized technique.</p>

    <h2>How to Improve Your Typing Speed</h2>
    <ul>
      <li><strong>Learn proper finger placement:</strong> Keep your fingers on the home row (ASDF for the left hand, JKL; for the right). Each finger is responsible for specific keys, and maintaining this discipline prevents inefficient reaching and cross-hand movements.</li>
      <li><strong>Focus on accuracy first:</strong> Speed follows accuracy, not the other way around. Typing slowly with zero errors builds correct muscle memory. Typing fast with many errors reinforces bad habits that are harder to unlearn later.</li>
      <li><strong>Practice consistently:</strong> Short daily sessions of 15 to 30 minutes are more effective than occasional marathon sessions. Consistent practice leverages the spacing effect, allowing your brain to consolidate motor patterns between sessions.</li>
      <li><strong>Avoid looking at the keyboard:</strong> Cover the keyboard with a cloth if necessary. The temporary slowdown from not looking is an investment that pays off rapidly as your fingers learn key positions through touch alone.</li>
      <li><strong>Use typing training software:</strong> Programs that progressively introduce new keys and provide immediate feedback accelerate learning. Gamified typing trainers can also make practice more engaging and sustainable.</li>
      <li><strong>Type real content:</strong> After mastering the basics, practice by typing real text such as articles, emails, or code. Real-world typing involves punctuation, numbers, and formatting that standard drills may not cover.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>

    <h3>What is a good typing speed?</h3>
    <p>The average typing speed is around 40 WPM. A speed of 50 to 70 WPM is considered good for most purposes. Professional typists and programmers often type at 70 to 100 WPM, while competitive typists can exceed 150 WPM.</p>

    <h3>How is WPM calculated?</h3>
    <p>Words per minute is calculated by dividing the total number of characters typed by 5 (the standard word length) and then dividing by the elapsed time in minutes. This standardized formula ensures fair comparison regardless of the actual word lengths in the passage.</p>

    <h3>How can I improve my typing speed?</h3>
    <p>Practice touch typing by keeping your fingers on the home row and not looking at the keyboard. Start slowly with a focus on accuracy, and speed will increase naturally over time. Daily practice of 15 to 30 minutes is more effective than occasional long sessions.</p>

    <h3>Does typing speed matter for programming?</h3>
    <p>While programming involves more thinking than typing, a reasonable typing speed of 50 or more WPM helps maintain flow and reduces the friction between thought and code. Fast typists spend less cognitive effort on the mechanical act of typing, freeing mental resources for problem-solving.</p>
  </article>

  <CrossLinks links={[
    { href: '/test/reaction-time-test/', label: 'Reaction Time Test', icon: '\u26A1' },
    { href: '/test/verbal-memory-test/', label: 'Verbal Memory Test', icon: '\uD83D\uDCDD' },
    { href: '/test/number-memory-test/', label: 'Number Memory Test', icon: '\uD83E\uDDE0' },
  ]} />
  <AdUnit slot="game-bottom" format="horizontal" />
</BaseLayout>

<style>
  .game-area { cursor: default; user-select: auto; -webkit-user-select: auto; }

  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    margin-bottom: 4px;
    flex-wrap: wrap;
    gap: 8px;
  }
  .level-info { font-weight: 700; font-size: 1rem; color: var(--color-text); }
  .lives-info { font-size: 0.95rem; font-weight: 600; color: var(--color-text-muted); }

  .typing-passage {
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.05rem;
    line-height: 1.8;
    text-align: left;
    padding: 16px 20px;
    margin: 0 16px 12px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    min-height: 80px;
    max-height: 160px;
    overflow-y: auto;
    color: var(--color-text-muted);
    word-wrap: break-word;
  }
  :global(.char-correct) { color: var(--color-text); }
  :global(.char-wrong) { color: #ef4444; background: rgba(239,68,68,0.15); border-radius: 2px; }
  :global(.char-current) { border-bottom: 2px solid var(--color-primary); color: var(--color-text); }

  .typing-input {
    width: calc(100% - 40px);
    margin: 0 20px 16px;
    padding: 12px 16px;
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.05rem;
    line-height: 1.6;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    color: var(--color-text);
    resize: none;
    outline: none;
    transition: border-color 0.15s;
  }
  .typing-input:focus {
    border-color: var(--color-primary);
  }

  .typing-result-details {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 12px;
    line-height: 1.8;
  }

  .play-view {
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .result-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 280px;
    padding: 24px;
  }
  .result-icon { font-size: 3rem; margin-bottom: 8px; }
  .result-label {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 12px;
  }

  @media (max-width: 640px) {
    .typing-passage { font-size: 0.9rem; padding: 12px 14px; margin: 0 8px 10px; }
    .typing-input { width: calc(100% - 20px); margin: 0 10px 12px; font-size: 0.9rem; }
    .status-bar { font-size: 0.85rem; }
  }
</style>

<script define:vars={{ gameName: "Typing Speed Test", gameSlug: "typing-speed-test", gameIcon: "\u2328", metricLabel: "Speed", metricUnit: "WPM" }}>
(function () {
  'use strict';

  var PASSAGES = [
    "The quick brown fox jumps over the lazy dog near the riverbank. Sunlight filters through the tall oak trees as birds sing their morning songs. A gentle breeze carries the scent of wildflowers across the open meadow. The farmer walks along the dirt path toward the old red barn.",
    "Technology has transformed the way people communicate and work in the modern world. Smartphones connect billions of people across continents in real time. Cloud computing allows businesses to store and process vast amounts of data without physical servers.",
    "Learning a new skill requires patience, practice, and persistence. Whether you are studying a musical instrument, a foreign language, or a sport, the early stages often feel frustrating. Progress seems slow at first because your brain is building new neural pathways.",
    "The ocean covers more than seventy percent of the surface of the Earth and remains largely unexplored. Deep beneath the waves, strange creatures thrive in total darkness near volcanic vents on the ocean floor. Marine biologists continue to discover new species every year.",
    "Cooking is both an art and a science that brings people together around the table. A simple meal prepared with fresh ingredients can be more satisfying than an elaborate restaurant dish. Understanding basic techniques like roasting and braising opens up endless possibilities."
  ];

  var TIME_LIMIT = 60;

  var RATING_SCALE = [
    { min: 100, label: 'Expert', color: '#16a34a' },
    { min: 70, label: 'Fast', color: '#22c55e' },
    { min: 50, label: 'Good', color: '#2563eb' },
    { min: 30, label: 'Average', color: '#f59e0b' },
    { min: 0, label: 'Beginner', color: '#ef4444' }
  ];

  function getRating(wpm) {
    for (var i = 0; i < RATING_SCALE.length; i++) {
      if (wpm >= RATING_SCALE[i].min) return RATING_SCALE[i];
    }
    return { label: 'Beginner', color: '#ef4444' };
  }

  var STORAGE_KEY = 'toolcalcs_typing-speed-test_history';
  var MAX_HISTORY = 20;

  function loadHistory() {
    try { var r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch (e) {}
    return [];
  }
  function saveHistory(h) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(h.slice(0, MAX_HISTORY))); } catch (e) {}
  }
  function addToHistory(wpm) {
    var h = loadHistory();
    h.unshift({ score: wpm, date: new Date().toISOString(), rating: getRating(wpm).label });
    saveHistory(h);
  }

  var instructionsView = document.getElementById('instructionsView');
  var playView = document.getElementById('playView');
  var resultView = document.getElementById('resultView');
  var startBtn = document.getElementById('startBtn');
  var tryAgainBtn = document.getElementById('tryAgainBtn');
  var wpmInfo = document.getElementById('wpmInfo');
  var accInfo = document.getElementById('accInfo');
  var timerInfo = document.getElementById('timerInfo');
  var passageDisplay = document.getElementById('passageDisplay');
  var typingInput = document.getElementById('typingInput');
  var finalWpm = document.getElementById('finalWpm');
  var resultDetails = document.getElementById('resultDetails');
  var ratingBadge = document.getElementById('ratingBadge');
  var attemptHistorySection = document.getElementById('attemptHistory');
  var historyList = document.getElementById('historyList');

  var currentPassage = '';
  var isPlaying = false;
  var startTime = 0;
  var timerInterval = null;
  var timeLeft = TIME_LIMIT;

  function showView(view) {
    instructionsView.style.display = 'none';
    playView.style.display = 'none';
    resultView.style.display = 'none';
    view.style.display = '';
  }

  function renderPassage(typed) {
    var html = '';
    for (var i = 0; i < currentPassage.length; i++) {
      var rawCh = currentPassage[i];
      var ch = rawCh === ' ' ? '&nbsp;' : rawCh === '<' ? '&lt;' : rawCh === '>' ? '&gt;' : rawCh;
      if (i < typed.length) {
        if (typed[i] === currentPassage[i]) {
          html += '<span class="char-correct">' + ch + '</span>';
        } else {
          html += '<span class="char-wrong">' + ch + '</span>';
        }
      } else if (i === typed.length) {
        html += '<span class="char-current">' + ch + '</span>';
      } else {
        html += ch;
      }
    }
    passageDisplay.innerHTML = html;
  }

  function calcWpm(typed, elapsedSec) {
    if (elapsedSec <= 0) return 0;
    var correctChars = 0;
    for (var i = 0; i < typed.length && i < currentPassage.length; i++) {
      if (typed[i] === currentPassage[i]) correctChars++;
    }
    return Math.round((correctChars / 5) / (elapsedSec / 60));
  }

  function calcAccuracy(typed) {
    if (typed.length === 0) return 100;
    var correct = 0;
    var len = Math.min(typed.length, currentPassage.length);
    for (var i = 0; i < len; i++) {
      if (typed[i] === currentPassage[i]) correct++;
    }
    return Math.round((correct / typed.length) * 100);
  }

  function updateStats() {
    if (!isPlaying) return;
    var typed = typingInput.value;
    var elapsed = (Date.now() - startTime) / 1000;
    var wpm = calcWpm(typed, elapsed);
    var acc = calcAccuracy(typed);
    wpmInfo.textContent = 'WPM: ' + wpm;
    accInfo.textContent = 'Accuracy: ' + acc + '%';
  }

  function tick() {
    timeLeft--;
    timerInfo.textContent = timeLeft + 's';
    if (timeLeft <= 0) {
      endGame();
    }
  }

  function startGame() {
    currentPassage = PASSAGES[Math.floor(Math.random() * PASSAGES.length)];
    isPlaying = false;
    startTime = 0;
    timeLeft = TIME_LIMIT;
    typingInput.value = '';
    typingInput.disabled = false;
    wpmInfo.textContent = 'WPM: 0';
    accInfo.textContent = 'Accuracy: 100%';
    timerInfo.textContent = TIME_LIMIT + 's';
    if (timerInterval) clearInterval(timerInterval);
    timerInterval = null;
    renderPassage('');
    showView(playView);
    typingInput.focus();
  }

  function endGame() {
    isPlaying = false;
    if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
    typingInput.disabled = true;

    var typed = typingInput.value;
    var elapsed = (Date.now() - startTime) / 1000;
    var wpm = calcWpm(typed, elapsed);
    var acc = calcAccuracy(typed);
    var rating = getRating(wpm);

    showView(resultView);
    finalWpm.textContent = String(wpm);
    resultDetails.innerHTML = 'Accuracy: ' + acc + '%<br>Characters: ' + typed.length + '<br>Time: ' + Math.round(elapsed) + 's';
    ratingBadge.textContent = rating.label;
    ratingBadge.style.background = rating.color;

    addToHistory(wpm);
    renderHistory();

    if (window.GameShare) {
      window.GameShare.show({
        gameName: gameName,
        gameSlug: gameSlug,
        gameIcon: gameIcon,
        score: wpm,
        unit: metricUnit,
        metricLabel: metricLabel,
        ratingLabel: rating.label,
        ratingColor: rating.color
      });
    }
  }

  typingInput.addEventListener('input', function () {
    if (!startTime) {
      startTime = Date.now();
      isPlaying = true;
      timerInterval = setInterval(tick, 1000);
    }
    var typed = typingInput.value;
    renderPassage(typed);
    updateStats();

    if (typed.length >= currentPassage.length) {
      endGame();
    }
  });

  function renderHistory() {
    var history = loadHistory();
    if (history.length === 0) { attemptHistorySection.hidden = true; return; }
    attemptHistorySection.hidden = false;
    historyList.innerHTML = history.map(function (e) {
      var r = getRating(e.score);
      return '<div class="history-item">' +
        '<span class="history-score">' + e.score + ' WPM</span>' +
        '<span class="history-rating" style="background:' + r.color + '">' + r.label + '</span>' +
        '<span class="history-time">' + formatDate(e.date) + '</span>' +
        '</div>';
    }).join('');
  }

  function formatDate(iso) {
    try { return new Date(iso).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }); }
    catch (e) { return ''; }
  }

  startBtn.addEventListener('click', startGame);
  tryAgainBtn.addEventListener('click', startGame);
  renderHistory();
})();
</script>
