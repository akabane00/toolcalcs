---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getGameBySlug } from '../../data/games';
import '../../styles/game.css';
import GameShare from '../../components/GameShare.astro';

const game = getGameBySlug('wordle-game')!;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tests & Games", "item": "https://toolcalcs.com/test/" },
      { "@type": "ListItem", "position": 3, "name": "Wordle Game" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Wordle Game",
    "url": "https://toolcalcs.com/test/wordle-game/",
    "applicationCategory": "GameApplication",
    "operatingSystem": "All",
    "browserRequirements": "Requires JavaScript",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "description": "Guess the hidden 5-letter word in 6 tries. Green, yellow, and gray tile clues guide you to the answer. A free online Wordle clone you can play unlimited times."
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is Wordle?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Wordle is a word-guessing puzzle where you have 6 attempts to guess a hidden 5-letter word. After each guess, tiles change color: green means the letter is correct and in the right position, yellow means the letter is in the word but in the wrong position, and gray means the letter is not in the word at all.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the best starting word for Wordle?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Popular high-performing starting words include CRANE, SLATE, ADIEU, AROSE, and STARE. These words contain common letters (vowels and frequent consonants like R, S, T, N) that help eliminate possibilities quickly. The ideal first guess uses 5 unique, frequently occurring letters.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I play Wordle more than once a day?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The original Wordle by Josh Wardle only allows one puzzle per day. However, this free Wordle clone on ToolCalcs lets you play unlimited games by clicking the New Word button to generate a fresh puzzle anytime you want.',
        },
      },
      {
        '@type': 'Question',
        name: 'How many possible 5-letter words are there?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'There are roughly 12,972 five-letter words in the English language, though the original Wordle uses a curated list of about 2,309 common solution words. This clone uses a curated list of 200 common, well-known 5-letter words to keep the game fun and fair.',
        },
      },
    ],
  }
];
---

<BaseLayout
  title="Wordle Game - Daily Word Guessing Puzzle | ToolCalcs"
  description="Play Wordle online for free. Guess the hidden 5-letter word in 6 tries using green, yellow, and gray clues. Unlimited games with a New Word button."
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/test/">Tests & Games</a> &rsaquo;
    <span>Wordle Game</span>
  </nav>

  <h1>Wordle Game</h1>
  <p class="page-desc">Guess the hidden 5-letter word in 6 tries. Each guess reveals color clues to guide you to the answer.</p>

  <div class="game-box">
    <div class="game-area wordle-area" id="gameArea" role="region" aria-label="Wordle game area" aria-live="polite">
      <div id="messageBar" class="wordle-message" aria-live="assertive"></div>
      <div class="wordle-board" id="wordleBoard"></div>
      <div class="wordle-keyboard" id="wordleKeyboard"></div>
      <button class="game-btn primary wordle-new-btn" id="newWordBtn" type="button" style="display:none;">New Word</button>
    </div>

    <GameShare />

    <div class="attempt-history" id="attemptHistory" hidden>
      <h3>Attempt History</h3>
      <div class="history-list" id="historyList"></div>
    </div>
  </div>

  <AdUnit slot="game-mid" format="horizontal" />

  <article class="content-section">
    <h2>What Is Wordle?</h2>
    <p>Wordle is a deceptively simple yet deeply addictive word-guessing puzzle that took the internet by storm in late 2021 and early 2022. Created by software engineer Josh Wardle as a personal gift for his partner, the game quickly spread from a small group of friends to millions of daily players worldwide. The concept is straightforward: guess a hidden 5-letter English word within 6 attempts. After each guess, the game provides color-coded feedback on every letter, telling you whether each letter is in the correct position (green), present in the word but misplaced (yellow), or not in the word at all (gray).</p>
    <p>What makes Wordle so compelling is the elegant balance between simplicity and strategy. The rules can be explained in 30 seconds, yet mastering the game requires vocabulary knowledge, pattern recognition, letter frequency awareness, and logical deduction. Each guess narrows the possibilities, and the satisfaction of solving a puzzle — especially in 2 or 3 tries — creates a dopamine rush that keeps players coming back day after day.</p>
    <p>This free online Wordle clone lets you play unlimited puzzles without waiting for the next daily word. Click "New Word" at any time to generate a fresh challenge. The game uses a curated list of 200 common English words, ensuring every answer is a familiar, recognizable word rather than an obscure term that would feel unfair.</p>

    <h2>The History of Wordle</h2>
    <p>Josh Wardle (whose surname inspired the game's name) initially created Wordle during the COVID-19 pandemic as a small project for himself and his partner, Palak Shah, who loved word games. He made it available to the public in October 2021, and by January 2022, the game had exploded from 90 daily players to over 2 million. The iconic grid of colored squares that players shared on social media — without revealing the answer — became one of the most recognizable symbols of internet culture in 2022.</p>
    <p>In January 2022, The New York Times acquired Wordle for an undisclosed sum reported to be in the "low seven figures." The game remains free to play on the NYT website, though it now sits alongside the paper's other popular games like Spelling Bee, Connections, and the classic Crossword. Wordle's success spawned countless variants: Dordle (two words at once), Quordle (four words), Octordle (eight words), Worldle (geography), Heardle (music), and many more.</p>
    <p>The game's minimalist design was part of its appeal. There were no ads, no accounts, no push notifications — just one puzzle per day, shared equally by everyone playing. This constraint created a communal experience where friends, coworkers, and strangers could compare results without spoiling the answer, fostering social connection through a shared daily ritual.</p>

    <h2>How to Play This Wordle Clone</h2>
    <p>Playing this Wordle game is simple and intuitive. When you load the page, a random 5-letter word is selected from the word list. You have 6 attempts to guess it. Type your guess using either the on-screen keyboard or your physical keyboard, then press Enter to submit.</p>
    <ul>
      <li><strong>Green tile:</strong> The letter is in the word AND in the correct position. Lock this letter into that spot for future guesses.</li>
      <li><strong>Yellow tile:</strong> The letter is in the word but NOT in the correct position. You know it belongs somewhere else in the word.</li>
      <li><strong>Gray tile:</strong> The letter is NOT in the word at all. Eliminate it from all future guesses.</li>
    </ul>
    <p>After submitting a guess, each tile flips to reveal its color with a satisfying animation. The on-screen keyboard also updates to reflect the status of each letter, making it easy to see which letters you have tried and their results. If you guess the word correctly, a congratulations message appears. If you exhaust all 6 guesses, the hidden word is revealed. Click "New Word" at any time to start a fresh puzzle.</p>

    <h2>Best Starting Words for Wordle</h2>
    <p>Your first guess is arguably the most important move in any Wordle game. A strong opening word can reveal multiple correct letters and dramatically narrow down the possible solutions. Linguistic analysis and computational studies have identified several optimal starting words:</p>
    <ul>
      <li><strong>CRANE</strong> — Contains three of the most common consonants (C, R, N) and two vowels (A, E). Frequently cited as the mathematically optimal first guess based on information theory analysis.</li>
      <li><strong>SLATE</strong> — Features S, L, T (three of the top 5 most frequent consonants in English) plus A and E. The New York Times' WordleBot has recommended SLATE as a top starter.</li>
      <li><strong>ADIEU</strong> — Covers four of five vowels in a single guess (A, I, E, U). While it lacks strong consonants, knowing which vowels are present is extremely valuable.</li>
      <li><strong>AROSE</strong> — Includes A, O, E (three vowels) alongside R and S, two of the most common consonants. Provides excellent coverage of the letter frequency spectrum.</li>
      <li><strong>STARE</strong> — Combines S, T, R (the three most common consonants) with A and E. This word consistently performs well in simulation studies.</li>
    </ul>
    <p>Beyond choosing a good first word, a strong second guess should complement your opener by testing new letters. For example, if you start with CRANE, a good follow-up might be LOUDS or PILOT, which test entirely different letters and maximizes the information you gain from two guesses.</p>

    <h2>Wordle Strategy Tips</h2>
    <p>Consistently solving Wordle in 3-4 guesses requires more than luck. Here are proven strategies used by top players:</p>
    <h3>Maximize Information Early</h3>
    <p>Your first two guesses should collectively cover 10 unique, frequently-used letters. Avoid repeating letters in your opening guesses. For example, starting with CRANE followed by LIGHT tests 10 different letters, giving you maximum information to work with for your remaining guesses.</p>
    <h3>Think About Letter Position Frequency</h3>
    <p>Certain letters appear more often in specific positions. For instance, S is extremely common as the first letter but also frequent as the last letter. The letter Y appears disproportionately at the end of words. Understanding positional frequency helps you make smarter guesses when you have partial information.</p>
    <h3>Use Process of Elimination</h3>
    <p>Pay close attention to gray letters. Every eliminated letter significantly reduces the solution space. If you know a word contains A and R but not E, S, T, L, or N, the number of valid 5-letter words drops dramatically. Mentally (or on paper) tracking eliminated letters is one of the most effective strategies.</p>
    <h3>Watch for Common Patterns</h3>
    <p>English words follow predictable patterns. Common endings include -IGHT, -TION, -OUND, -ATCH, and -ASTE. Common beginnings include SH-, TH-, CH-, and ST-. When you have partial information, thinking about these patterns can help you generate valid guesses more quickly.</p>
    <h3>Avoid the "Green Lock" Trap</h3>
    <p>When you find a green letter early, resist the temptation to only guess words that keep it in place. Sometimes it is more efficient to sacrifice a known green letter to test other positions and letters, especially if you are stuck between many possibilities.</p>

    <h2>Letter Frequency in English Words</h2>
    <p>Understanding which letters appear most frequently in 5-letter English words gives you a significant advantage. Research analyzing the Wordle word list reveals the following frequency rankings:</p>
    <ul>
      <li><strong>Most common letters:</strong> E, A, R, O, T, L, I, S, N — these nine letters account for the majority of all letter occurrences in 5-letter words.</li>
      <li><strong>Moderately common:</strong> H, D, U, C, P, M, Y — useful letters that appear in many words but less frequently than the top tier.</li>
      <li><strong>Less common:</strong> G, B, W, F, K, V — these appear in fewer words and are lower-priority guesses.</li>
      <li><strong>Rare letters:</strong> X, J, Q, Z — these appear in very few 5-letter words and should generally not be guessed early unless you have strong evidence.</li>
    </ul>
    <p>The vowels E, A, O, and I are particularly important because most 5-letter words contain at least two vowels. Identifying which vowels are present in the target word is often the key to solving the puzzle quickly.</p>

    <h2>Similar Word Games</h2>
    <p>Wordle's success inspired an entire genre of daily puzzle games. If you enjoy Wordle, you might also like these popular variants:</p>
    <ul>
      <li><strong>Dordle:</strong> Solve two Wordles simultaneously with shared guesses. Each guess applies to both boards, and you have 7 attempts total.</li>
      <li><strong>Quordle:</strong> Four Wordles at once with 9 guesses. Significantly harder, as you must balance progress across all four boards.</li>
      <li><strong>Absurdle:</strong> An adversarial version where the game actively tries to avoid your guesses by changing the target word within the constraints of previous clues.</li>
      <li><strong>Nerdle:</strong> A mathematical version where you guess equations instead of words, using numbers and operators.</li>
      <li><strong>Worldle:</strong> Guess a country or territory based on its silhouette shape, with distance and direction clues after each guess.</li>
    </ul>

    <h2>Frequently Asked Questions</h2>

    <details>
      <summary>What is the best first word in Wordle?</summary>
      <p>Computational analysis suggests CRANE, SLATE, and STARE are among the best starting words. They contain frequently occurring letters and provide maximum information. However, any word with common, non-repeating letters is a solid choice. The key is using letters that appear often in English 5-letter words.</p>
    </details>

    <details>
      <summary>Is there a strategy to always win Wordle?</summary>
      <p>While there is no guaranteed strategy to always guess correctly, you can dramatically improve your odds by starting with information-rich words, paying attention to letter positions, and systematically eliminating possibilities. Most experienced players solve the puzzle in 3-4 guesses on average by following these principles.</p>
    </details>

    <details>
      <summary>What happens if I use a letter that appears twice in the word?</summary>
      <p>If the target word contains a double letter (like TEETH or LLAMA), the game handles it precisely. A letter will only show as yellow or green if there are remaining unmatched instances of that letter in the word. If you guess a letter twice and it only appears once in the answer, one instance may be green or yellow while the other is gray.</p>
    </details>

    <details>
      <summary>How many guesses do most people need?</summary>
      <p>Statistics from millions of Wordle players show that the average number of guesses is about 4. Solving in 1 guess is essentially luck (a 1 in 2,309 chance with the official word list). Solving in 2 is rare and impressive. Three guesses is excellent, four is solid, five is average, and six is a close call. Failing to solve in 6 guesses happens to everyone occasionally.</p>
    </details>

    <details>
      <summary>Can I play this Wordle clone on mobile?</summary>
      <p>Yes. This game is fully responsive and works on smartphones, tablets, and desktop computers. The on-screen keyboard is optimized for touch input, and the tile grid scales to fit any screen size. You can play in both portrait and landscape orientation.</p>
    </details>

    <details>
      <summary>Why are some Wordle words harder than others?</summary>
      <p>Words with uncommon letter combinations, double letters, or rare consonants tend to be harder. Words like KNOLL, VIVID, or NYMPH are notoriously difficult because they contain unusual patterns that players do not typically guess early. Words with common letters in common positions (like STARE or CRANE) are generally easier to deduce through elimination.</p>
    </details>
  </article>

  <AdUnit slot="game-bottom" format="horizontal" />
</BaseLayout>

<style>
  .wordle-area {
    cursor: default;
    user-select: auto;
    -webkit-user-select: auto;
    max-width: 520px;
    min-height: auto;
    padding: 16px 8px;
    overflow: visible;
  }

  .wordle-message {
    min-height: 36px;
    line-height: 36px;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text);
    text-align: center;
  }

  .wordle-board {
    display: grid;
    grid-template-rows: repeat(6, 1fr);
    gap: 5px;
    justify-content: center;
    margin: 0 auto 16px;
    max-width: 350px;
  }

  :global(.wordle-row) {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 5px;
  }

  :global(.wordle-tile) {
    width: 62px;
    height: 62px;
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-text);
    background: transparent;
    border-radius: 4px;
    transition: transform 0.1s;
    box-sizing: border-box;
  }

  :global(.wordle-tile.filled) {
    border-color: var(--color-text-muted);
    animation: wordle-pop 0.08s ease-out;
  }

  :global(.wordle-tile.correct) {
    background: #6aaa64;
    border-color: #6aaa64;
    color: #fff;
  }
  :global(.wordle-tile.present) {
    background: #c9b458;
    border-color: #c9b458;
    color: #fff;
  }
  :global(.wordle-tile.absent) {
    background: #787c7e;
    border-color: #787c7e;
    color: #fff;
  }

  :global(.wordle-tile.reveal) {
    animation: wordle-flip 0.5s ease forwards;
  }

  @keyframes wordle-pop {
    0% { transform: scale(1); }
    50% { transform: scale(1.08); }
    100% { transform: scale(1); }
  }

  @keyframes wordle-flip {
    0% { transform: rotateX(0); }
    45% { transform: rotateX(90deg); }
    55% { transform: rotateX(90deg); }
    100% { transform: rotateX(0); }
  }

  .wordle-keyboard {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin: 0 auto;
    max-width: 500px;
  }

  :global(.kb-row) {
    display: flex;
    gap: 5px;
    justify-content: center;
  }

  :global(.kb-key) {
    min-width: 33px;
    height: 52px;
    border: none;
    border-radius: 4px;
    background: var(--color-surface-hover, #d3d6da);
    color: var(--color-text);
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    padding: 0 6px;
    transition: background 0.15s, color 0.15s;
    user-select: none;
    -webkit-user-select: none;
  }

  :global(.kb-key:active) {
    transform: scale(0.95);
  }

  :global(.kb-key.wide) {
    min-width: 58px;
    font-size: 0.72rem;
  }

  :global(.kb-key.correct) {
    background: #6aaa64;
    color: #fff;
  }
  :global(.kb-key.present) {
    background: #c9b458;
    color: #fff;
  }
  :global(.kb-key.absent) {
    background: #787c7e;
    color: #fff;
  }

  .wordle-new-btn {
    margin-top: 12px;
  }

  /* Responsive */
  @media (max-width: 420px) {
    :global(.wordle-tile) {
      width: 52px;
      height: 52px;
      font-size: 1.5rem;
    }
    :global(.kb-key) {
      min-width: 26px;
      height: 46px;
      font-size: 0.75rem;
      padding: 0 4px;
    }
    :global(.kb-key.wide) {
      min-width: 46px;
      font-size: 0.65rem;
    }
  }

  @media (max-width: 340px) {
    :global(.wordle-tile) {
      width: 44px;
      height: 44px;
      font-size: 1.3rem;
    }
    :global(.kb-key) {
      min-width: 22px;
      height: 40px;
      font-size: 0.68rem;
    }
  }
</style>

<script is:inline>
(function () {
  var WORDS = [
    'APPLE','BEACH','BRAIN','CHARM','DANCE','EARLY','FLAME','GHOST','HAPPY','IMAGE',
    'JUICE','KNEEL','LEMON','MAGIC','NOBLE','OCEAN','PEARL','QUEEN','RAISE','SMILE',
    'TOWER','UNITY','VIVID','WHALE','YOUTH','ZEBRA','ABOUT','ABOVE','ABUSE','ACTOR',
    'ADAPT','ADMIT','ADOPT','ADULT','AFTER','AGAIN','AGENT','AGREE','ALBUM','ALIEN',
    'ALIGN','ALLOW','ALONE','ALTER','AMONG','ANGEL','ANGER','ANGLE','ANGRY','ANKLE',
    'APART','ARENA','ARGUE','ARISE','ARMOR','ASSET','AVOID','AWARD','BAKER','BASIC',
    'BEGAN','BEING','BELOW','BENCH','BLACK','BLADE','BLAME','BLANK','BLAST','BLAZE',
    'BLEED','BLEND','BLIND','BLOCK','BLOOD','BLOOM','BLOWN','BOARD','BONUS','BOUND',
    'BRAVE','BREAD','BREAK','BRICK','BRIEF','BRING','BROAD','BROWN','BRUSH','BUILD',
    'BURST','BUYER','CABIN','CABLE','CAMEL','CANDY','CARRY','CATCH','CAUSE','CHAIN',
    'CHAIR','CHEAP','CHECK','CHEST','CHIEF','CHILD','CHORD','CIVIL','CLAIM','CLASS',
    'CLEAN','CLEAR','CLIMB','CLOCK','CLOSE','CLOTH','CLOUD','COACH','COAST','COLOR',
    'COUCH','COUNT','COURT','COVER','CRAFT','CRANE','CRASH','CRAZY','CREAM','CRIME',
    'CROSS','CROWD','CROWN','CRUEL','CRUSH','CURVE','CYCLE','DAILY','DEALT','DEATH',
    'DEBUT','DECOR','DELAY','DELTA','DEMON','DEPTH','DIRTY','DOUBT','DRAFT','DRAIN',
    'DRAMA','DRANK','DREAM','DRESS','DRIED','DRIFT','DRINK','DRIVE','DRONE','DYING',
    'EAGER','EARTH','EIGHT','ELITE','EMPTY','ENEMY','ENJOY','ENTER','EQUAL','ERROR',
    'EVENT','EXACT','EXIST','EXTRA','FAINT','FAITH','FALSE','FANCY','FATAL','FAVOR',
    'FEAST','FENCE','FIBER','FIELD','FIGHT','FINAL','FIRST','FIXED','FLASH','FLESH',
    'FLOAT','FLOOD','FLOOR','FLOUR','FLUID','FOCUS','FORCE','FORGE','FOUND','FRAME',
  ];

  var target = '';
  var currentRow = 0;
  var currentCol = 0;
  var gameOver = false;
  var board = [];
  var attempts = [];

  var boardEl = document.getElementById('wordleBoard');
  var kbEl = document.getElementById('wordleKeyboard');
  var msgEl = document.getElementById('messageBar');
  var newBtn = document.getElementById('newWordBtn');

  var kbRows = [
    ['Q','W','E','R','T','Y','U','I','O','P'],
    ['A','S','D','F','G','H','J','K','L'],
    ['ENTER','Z','X','C','V','B','N','M','BACK']
  ];

  var letterStatus = {};

  function init() {
    target = WORDS[Math.floor(Math.random() * WORDS.length)];
    currentRow = 0;
    currentCol = 0;
    gameOver = false;
    board = [];
    attempts = [];
    letterStatus = {};
    msgEl.textContent = '';
    newBtn.style.display = 'none';
    buildBoard();
    buildKeyboard();
  }

  function buildBoard() {
    boardEl.innerHTML = '';
    board = [];
    for (var r = 0; r < 6; r++) {
      var row = document.createElement('div');
      row.className = 'wordle-row';
      var tiles = [];
      for (var c = 0; c < 5; c++) {
        var tile = document.createElement('div');
        tile.className = 'wordle-tile';
        tile.setAttribute('data-row', r);
        tile.setAttribute('data-col', c);
        row.appendChild(tile);
        tiles.push(tile);
      }
      boardEl.appendChild(row);
      board.push(tiles);
    }
  }

  function buildKeyboard() {
    kbEl.innerHTML = '';
    for (var r = 0; r < kbRows.length; r++) {
      var rowDiv = document.createElement('div');
      rowDiv.className = 'kb-row';
      for (var k = 0; k < kbRows[r].length; k++) {
        var key = kbRows[r][k];
        var btn = document.createElement('button');
        btn.className = 'kb-key';
        btn.setAttribute('type', 'button');
        btn.setAttribute('data-key', key);
        if (key === 'ENTER' || key === 'BACK') {
          btn.classList.add('wide');
        }
        btn.textContent = key === 'BACK' ? '\u232B' : key;
        btn.addEventListener('click', handleKeyClick);
        rowDiv.appendChild(btn);
      }
      kbEl.appendChild(rowDiv);
    }
  }

  function handleKeyClick(e) {
    var key = e.currentTarget.getAttribute('data-key');
    processKey(key);
  }

  function processKey(key) {
    if (gameOver) return;

    if (key === 'BACK' || key === 'BACKSPACE') {
      if (currentCol > 0) {
        currentCol--;
        board[currentRow][currentCol].textContent = '';
        board[currentRow][currentCol].classList.remove('filled');
      }
      return;
    }

    if (key === 'ENTER') {
      if (currentCol < 5) {
        showMessage('Not enough letters');
        shakeRow(currentRow);
        return;
      }
      submitGuess();
      return;
    }

    if (key.length === 1 && key >= 'A' && key <= 'Z') {
      if (currentCol < 5) {
        board[currentRow][currentCol].textContent = key;
        board[currentRow][currentCol].classList.add('filled');
        currentCol++;
      }
    }
  }

  function submitGuess() {
    var guess = '';
    for (var c = 0; c < 5; c++) {
      guess += board[currentRow][c].textContent;
    }

    var result = evaluateGuess(guess, target);

    revealRow(currentRow, result, function () {
      updateKeyboard(guess, result);
      attempts.push({ guess: guess, result: result });

      if (guess === target) {
        gameOver = true;
        var messages = ['Genius!', 'Magnificent!', 'Impressive!', 'Splendid!', 'Great!', 'Phew!'];
        showMessage(messages[currentRow] || 'You got it!');
        newBtn.style.display = '';
        showShareResult(currentRow + 1);
        return;
      }

      currentRow++;
      currentCol = 0;

      if (currentRow >= 6) {
        gameOver = true;
        showMessage('The word was ' + target);
        newBtn.style.display = '';
        showShareResult(7);
      }
    });
  }

  function evaluateGuess(guess, answer) {
    var result = ['absent', 'absent', 'absent', 'absent', 'absent'];
    var answerArr = answer.split('');
    var guessArr = guess.split('');
    var used = [false, false, false, false, false];

    // First pass: correct positions
    for (var i = 0; i < 5; i++) {
      if (guessArr[i] === answerArr[i]) {
        result[i] = 'correct';
        used[i] = true;
        guessArr[i] = null;
      }
    }

    // Second pass: present but wrong position
    for (var i = 0; i < 5; i++) {
      if (guessArr[i] === null) continue;
      for (var j = 0; j < 5; j++) {
        if (!used[j] && guessArr[i] === answerArr[j]) {
          result[i] = 'present';
          used[j] = true;
          break;
        }
      }
    }

    return result;
  }

  function revealRow(row, result, callback) {
    var tiles = board[row];
    var delay = 0;

    for (var c = 0; c < 5; c++) {
      (function (col, d) {
        setTimeout(function () {
          tiles[col].classList.add('reveal');
          // Apply color at the midpoint of the flip animation
          setTimeout(function () {
            tiles[col].classList.add(result[col]);
          }, 250);
        }, d);
      })(c, delay);
      delay += 300;
    }

    setTimeout(function () {
      if (callback) callback();
    }, delay + 300);
  }

  function updateKeyboard(guess, result) {
    var priority = { correct: 3, present: 2, absent: 1 };

    for (var i = 0; i < 5; i++) {
      var letter = guess[i];
      var status = result[i];
      var current = letterStatus[letter];

      if (!current || priority[status] > priority[current]) {
        letterStatus[letter] = status;
      }
    }

    var keys = kbEl.querySelectorAll('.kb-key');
    for (var k = 0; k < keys.length; k++) {
      var keyVal = keys[k].getAttribute('data-key');
      if (letterStatus[keyVal]) {
        keys[k].classList.remove('correct', 'present', 'absent');
        keys[k].classList.add(letterStatus[keyVal]);
      }
    }
  }

  function showMessage(text) {
    msgEl.textContent = text;
    if (text && !gameOver) {
      setTimeout(function () {
        if (msgEl.textContent === text) msgEl.textContent = '';
      }, 2000);
    }
  }

  function shakeRow(row) {
    var rowEl = board[row][0].parentElement;
    rowEl.style.animation = 'none';
    rowEl.offsetHeight; // force reflow
    rowEl.style.animation = 'wordle-shake 0.5s ease';
    setTimeout(function () {
      rowEl.style.animation = '';
    }, 500);
  }

  function showShareResult(guessCount) {
    if (!window.GameShare) return;

    var won = guessCount <= 6;
    var ratingLabels = ['', 'Genius!', 'Brilliant!', 'Great!', 'Good', 'Close Call', 'Phew!'];
    var ratingColors = ['', '#16a34a', '#22c55e', '#2563eb', '#f59e0b', '#ef4444', '#dc2626'];
    var label = won ? (ratingLabels[guessCount] || 'Phew!') : 'Failed';
    var color = won ? (ratingColors[guessCount] || '#dc2626') : '#787c7e';

    window.GameShare.show({
      gameName: 'Wordle Game',
      gameSlug: 'wordle-game',
      gameIcon: '\uD83D\uDFE9',
      score: won ? guessCount : 'X',
      unit: won ? 'guesses' : '/6',
      metricLabel: 'Guesses Used',
      ratingLabel: label,
      ratingColor: color
    });

    // Attempt history
    var historyEl = document.getElementById('attemptHistory');
    var listEl = document.getElementById('historyList');
    if (historyEl && listEl) {
      var grid = '';
      for (var r = 0; r < attempts.length; r++) {
        var line = '';
        for (var c = 0; c < 5; c++) {
          var s = attempts[r].result[c];
          if (s === 'correct') line += '\uD83D\uDFE9';
          else if (s === 'present') line += '\uD83D\uDFE8';
          else line += '\u2B1C';
        }
        grid += '<div>' + line + '</div>';
      }
      listEl.innerHTML = grid;
      historyEl.hidden = false;
    }
  }

  // Physical keyboard support
  document.addEventListener('keydown', function (e) {
    if (e.ctrlKey || e.metaKey || e.altKey) return;
    var key = e.key.toUpperCase();
    if (key === 'BACKSPACE') {
      e.preventDefault();
      processKey('BACK');
    } else if (key === 'ENTER') {
      e.preventDefault();
      processKey('ENTER');
    } else if (key.length === 1 && key >= 'A' && key <= 'Z') {
      e.preventDefault();
      processKey(key);
    }
  });

  newBtn.addEventListener('click', function () {
    if (window.GameShare && window.GameShare.hide) {
      window.GameShare.hide();
    }
    var historyEl = document.getElementById('attemptHistory');
    if (historyEl) historyEl.hidden = true;
    init();
  });

  // Add shake keyframe dynamically
  var styleSheet = document.createElement('style');
  styleSheet.textContent = '@keyframes wordle-shake { 0%, 100% { transform: translateX(0); } 10%, 30%, 50%, 70%, 90% { transform: translateX(-4px); } 20%, 40%, 60%, 80% { transform: translateX(4px); } }';
  document.head.appendChild(styleSheet);

  init();
})();
</script>
