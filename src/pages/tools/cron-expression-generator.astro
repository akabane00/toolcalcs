<script>
  (function () {
    'use strict';

    // --- Types ---
    interface FieldConfig {
      id: string;
      name: string;
      min: number;
      max: number;
      valueEl: HTMLElement;
      fieldEl: HTMLElement;
      names?: string[];
    }

    // --- Constants ---
    const MONTH_NAMES = ['', 'January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
    const DOW_NAMES = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
    const DOW_SHORT = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

    // --- DOM ---
    const cronOutput = document.getElementById('cronOutput') as HTMLElement;
    const cronDescription = document.getElementById('cronDescription') as HTMLElement;
    const runList = document.getElementById('runList') as HTMLUListElement;
    const copyCronBtn = document.getElementById('copyCronBtn') as HTMLButtonElement;
    const manualInput = document.getElementById('manualInput') as HTMLInputElement;
    const parseBtn = document.getElementById('parseBtn') as HTMLButtonElement;
    const errorEl = document.getElementById('toolError') as HTMLDivElement;

    // --- Field Configurations ---
    const fields: FieldConfig[] = [
      { id: 'fieldMinute', name: 'minute', min: 0, max: 59, valueEl: document.getElementById('minuteValue')!, fieldEl: document.getElementById('fieldMinute')! },
      { id: 'fieldHour', name: 'hour', min: 0, max: 23, valueEl: document.getElementById('hourValue')!, fieldEl: document.getElementById('fieldHour')! },
      { id: 'fieldDom', name: 'dom', min: 1, max: 31, valueEl: document.getElementById('domValue')!, fieldEl: document.getElementById('fieldDom')! },
      { id: 'fieldMonth', name: 'month', min: 1, max: 12, valueEl: document.getElementById('monthValue')!, fieldEl: document.getElementById('fieldMonth')! },
      { id: 'fieldDow', name: 'dow', min: 0, max: 6, valueEl: document.getElementById('dowValue')!, fieldEl: document.getElementById('fieldDow')! },
    ];

    // --- Helpers ---
    function showError(msg: string): void {
      errorEl.textContent = msg;
      errorEl.hidden = false;
    }

    function clearError(): void {
      errorEl.textContent = '';
      errorEl.hidden = true;
    }

    function showCopyFeedback(btn: HTMLButtonElement): void {
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = original;
        btn.classList.remove('copied');
      }, 1500);
    }

    async function copyToClipboard(text: string, btn: HTMLButtonElement): Promise<void> {
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        showCopyFeedback(btn);
      } catch {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        showCopyFeedback(btn);
      }
    }

    // --- Get active mode for a field ---
    function getActiveMode(fieldEl: HTMLElement): string {
      const activeBtn = fieldEl.querySelector('.mode-btn.active') as HTMLButtonElement;
      return activeBtn ? activeBtn.dataset.mode || 'every' : 'every';
    }

    // --- Build field value from UI ---
    function getFieldValue(field: FieldConfig): string {
      const el = field.fieldEl;
      const mode = getActiveMode(el);

      if (mode === 'every') {
        return '*';
      }

      if (mode === 'specific') {
        if (field.name === 'dow') {
          const checked = el.querySelectorAll('.dow-checkboxes input:checked') as NodeListOf<HTMLInputElement>;
          if (checked.length === 0) return '*';
          const vals = Array.from(checked).map(cb => cb.value);
          return vals.join(',');
        }
        const input = el.querySelector('.mode-input[data-mode="specific"] .specific-input') as HTMLInputElement;
        const val = input.value.trim();
        if (!val) return '*';
        // Validate comma-separated numbers
        const nums = val.split(',').map(s => s.trim()).filter(s => s !== '');
        const validNums = nums.filter(s => {
          const n = parseInt(s, 10);
          return !isNaN(n) && n >= field.min && n <= field.max;
        });
        return validNums.length > 0 ? validNums.join(',') : '*';
      }

      if (mode === 'range') {
        if (field.name === 'dow') {
          const from = (el.querySelector('.range-from-dow') as HTMLSelectElement).value;
          const to = (el.querySelector('.range-to-dow') as HTMLSelectElement).value;
          return `${from}-${to}`;
        }
        const from = (el.querySelector('.range-from') as HTMLInputElement).value;
        const to = (el.querySelector('.range-to') as HTMLInputElement).value;
        return `${from}-${to}`;
      }

      if (mode === 'step') {
        const every = (el.querySelector('.mode-input[data-mode="step"] .step-every') as HTMLInputElement).value;
        let start: string;
        if (field.name === 'dow') {
          start = (el.querySelector('.step-start-dow') as HTMLSelectElement).value;
        } else {
          start = (el.querySelector('.mode-input[data-mode="step"] .step-start') as HTMLInputElement).value;
        }
        return `${start}/${every}`;
      }

      return '*';
    }

    // --- Build cron expression from UI ---
    function buildExpression(): string {
      return fields.map(f => getFieldValue(f)).join(' ');
    }

    // --- Describe a cron expression in human-readable form ---
    function describeCron(expr: string): string {
      const parts = expr.split(/\s+/);
      if (parts.length !== 5) return 'Invalid expression';

      const [minute, hour, dom, month, dow] = parts;
      const segments: string[] = [];

      // Minute
      if (minute === '*') {
        segments.push('every minute');
      } else if (minute.includes('/')) {
        const [start, step] = minute.split('/');
        if (start === '*' || start === '0') {
          segments.push(`every ${step} minute(s)`);
        } else {
          segments.push(`every ${step} minute(s) starting at minute ${start}`);
        }
      } else if (minute.includes('-')) {
        segments.push(`at minutes ${minute}`);
      } else if (minute.includes(',')) {
        segments.push(`at minutes ${minute}`);
      } else {
        segments.push(`at minute ${minute}`);
      }

      // Hour
      if (hour === '*') {
        // If minute is specific but hour is every, keep the "of every hour" implicit
        if (minute !== '*') {
          segments.push('of every hour');
        }
      } else if (hour.includes('/')) {
        const [start, step] = hour.split('/');
        if (start === '*' || start === '0') {
          segments.push(`every ${step} hour(s)`);
        } else {
          segments.push(`every ${step} hour(s) starting at hour ${start}`);
        }
      } else if (hour.includes('-')) {
        const [from, to] = hour.split('-');
        segments.push(`between ${formatHour(parseInt(from))} and ${formatHour(parseInt(to))}`);
      } else if (hour.includes(',')) {
        const hours = hour.split(',').map(h => formatHour(parseInt(h)));
        segments.push(`at ${hours.join(', ')}`);
      } else {
        // Replace "at minute X" with "at HH:MM"
        const h = parseInt(hour);
        const m = minute === '*' ? 0 : parseInt(minute);
        if (!minute.includes('/') && !minute.includes('-') && !minute.includes(',') && minute !== '*') {
          segments.length = 0;
          segments.push(`at ${formatHour(h)}:${String(m).padStart(2, '0')}`);
        } else {
          segments.push(`during the ${formatHour(h)} hour`);
        }
      }

      // Day of Month
      if (dom !== '*') {
        if (dom.includes('/')) {
          const [start, step] = dom.split('/');
          segments.push(`every ${step} day(s) starting on day ${start}`);
        } else if (dom.includes('-')) {
          segments.push(`on days ${dom} of the month`);
        } else if (dom.includes(',')) {
          segments.push(`on days ${dom} of the month`);
        } else {
          segments.push(`on day ${dom} of the month`);
        }
      }

      // Month
      if (month !== '*') {
        if (month.includes('/')) {
          const [start, step] = month.split('/');
          segments.push(`every ${step} month(s) starting in ${MONTH_NAMES[parseInt(start)] || 'month ' + start}`);
        } else if (month.includes('-')) {
          const [from, to] = month.split('-');
          segments.push(`in ${MONTH_NAMES[parseInt(from)] || from} through ${MONTH_NAMES[parseInt(to)] || to}`);
        } else if (month.includes(',')) {
          const months = month.split(',').map(m => MONTH_NAMES[parseInt(m)] || m);
          segments.push(`in ${months.join(', ')}`);
        } else {
          segments.push(`in ${MONTH_NAMES[parseInt(month)] || month}`);
        }
      }

      // Day of Week
      if (dow !== '*') {
        if (dow.includes('/')) {
          const [start, step] = dow.split('/');
          segments.push(`every ${step} day(s) of the week starting on ${DOW_NAMES[parseInt(start)] || start}`);
        } else if (dow.includes('-')) {
          const [from, to] = dow.split('-');
          segments.push(`on ${DOW_NAMES[parseInt(from)] || from} through ${DOW_NAMES[parseInt(to)] || to}`);
        } else if (dow.includes(',')) {
          const days = dow.split(',').map(d => DOW_SHORT[parseInt(d)] || d);
          segments.push(`on ${days.join(', ')}`);
        } else {
          segments.push(`on ${DOW_NAMES[parseInt(dow)] || dow}`);
        }
      }

      const desc = segments.join(', ');
      return desc.charAt(0).toUpperCase() + desc.slice(1);
    }

    function formatHour(h: number): string {
      if (h === 0) return '12 AM';
      if (h === 12) return '12 PM';
      if (h < 12) return `${h} AM`;
      return `${h - 12} PM`;
    }

    // --- Calculate next N run times ---
    function getNextRuns(expr: string, count: number): Date[] {
      const parts = expr.split(/\s+/);
      if (parts.length !== 5) return [];

      const [minExpr, hourExpr, domExpr, monthExpr, dowExpr] = parts;
      const results: Date[] = [];
      const now = new Date();
      // Start checking from the next minute
      const check = new Date(now.getFullYear(), now.getMonth(), now.getDate(), now.getHours(), now.getMinutes() + 1, 0, 0);

      // Expand a cron field into a set of matching values
      function expandField(expr: string, min: number, max: number): Set<number> {
        const values = new Set<number>();
        const parts = expr.split(',');
        for (const part of parts) {
          if (part === '*') {
            for (let i = min; i <= max; i++) values.add(i);
          } else if (part.includes('/')) {
            const [rangeStr, stepStr] = part.split('/');
            const step = parseInt(stepStr, 10);
            let start = min;
            let end = max;
            if (rangeStr !== '*') {
              if (rangeStr.includes('-')) {
                const [fromStr, toStr] = rangeStr.split('-');
                start = parseInt(fromStr, 10);
                end = parseInt(toStr, 10);
              } else {
                start = parseInt(rangeStr, 10);
              }
            }
            for (let i = start; i <= end; i += step) {
              values.add(i);
            }
          } else if (part.includes('-')) {
            const [fromStr, toStr] = part.split('-');
            const from = parseInt(fromStr, 10);
            const to = parseInt(toStr, 10);
            if (from <= to) {
              for (let i = from; i <= to; i++) values.add(i);
            } else {
              // Wrap-around range (e.g. 5-2 in dow = Fri through Tue)
              for (let i = from; i <= max; i++) values.add(i);
              for (let i = min; i <= to; i++) values.add(i);
            }
          } else {
            const val = parseInt(part, 10);
            if (!isNaN(val)) values.add(val);
          }
        }
        return values;
      }

      const validMinutes = expandField(minExpr, 0, 59);
      const validHours = expandField(hourExpr, 0, 23);
      const validDom = expandField(domExpr, 1, 31);
      const validMonths = expandField(monthExpr, 1, 12);
      const validDow = expandField(dowExpr, 0, 6);

      // Limit iterations to prevent infinite loops (scan up to 2 years)
      const maxIterations = 2 * 366 * 24 * 60;
      let iterations = 0;

      while (results.length < count && iterations < maxIterations) {
        const min = check.getMinutes();
        const hr = check.getHours();
        const dayOfMonth = check.getDate();
        const month = check.getMonth() + 1;
        const dayOfWeek = check.getDay();

        // Check if the current minute matches
        if (
          validMinutes.has(min) &&
          validHours.has(hr) &&
          validDom.has(dayOfMonth) &&
          validMonths.has(month) &&
          validDow.has(dayOfWeek)
        ) {
          results.push(new Date(check));
        }

        // Advance by 1 minute
        check.setMinutes(check.getMinutes() + 1);

        // Optimization: if the current hour is not valid, skip to the next valid hour
        if (!validHours.has(check.getHours()) && validMinutes.size < 60) {
          // Skip ahead to the start of the next hour
          check.setMinutes(0);
          check.setHours(check.getHours() + 1);
        }

        // Optimization: if the current month is not valid, skip to the first day of the next valid month
        if (!validMonths.has(check.getMonth() + 1)) {
          check.setDate(1);
          check.setHours(0);
          check.setMinutes(0);
          check.setMonth(check.getMonth() + 1);
        }

        iterations++;
      }

      return results;
    }

    // --- Update the display ---
    function updateDisplay(): void {
      clearError();
      const expr = buildExpression();

      // Update field value badges
      fields.forEach(f => {
        f.valueEl.textContent = getFieldValue(f);
      });

      // Update output
      cronOutput.textContent = expr;
      manualInput.value = expr;

      // Description
      cronDescription.textContent = describeCron(expr);

      // Next runs
      const runs = getNextRuns(expr, 5);
      if (runs.length === 0) {
        runList.innerHTML = '<li>No upcoming runs found within the next 2 years</li>';
      } else {
        runList.innerHTML = runs.map(d => {
          const options: Intl.DateTimeFormatOptions = {
            weekday: 'short',
            year: 'numeric',
            month: 'short',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
            hour12: true,
          };
          return `<li>${d.toLocaleString(undefined, options)}</li>`;
        }).join('');
      }
    }

    // --- Parse a cron expression into the UI ---
    function parseExpression(expr: string): void {
      const parts = expr.trim().split(/\s+/);
      if (parts.length !== 5) {
        showError('Invalid cron expression. Expected 5 fields separated by spaces (minute hour day-of-month month day-of-week).');
        return;
      }

      clearError();
      const fieldValues = parts;

      fields.forEach((field, i) => {
        const val = fieldValues[i];
        const el = field.fieldEl;

        // Determine which mode this value represents
        let mode = 'every';
        if (val === '*') {
          mode = 'every';
        } else if (val.includes('/')) {
          mode = 'step';
        } else if (val.includes('-') && !val.includes(',')) {
          mode = 'range';
        } else {
          mode = 'specific';
        }

        // Activate the mode button
        const modeButtons = el.querySelectorAll('.mode-btn') as NodeListOf<HTMLButtonElement>;
        modeButtons.forEach(btn => {
          btn.classList.toggle('active', btn.dataset.mode === mode);
        });

        // Show correct mode input
        const modeInputs = el.querySelectorAll('.mode-input') as NodeListOf<HTMLElement>;
        modeInputs.forEach(mi => {
          mi.classList.toggle('active', mi.dataset.mode === mode);
        });

        // Populate inputs based on mode
        if (mode === 'specific') {
          if (field.name === 'dow') {
            const checkboxes = el.querySelectorAll('.dow-checkboxes input') as NodeListOf<HTMLInputElement>;
            const selectedVals = val.split(',');
            checkboxes.forEach(cb => {
              cb.checked = selectedVals.includes(cb.value);
            });
          } else {
            const input = el.querySelector('.mode-input[data-mode="specific"] .specific-input') as HTMLInputElement;
            input.value = val;
          }
        } else if (mode === 'range') {
          const [from, to] = val.split('-');
          if (field.name === 'dow') {
            (el.querySelector('.range-from-dow') as HTMLSelectElement).value = from;
            (el.querySelector('.range-to-dow') as HTMLSelectElement).value = to;
          } else {
            (el.querySelector('.range-from') as HTMLInputElement).value = from;
            (el.querySelector('.range-to') as HTMLInputElement).value = to;
          }
        } else if (mode === 'step') {
          const [startPart, everyPart] = val.split('/');
          (el.querySelector('.mode-input[data-mode="step"] .step-every') as HTMLInputElement).value = everyPart;
          if (field.name === 'dow') {
            (el.querySelector('.step-start-dow') as HTMLSelectElement).value = startPart === '*' ? '0' : startPart;
          } else {
            (el.querySelector('.mode-input[data-mode="step"] .step-start') as HTMLInputElement).value = startPart === '*' ? String(field.min) : startPart;
          }
        }
      });

      updateDisplay();
    }

    // --- Wire up mode switching ---
    fields.forEach(field => {
      const el = field.fieldEl;

      // Mode button clicks
      const modeButtons = el.querySelectorAll('.mode-btn') as NodeListOf<HTMLButtonElement>;
      modeButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          modeButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          const modeInputs = el.querySelectorAll('.mode-input') as NodeListOf<HTMLElement>;
          modeInputs.forEach(mi => {
            mi.classList.toggle('active', mi.dataset.mode === btn.dataset.mode);
          });
          updateDisplay();
        });
      });

      // Input change events
      el.querySelectorAll('input, select').forEach(input => {
        input.addEventListener('input', updateDisplay);
        input.addEventListener('change', updateDisplay);
      });
    });

    // --- Preset buttons ---
    document.querySelectorAll('.preset-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cron = (btn as HTMLElement).dataset.cron;
        if (cron) {
          parseExpression(cron);
        }
      });
    });

    // --- Copy button ---
    copyCronBtn.addEventListener('click', () => {
      const text = cronOutput.textContent || '';
      if (text) {
        copyToClipboard(text, copyCronBtn);
      }
    });

    // --- Parse button ---
    parseBtn.addEventListener('click', () => {
      const val = manualInput.value.trim();
      if (val) {
        parseExpression(val);
      }
    });

    // Allow Enter key to parse
    manualInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const val = manualInput.value.trim();
        if (val) {
          parseExpression(val);
        }
      }
    });

    // --- Initial render ---
    updateDisplay();
  })();
</script>
