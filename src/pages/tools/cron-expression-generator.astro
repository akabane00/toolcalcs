import AdUnit from '../../components/AdUnit.astro';
import { getToolBySlug } from '../../data/tools';
import '../../styles/tool.css';

const tool = getToolBySlug('cron-expression-generator')!;
const structuredData = [
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Web Tools", "item": "https://toolcalcs.com/tools/" },
    { "@type": "ListItem", "position": 3, "name": "Cron Expression Generator" }
  ]},
  { "@context": "https://schema.org", "@type": "WebApplication", "name": "Cron Expression Generator", "url": "https://toolcalcs.com/tools/cron-expression-generator/", "applicationCategory": "DeveloperApplication", "operatingSystem": "All", "browserRequirements": "Requires JavaScript", "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }, "description": "Build and validate cron expressions visually." },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [
    { "@type": "Question", "name": "What is a cron expression?", "acceptedAnswer": { "@type": "Answer", "text": "A cron expression is a string of five fields separated by spaces that defines a schedule. The fields represent: minute (0-59), hour (0-23), day of month (1-31), month (1-12), and day of week (0-6, where 0 is Sunday). Special characters like * (any), , (list), - (range), and / (step) allow flexible scheduling." }},
    { "@type": "Question", "name": "What does */5 mean in cron?", "acceptedAnswer": { "@type": "Answer", "text": "The */5 syntax means 'every 5th interval.' For example, */5 in the minute field means every 5 minutes (0, 5, 10, 15...). */2 in the hour field means every 2 hours (0, 2, 4, 6...)." }},
    { "@type": "Question", "name": "What is the difference between cron and crontab?", "acceptedAnswer": { "@type": "Answer", "text": "Cron is the daemon (background service) that runs scheduled tasks. Crontab (cron table) is the file where you define the schedule and commands. You edit the crontab using the 'crontab -e' command." }}
