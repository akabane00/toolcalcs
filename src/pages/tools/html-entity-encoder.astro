<script>
  const inputEl = document.getElementById('toolInput') as HTMLTextAreaElement;
  const outputEl = document.getElementById('toolOutput') as HTMLTextAreaElement;
  const encodeBtn = document.getElementById('encodeBtn') as HTMLButtonElement;
  const decodeBtn = document.getElementById('decodeBtn') as HTMLButtonElement;
  const swapBtn = document.getElementById('swapBtn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clearBtn') as HTMLButtonElement;
  const copyBtn = document.getElementById('copyBtn') as HTMLButtonElement;
  const errorEl = document.getElementById('toolError') as HTMLDivElement;
  const modeRadios = document.querySelectorAll<HTMLInputElement>('input[name="encodeMode"]');

  function showError(message: string): void {
    errorEl.textContent = message;
    errorEl.hidden = false;
  }

  function clearError(): void {
    errorEl.textContent = '';
    errorEl.hidden = true;
  }

  function getEncodeMode(): string {
    for (const radio of modeRadios) {
      if (radio.checked) return radio.value;
    }
    return 'named';
  }

  /**
   * Named entity lookup table for common characters.
   */
  const namedEntities: Record<string, string> = {
    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&apos;',
    '\u00A0': '&nbsp;',
    '\u00A9': '&copy;', '\u00AE': '&reg;', '\u2122': '&trade;',
    '\u20AC': '&euro;', '\u00A3': '&pound;', '\u00A5': '&yen;', '\u00A2': '&cent;',
    '\u00A7': '&sect;', '\u00B0': '&deg;', '\u00B1': '&plusmn;',
    '\u00D7': '&times;', '\u00F7': '&divide;', '\u00B6': '&para;',
    '\u2022': '&bull;',
    '\u2013': '&ndash;', '\u2014': '&mdash;',
    '\u201C': '&ldquo;', '\u201D': '&rdquo;',
    '\u2018': '&lsquo;', '\u2019': '&rsquo;',
    '\u2026': '&hellip;',
    '\u2190': '&larr;', '\u2192': '&rarr;', '\u2191': '&uarr;', '\u2193': '&darr;',
    '\u2660': '&spades;', '\u2663': '&clubs;', '\u2665': '&hearts;', '\u2666': '&diams;',
  };

  /**
   * Characters that are safe to leave unencoded in named mode:
   * ASCII printable characters excluding those in the named entity table.
   */
  function isSafeAscii(code: number): boolean {
    // Space (32) through tilde (126), excluding & < > " '
    if (code >= 32 && code <= 126) {
      const ch = String.fromCharCode(code);
      if (ch === '&' || ch === '<' || ch === '>' || ch === '"' || ch === "'") {
        return false;
      }
      return true;
    }
    // Also allow newline and tab
    if (code === 10 || code === 13 || code === 9) return true;
    return false;
  }

  /**
   * Encode a string to HTML entities using the selected mode.
   */
  function encodeEntities(text: string, mode: string): string {
    let result = '';
    for (const char of text) {
      const code = char.codePointAt(0)!;

      if (mode === 'named') {
        // Check named lookup first
        if (namedEntities[char]) {
          result += namedEntities[char];
        } else if (isSafeAscii(code)) {
          result += char;
        } else {
          // Fallback to decimal for unlisted non-ASCII chars
          result += '&#' + code + ';';
        }
      } else if (mode === 'decimal') {
        if (isSafeAscii(code)) {
          result += char;
        } else {
          result += '&#' + code + ';';
        }
      } else {
        // hex
        if (isSafeAscii(code)) {
          result += char;
        } else {
          result += '&#x' + code.toString(16).toUpperCase() + ';';
        }
      }
    }
    return result;
  }

  /**
   * Decode HTML entities back to plain text using the browser's HTML parser.
   */
  function decodeEntities(encoded: string): string {
    const el = document.createElement('textarea');
    el.innerHTML = encoded;
    return el.value;
  }

  // --- Encode ---
  encodeBtn.addEventListener('click', () => {
    clearError();
    const text = inputEl.value;
    if (!text) {
      outputEl.value = '';
      return;
    }
    try {
      const mode = getEncodeMode();
      outputEl.value = encodeEntities(text, mode);
    } catch (e) {
      showError('Encoding failed. Please check your input text.');
    }
  });

  // --- Decode ---
  decodeBtn.addEventListener('click', () => {
    clearError();
    const text = inputEl.value;
    if (!text) {
      outputEl.value = '';
      return;
    }
    try {
      outputEl.value = decodeEntities(text);
    } catch (e) {
      showError('Decoding failed. The input may contain malformed entity references.');
    }
  });

  // --- Swap ---
  swapBtn.addEventListener('click', () => {
    clearError();
    const temp = inputEl.value;
    inputEl.value = outputEl.value;
    outputEl.value = temp;
  });

  // --- Clear ---
  clearBtn.addEventListener('click', () => {
    inputEl.value = '';
    outputEl.value = '';
    clearError();
  });

  // --- Copy ---
  copyBtn.addEventListener('click', async () => {
    const text = outputEl.value;
    if (!text) return;
    try {
      await navigator.clipboard.writeText(text);
      copyBtn.textContent = 'Copied!';
      copyBtn.classList.add('copied');
      setTimeout(() => {
        copyBtn.textContent = 'Copy';
        copyBtn.classList.remove('copied');
      }, 1500);
    } catch {
      outputEl.select();
      document.execCommand('copy');
      copyBtn.textContent = 'Copied!';
      copyBtn.classList.add('copied');
      setTimeout(() => {
        copyBtn.textContent = 'Copy';
        copyBtn.classList.remove('copied');
      }, 1500);
    }
  });
</script>
