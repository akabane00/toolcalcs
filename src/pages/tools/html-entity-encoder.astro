    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Web Tools", "item": "https://toolcalcs.com/tools/" },
    { "@type": "ListItem", "position": 3, "name": "HTML Entity Encoder/Decoder" }
  ]},
  { "@context": "https://schema.org", "@type": "WebApplication", "name": "HTML Entity Encoder & Decoder", "url": "https://toolcalcs.com/tools/html-entity-encoder/", "applicationCategory": "DeveloperApplication", "operatingSystem": "All", "browserRequirements": "Requires JavaScript", "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }, "description": "Encode and decode HTML entities online." },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [
    { "@type": "Question", "name": "What are HTML entities?", "acceptedAnswer": { "@type": "Answer", "text": "HTML entities are special codes used to represent characters that have reserved meaning in HTML (like < > & \") or characters not easily typed on a keyboard. They start with & and end with ; — for example, &lt; represents <." }},
    { "@type": "Question", "name": "When should I use HTML entities?", "acceptedAnswer": { "@type": "Answer", "text": "Use HTML entities when you need to display reserved HTML characters as text (like showing <div> in a web page), when inserting special symbols (©, ™, €), or when dealing with characters outside your document's character encoding." }},
