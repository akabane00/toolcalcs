    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
    margin: 8px 0;
  }

  /* --- Inline code --- */
  .md-preview :global(code) {
    font-family: 'Courier New', Consolas, monospace;
    font-size: 0.85em;
    background: rgba(0, 0, 0, 0.06);
    padding: 2px 6px;
    border-radius: 4px;
  }
  [data-theme="dark"] .md-preview :global(code) {
    background: rgba(255, 255, 255, 0.1);
  }

  /* --- Code blocks --- */
  .md-preview :global(pre) {
    background: #1e293b;
    color: #e2e8f0;
    padding: 16px;
    border-radius: var(--radius);
    overflow-x: auto;
    margin: 12px 0;
    line-height: 1.5;
  }
  .md-preview :global(pre code) {
    background: none;
    padding: 0;
    border-radius: 0;
    font-size: 0.85rem;
    color: inherit;
  }

  /* --- Blockquotes --- */
  .md-preview :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: 8px 16px;
    margin: 12px 0;
    color: var(--color-text-muted);
    background: rgba(37, 99, 235, 0.04);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  [data-theme="dark"] .md-preview :global(blockquote) {
    background: rgba(96, 165, 250, 0.06);
  }
  .md-preview :global(blockquote p) { margin: 0 0 8px; }
  .md-preview :global(blockquote p:last-child) { margin-bottom: 0; }

  /* --- Lists --- */
  .md-preview :global(ul),
  .md-preview :global(ol) {
    margin: 8px 0 12px 24px;
  }
  .md-preview :global(li) { margin-bottom: 4px; }
  .md-preview :global(li ul),
  .md-preview :global(li ol) { margin-top: 4px; margin-bottom: 4px; }

  /* --- Tables --- */
  .md-preview :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0;
    font-size: 0.9rem;
  }
  .md-preview :global(th),
  .md-preview :global(td) {
    border: 1px solid var(--color-border);
    padding: 8px 12px;
    text-align: left;
  }
  .md-preview :global(th) {
    background: rgba(0, 0, 0, 0.04);
    font-weight: 600;
  }
  [data-theme="dark"] .md-preview :global(th) {
    background: rgba(255, 255, 255, 0.06);
  }
  .md-preview :global(tr:nth-child(even) td) {
    background: rgba(0, 0, 0, 0.02);
  }
  [data-theme="dark"] .md-preview :global(tr:nth-child(even) td) {
    background: rgba(255, 255, 255, 0.02);
  }

  /* --- Horizontal rule --- */
  .md-preview :global(hr) {
    border: none;
    border-top: 2px solid var(--color-border);
    margin: 24px 0;
  }

  /* --- Code block language label --- */
  .md-preview :global(.code-lang) {
    display: block;
    font-size: 0.7rem;
    color: #94a3b8;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  @media (max-width: 640px) {
    .md-textarea,
    .md-preview {
      min-height: 300px;
    }
  }
</style>

<script>
  const inputEl = document.getElementById('mdInput') as HTMLTextAreaElement;
  const previewEl = document.getElementById('mdPreview') as HTMLDivElement;
  const copyHtmlBtn = document.getElementById('copyHtmlBtn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clearBtn') as HTMLButtonElement;

  function escapeHtml(text: string): string {
    return text
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function parseMarkdown(md: string): string {
    let html = md;

    // Store code blocks and inline code to protect from other transformations
    const codeBlocks: string[] = [];
    const inlineCodes: string[] = [];

    // 1. Fenced code blocks: ```lang\ncode\n```
    html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_match, lang: string, code: string) => {
      const langLabel = lang ? `<span class="code-lang">${escapeHtml(lang)}</span>` : '';
      const escaped = escapeHtml(code.replace(/\n$/, ''));
      const placeholder = `%%CODEBLOCK_${codeBlocks.length}%%`;
      codeBlocks.push(`<pre>${langLabel}<code>${escaped}</code></pre>`);
      return placeholder;
    });

    // 2. Inline code: `code`
    html = html.replace(/`([^`\n]+)`/g, (_match, code: string) => {
      const placeholder = `%%INLINECODE_${inlineCodes.length}%%`;
      inlineCodes.push(`<code>${escapeHtml(code)}</code>`);
      return placeholder;
    });

    // Split into lines for block-level processing
    const lines = html.split('\n');
    const outputLines: string[] = [];
    let i = 0;

    while (i < lines.length) {
      const line = lines[i];

      // Blockquotes
      if (/^>\s?/.test(line)) {
        const quoteLines: string[] = [];
        while (i < lines.length && /^>\s?/.test(lines[i])) {
          quoteLines.push(lines[i].replace(/^>\s?/, ''));
          i++;
        }
        const innerHtml = parseInline(quoteLines.join('\n').replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>'));
        outputLines.push(`<blockquote><p>${innerHtml}</p></blockquote>`);
        continue;
      }

      // Headings: # through ######
      const headingMatch = line.match(/^(#{1,6})\s+(.+)$/);
      if (headingMatch) {
        const level = headingMatch[1].length;
        const text = parseInline(headingMatch[2]);
        outputLines.push(`<h${level}>${text}</h${level}>`);
        i++;
        continue;
      }

      // Horizontal rules: --- or *** or ___
      if (/^(\*{3,}|-{3,}|_{3,})\s*$/.test(line.trim())) {
        outputLines.push('<hr>');
        i++;
        continue;
      }

      // Tables: | header | header |
      if (/^\|.+\|/.test(line) && i + 1 < lines.length && /^\|[\s:]*-+[\s:]*/.test(lines[i + 1])) {
        const tableLines: string[] = [];
        while (i < lines.length && /^\|.+\|/.test(lines[i])) {
          tableLines.push(lines[i]);
          i++;
        }
        outputLines.push(parseTable(tableLines));
        continue;
      }

      // Unordered list: - or * at start
      if (/^(\s*)([-*+])\s+/.test(line)) {
        const listResult = parseUnorderedList(lines, i);
        outputLines.push(listResult.html);
        i = listResult.nextIndex;
        continue;
      }

      // Ordered list: 1. at start
      if (/^(\s*)\d+\.\s+/.test(line)) {
        const listResult = parseOrderedList(lines, i);
        outputLines.push(listResult.html);
        i = listResult.nextIndex;
        continue;
      }

      // Empty line
      if (line.trim() === '') {
        outputLines.push('');
        i++;
        continue;
      }

      // Paragraph: collect consecutive non-empty lines
      const paraLines: string[] = [];
      while (
        i < lines.length &&
        lines[i].trim() !== '' &&
        !/^#{1,6}\s/.test(lines[i]) &&
        !/^(\*{3,}|-{3,}|_{3,})\s*$/.test(lines[i].trim()) &&
        !/^>\s?/.test(lines[i]) &&
        !/^\|.+\|/.test(lines[i]) &&
        !/^(\s*)([-*+])\s+/.test(lines[i]) &&
        !/^(\s*)\d+\.\s+/.test(lines[i]) &&
        !lines[i].startsWith('%%CODEBLOCK_')
      ) {
        paraLines.push(lines[i]);
        i++;
      }
      if (paraLines.length > 0) {
        const text = parseInline(paraLines.join('<br>'));
        outputLines.push(`<p>${text}</p>`);
        continue;
      }

      // Fallback: code block placeholders or anything else
      outputLines.push(line);
      i++;
    }

    html = outputLines.filter((line, idx) => {
      // Remove consecutive empty strings to avoid excessive whitespace
      if (line === '' && idx > 0 && outputLines[idx - 1] === '') return false;
      return true;
    }).join('\n');

    // Restore code blocks
    for (let j = 0; j < codeBlocks.length; j++) {
      html = html.replace(`<p>%%CODEBLOCK_${j}%%</p>`, codeBlocks[j]);
      html = html.replace(`%%CODEBLOCK_${j}%%`, codeBlocks[j]);
    }

    // Restore inline codes
    for (let j = 0; j < inlineCodes.length; j++) {
      html = html.replace(`%%INLINECODE_${j}%%`, inlineCodes[j]);
    }

    return html.trim();
  }

  function parseInline(text: string): string {
    // Bold + Italic: ***text***
    text = text.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');

    // Bold: **text** or __text__
    text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    text = text.replace(/__(.+?)__/g, '<strong>$1</strong>');

    // Italic: *text* or _text_
    text = text.replace(/\*(.+?)\*/g, '<em>$1</em>');
    text = text.replace(/(?<![a-zA-Z0-9])_(.+?)_(?![a-zA-Z0-9])/g, '<em>$1</em>');

    // Strikethrough: ~~text~~
    text = text.replace(/~~(.+?)~~/g, '<del>$1</del>');

    // Images: ![alt](url)
    text = text.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" loading="lazy">');

    // Links: [text](url)
    text = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');

    return text;
  }

  function parseUnorderedList(lines: string[], startIdx: number): { html: string; nextIndex: number } {
    const items: { indent: number; text: string }[] = [];
    let i = startIdx;

    while (i < lines.length) {
      const match = lines[i].match(/^(\s*)([-*+])\s+(.*)/);
      if (!match) break;
      items.push({ indent: match[1].length, text: match[3] });
      i++;
    }

    return { html: buildNestedList(items, 'ul'), nextIndex: i };
  }

  function parseOrderedList(lines: string[], startIdx: number): { html: string; nextIndex: number } {
    const items: { indent: number; text: string }[] = [];
    let i = startIdx;

    while (i < lines.length) {
      const match = lines[i].match(/^(\s*)\d+\.\s+(.*)/);
      if (!match) break;
      items.push({ indent: match[1].length, text: match[2] });
      i++;
    }

    return { html: buildNestedList(items, 'ol'), nextIndex: i };
  }

  function buildNestedList(items: { indent: number; text: string }[], tag: 'ul' | 'ol'): string {
    if (items.length === 0) return '';

    const baseIndent = items[0].indent;
    let html = `<${tag}>`;
    let i = 0;

    while (i < items.length) {
      const item = items[i];

      if (item.indent === baseIndent) {
        html += `<li>${parseInline(item.text)}`;
        // Check if next items are nested
        const nested: { indent: number; text: string }[] = [];
        let j = i + 1;
        while (j < items.length && items[j].indent > baseIndent) {
          nested.push(items[j]);
          j++;
        }
        if (nested.length > 0) {
          html += buildNestedList(nested, tag);
        }
        html += '</li>';
        i = j;
      } else {
        i++;
      }
    }

    html += `</${tag}>`;
    return html;
  }

  function parseTable(lines: string[]): string {
    if (lines.length < 2) return '';

    function parseCells(row: string): string[] {
      return row
        .replace(/^\|/, '')
        .replace(/\|$/, '')
        .split('|')
        .map(cell => cell.trim());
    }

    const headers = parseCells(lines[0]);
    // Parse alignment from divider row
    const dividerCells = parseCells(lines[1]);
    const alignments: string[] = dividerCells.map(cell => {
      const trimmed = cell.trim();
      if (trimmed.startsWith(':') && trimmed.endsWith(':')) return 'center';
      if (trimmed.endsWith(':')) return 'right';
      return 'left';
    });

    let html = '<table><thead><tr>';
    for (let c = 0; c < headers.length; c++) {
      const align = alignments[c] ? ` style="text-align:${alignments[c]}"` : '';
      html += `<th${align}>${parseInline(headers[c])}</th>`;
    }
    html += '</tr></thead><tbody>';

    for (let r = 2; r < lines.length; r++) {
      const cells = parseCells(lines[r]);
      html += '<tr>';
      for (let c = 0; c < headers.length; c++) {
        const align = alignments[c] ? ` style="text-align:${alignments[c]}"` : '';
        html += `<td${align}>${parseInline(cells[c] || '')}</td>`;
      }
      html += '</tr>';
    }

    html += '</tbody></table>';
    return html;
  }

  function updatePreview(): void {
    const md = inputEl.value;
    if (!md.trim()) {
      previewEl.innerHTML = '<p style="color:var(--color-text-muted);">Start typing Markdown to see the preview...</p>';
      return;
    }
    previewEl.innerHTML = parseMarkdown(md);
  }

  async function copyHtml(): Promise<void> {
    const md = inputEl.value;
    if (!md.trim()) return;

    const html = parseMarkdown(md);
    try {
      await navigator.clipboard.writeText(html);
      copyHtmlBtn.textContent = 'Copied!';
      copyHtmlBtn.classList.add('copied');
      setTimeout(() => {
        copyHtmlBtn.textContent = 'Copy HTML';
        copyHtmlBtn.classList.remove('copied');
      }, 2000);
    } catch {
      const tempArea = document.createElement('textarea');
      tempArea.value = html;
      document.body.appendChild(tempArea);
      tempArea.select();
      document.execCommand('copy');
      document.body.removeChild(tempArea);
      copyHtmlBtn.textContent = 'Copied!';
      copyHtmlBtn.classList.add('copied');
      setTimeout(() => {
        copyHtmlBtn.textContent = 'Copy HTML';
        copyHtmlBtn.classList.remove('copied');
      }, 2000);
    }
  }

  function clearAll(): void {
    inputEl.value = '';
    previewEl.innerHTML = '<p style="color:var(--color-text-muted);">Start typing Markdown to see the preview...</p>';
    inputEl.focus();
  }

  // Events
  inputEl.addEventListener('input', updatePreview);
  copyHtmlBtn.addEventListener('click', copyHtml);
  clearBtn.addEventListener('click', clearAll);

  // Initial render
  updatePreview();
</script>
