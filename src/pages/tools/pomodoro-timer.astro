      <li><a href="/date-time-calculators/date-difference-calculator/">Date Difference Calculator</a> - Calculate the number of days between two dates.</li>
      <li><a href="/tools/password-generator/">Password Generator</a> - Generate strong, secure passwords for your accounts.</li>
    </ul>
  </article>

  <AdUnit slot="tool-bottom" format="horizontal" />
</BaseLayout>

<style>
  /* Timer Container */
  .timer-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 16px 0 8px;
  }

  /* Phase Label */
  .phase-label {
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #dc4a2c;
    transition: color 0.3s;
  }
  .phase-label.short-break {
    color: #16a34a;
  }
  .phase-label.long-break {
    color: #2563eb;
  }

  /* Timer Ring */
  .timer-ring-wrapper {
    position: relative;
    width: 220px;
    height: 220px;
  }
  .timer-ring {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }
  .timer-ring-bg {
    fill: none;
    stroke: var(--color-border);
    stroke-width: 8;
  }
  .timer-ring-progress {
    fill: none;
    stroke: #dc4a2c;
    stroke-width: 8;
    stroke-linecap: round;
    stroke-dasharray: 628.318;
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.5s linear, stroke 0.3s;
  }
  .timer-ring-progress.short-break {
    stroke: #16a34a;
  }
  .timer-ring-progress.long-break {
    stroke: #2563eb;
  }

  /* Timer Display */
  .timer-display {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 3rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  /* Session Counter */
  .session-counter {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* Timer Controls */
  .timer-controls {
    justify-content: center;
  }

  /* Focus Stats */
  .focus-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 0 4px;
    font-size: 0.9rem;
    border-top: 1px solid var(--color-border);
    margin-top: 12px;
  }
  .focus-stats-label {
    color: var(--color-text-muted);
  }
  .focus-stats-value {
    font-weight: 700;
    color: var(--color-text);
  }

  /* Settings Panel */
  .settings-panel {
    margin-top: 16px;
    border-top: 1px solid var(--color-border);
    padding-top: 12px;
  }
  .settings-toggle {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-muted);
    cursor: pointer;
    user-select: none;
    padding: 4px 0;
  }
  .settings-toggle:hover {
    color: var(--color-primary);
  }
  .settings-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 12px;
  }
  .settings-grid .tool-option input[type="number"] {
    width: 100%;
  }

  @media (max-width: 640px) {
    .timer-display {
      font-size: 2.4rem;
    }
    .timer-ring-wrapper {
      width: 180px;
      height: 180px;
    }
    .settings-grid {
      grid-template-columns: 1fr;
    }
    .timer-controls {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .timer-controls .tool-btn {
      flex: 1 1 calc(50% - 4px);
      min-width: 0;
      width: auto;
    }
  }
</style>

<script>
  // ===== Pomodoro Timer =====

  type Phase = 'work' | 'shortBreak' | 'longBreak';

  interface PomodoroSettings {
    workDuration: number;
    shortBreakDuration: number;
    longBreakDuration: number;
    sessionsBeforeLongBreak: number;
  }

  interface PomodoroState {
    phase: Phase;
    currentSession: number;
    timeRemaining: number;
    totalTime: number;
    isRunning: boolean;
    intervalId: number | null;
  }

  const STORAGE_KEY_SETTINGS = 'pomodoro-settings';
  const STORAGE_KEY_FOCUS = 'pomodoro-focus-today';
  const CIRCUMFERENCE = 2 * Math.PI * 100; // 628.318

  // DOM Elements
  const phaseLabel = document.getElementById('phaseLabel') as HTMLElement;
  const timerDisplay = document.getElementById('timerDisplay') as HTMLElement;
  const timerProgress = document.getElementById('timerProgress') as SVGCircleElement;
  const sessionCounter = document.getElementById('sessionCounter') as HTMLElement;
  const startBtn = document.getElementById('startBtn') as HTMLButtonElement;
  const pauseBtn = document.getElementById('pauseBtn') as HTMLButtonElement;
  const resetBtn = document.getElementById('resetBtn') as HTMLButtonElement;
  const skipBtn = document.getElementById('skipBtn') as HTMLButtonElement;
  const focusTimeDisplay = document.getElementById('focusTimeDisplay') as HTMLElement;
  const workDurationInput = document.getElementById('workDuration') as HTMLInputElement;
  const shortBreakInput = document.getElementById('shortBreakDuration') as HTMLInputElement;
  const longBreakInput = document.getElementById('longBreakDuration') as HTMLInputElement;
  const sessionsCountInput = document.getElementById('sessionsCount') as HTMLInputElement;

  // Load settings from localStorage
  function loadSettings(): PomodoroSettings {
    const defaults: PomodoroSettings = {
      workDuration: 25,
      shortBreakDuration: 5,
      longBreakDuration: 15,
      sessionsBeforeLongBreak: 4,
    };
    try {
      const saved = localStorage.getItem(STORAGE_KEY_SETTINGS);
      if (saved) {
        const parsed = JSON.parse(saved);
        return { ...defaults, ...parsed };
      }
    } catch {
      // ignore parse errors
    }
    return defaults;
  }

  function saveSettings(settings: PomodoroSettings): void {
    try {
      localStorage.setItem(STORAGE_KEY_SETTINGS, JSON.stringify(settings));
    } catch {
      // ignore storage errors
    }
  }

  // Focus time tracking
  function getTodayKey(): string {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }

  function loadFocusTime(): number {
    try {
      const saved = localStorage.getItem(STORAGE_KEY_FOCUS);
      if (saved) {
        const parsed = JSON.parse(saved);
        if (parsed.date === getTodayKey()) {
          return parsed.seconds || 0;
        }
      }
    } catch {
      // ignore
    }
    return 0;
  }

  function saveFocusTime(seconds: number): void {
    try {
      localStorage.setItem(STORAGE_KEY_FOCUS, JSON.stringify({
        date: getTodayKey(),
        seconds,
      }));
    } catch {
      // ignore
    }
  }

  function formatFocusTime(totalSeconds: number): string {
    const hours = Math.floor(totalSeconds / 3600);
    const minutes = Math.floor((totalSeconds % 3600) / 60);
    if (hours > 0) {
      return `${hours}h ${minutes}m`;
    }
    return `${minutes} min`;
  }

  // Audio notification using Web Audio API
  function playNotificationBeep(): void {
    try {
      const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();

      // Play three short beeps
      const beepDuration = 0.15;
      const gapDuration = 0.1;

      for (let i = 0; i < 3; i++) {
        const startTime = audioCtx.currentTime + i * (beepDuration + gapDuration);

        const oscillator = audioCtx.createOscillator();
        const gainNode = audioCtx.createGain();

        oscillator.connect(gainNode);
        gainNode.connect(audioCtx.destination);

        oscillator.type = 'sine';
        oscillator.frequency.setValueAtTime(880, startTime);

        gainNode.gain.setValueAtTime(0, startTime);
        gainNode.gain.linearRampToValueAtTime(0.3, startTime + 0.01);
        gainNode.gain.linearRampToValueAtTime(0, startTime + beepDuration);

        oscillator.start(startTime);
        oscillator.stop(startTime + beepDuration);
      }

      // Close audio context after beeps finish
      setTimeout(() => { audioCtx.close(); }, 1000);
    } catch {
      // Web Audio API not supported; fail silently
    }
  }

  // Initialize settings UI
  const settings = loadSettings();
  workDurationInput.value = String(settings.workDuration);
  shortBreakInput.value = String(settings.shortBreakDuration);
  longBreakInput.value = String(settings.longBreakDuration);
  sessionsCountInput.value = String(settings.sessionsBeforeLongBreak);

  // Timer state
  let focusSecondsToday = loadFocusTime();
  focusTimeDisplay.textContent = formatFocusTime(focusSecondsToday);

  const state: PomodoroState = {
    phase: 'work',
    currentSession: 1,
    timeRemaining: settings.workDuration * 60,
    totalTime: settings.workDuration * 60,
    isRunning: false,
    intervalId: null,
  };

  // Update display
  function formatTime(seconds: number): string {
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
  }

  function getPhaseClass(phase: Phase): string {
    if (phase === 'shortBreak') return 'short-break';
    if (phase === 'longBreak') return 'long-break';
    return '';
  }

  function getPhaseName(phase: Phase): string {
    if (phase === 'shortBreak') return 'Short Break';
    if (phase === 'longBreak') return 'Long Break';
    return 'Work';
  }

  function updateDisplay(): void {
    timerDisplay.textContent = formatTime(state.timeRemaining);

    // Update progress ring
    const progress = state.totalTime > 0
      ? (state.totalTime - state.timeRemaining) / state.totalTime
      : 0;
    const offset = CIRCUMFERENCE * (1 - progress);
    timerProgress.style.strokeDashoffset = String(offset);

    // Update phase label styling
    const phaseClass = getPhaseClass(state.phase);
    phaseLabel.textContent = getPhaseName(state.phase);
    phaseLabel.className = 'phase-label' + (phaseClass ? ' ' + phaseClass : '');
    timerProgress.className.baseVal = 'timer-ring-progress' + (phaseClass ? ' ' + phaseClass : '');

    // Session counter
    const totalSessions = parseInt(sessionsCountInput.value) || 4;
    sessionCounter.textContent = `Session ${state.currentSession} of ${totalSessions}`;

    // Update document title
    if (state.isRunning) {
      document.title = `${formatTime(state.timeRemaining)} - ${getPhaseName(state.phase)} | Pomodoro Timer`;
    } else {
      document.title = 'Pomodoro Timer - Free Online Focus Timer | ToolCalcs';
    }
  }

  function getSettingsFromUI(): PomodoroSettings {
    return {
      workDuration: Math.max(1, Math.min(120, parseInt(workDurationInput.value) || 25)),
      shortBreakDuration: Math.max(1, Math.min(30, parseInt(shortBreakInput.value) || 5)),
      longBreakDuration: Math.max(1, Math.min(60, parseInt(longBreakInput.value) || 15)),
      sessionsBeforeLongBreak: Math.max(1, Math.min(12, parseInt(sessionsCountInput.value) || 4)),
    };
  }

  function getDurationForPhase(phase: Phase): number {
    const s = getSettingsFromUI();
    if (phase === 'shortBreak') return s.shortBreakDuration * 60;
    if (phase === 'longBreak') return s.longBreakDuration * 60;
    return s.workDuration * 60;
  }

  function advancePhase(): void {
    const s = getSettingsFromUI();

    if (state.phase === 'work') {
      // Finished a work session - decide break type
      if (state.currentSession >= s.sessionsBeforeLongBreak) {
        state.phase = 'longBreak';
      } else {
        state.phase = 'shortBreak';
      }
    } else {
      // Finished a break - start next work session
      if (state.phase === 'longBreak') {
        state.currentSession = 1;
      } else {
        state.currentSession++;
      }
      state.phase = 'work';
    }

    state.totalTime = getDurationForPhase(state.phase);
    state.timeRemaining = state.totalTime;
  }

  function tick(): void {
    if (state.timeRemaining <= 0) {
      // Timer completed
      stopTimer();
      playNotificationBeep();
      advancePhase();
      updateDisplay();
      // Auto-start is intentionally not done so the user can control pacing
      return;
    }

    state.timeRemaining--;

    // Track focus time for work phases
    if (state.phase === 'work') {
      focusSecondsToday++;
      saveFocusTime(focusSecondsToday);
      focusTimeDisplay.textContent = formatFocusTime(focusSecondsToday);
    }

    updateDisplay();
  }

  function startTimer(): void {
    if (state.isRunning) return;
    state.isRunning = true;
    state.intervalId = window.setInterval(tick, 1000);
    startBtn.disabled = true;
    pauseBtn.disabled = false;
    updateDisplay();
  }

  function stopTimer(): void {
    state.isRunning = false;
    if (state.intervalId !== null) {
      clearInterval(state.intervalId);
      state.intervalId = null;
    }
    startBtn.disabled = false;
    pauseBtn.disabled = true;
    // Restore page title
    document.title = 'Pomodoro Timer - Free Online Focus Timer | ToolCalcs';
  }

  function resetTimer(): void {
    stopTimer();
    state.phase = 'work';
    state.currentSession = 1;
    const s = getSettingsFromUI();
    state.totalTime = s.workDuration * 60;
    state.timeRemaining = state.totalTime;
    updateDisplay();
  }

  function skipPhase(): void {
    stopTimer();
    advancePhase();
    updateDisplay();
  }

  // Event listeners
  startBtn.addEventListener('click', startTimer);
  pauseBtn.addEventListener('click', stopTimer);
  resetBtn.addEventListener('click', resetTimer);
  skipBtn.addEventListener('click', skipPhase);

  // Settings change handlers
  const settingsInputs = [workDurationInput, shortBreakInput, longBreakInput, sessionsCountInput];
  settingsInputs.forEach((input) => {
    input.addEventListener('change', () => {
      const s = getSettingsFromUI();
      saveSettings(s);

      // If timer is not running and we are at the start of a phase, update duration
      if (!state.isRunning && state.timeRemaining === state.totalTime) {
        state.totalTime = getDurationForPhase(state.phase);
        state.timeRemaining = state.totalTime;
        updateDisplay();
      }
    });
  });

  // Handle page visibility for accurate timing
  let hiddenTime: number | null = null;

  document.addEventListener('visibilitychange', () => {
    if (document.hidden && state.isRunning) {
      hiddenTime = Date.now();
    } else if (!document.hidden && hiddenTime !== null && state.isRunning) {
      const elapsed = Math.floor((Date.now() - hiddenTime) / 1000);
      hiddenTime = null;

      if (elapsed > 0 && state.timeRemaining > 0) {
        const secondsToSubtract = Math.min(elapsed, state.timeRemaining);

        // Track focus time for the hidden period
        if (state.phase === 'work') {
          focusSecondsToday += secondsToSubtract;
          saveFocusTime(focusSecondsToday);
          focusTimeDisplay.textContent = formatFocusTime(focusSecondsToday);
        }

        state.timeRemaining -= secondsToSubtract;

        if (state.timeRemaining <= 0) {
          state.timeRemaining = 0;
          stopTimer();
          playNotificationBeep();
          advancePhase();
        }

        updateDisplay();
      }
    }
  });

  // Initial display
  updateDisplay();
</script>
