    }
    .dice-face {
      width: 44px;
      height: 44px;
      font-size: 1.1rem;
    }
    .coin-display {
      width: 100px;
      height: 100px;
      font-size: 1rem;
    }
  }
</style>

<script>
  (function () {
    'use strict';

    // --- Cryptographic random helpers ---
    function secureRandomInt(max: number): number {
      const array = new Uint32Array(1);
      const limit = Math.floor(4294967296 / max) * max;
      do {
        crypto.getRandomValues(array);
      } while (array[0] >= limit);
      return array[0] % max;
    }

    function secureRandomRange(min: number, max: number): number {
      return min + secureRandomInt(max - min + 1);
    }

    // --- Tab switching ---
    const tabs = document.querySelectorAll<HTMLButtonElement>('.rng-tab');
    const panels = document.querySelectorAll<HTMLDivElement>('.rng-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach(p => {
          p.classList.remove('active');
          p.hidden = true;
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        const panelId = tab.getAttribute('aria-controls')!;
        const panel = document.getElementById(panelId)!;
        panel.classList.add('active');
        panel.hidden = false;
      });
    });

    // ==========================================
    // NUMBER GENERATOR
    // ==========================================
    const numMin = document.getElementById('numMin') as HTMLInputElement;
    const numMax = document.getElementById('numMax') as HTMLInputElement;
    const numQty = document.getElementById('numQty') as HTMLInputElement;
    const numDuplicates = document.getElementById('numDuplicates') as HTMLInputElement;
    const numSort = document.getElementById('numSort') as HTMLInputElement;
    const numGenerate = document.getElementById('numGenerate') as HTMLButtonElement;
    const numCopy = document.getElementById('numCopy') as HTMLButtonElement;
    const numResults = document.getElementById('numResults')!;
    const numError = document.getElementById('numError')!;

    let lastNumbers: number[] = [];

    function showNumError(msg: string) {
      numError.textContent = msg;
      numError.style.display = 'block';
      numResults.innerHTML = '';
    }

    function hideNumError() {
      numError.style.display = 'none';
    }

    function generateNumbers() {
      hideNumError();
      const min = parseInt(numMin.value);
      const max = parseInt(numMax.value);
      let qty = parseInt(numQty.value);
      const allowDupes = numDuplicates.checked;
      const sortAsc = numSort.checked;

      if (isNaN(min) || isNaN(max)) {
        showNumError('Please enter valid minimum and maximum values.');
        return;
      }
      if (min > max) {
        showNumError('Minimum must be less than or equal to maximum.');
        return;
      }
      if (isNaN(qty) || qty < 1) qty = 1;
      if (qty > 100) qty = 100;

      const range = max - min + 1;
      if (!allowDupes && qty > range) {
        showNumError(`Cannot generate ${qty} unique numbers in a range of ${range}. Increase the range or allow duplicates.`);
        return;
      }

      let numbers: number[] = [];
      if (allowDupes) {
        for (let i = 0; i < qty; i++) {
          numbers.push(secureRandomRange(min, max));
        }
      } else {
        // Fisher-Yates selection for unique numbers
        if (qty <= range / 2) {
          const seen = new Set<number>();
          while (seen.size < qty) {
            seen.add(secureRandomRange(min, max));
          }
          numbers = Array.from(seen);
        } else {
          // Build full array and shuffle-pick
          const pool: number[] = [];
          for (let i = min; i <= max; i++) pool.push(i);
          for (let i = pool.length - 1; i > 0; i--) {
            const j = secureRandomInt(i + 1);
            const tmp = pool[i];
            pool[i] = pool[j];
            pool[j] = tmp;
          }
          numbers = pool.slice(0, qty);
        }
      }

      if (sortAsc) {
        numbers.sort((a, b) => a - b);
      }

      lastNumbers = numbers;
      renderNumbers(numbers);
    }

    function renderNumbers(numbers: number[]) {
      const isSingle = numbers.length === 1;
      const html = '<div class="rng-numbers">' +
        numbers.map(n => `<span class="rng-number${isSingle ? ' single' : ''}">${n.toLocaleString()}</span>`).join('') +
        '</div>';
      numResults.innerHTML = html;
    }

    numGenerate.addEventListener('click', generateNumbers);

    numCopy.addEventListener('click', () => {
      if (lastNumbers.length === 0) return;
      const text = lastNumbers.join(', ');
      navigator.clipboard.writeText(text).then(() => {
        showCopyFeedback(numCopy);
      }).catch(() => {
        fallbackCopy(text);
        showCopyFeedback(numCopy);
      });
    });

    // ==========================================
    // DICE ROLLER
    // ==========================================
    const diceType = document.getElementById('diceType') as HTMLSelectElement;
    const diceCount = document.getElementById('diceCount') as HTMLInputElement;
    const diceRollBtn = document.getElementById('diceRoll') as HTMLButtonElement;
    const diceCopy = document.getElementById('diceCopy') as HTMLButtonElement;
    const diceResults = document.getElementById('diceResults')!;

    let lastDice: number[] = [];
    let lastDiceSum = 0;

    function rollDice() {
      let faces = parseInt(diceType.value);
      let count = parseInt(diceCount.value);
      if (isNaN(count) || count < 1) count = 1;
      if (count > 20) count = 20;

      const rolls: number[] = [];
      for (let i = 0; i < count; i++) {
        rolls.push(secureRandomRange(1, faces));
      }

      lastDice = rolls;
      lastDiceSum = rolls.reduce((s, v) => s + v, 0);
      renderDice(rolls, faces, lastDiceSum);
    }

    function renderDice(rolls: number[], faces: number, sum: number) {
      let html = '<div class="dice-results-inner">';
      rolls.forEach((val, idx) => {
        html += `<div class="dice-item">
          <span class="dice-face rolling" style="animation-delay:${idx * 0.05}s">` + val + `</span>
          <span class="dice-label">d${faces}</span>
        </div>`;
      });
      html += '</div>';
      if (rolls.length > 1) {
        html += `<div class="dice-sum"><span class="dice-sum-label">Total:</span> ${sum}</div>`;
      }
      diceResults.innerHTML = html;
    }

    diceRollBtn.addEventListener('click', rollDice);

    diceCopy.addEventListener('click', () => {
      if (lastDice.length === 0) return;
      const text = lastDice.join(', ') + (lastDice.length > 1 ? ` (Total: ${lastDiceSum})` : '');
      navigator.clipboard.writeText(text).then(() => {
        showCopyFeedback(diceCopy);
      }).catch(() => {
        fallbackCopy(text);
        showCopyFeedback(diceCopy);
      });
    });

    // ==========================================
    // COIN FLIPPER
    // ==========================================
    const coinFlipBtn = document.getElementById('coinFlip') as HTMLButtonElement;
    const coinResetBtn = document.getElementById('coinReset') as HTMLButtonElement;
    const coinDisplay = document.getElementById('coinDisplay')!;
    const coinStats = document.getElementById('coinStats')!;
    const coinHistory = document.getElementById('coinHistory')!;

    let coinResults: ('H' | 'T')[] = [];

    function flipCoin() {
      const isHeads = secureRandomInt(2) === 0;
      const result = isHeads ? 'H' : 'T';
      coinResults.push(result);

      // Animate coin
      coinDisplay.className = 'coin-display flipping ' + (isHeads ? 'heads' : 'tails');
      coinDisplay.textContent = isHeads ? 'Heads' : 'Tails';

      // Remove animation class after it completes
      setTimeout(() => {
        coinDisplay.classList.remove('flipping');
      }, 500);

      updateCoinHistory();
    }

    function updateCoinHistory() {
      const heads = coinResults.filter(r => r === 'H').length;
      const tails = coinResults.length - heads;
      const pct = coinResults.length > 0 ? ((heads / coinResults.length) * 100).toFixed(1) : '0.0';

      coinStats.textContent = `${coinResults.length} flip${coinResults.length !== 1 ? 's' : ''}: ${heads} heads (${pct}%), ${tails} tails (${(100 - parseFloat(pct)).toFixed(1)}%)`;

      let html = '';
      coinResults.forEach(r => {
        html += `<span class="coin-pip ${r === 'H' ? 'heads' : 'tails'}">${r}</span>`;
      });
      coinHistory.innerHTML = html;
    }

    function resetCoin() {
      coinResults = [];
      coinDisplay.className = 'coin-display';
      coinDisplay.textContent = '';
      coinStats.textContent = '';
      coinHistory.innerHTML = '';
    }

    coinFlipBtn.addEventListener('click', flipCoin);
    coinResetBtn.addEventListener('click', resetCoin);

    // ==========================================
    // SHARED UTILITIES
    // ==========================================
    function showCopyFeedback(btn: HTMLButtonElement) {
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = original;
        btn.classList.remove('copied');
      }, 1500);
    }

    function fallbackCopy(text: string) {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
    }
  })();
</script>
