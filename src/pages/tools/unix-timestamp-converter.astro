  }
  .ts-format-hint {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-top: 6px;
    min-height: 1.2em;
  }

  /* Results Cards */
  .ts-results {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 12px;
  }
  .ts-result-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .ts-result-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    min-width: 80px;
    white-space: nowrap;
  }
  .ts-result-value {
    flex: 1;
    font-size: 0.9rem;
    color: var(--color-text);
    word-break: break-word;
  }
  .ts-mono {
    font-family: 'Courier New', Consolas, monospace;
  }

  /* Date to Timestamp Inputs */
  .ts-tz-toggle {
    display: inline-flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 12px;
  }
  .ts-tz-btn {
    padding: 6px 16px;
    border: none;
    background: var(--color-bg);
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .ts-tz-btn.active {
    background: var(--color-primary);
    color: #fff;
  }
  .ts-tz-btn:not(.active):hover {
    background: var(--color-surface);
  }

  .ts-date-inputs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
  }
  .ts-date-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ts-date-field label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .ts-date-field input {
    width: 72px;
    padding: 8px 8px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-family: 'Courier New', Consolas, monospace;
    background: var(--color-bg);
    color: var(--color-text);
    text-align: center;
    -moz-appearance: textfield;
  }
  .ts-date-field input:focus {
    outline: none;
