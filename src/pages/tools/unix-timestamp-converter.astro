---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getToolBySlug } from '../../data/tools';
import '../../styles/tool.css';

const tool = getToolBySlug('unix-timestamp-converter')!;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Web Tools", "item": "https://toolcalcs.com/tools/" },
      { "@type": "ListItem", "position": 3, "name": "Unix Timestamp Converter" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Unix Timestamp Converter",
    "url": "https://toolcalcs.com/tools/unix-timestamp-converter/",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "All",
    "browserRequirements": "Requires JavaScript",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "description": "Convert Unix timestamps to dates and dates to timestamps."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a Unix timestamp?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A Unix timestamp is the number of seconds elapsed since January 1, 1970 (UTC), known as the Unix epoch. It is widely used in programming and databases to represent points in time as simple integers."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between seconds and milliseconds timestamps?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Standard Unix timestamps count seconds since the epoch (10 digits). JavaScript and some APIs use millisecond timestamps (13 digits). This tool auto-detects which format you enter."
        }
      },
      {
        "@type": "Question",
        "name": "Is the Unix timestamp affected by time zones?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Unix timestamps always represent UTC time. When displaying a timestamp as a human-readable date, the conversion depends on the viewer's timezone, but the underlying timestamp value is timezone-independent."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="Unix Timestamp Converter - Convert Epoch Time to Date | ToolCalcs"
  description={tool.description}
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/tools/">Web Tools</a> &rsaquo;
    <span>Unix Timestamp Converter</span>
  </nav>

  <h1>{tool.title}</h1>
  <p class="page-desc">Convert between Unix timestamps and human-readable dates. See the current epoch time updating live, convert any timestamp to a formatted date, or pick a date to get its timestamp.</p>

  <div class="tool-box">
    <!-- Live Clock Section -->
    <div class="ts-section">
      <label class="tool-label">Current Unix Timestamp</label>
      <div class="live-clock-row">
        <div class="live-clock-display">
          <span class="live-value" id="liveSeconds">---</span>
          <span class="live-unit">seconds</span>
        </div>
        <button type="button" class="copy-btn" id="copyLiveSeconds">Copy</button>
      </div>
      <div class="live-clock-row">
        <div class="live-clock-display">
          <span class="live-value live-value-ms" id="liveMilliseconds">---</span>
          <span class="live-unit">milliseconds</span>
        </div>
        <button type="button" class="copy-btn" id="copyLiveMs">Copy</button>
      </div>
    </div>

    <hr class="ts-divider" />

    <!-- Timestamp to Date Section -->
    <div class="ts-section">
      <label class="tool-label" for="tsInput">Timestamp &rarr; Date</label>
      <div class="ts-input-row">
        <input type="number" id="tsInput" class="ts-number-input" placeholder="e.g. 1700000000 or 1700000000000" />
        <button type="button" class="tool-btn primary" id="tsConvertBtn">Convert</button>
        <button type="button" class="tool-btn secondary" id="tsNowBtn">Now</button>
      </div>
      <div class="ts-format-hint" id="tsFormatHint"></div>
      <div class="tool-error" id="tsError" hidden></div>
      <div class="ts-results" id="tsResults" hidden>
        <div class="ts-result-card">
          <span class="ts-result-label">UTC</span>
          <span class="ts-result-value" id="tsUtc">--</span>
          <button type="button" class="copy-btn" data-copy-target="tsUtc">Copy</button>
        </div>
        <div class="ts-result-card">
          <span class="ts-result-label">Local Time</span>
          <span class="ts-result-value" id="tsLocal">--</span>
          <button type="button" class="copy-btn" data-copy-target="tsLocal">Copy</button>
        </div>
        <div class="ts-result-card">
          <span class="ts-result-label">ISO 8601</span>
          <span class="ts-result-value ts-mono" id="tsIso">--</span>
          <button type="button" class="copy-btn" data-copy-target="tsIso">Copy</button>
        </div>
        <div class="ts-result-card">
          <span class="ts-result-label">Relative</span>
          <span class="ts-result-value" id="tsRelative">--</span>
        </div>
      </div>
    </div>

    <hr class="ts-divider" />

    <!-- Date to Timestamp Section -->
