      width: 100%;
    }
  }
</style>

<script>
  // --- DOM Elements ---
  const liveSecondsEl = document.getElementById('liveSeconds') as HTMLSpanElement;
  const liveMillisecondsEl = document.getElementById('liveMilliseconds') as HTMLSpanElement;
  const copyLiveSecondsBtn = document.getElementById('copyLiveSeconds') as HTMLButtonElement;
  const copyLiveMsBtn = document.getElementById('copyLiveMs') as HTMLButtonElement;

  const tsInput = document.getElementById('tsInput') as HTMLInputElement;
  const tsConvertBtn = document.getElementById('tsConvertBtn') as HTMLButtonElement;
  const tsNowBtn = document.getElementById('tsNowBtn') as HTMLButtonElement;
  const tsFormatHint = document.getElementById('tsFormatHint') as HTMLDivElement;
  const tsError = document.getElementById('tsError') as HTMLDivElement;
  const tsResults = document.getElementById('tsResults') as HTMLDivElement;
  const tsUtcEl = document.getElementById('tsUtc') as HTMLSpanElement;
  const tsLocalEl = document.getElementById('tsLocal') as HTMLSpanElement;
  const tsIsoEl = document.getElementById('tsIso') as HTMLSpanElement;
  const tsRelativeEl = document.getElementById('tsRelative') as HTMLSpanElement;

  const dtYear = document.getElementById('dtYear') as HTMLInputElement;
  const dtMonth = document.getElementById('dtMonth') as HTMLInputElement;
  const dtDay = document.getElementById('dtDay') as HTMLInputElement;
  const dtHour = document.getElementById('dtHour') as HTMLInputElement;
  const dtMinute = document.getElementById('dtMinute') as HTMLInputElement;
  const dtSecond = document.getElementById('dtSecond') as HTMLInputElement;
  const dtConvertBtn = document.getElementById('dtConvertBtn') as HTMLButtonElement;
  const dtNowBtn = document.getElementById('dtNowBtn') as HTMLButtonElement;
  const dtError = document.getElementById('dtError') as HTMLDivElement;
  const dtResults = document.getElementById('dtResults') as HTMLDivElement;
  const dtSecondsEl = document.getElementById('dtSeconds') as HTMLSpanElement;
  const dtMillisecondsEl = document.getElementById('dtMilliseconds') as HTMLSpanElement;

  const tzLocalBtn = document.getElementById('tzLocal') as HTMLButtonElement;
  const tzUtcBtn = document.getElementById('tzUtc') as HTMLButtonElement;

  let selectedTz: 'local' | 'utc' = 'local';

  // --- Utility: Copy to clipboard ---
  function copyToClipboard(text: string, btn: HTMLButtonElement): void {
    navigator.clipboard.writeText(text).then(() => {
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = original;
        btn.classList.remove('copied');
      }, 1500);
    }).catch(() => {
      // Fallback
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.textContent = original;
        btn.classList.remove('copied');
      }, 1500);
    });
  }

  // --- Live Clock ---
  function updateLiveClock(): void {
    const now = Date.now();
    const seconds = Math.floor(now / 1000);
    liveSecondsEl.textContent = seconds.toLocaleString('en-US');
    liveMillisecondsEl.textContent = now.toLocaleString('en-US');
  }

  updateLiveClock();
  setInterval(updateLiveClock, 1000);

  copyLiveSecondsBtn.addEventListener('click', () => {
    const seconds = String(Math.floor(Date.now() / 1000));
    copyToClipboard(seconds, copyLiveSecondsBtn);
  });

  copyLiveMsBtn.addEventListener('click', () => {
    const ms = String(Date.now());
    copyToClipboard(ms, copyLiveMsBtn);
  });

  // --- Relative time ---
  function getRelativeTime(date: Date): string {
    const now = Date.now();
    const diffMs = now - date.getTime();
    const absDiffMs = Math.abs(diffMs);
    const isFuture = diffMs < 0;

    const seconds = Math.floor(absDiffMs / 1000);
    const minutes = Math.floor(seconds / 60);
    const hours = Math.floor(minutes / 60);
    const days = Math.floor(hours / 24);
    const weeks = Math.floor(days / 7);
    const months = Math.floor(days / 30.44);
    const years = Math.floor(days / 365.25);

    let text: string;
    if (seconds < 5) {
      return 'just now';
    } else if (seconds < 60) {
      text = seconds + ' second' + (seconds !== 1 ? 's' : '');
    } else if (minutes < 60) {
      text = minutes + ' minute' + (minutes !== 1 ? 's' : '');
    } else if (hours < 24) {
      text = hours + ' hour' + (hours !== 1 ? 's' : '');
    } else if (days < 7) {
      text = days + ' day' + (days !== 1 ? 's' : '');
    } else if (weeks < 5) {
      text = weeks + ' week' + (weeks !== 1 ? 's' : '');
    } else if (months < 12) {
      text = months + ' month' + (months !== 1 ? 's' : '');
    } else {
      text = years + ' year' + (years !== 1 ? 's' : '');
    }

    return isFuture ? 'in ' + text : text + ' ago';
  }

  // --- Format date helpers ---
  function formatFullDate(date: Date, utc: boolean): string {
    const options: Intl.DateTimeFormatOptions = {
      weekday: 'long',
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
      hour12: true,
      timeZoneName: 'short',
    };
    if (utc) {
      options.timeZone = 'UTC';
    }
    return date.toLocaleString('en-US', options);
  }

  // --- Detect timestamp format ---
  function detectTimestampFormat(value: string): 'seconds' | 'milliseconds' | null {
    const trimmed = value.trim();
    if (!/^-?\d+$/.test(trimmed)) return null;

    const num = Number(trimmed);
    if (!Number.isFinite(num)) return null;

    const absNum = Math.abs(num);
    // 13+ digits -> milliseconds
    if (absNum >= 1e12) return 'milliseconds';
    // 10 digits or fewer -> seconds
    return 'seconds';
  }

  // --- Timestamp to date conversion ---
  function convertTimestampToDate(): void {
    tsError.hidden = true;
    tsResults.hidden = true;
    tsFormatHint.textContent = '';

    const raw = tsInput.value.trim();
    if (!raw) {
      tsError.textContent = 'Please enter a Unix timestamp.';
      tsError.hidden = false;
      return;
    }

    const format = detectTimestampFormat(raw);
    if (!format) {
      tsError.textContent = 'Invalid timestamp. Please enter a numeric value (e.g. 1700000000).';
      tsError.hidden = false;
      return;
    }

    const num = Number(raw);
    const ms = format === 'milliseconds' ? num : num * 1000;
    const date = new Date(ms);

    if (isNaN(date.getTime())) {
      tsError.textContent = 'The timestamp produces an invalid date. Please check your input.';
      tsError.hidden = false;
      return;
    }

    tsFormatHint.textContent = 'Detected format: ' + format + ' (' + (format === 'seconds' ? '10-digit' : '13-digit') + ')';

    tsUtcEl.textContent = formatFullDate(date, true);
    tsLocalEl.textContent = formatFullDate(date, false);
    tsIsoEl.textContent = date.toISOString();
    tsRelativeEl.textContent = getRelativeTime(date);

    tsResults.hidden = false;
  }

  tsConvertBtn.addEventListener('click', convertTimestampToDate);

  tsInput.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') {
      convertTimestampToDate();
    }
  });

  tsNowBtn.addEventListener('click', () => {
    tsInput.value = String(Math.floor(Date.now() / 1000));
    convertTimestampToDate();
  });

  // --- Auto-detect hint on input ---
  tsInput.addEventListener('input', () => {
    const raw = tsInput.value.trim();
    if (!raw) {
      tsFormatHint.textContent = '';
      return;
    }
    const format = detectTimestampFormat(raw);
    if (format) {
      tsFormatHint.textContent = 'Detected: ' + format + ' (' + (format === 'seconds' ? '10-digit' : '13-digit') + ')';
    } else {
      tsFormatHint.textContent = '';
    }
  });

  // --- Date to timestamp: populate with current date ---
  function populateDateFields(date: Date, utc: boolean): void {
    if (utc) {
      dtYear.value = String(date.getUTCFullYear());
      dtMonth.value = String(date.getUTCMonth() + 1);
      dtDay.value = String(date.getUTCDate());
      dtHour.value = String(date.getUTCHours());
      dtMinute.value = String(date.getUTCMinutes());
      dtSecond.value = String(date.getUTCSeconds());
    } else {
      dtYear.value = String(date.getFullYear());
      dtMonth.value = String(date.getMonth() + 1);
      dtDay.value = String(date.getDate());
      dtHour.value = String(date.getHours());
      dtMinute.value = String(date.getMinutes());
      dtSecond.value = String(date.getSeconds());
    }
  }

  // Initialize date fields with current date
  populateDateFields(new Date(), selectedTz === 'utc');

  // --- Timezone toggle ---
  tzLocalBtn.addEventListener('click', () => {
    if (selectedTz === 'local') return;
    selectedTz = 'local';
    tzLocalBtn.classList.add('active');
    tzUtcBtn.classList.remove('active');
  });

  tzUtcBtn.addEventListener('click', () => {
    if (selectedTz === 'utc') return;
    selectedTz = 'utc';
    tzUtcBtn.classList.add('active');
    tzLocalBtn.classList.remove('active');
  });

  // --- Date to timestamp conversion ---
  function convertDateToTimestamp(): void {
    dtError.hidden = true;
    dtResults.hidden = true;

    const year = parseInt(dtYear.value, 10);
    const month = parseInt(dtMonth.value, 10);
    const day = parseInt(dtDay.value, 10);
    const hour = parseInt(dtHour.value, 10) || 0;
    const minute = parseInt(dtMinute.value, 10) || 0;
    const second = parseInt(dtSecond.value, 10) || 0;

    if (isNaN(year) || isNaN(month) || isNaN(day)) {
      dtError.textContent = 'Please fill in at least the year, month, and day fields.';
      dtError.hidden = false;
      return;
    }

    if (month < 1 || month > 12) {
      dtError.textContent = 'Month must be between 1 and 12.';
      dtError.hidden = false;
      return;
    }

    if (day < 1 || day > 31) {
      dtError.textContent = 'Day must be between 1 and 31.';
      dtError.hidden = false;
      return;
    }

    let date: Date;
    if (selectedTz === 'utc') {
      date = new Date(Date.UTC(year, month - 1, day, hour, minute, second));
    } else {
      date = new Date(year, month - 1, day, hour, minute, second);
    }

    // Handle years 0-99 explicitly since Date constructor treats them as 1900-1999
    if (year >= 0 && year < 100) {
      if (selectedTz === 'utc') {
        date.setUTCFullYear(year);
      } else {
        date.setFullYear(year);
      }
    }

    if (isNaN(date.getTime())) {
      dtError.textContent = 'The entered date is invalid. Please check your values.';
      dtError.hidden = false;
      return;
    }

    const ms = date.getTime();
    const seconds = Math.floor(ms / 1000);

    dtSecondsEl.textContent = seconds.toLocaleString('en-US');
    dtMillisecondsEl.textContent = ms.toLocaleString('en-US');

    dtResults.hidden = false;
  }

  dtConvertBtn.addEventListener('click', convertDateToTimestamp);

  dtNowBtn.addEventListener('click', () => {
    populateDateFields(new Date(), selectedTz === 'utc');
    convertDateToTimestamp();
  });

  // --- Copy buttons for result cards ---
  document.querySelectorAll<HTMLButtonElement>('.copy-btn[data-copy-target]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-copy-target');
      if (!targetId) return;
      const targetEl = document.getElementById(targetId);
      if (!targetEl) return;

      // For numeric values displayed with locale formatting, copy the raw number
      let text = targetEl.textContent || '';
      if (targetId === 'dtSeconds' || targetId === 'dtMilliseconds') {
        text = text.replace(/,/g, '');
      }

      copyToClipboard(text, btn);
    });
  });
</script>
