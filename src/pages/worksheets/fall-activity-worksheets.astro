---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getWorksheetBySlug } from '../../data/worksheets';
import '../../styles/worksheet.css';

const ws = getWorksheetBySlug('fall-activity-worksheets')!;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Worksheets", "item": "https://toolcalcs.com/worksheets/" },
      { "@type": "ListItem", "position": 3, "name": "Fall Activity Worksheets" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LearningResource",
    "name": "Fall Activity Worksheets",
    "description": "Fall Activity Worksheets - free printable for seasonal and themed.",
    "learningResourceType": "worksheet",
    "educationalUse": "practice",
    "isAccessibleForFree": true,
    "inLanguage": "en"
  }
];
---

<BaseLayout
  title="Free Fall Activity Worksheets - Printable Practice | ToolCalcs"
  description={ws.description}
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/worksheets/">Worksheets</a> &rsaquo;
    <span>Fall Activity Worksheets</span>
  </nav>

  <h1>{ws.title}</h1>
  <p class="page-desc">{ws.description}</p>

  <div class="worksheet-box">
    <div class="worksheet-actions">
      <button class="ws-btn primary" onclick="window.print()">Print Worksheet</button>
      <a href="/worksheets/" class="ws-btn">Back to All Worksheets</a>
    </div>

    <div class="worksheet-content">
      <div class="worksheet-header-print">
        <h2>Fall Activity Worksheets</h2>
        <div class="name-date">
          <span>Name: ___________________</span>
          <span>Date: ___________________</span>
        </div>
      </div>
      <div class="static-worksheet-area">
        <p class="ws-instructions">Instructions for parents and teachers:</p>
        <p>Activities include counting falling leaves, coloring apples, matching pumpkins, and tracing fall vocabulary. Perfect for September and October classroom centers.</p>
        <p class="ws-tip"><strong>Tip:</strong> Print multiple copies for repeated practice. Younger children may need adult help reading instructions.</p>
      </div>
    </div>
  </div>

  <AdUnit slot="ws-mid" format="rectangle" />

  <article class="content-section">
    <h2>About These Fall Activity Worksheets</h2>
    <p>Activities include counting falling leaves, coloring apples, matching pumpkins, and tracing fall vocabulary. Perfect for September and October classroom centers.</p>

    <h2>Why Seasonal and Themed Practice Matters</h2>
    <p>Autumn themes connect children to seasonal changes happening around them while providing engaging practice with familiar fall imagery.</p>

    <h2>How to Use This Worksheet</h2>
    <p>Click the Print Worksheet button above to print a clean copy without the navigation or settings panel. The printable area is sized for standard 8.5 by 11 inch paper. Use the worksheet as part of daily practice, classroom centers, homeschool curriculum, or holiday activities.</p>

    <h2>Tips for Parents and Teachers</h2>
    <ul>
      <li><strong>Keep sessions short.</strong> Five to ten minutes of focused practice is more effective than longer, frustrated sessions.</li>
      <li><strong>Praise effort, not just correctness.</strong> Children who feel safe making mistakes learn faster than those who fear failure.</li>
      <li><strong>Make it fun.</strong> Add stickers, use colorful pencils, or turn the worksheet into a game with timers or rewards.</li>
      <li><strong>Print plenty.</strong> Each worksheet is free and unlimited, so print fresh copies as often as your child needs them.</li>
      <li><strong>Combine with hands-on learning.</strong> Pair worksheets with real objects, blocks, or movement activities for the best results.</li>
    </ul>

    <h2>Related Worksheets</h2>
    <ul>
      <li><a href="/worksheets/">Browse All Worksheets</a> - See all 95+ free printable worksheets organized by category and grade.</li>
      <li><a href="/worksheets/addition-worksheets/">Addition Worksheets</a> - Practice basic addition for K-3 students.</li>
      <li><a href="/worksheets/sight-words-worksheets/">Sight Words Worksheets</a> - Build reading fluency with high-frequency word practice.</li>
    </ul>
  </article>

  <AdUnit slot="ws-bottom" format="horizontal" />
</BaseLayout>

<style>
  .static-worksheet-area {
    padding: 24px 16px;
    text-align: left;
    line-height: 1.7;
  }
  .ws-instructions {
    font-weight: 600;
    margin-bottom: 8px;
  }
  .ws-tip {
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--color-bg);
    border-left: 3px solid var(--color-primary);
    border-radius: 4px;
    font-size: 0.92rem;
  }
</style>
