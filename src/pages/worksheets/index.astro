---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import ExploreMore from '../../components/ExploreMore.astro';
import { worksheets, type Worksheet } from '../../data/worksheets';
import '../../styles/category.css';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
    { "@type": "ListItem", "position": 2, "name": "Worksheets" }
  ]
};

function getBySlug(slug: string): Worksheet | undefined {
  return worksheets.find(w => w.slug === slug);
}

const categories = [
  {
    title: 'Basic Operations',
    description: 'Build a strong foundation with addition, subtraction, multiplication, and division practice.',
    slugs: ['addition-worksheets', 'subtraction-worksheets', 'multiplication-worksheets', 'division-worksheets', 'long-division-worksheets', 'fact-families-worksheets', 'multiplication-tables-worksheets'],
  },
  {
    title: 'Number Sense',
    description: 'Develop number understanding with place value, counting, comparing, decimals, and percentages.',
    slugs: ['number-tracing', 'skip-counting', 'place-value-worksheets', 'rounding-worksheets', 'comparing-numbers-worksheets', 'even-and-odd-worksheets', 'number-patterns-worksheets', 'decimals-worksheets', 'percentages-worksheets', 'mean-median-mode-worksheets', 'exponents-worksheets', 'gcf-and-lcm-worksheets', 'average-worksheets', 'prime-numbers-worksheets'],
  },
  {
    title: 'Visual & Applied Math',
    description: 'Apply math to the real world with time, money, fractions, geometry, and measurement.',
    slugs: ['telling-time-worksheets', 'counting-money-worksheets', 'number-line-worksheets', 'fractions-worksheets', 'area-and-perimeter-worksheets', 'geometry-worksheets', 'measurement-worksheets', 'volume-worksheets', 'triangle-worksheets', 'temperature-conversion-worksheets', 'length-conversion-worksheets', 'weight-conversion-worksheets', 'cooking-measurement-worksheets', 'elapsed-time-worksheets'],
  },
  {
    title: 'Problem Solving',
    description: 'Challenge students with multi-step operations and real-world word problems.',
    slugs: ['order-of-operations-worksheets', 'word-problems-worksheets', 'algebra-worksheets', 'ratio-and-proportion-worksheets', 'quadratic-equations-worksheets', 'speed-distance-worksheets', 'sales-tax-worksheets', 'probability-worksheets', 'integers-worksheets', 'coordinate-plane-worksheets', 'proportions-worksheets', 'scientific-notation-worksheets', 'one-step-equations-worksheets', 'two-step-equations-worksheets', 'inequalities-worksheets', 'pythagorean-theorem-worksheets', 'slope-worksheets'],
  },
  {
    title: 'Reading Comprehension',
    description: 'Build critical reading skills with main idea, cause and effect, inference, vocabulary, and sequencing practice.',
    slugs: ['reading-main-idea-worksheets', 'reading-cause-effect-worksheets', 'reading-inference-worksheets', 'reading-vocabulary-context-worksheets', 'reading-sequencing-worksheets'],
  },
  {
    title: 'Language Arts',
    description: 'English fundamentals: alphabet, sight words, phonics, spelling, vocabulary, grammar, punctuation, and parts of speech.',
    slugs: ['alphabet-tracing-worksheets', 'sight-words-worksheets', 'phonics-worksheets', 'spelling-worksheets', 'vocabulary-worksheets', 'grammar-worksheets', 'punctuation-worksheets', 'capitalization-worksheets', 'synonyms-antonyms-worksheets', 'parts-of-speech-worksheets'],
  },
  {
    title: 'Pre-K & Early Learning',
    description: 'Hands-on activities for the youngest learners: letter tracing, color by number, shapes, patterns, and counting.',
    slugs: ['letter-tracing-worksheets', 'color-by-number-worksheets', 'shape-recognition-worksheets', 'pattern-matching-worksheets', 'connect-the-dots-worksheets', 'maze-worksheets', 'same-and-different-worksheets', 'counting-pictures-worksheets'],
  },
  {
    title: 'Seasonal & Themed',
    description: 'Holiday and seasonal worksheets that make learning fun all year round: Christmas, Halloween, Easter, Thanksgiving, and more.',
    slugs: ['christmas-math-worksheets', 'halloween-counting-worksheets', 'easter-word-worksheets', 'thanksgiving-reading-worksheets', 'valentine-crafts-worksheets', 'summer-review-worksheets', 'back-to-school-worksheets', 'st-patricks-day-worksheets', 'earth-day-worksheets', 'fall-activity-worksheets'],
  },
  {
    title: 'Puzzles & Games',
    description: 'Brain-building games that disguise learning as fun: word searches, crosswords, Sudoku, mazes, and logic puzzles.',
    slugs: ['word-search-worksheets', 'crossword-worksheets', 'sudoku-kids-worksheets', 'cryptogram-worksheets', 'memory-match-worksheets', 'bingo-worksheets', 'hangman-worksheets', 'find-the-difference-worksheets', 'logic-puzzle-worksheets', 'brain-teaser-worksheets'],
  },
];
---

<BaseLayout
  title="95+ Free Printable Worksheets - Math, Reading & Language Arts | ToolCalcs"
  description="95+ free printable worksheets for Pre-K through 10th grade. Math, reading, language arts, phonics, sight words, seasonal activities, puzzles, and games. Print unlimited copies."
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo; <span>Worksheets</span>
  </nav>

  <h1>Printable Worksheets</h1>
  <p class="page-desc">95+ free printable worksheets for Pre-K through 10th grade. Math, language arts, reading, seasonal themes, and puzzles. Choose a category, print, and practice.</p>

  <section class="grade-hubs">
    <h2>Browse by Grade Level</h2>
    <div class="grade-hub-grid">
      <a href="/worksheets/grade/preschool/" class="grade-hub-card"><strong>Preschool</strong><span>Ages 3-5</span></a>
      <a href="/worksheets/grade/kindergarten/" class="grade-hub-card"><strong>Kindergarten</strong><span>Ages 5-6</span></a>
      <a href="/worksheets/grade/1st-grade/" class="grade-hub-card"><strong>1st Grade</strong><span>Ages 6-7</span></a>
      <a href="/worksheets/grade/2nd-grade/" class="grade-hub-card"><strong>2nd Grade</strong><span>Ages 7-8</span></a>
      <a href="/worksheets/grade/3rd-grade/" class="grade-hub-card"><strong>3rd Grade</strong><span>Ages 8-9</span></a>
      <a href="/worksheets/grade/4th-grade/" class="grade-hub-card"><strong>4th Grade</strong><span>Ages 9-10</span></a>
      <a href="/worksheets/grade/5th-grade/" class="grade-hub-card"><strong>5th Grade</strong><span>Ages 10-11</span></a>
      <a href="/worksheets/grade/6th-grade/" class="grade-hub-card"><strong>6th Grade</strong><span>Ages 11-12</span></a>
    </div>
  </section>

  <div class="grade-filter" id="gradeFilter">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="0,0">Pre-K</button>
    <button class="filter-btn" data-filter="0,2">K-2</button>
    <button class="filter-btn" data-filter="1,3">1-3</button>
    <button class="filter-btn" data-filter="2,4">2-4</button>
    <button class="filter-btn" data-filter="3,5">3-5</button>
    <button class="filter-btn" data-filter="4,6">4-6</button>
    <button class="filter-btn" data-filter="5,7">5-7</button>
    <button class="filter-btn" data-filter="6,8">6-8</button>
    <button class="filter-btn" data-filter="8,10">8-10</button>
  </div>

  <AdUnit slot="cat-top" format="horizontal" />

  {categories.map(cat => (
    <section class="ws-category" data-category>
      <h2>{cat.title}</h2>
      <p class="cat-desc">{cat.description}</p>
      <div class="calc-grid">
        {cat.slugs.map(slug => {
          const ws = getBySlug(slug);
          if (!ws) return null;
          return (
            <a href={`/worksheets/${ws.slug}/`} class="calc-card" data-grades={ws.gradeRange}>
              <span class="calc-icon">{ws.icon}</span>
              <h3>{ws.title}</h3>
              <p>{ws.description}</p>
              <span class="grade-badge">Grades {ws.gradeRange}</span>
            </a>
          );
        })}
      </div>
    </section>
  ))}

  <ExploreMore currentCategorySlug="worksheets" />

  <AdUnit slot="cat-bottom" format="horizontal" />
</BaseLayout>

<script is:inline>
  (function () {
    var gradeMap = {
      'Pre-K': [0, 0],
      'K-2': [0, 2],
      'K-3': [0, 3],
      '1-3': [1, 3],
      '1-4': [1, 4],
      '1-6': [1, 6],
      '2-4': [2, 4],
      '2-5': [2, 5],
      '3-5': [3, 5],
      '4-6': [4, 6],
      '5-7': [5, 7],
      '6-8': [6, 8],
      '8-10': [8, 10]
    };

    var filterBtns = document.querySelectorAll('.filter-btn');
    var cards = document.querySelectorAll('.calc-card[data-grades]');
    var catSections = document.querySelectorAll('.ws-category');

    function filterCards(filterValue) {
      filterBtns.forEach(function (btn) {
        btn.classList.toggle('active', btn.dataset.filter === filterValue);
      });

      if (filterValue === 'all') {
        cards.forEach(function (card) { card.style.display = ''; });
        catSections.forEach(function (sec) { sec.style.display = ''; });
        return;
      }

      var parts = filterValue.split(',');
      var fMin = parseInt(parts[0], 10);
      var fMax = parseInt(parts[1], 10);

      cards.forEach(function (card) {
        var range = gradeMap[card.dataset.grades];
        if (!range) { card.style.display = 'none'; return; }
        var visible = range[0] <= fMax && range[1] >= fMin;
        card.style.display = visible ? '' : 'none';
      });

      catSections.forEach(function (sec) {
        var visibleCards = sec.querySelectorAll('.calc-card:not([style*="display: none"])');
        sec.style.display = visibleCards.length > 0 ? '' : 'none';
      });
    }

    filterBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var filter = btn.dataset.filter;
        filterCards(filter);
        history.replaceState(null, '', '#grade-' + (filter === 'all' ? 'all' : filter.replace(',', '-')));
      });
    });

    var hash = location.hash.replace('#grade-', '');
    if (hash && hash !== '' && hash !== 'all') {
      var filterVal = hash.replace('-', ',');
      filterCards(filterVal);
    }
  })();
</script>

<style>
  .grade-badge {
    display: inline-block;
    margin-top: 8px;
    padding: 2px 10px;
    font-size: 0.75rem;
    font-weight: 600;
    background: #eff6ff;
    color: var(--color-primary);
    border-radius: 12px;
  }

  .grade-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }
  .filter-btn {
    padding: 6px 14px;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    background: var(--color-bg);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .filter-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .filter-btn.active {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .ws-category {
    margin-bottom: 32px;
  }
  .ws-category h2 {
    font-size: 1.3rem;
    margin-bottom: 4px;
  }
  .cat-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 16px;
  }

  .calc-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .grade-hubs {
    margin-bottom: 32px;
  }
  .grade-hubs h2 {
    font-size: 1.2rem;
    margin-bottom: 12px;
  }
  .grade-hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 10px;
  }
  .grade-hub-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 14px 12px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.15s;
  }
  .grade-hub-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }
  .grade-hub-card strong {
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 2px;
  }
  .grade-hub-card span {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
</style>
