---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getWorksheetBySlug } from '../../data/worksheets';
import '../../styles/worksheet.css';

const ws = getWorksheetBySlug('letter-tracing-worksheets')!;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Worksheets", "item": "https://toolcalcs.com/worksheets/" },
      { "@type": "ListItem", "position": 3, "name": "Letter Tracing Worksheets" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LearningResource",
    "name": "Letter Tracing Worksheets",
    "description": "Letter Tracing Worksheets - free printable for pre-k and early learning.",
    "learningResourceType": "worksheet",
    "educationalUse": "practice",
    "isAccessibleForFree": true,
    "inLanguage": "en"
  }
];
---

<BaseLayout
  title="Free Letter Tracing Worksheets - Printable Practice | ToolCalcs"
  description={ws.description}
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/worksheets/">Worksheets</a> &rsaquo;
    <span>Letter Tracing Worksheets</span>
  </nav>

  <h1>{ws.title}</h1>
  <p class="page-desc">{ws.description}</p>

  <div class="worksheet-box">
    <div class="worksheet-actions">
      <button class="ws-btn primary" onclick="window.print()">Print Worksheet</button>
      <a href="/worksheets/" class="ws-btn">Back to All Worksheets</a>
    </div>

    <div class="worksheet-content">
      <div class="worksheet-header-print">
        <h2>Letter Tracing Worksheets</h2>
        <div class="name-date">
          <span>Name: ___________________</span>
          <span>Date: ___________________</span>
        </div>
      </div>
      <div class="static-worksheet-area">
        <p class="ws-instructions">Choose a letter to print its dedicated tracing worksheet:</p>
        <div class="letter-picker">
          <a href="/worksheets/letter/a/" class="lp-letter">A</a>
          <a href="/worksheets/letter/b/" class="lp-letter">B</a>
          <a href="/worksheets/letter/c/" class="lp-letter">C</a>
          <a href="/worksheets/letter/d/" class="lp-letter">D</a>
          <a href="/worksheets/letter/e/" class="lp-letter">E</a>
          <a href="/worksheets/letter/f/" class="lp-letter">F</a>
          <a href="/worksheets/letter/g/" class="lp-letter">G</a>
          <a href="/worksheets/letter/h/" class="lp-letter">H</a>
          <a href="/worksheets/letter/i/" class="lp-letter">I</a>
          <a href="/worksheets/letter/j/" class="lp-letter">J</a>
          <a href="/worksheets/letter/k/" class="lp-letter">K</a>
          <a href="/worksheets/letter/l/" class="lp-letter">L</a>
          <a href="/worksheets/letter/m/" class="lp-letter">M</a>
          <a href="/worksheets/letter/n/" class="lp-letter">N</a>
          <a href="/worksheets/letter/o/" class="lp-letter">O</a>
          <a href="/worksheets/letter/p/" class="lp-letter">P</a>
          <a href="/worksheets/letter/q/" class="lp-letter">Q</a>
          <a href="/worksheets/letter/r/" class="lp-letter">R</a>
          <a href="/worksheets/letter/s/" class="lp-letter">S</a>
          <a href="/worksheets/letter/t/" class="lp-letter">T</a>
          <a href="/worksheets/letter/u/" class="lp-letter">U</a>
          <a href="/worksheets/letter/v/" class="lp-letter">V</a>
          <a href="/worksheets/letter/w/" class="lp-letter">W</a>
          <a href="/worksheets/letter/x/" class="lp-letter">X</a>
          <a href="/worksheets/letter/y/" class="lp-letter">Y</a>
          <a href="/worksheets/letter/z/" class="lp-letter">Z</a>
        </div>
        <p class="ws-tip"><strong>Tip:</strong> Each letter has its own page with uppercase and lowercase practice plus example words starting with that letter.</p>
      </div>
    </div>
  </div>

  <AdUnit slot="ws-mid" format="rectangle" />

  <article class="content-section">
    <h2>About These Letter Tracing Worksheets</h2>
    <p>Choose any letter and print as many practice pages as needed. Each sheet shows correct letter formation with starting dots, directional arrows, and dotted-line guides.</p>

    <h2>Why Pre-K and Early Learning Practice Matters</h2>
    <p>Letter tracing develops fine motor control, hand-eye coordination, and letter recognition simultaneously. It is the bridge between hearing letters and writing them.</p>

    <h2>How to Use This Worksheet</h2>
    <p>Click the Print Worksheet button above to print a clean copy without the navigation or settings panel. The printable area is sized for standard 8.5 by 11 inch paper. Use the worksheet as part of daily practice, classroom centers, homeschool curriculum, or holiday activities.</p>

    <h2>Tips for Parents and Teachers</h2>
    <ul>
      <li><strong>Keep sessions short.</strong> Five to ten minutes of focused practice is more effective than longer, frustrated sessions.</li>
      <li><strong>Praise effort, not just correctness.</strong> Children who feel safe making mistakes learn faster than those who fear failure.</li>
      <li><strong>Make it fun.</strong> Add stickers, use colorful pencils, or turn the worksheet into a game with timers or rewards.</li>
      <li><strong>Print plenty.</strong> Each worksheet is free and unlimited, so print fresh copies as often as your child needs them.</li>
      <li><strong>Combine with hands-on learning.</strong> Pair worksheets with real objects, blocks, or movement activities for the best results.</li>
    </ul>

    <h2>Related Worksheets</h2>
    <ul>
      <li><a href="/worksheets/">Browse All Worksheets</a> - See all 95+ free printable worksheets organized by category and grade.</li>
      <li><a href="/worksheets/addition-worksheets/">Addition Worksheets</a> - Practice basic addition for K-3 students.</li>
      <li><a href="/worksheets/sight-words-worksheets/">Sight Words Worksheets</a> - Build reading fluency with high-frequency word practice.</li>
    </ul>
  </article>

  <AdUnit slot="ws-bottom" format="horizontal" />
</BaseLayout>

<style>
  .static-worksheet-area {
    padding: 24px 16px;
    text-align: left;
    line-height: 1.7;
  }
  .ws-instructions {
    font-weight: 600;
    margin-bottom: 8px;
  }
  .ws-tip {
    margin-top: 16px;
    padding: 12px 16px;
    background: var(--color-bg);
    border-left: 3px solid var(--color-primary);
    border-radius: 4px;
    font-size: 0.92rem;
  }
  .letter-picker {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 16px 0;
    justify-content: center;
  }
  .lp-letter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.3rem;
    background: var(--color-surface);
    transition: all 0.15s;
  }
  .lp-letter:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: scale(1.05);
  }
</style>
