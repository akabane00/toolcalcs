  function shuffle(arr) {
    for (var i = arr.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var temp = arr[i]; arr[i] = arr[j]; arr[j] = temp;
    }
    return arr;
  }

  function generateProblems() {
    var count = parseInt(document.getElementById('cfgProblems').value, 10);
    var level = document.getElementById('cfgLevel').value;

    if (isNaN(count) || count < 3) count = 3;
    if (count > 10) count = 10;

    var pool = passageBank[level].slice();
    shuffle(pool);
    selected = [];

    var items = pool.slice(0, Math.min(count, pool.length));
    for (var i = 0; i < items.length; i++) {
      var item = items[i];
      // Create scrambled version
      var correctOrder = item.steps.slice();
      var scrambled = item.steps.slice();
      // Shuffle until different from original
      var attempts = 0;
      do {
        shuffle(scrambled);
        attempts++;
      } while (scrambled.join('|') === correctOrder.join('|') && attempts < 50);

      selected.push({
        title: item.title,
        scrambled: scrambled,
        correctOrder: correctOrder
      });
    }

    renderProblems();
    renderAnswerKey();
    updateAnswerVisibility();
  }

  function renderProblems() {
    var grid = document.getElementById('problemGrid');
    var showAnswers = document.getElementById('toggleAnswers').checked;
    var html = '';

    for (var i = 0; i < selected.length; i++) {
      var p = selected[i];
      html += '<div class="reading-passage">';
      html += '<div class="problem-number">' + (i + 1) + ')</div>';
      html += '<div class="passage-question"><strong>' + p.title + '</strong></div>';
      html += '<div class="passage-text">Put these events in the correct order (1, 2, 3...):</div>';
      html += '<div class="sequencing-events">';
      for (var j = 0; j < p.scrambled.length; j++) {
        var correctNum = '';
        if (showAnswers) {
          for (var k = 0; k < p.correctOrder.length; k++) {
            if (p.correctOrder[k] === p.scrambled[j]) {
              correctNum = k + 1;
              break;
            }
          }
        }
        html += '<div class="sequence-item">';
        html += '<span class="sequence-blank">' + (showAnswers ? correctNum : '___') + '</span>';
        html += '<span class="sequence-text">' + p.scrambled[j] + '</span>';
        html += '</div>';
      }
      html += '</div>';
      html += '</div>';
    }

    grid.innerHTML = html;
  }

  function renderAnswerKey() {
    var answerGrid = document.getElementById('answerGrid');
    var html = '';
    for (var i = 0; i < selected.length; i++) {
      var p = selected[i];
      html += '<div class="answer-item" style="display:block;margin-bottom:12px">';
      html += '<strong>' + (i + 1) + '. ' + p.title + ':</strong><br>';
      for (var j = 0; j < p.correctOrder.length; j++) {
        html += (j + 1) + '. ' + p.correctOrder[j] + '<br>';
      }
      html += '</div>';
    }
    answerGrid.innerHTML = html;
  }

  function updateAnswerVisibility() {
    var showAnswers = document.getElementById('toggleAnswers').checked;
    var answerKey = document.getElementById('answerKey');
    if (showAnswers) { answerKey.classList.remove('hidden'); }
    else { answerKey.classList.add('hidden'); }
    renderProblems();
  }

  document.getElementById('btnGenerate').addEventListener('click', generateProblems);
  document.getElementById('btnPrint').addEventListener('click', function () { window.print(); });
  document.getElementById('toggleAnswers').addEventListener('change', updateAnswerVisibility);
  generateProblems();
</script>
