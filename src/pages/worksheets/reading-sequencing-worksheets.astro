      { title: "Building a House", steps: ["An architect draws blueprints based on the homeowner's requirements.", "Workers pour a concrete foundation and let it cure for several days.", "Carpenters build the wooden frame including walls, floors, and roof trusses.", "Electricians and plumbers install wiring, pipes, and ventilation systems.", "Drywall is hung, sanded, and painted in each room.", "The family receives the keys and moves into their new home."] },
      { title: "A Criminal Trial", steps: ["Police investigate a crime and gather evidence including witness statements.", "The district attorney reviews the evidence and decides to file charges.", "The defendant appears in court for an arraignment and enters a plea.", "Both sides present their arguments and evidence to the jury during the trial.", "The jury deliberates in private and reaches a verdict.", "The judge announces the verdict and, if guilty, sets a sentencing date."] },
      { title: "Publishing a Book", steps: ["The author writes a first draft of the manuscript over several months.", "The author revises the draft multiple times based on feedback from early readers.", "A literary agent submits the manuscript to publishers on the author's behalf.", "A publishing house accepts the manuscript and assigns an editor to work with the author.", "The book is designed, printed, and distributed to bookstores across the country.", "The author does a book tour with readings and signings to promote the release."] },
