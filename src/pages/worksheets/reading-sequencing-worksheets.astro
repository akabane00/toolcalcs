const ws = getWorksheetBySlug('reading-sequencing-worksheets')!;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://toolcalcs.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Worksheets",
      "item": "https://toolcalcs.com/worksheets/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Sequencing Worksheets"
    }
  ]
};
---

<BaseLayout
  title="Free Sequencing Worksheets - Reading Comprehension Practice | ToolCalcs"
  description={ws.description}
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/worksheets/">Worksheets</a> &rsaquo;
    <span>Sequencing Worksheets</span>
  </nav>

  <h1>{ws.title}</h1>
  <p class="page-desc">{ws.description}</p>

  <div class="worksheet-box">
    <div class="config-panel">
      <h3>Settings</h3>
      <div class="config-inputs">
        <div class="config-group">
          <label for="cfgProblems">Number of Problems</label>
          <input type="number" id="cfgProblems" value="5" min="3" max="10" />
        </div>
        <div class="config-group">
          <label for="cfgLevel">Difficulty Level</label>
          <select id="cfgLevel">
            <option value="easy">Easy</option>
            <option value="medium" selected>Medium</option>
            <option value="hard">Hard</option>
          </select>
        </div>
      </div>
    </div>

    <div class="worksheet-actions">
      <button class="ws-btn primary" id="btnGenerate">Generate New</button>
      <button class="ws-btn print" id="btnPrint">Print</button>
      <label class="toggle-label">
        <input type="checkbox" id="toggleAnswers" />
        Show Answers
      </label>
    </div>

    <div class="worksheet-content" id="worksheetContent">
      <div class="worksheet-header-print">
        <h2>Sequencing Practice</h2>
        <p><em>Put the events in the correct order by writing numbers (1, 2, 3...) next to each event.</em></p>
        <div class="name-date">
          <span>Name: ___________________</span>
          <span>Date: ___________________</span>
        </div>
      </div>
      <div class="problem-grid reading-grid" id="problemGrid"></div>
      <div class="answer-key hidden" id="answerKey">
        <h3>Answer Key</h3>
        <div class="answer-grid" id="answerGrid"></div>
      </div>
    </div>
  </div>

  <AdUnit slot="ws-mid" format="rectangle" />

  <article class="content-section">
    <h2>Why Sequencing Skills Matter</h2>
    <p>Sequencing is the ability to put events, steps, or ideas in the correct order. This fundamental reading comprehension skill helps students understand the structure of stories, follow instructions, summarize texts, and retell events accurately. When students can identify the order in which things happen, they gain a deeper understanding of cause and effect, plot development, and logical progression in both fiction and nonfiction.</p>
    <p>Sequencing is tested on standardized reading assessments at every grade level and is closely connected to other comprehension skills like summarizing and identifying cause and effect. Students who struggle with sequencing often have difficulty retelling stories, following multi-step directions, and writing organized paragraphs of their own.</p>

    <h2>How to Practice Sequencing</h2>
    <ul>
      <li><strong>Look for signal words.</strong> Words like "first," "next," "then," "after," "before," "finally," and "last" help identify the order of events.</li>
      <li><strong>Think about what makes sense.</strong> Even without signal words, ask yourself: "What had to happen before this could happen?"</li>
      <li><strong>Read the whole passage first.</strong> Get the big picture before trying to number the events.</li>
      <li><strong>Use a timeline.</strong> Drawing a simple timeline or numbered list can help organize events visually.</li>
    </ul>

    <h2>Types of Sequencing Activities</h2>
    <p>These worksheets present sets of scrambled events from a short scenario. Students must read all the events and assign a number to each one to show the correct order. At the easy level, scenarios involve familiar daily activities with 4 steps. At the medium level, scenarios include 5 steps and less obvious ordering. At the hard level, scenarios have 6 steps and require careful reasoning about which event must precede or follow another.</p>

    <h2>Tips for Teachers and Parents</h2>
    <ul>
      <li><strong>Start with familiar routines.</strong> Getting dressed, making a sandwich, or brushing teeth are great first sequencing activities because students know the correct order from experience.</li>
      <li><strong>Progress to story events.</strong> Once students master sequencing routines, move to story-based sequences where they must rely on text comprehension rather than prior knowledge.</li>
      <li><strong>Discuss wrong answers.</strong> When a student puts events in the wrong order, discuss why the correct order makes more sense rather than simply marking it wrong.</li>
    </ul>

    <h2>Related Worksheets</h2>
    <ul>
      <li><a href="/worksheets/reading-main-idea-worksheets/">Main Idea Worksheets</a> - Identify the central idea of reading passages.</li>
      <li><a href="/worksheets/reading-cause-effect-worksheets/">Cause and Effect Worksheets</a> - Identify causes and effects in text.</li>
      <li><a href="/worksheets/reading-inference-worksheets/">Making Inferences Worksheets</a> - Draw conclusions from text evidence.</li>
    </ul>
  </article>

  <AdUnit slot="ws-bottom" format="horizontal" />
</BaseLayout>

