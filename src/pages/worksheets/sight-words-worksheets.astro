---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getWorksheetBySlug } from '../../data/worksheets';
import '../../styles/worksheet.css';

const ws = getWorksheetBySlug('sight-words-worksheets')!;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Worksheets", "item": "https://toolcalcs.com/worksheets/" },
      { "@type": "ListItem", "position": 3, "name": "Sight Words Worksheets" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LearningResource",
    "name": "Sight Words Worksheets",
    "description": "Free printable Dolch and Fry sight words worksheets for K-2 readers.",
    "learningResourceType": "worksheet",
    "educationalUse": "practice",
    "isAccessibleForFree": true,
    "inLanguage": "en"
  }
];
---

<BaseLayout
  title="Free Sight Words Worksheets - Dolch & Fry Lists Printable | ToolCalcs"
  description={ws.description}
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/worksheets/">Worksheets</a> &rsaquo;
    <span>Sight Words Worksheets</span>
  </nav>

  <h1>Sight Words Worksheets</h1>
  <p class="page-desc">{ws.description}</p>

  <div class="worksheet-box">
    <div class="config-panel">
      <h3>Settings</h3>
      <div class="config-inputs">
        <div class="config-group">
          <label for="cfgList">Word List</label>
          <select id="cfgList">
            <option value="preprimer">Pre-Primer (Pre-K)</option>
            <option value="primer" selected>Primer (Kindergarten)</option>
            <option value="first">First Grade</option>
            <option value="second">Second Grade</option>
            <option value="third">Third Grade</option>
          </select>
        </div>
        <div class="config-group">
          <label for="cfgCount">Words per Sheet</label>
          <input type="number" id="cfgCount" value="10" min="5" max="20" />
        </div>
        <div class="config-group">
          <label for="cfgActivity">Activity</label>
          <select id="cfgActivity">
            <option value="trace">Trace and Write</option>
            <option value="readWrite">Read, Write, and Box</option>
          </select>
        </div>
      </div>
    </div>

    <div class="worksheet-actions">
      <button class="ws-btn primary" id="btnGenerate">Generate New</button>
      <button class="ws-btn print" id="btnPrint">Print</button>
    </div>

    <div class="worksheet-content" id="worksheetContent">
      <div class="worksheet-header-print">
        <h2 id="sheetTitle">Sight Words Practice</h2>
        <div class="name-date">
          <span>Name: ___________________</span>
          <span>Date: ___________________</span>
        </div>
      </div>
      <div class="sw-area" id="swArea"></div>
    </div>
  </div>

  <AdUnit slot="ws-mid" format="rectangle" />

  <article class="content-section">
    <h2>About Sight Words Worksheets</h2>
    <p>Sight words are the most common words in written English. The Dolch list (created by Dr. Edward Dolch in 1936) and the Fry list (created by Dr. Edward Fry in 1957) together cover roughly 75 percent of the words found in early reading materials. Children who recognize these words instantly become fluent readers much faster than children who try to sound them out every time.</p>
    <p>Many sight words cannot be sounded out using normal phonics rules — words like "the," "was," "of," and "said" must simply be memorized through repeated exposure. Our worksheets give children that exposure in a structured, low-pressure way.</p>

    <h2>How to Use This Generator</h2>
    <p>Choose your word list based on your childs current grade. Pre-Primer is for the very first sight words children learn (typically late preschool). Primer covers kindergarten. First, second, and third grade lists build on each other. Pick the number of words and the activity type, then click "Generate New" to create a fresh worksheet.</p>
    <p>The "Trace and Write" activity shows each word in dotted-line format for tracing, followed by blank lines for independent writing. The "Read, Write, and Box" activity shows each word with a tracing line, a writing line, and three empty boxes for the child to write the word three more times from memory.</p>

    <h2>Dolch Sight Word Lists Explained</h2>
    <p>Dr. Edward Dolch developed his sight word list in 1936 by analyzing childrens books to find the most common words. He divided them into five lists by reading level:</p>
    <ul>
      <li><strong>Pre-Primer (40 words)</strong> - The very first sight words. Examples: the, a, I, see, to, my, like, go, can, is.</li>
      <li><strong>Primer (52 words)</strong> - Kindergarten level. Examples: at, are, be, but, came, did, do, eat, four, get.</li>
      <li><strong>First Grade (41 words)</strong> - Examples: after, again, an, any, ask, as, by, could, every, fly.</li>
      <li><strong>Second Grade (46 words)</strong> - Examples: always, around, because, been, before, best, both, buy, call, cold.</li>
      <li><strong>Third Grade (41 words)</strong> - Examples: about, better, bring, carry, clean, cut, done, draw, drink, eight.</li>
    </ul>
    <p>By the end of third grade, students should recognize all 220 Dolch sight words instantly without sounding them out.</p>

    <h2>Tips for Teaching Sight Words</h2>
    <ul>
      <li><strong>Start small.</strong> Introduce 3-5 new words at a time. Practice them daily for a week before adding more.</li>
      <li><strong>Multi-sensory practice.</strong> Have children say the word aloud, trace it with their finger, write it, and then build it with letter tiles or magnets.</li>
      <li><strong>Read the words in context.</strong> After mastering a word in isolation, find it in a book or sentence so the child sees how it works in real reading.</li>
      <li><strong>Make it a game.</strong> Use flashcards for quick review, play sight word bingo, or hide words around the house for a scavenger hunt.</li>
      <li><strong>Be patient with hard words.</strong> Words like "was," "said," and "they" trip up many beginning readers. Extra practice is normal — keep it positive.</li>
      <li><strong>Print fresh worksheets often.</strong> The same words on different worksheets prevents memorization of position and forces real recognition.</li>
    </ul>

    <h2>Related Worksheets</h2>
    <ul>
      <li><a href="/worksheets/phonics-worksheets/">Phonics Worksheets</a> - Build decoding skills alongside sight word memorization.</li>
      <li><a href="/worksheets/spelling-worksheets/">Spelling Worksheets</a> - Practice spelling for K-5 students.</li>
      <li><a href="/worksheets/vocabulary-worksheets/">Vocabulary Worksheets</a> - Build word knowledge with definitions and context.</li>
      <li><a href="/worksheets/alphabet-tracing-worksheets/">Alphabet Tracing Worksheets</a> - Letter formation practice for pre-readers.</li>
    </ul>
  </article>

  <AdUnit slot="ws-bottom" format="horizontal" />
</BaseLayout>

<style>
  .sw-area {
    padding: 20px 16px;
  }
  .sw-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    align-items: center;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px dashed #ccc;
  }
  .sw-word {
    font-family: 'Comic Sans MS', 'Marker Felt', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #d1d5db;
    text-transform: lowercase;
  }
  .sw-lines {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .sw-line {
    flex: 1;
    border-bottom: 2px solid #888;
    height: 26px;
  }
  .sw-box {
    width: 60px;
    height: 30px;
    border: 1.5px solid #888;
    border-radius: 3px;
  }
  @media (max-width: 600px) {
    .sw-row { grid-template-columns: 80px 1fr; }
    .sw-word { font-size: 1.3rem; }
    .sw-box { width: 45px; }
  }
</style>

<script is:inline>
  var SIGHT_WORDS = {
    preprimer: ['a','and','away','big','blue','can','come','down','find','for','funny','go','help','here','I','in','is','it','jump','little','look','make','me','my','not','one','play','red','run','said','see','the','three','to','two','up','we','where','yellow','you'],
    primer: ['all','am','are','at','ate','be','black','brown','but','came','did','do','eat','four','get','good','have','he','into','like','must','new','no','now','on','our','out','please','pretty','ran','ride','saw','say','she','so','soon','that','there','they','this','too','under','want','was','well','went','what','white','who','will','with','yes'],
    first: ['after','again','an','any','as','ask','by','could','every','fly','from','give','going','had','has','her','him','his','how','just','know','let','live','may','of','old','once','open','over','put','round','some','stop','take','thank','them','then','think','walk','were','when'],
    second: ['always','around','because','been','before','best','both','buy','call','cold','does','dont','fast','first','five','found','gave','goes','green','its','made','many','off','or','pull','read','right','sing','sit','sleep','tell','their','these','those','upon','us','use','very','wash','which','why','wish','work','would','write','your'],
    third: ['about','better','bring','carry','clean','cut','done','draw','drink','eight','fall','far','full','got','grow','hold','hot','hurt','if','keep','kind','laugh','light','long','much','myself','never','only','own','pick','seven','shall','show','six','small','start','ten','today','together','try','warm']
  };

  function pickWords(list, count) {
    var bank = SIGHT_WORDS[list].slice();
    for (var i = bank.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var t = bank[i]; bank[i] = bank[j]; bank[j] = t;
    }
    return bank.slice(0, count);
  }

  function generate() {
    var list = document.getElementById('cfgList').value;
    var count = parseInt(document.getElementById('cfgCount').value, 10) || 10;
    if (count < 5) count = 5;
    if (count > 20) count = 20;
    var activity = document.getElementById('cfgActivity').value;
    var words = pickWords(list, count);
    var labels = { preprimer: 'Pre-Primer', primer: 'Primer', first: 'First Grade', second: 'Second Grade', third: 'Third Grade' };
    document.getElementById('sheetTitle').textContent = 'Sight Words: ' + labels[list];

    var html = '';
    words.forEach(function(word) {
      var lineHtml = '';
      if (activity === 'trace') {
        lineHtml = '<div class="sw-lines"><div class="sw-line"></div><div class="sw-line"></div></div>';
      } else {
        lineHtml = '<div class="sw-lines"><div class="sw-line"></div><div class="sw-box"></div><div class="sw-box"></div><div class="sw-box"></div></div>';
      }
      html += '<div class="sw-row"><div class="sw-word">' + word + '</div>' + lineHtml + '</div>';
    });
    document.getElementById('swArea').innerHTML = html;
  }

  document.getElementById('btnGenerate').addEventListener('click', generate);
  document.getElementById('btnPrint').addEventListener('click', function() { window.print(); });
  document.getElementById('cfgList').addEventListener('change', generate);
  document.getElementById('cfgActivity').addEventListener('change', generate);
  document.getElementById('cfgCount').addEventListener('change', generate);
  generate();
</script>
