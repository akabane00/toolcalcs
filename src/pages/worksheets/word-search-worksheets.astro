---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdUnit from '../../components/AdUnit.astro';
import { getWorksheetBySlug } from '../../data/worksheets';
import '../../styles/worksheet.css';

const ws = getWorksheetBySlug('word-search-worksheets')!;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://toolcalcs.com/" },
      { "@type": "ListItem", "position": 2, "name": "Worksheets", "item": "https://toolcalcs.com/worksheets/" },
      { "@type": "ListItem", "position": 3, "name": "Word Search Worksheets" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "LearningResource",
    "name": "Word Search Worksheets",
    "description": "Free printable themed word search puzzles for kids.",
    "learningResourceType": "worksheet",
    "educationalUse": "practice",
    "isAccessibleForFree": true,
    "inLanguage": "en"
  }
];
---

<BaseLayout
  title="Free Word Search Worksheets - Printable Puzzles for Kids | ToolCalcs"
  description={ws.description}
  type="article"
  structuredData={structuredData}
>
  <nav class="breadcrumb">
    <a href="/">Home</a> &rsaquo;
    <a href="/worksheets/">Worksheets</a> &rsaquo;
    <span>Word Search Worksheets</span>
  </nav>

  <h1>Word Search Worksheets</h1>
  <p class="page-desc">{ws.description}</p>

  <div class="worksheet-box">
    <div class="config-panel">
      <h3>Settings</h3>
      <div class="config-inputs">
        <div class="config-group">
          <label for="cfgTheme">Theme</label>
          <select id="cfgTheme">
            <option value="animals">Animals</option>
            <option value="food">Food</option>
            <option value="sports">Sports</option>
            <option value="colors">Colors</option>
            <option value="seasons">Seasons</option>
            <option value="school">School</option>
            <option value="space">Space</option>
            <option value="ocean">Ocean</option>
          </select>
        </div>
        <div class="config-group">
          <label for="cfgSize">Grid Size</label>
          <select id="cfgSize">
            <option value="10">10 x 10 (Easy)</option>
            <option value="12" selected>12 x 12 (Medium)</option>
            <option value="15">15 x 15 (Hard)</option>
          </select>
        </div>
      </div>
    </div>

    <div class="worksheet-actions">
      <button class="ws-btn primary" id="btnGenerate">Generate New</button>
      <button class="ws-btn print" id="btnPrint">Print</button>
      <label class="toggle-label">
        <input type="checkbox" id="toggleAnswers" />
        Show Answers
      </label>
    </div>

    <div class="worksheet-content" id="worksheetContent">
      <div class="worksheet-header-print">
        <h2 id="puzzleTitle">Word Search</h2>
        <div class="name-date">
          <span>Name: ___________________</span>
          <span>Date: ___________________</span>
        </div>
      </div>
      <div class="ws-grid-wrap">
        <div class="ws-grid" id="wsGrid"></div>
        <div class="ws-words">
          <h3>Find these words:</h3>
          <ul id="wordList"></ul>
        </div>
      </div>
    </div>
  </div>

  <AdUnit slot="ws-mid" format="rectangle" />

  <article class="content-section">
    <h2>About Word Search Worksheets</h2>
    <p>Word search puzzles are one of the most engaging ways to build vocabulary, spelling, and visual scanning skills. Children get so absorbed in finding hidden words that they practice longer and learn more than they would with traditional fill-in-the-blank exercises. Each puzzle below is generated fresh every time you click "Generate New," so you always have a new challenge ready.</p>

    <h2>How to Use This Word Search Generator</h2>
    <p>Choose a theme that matches your interests or current lesson — animals, food, sports, colors, seasons, school, space, or ocean. Pick a grid size: 10x10 for early elementary students, 12x12 for upper elementary, or 15x15 for older kids who want a real challenge. Click "Generate New" to create a new puzzle. Click "Print" to produce a clean printer-friendly version with the settings panel hidden. Toggle "Show Answers" if a child gets stuck.</p>

    <h2>Educational Benefits</h2>
    <p>Word searches build several important skills at once:</p>
    <ul>
      <li><strong>Vocabulary expansion.</strong> Repeated exposure to themed words helps children learn and remember new vocabulary in context.</li>
      <li><strong>Spelling reinforcement.</strong> Finding each letter of a word in sequence reinforces correct spelling without the pressure of being tested.</li>
      <li><strong>Visual scanning.</strong> Searching the grid develops the eye-tracking skills needed for fluent reading.</li>
      <li><strong>Pattern recognition.</strong> Children learn to spot letter sequences in horizontal, vertical, and diagonal directions.</li>
      <li><strong>Focus and persistence.</strong> Word searches reward sustained attention and the willingness to keep looking when a word is hard to find.</li>
    </ul>

    <h2>Tips for Parents and Teachers</h2>
    <ul>
      <li><strong>Match difficulty to age.</strong> Use 10x10 grids for first and second graders. Move to 12x12 for grades 3-4, and 15x15 for older kids.</li>
      <li><strong>Read words aloud first.</strong> Before searching, have your child say each word in the list. This builds vocabulary even before the puzzle begins.</li>
      <li><strong>Use a highlighter.</strong> Highlighting words rather than circling them helps children focus and creates a colorful keepsake.</li>
      <li><strong>Time gently.</strong> Once your child is comfortable with a difficulty level, time them. The goal is improvement, not speed for its own sake.</li>
      <li><strong>Make it themed.</strong> Match the word search theme to a current lesson, holiday, or family interest for maximum engagement.</li>
    </ul>

    <h2>Related Worksheets</h2>
    <ul>
      <li><a href="/worksheets/crossword-worksheets/">Crossword Worksheets</a> - Build vocabulary and definitions with themed crosswords.</li>
      <li><a href="/worksheets/sight-words-worksheets/">Sight Words Worksheets</a> - Practice high-frequency reading words.</li>
      <li><a href="/worksheets/spelling-worksheets/">Spelling Worksheets</a> - Grade-level spelling practice with multiple activities.</li>
      <li><a href="/worksheets/vocabulary-worksheets/">Vocabulary Worksheets</a> - Build word knowledge with definitions and context.</li>
    </ul>
  </article>

  <AdUnit slot="ws-bottom" format="horizontal" />
</BaseLayout>

<style>
  .ws-grid-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    align-items: flex-start;
    padding: 16px;
  }
  .ws-grid {
    display: grid;
    gap: 0;
    font-family: 'Courier New', monospace;
    font-weight: 700;
  }
  .ws-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: 1px solid #ddd;
    font-size: 1rem;
    text-transform: uppercase;
  }
  .ws-cell.found {
    background: #fef3c7;
    color: #92400e;
  }
  .ws-words {
    flex: 1;
    min-width: 180px;
  }
  .ws-words h3 {
    font-size: 1rem;
    margin-bottom: 8px;
  }
  .ws-words ul {
    list-style: none;
    padding: 0;
    columns: 2;
    column-gap: 16px;
  }
  .ws-words li {
    padding: 4px 0;
    font-family: 'Courier New', monospace;
    text-transform: uppercase;
    font-size: 0.95rem;
  }
  .ws-words li.found {
    text-decoration: line-through;
    color: var(--color-text-muted);
  }
  @media (max-width: 600px) {
    .ws-cell { width: 24px; height: 24px; font-size: 0.85rem; }
  }
</style>

<script is:inline>
  var WORD_BANK = {
    animals: ['CAT','DOG','FISH','BIRD','HORSE','LION','TIGER','BEAR','WOLF','FROG','SNAKE','RABBIT','MOUSE','OWL','DEER','MONKEY','ZEBRA','PANDA'],
    food: ['BREAD','CHEESE','APPLE','BANANA','PIZZA','PASTA','RICE','SOUP','SALAD','EGG','MILK','BUTTER','SUGAR','HONEY','MEAT','FRUIT','BEAN','CORN'],
    sports: ['SOCCER','HOCKEY','TENNIS','GOLF','RUGBY','BOXING','SKIING','CYCLING','RUNNING','SURFING','SWIM','JUMP','BALL','GOAL','TEAM','COACH','RACE','GAME'],
    colors: ['RED','BLUE','GREEN','YELLOW','PURPLE','ORANGE','PINK','BROWN','BLACK','WHITE','GRAY','GOLD','SILVER','VIOLET','INDIGO','TEAL','CORAL','BEIGE'],
    seasons: ['SPRING','SUMMER','AUTUMN','WINTER','RAIN','SNOW','SUN','WIND','LEAF','FROST','BLOOM','HEAT','COLD','WARM','COOL','STORM','CLOUD','CLEAR'],
    school: ['BOOK','PEN','PENCIL','PAPER','DESK','CHAIR','RULER','ERASER','GLUE','CLASS','TEACHER','MATH','SCIENCE','READ','WRITE','LEARN','STUDY','TEST'],
    space: ['SUN','MOON','STAR','PLANET','EARTH','MARS','VENUS','SATURN','COMET','GALAXY','ORBIT','SPACE','ROCKET','ALIEN','METEOR','LUNAR','COSMIC','SOLAR'],
    ocean: ['FISH','WHALE','SHARK','CORAL','WAVE','BEACH','SAND','SHELL','OCEAN','SEA','REEF','TIDE','SALT','BOAT','SWIM','DIVE','DEEP','SAILOR']
  };

  var grid = [];
  var size = 12;
  var theme = 'animals';
  var placedWords = [];

  function pickWords(themeKey, max) {
    var bank = WORD_BANK[themeKey].slice();
    for (var i = bank.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var t = bank[i]; bank[i] = bank[j]; bank[j] = t;
    }
    var picked = [];
    for (var k = 0; k < bank.length && picked.length < max; k++) {
      if (bank[k].length <= size) picked.push(bank[k]);
    }
    return picked;
  }

  function emptyGrid(n) {
    var g = [];
    for (var i = 0; i < n; i++) {
      var row = [];
      for (var j = 0; j < n; j++) row.push('');
      g.push(row);
    }
    return g;
  }

  var DIRS = [[0,1],[1,0],[1,1],[-1,1]];

  function tryPlace(g, word) {
    for (var attempt = 0; attempt < 100; attempt++) {
      var dir = DIRS[Math.floor(Math.random() * DIRS.length)];
      var dr = dir[0], dc = dir[1];
      var r = Math.floor(Math.random() * size);
      var c = Math.floor(Math.random() * size);
      var endR = r + dr * (word.length - 1);
      var endC = c + dc * (word.length - 1);
      if (endR < 0 || endR >= size || endC < 0 || endC >= size) continue;
      var ok = true;
      for (var i = 0; i < word.length; i++) {
        var cr = r + dr * i;
        var cc = c + dc * i;
        if (g[cr][cc] !== '' && g[cr][cc] !== word[i]) { ok = false; break; }
      }
      if (!ok) continue;
      var cells = [];
      for (var i = 0; i < word.length; i++) {
        var cr = r + dr * i;
        var cc = c + dc * i;
        g[cr][cc] = word[i];
        cells.push([cr, cc]);
      }
      return cells;
    }
    return null;
  }

  function fillEmpty(g) {
    var letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    for (var i = 0; i < size; i++) {
      for (var j = 0; j < size; j++) {
        if (g[i][j] === '') g[i][j] = letters[Math.floor(Math.random() * 26)];
      }
    }
  }

  function generate() {
    theme = document.getElementById('cfgTheme').value;
    size = parseInt(document.getElementById('cfgSize').value, 10);
    var maxWords = size === 10 ? 10 : size === 12 ? 12 : 15;
    var words = pickWords(theme, maxWords);
    grid = emptyGrid(size);
    placedWords = [];
    for (var w = 0; w < words.length; w++) {
      var cells = tryPlace(grid, words[w]);
      if (cells) placedWords.push({ word: words[w], cells: cells });
    }
    fillEmpty(grid);
    render();
  }

  function render() {
    var gridEl = document.getElementById('wsGrid');
    gridEl.style.gridTemplateColumns = 'repeat(' + size + ', 28px)';
    var html = '';
    var showAnswers = document.getElementById('toggleAnswers').checked;
    var foundCells = {};
    if (showAnswers) {
      placedWords.forEach(function(p) {
        p.cells.forEach(function(c) { foundCells[c[0] + ',' + c[1]] = true; });
      });
    }
    for (var i = 0; i < size; i++) {
      for (var j = 0; j < size; j++) {
        var cls = foundCells[i + ',' + j] ? 'ws-cell found' : 'ws-cell';
        html += '<div class="' + cls + '">' + grid[i][j] + '</div>';
      }
    }
    gridEl.innerHTML = html;
    var listEl = document.getElementById('wordList');
    listEl.innerHTML = placedWords.map(function(p) {
      return '<li' + (showAnswers ? ' class="found"' : '') + '>' + p.word + '</li>';
    }).join('');
    document.getElementById('puzzleTitle').textContent = 'Word Search: ' + theme.charAt(0).toUpperCase() + theme.slice(1);
  }

  document.getElementById('btnGenerate').addEventListener('click', generate);
  document.getElementById('btnPrint').addEventListener('click', function() { window.print(); });
  document.getElementById('toggleAnswers').addEventListener('change', render);
  document.getElementById('cfgTheme').addEventListener('change', generate);
  document.getElementById('cfgSize').addEventListener('change', generate);
  generate();
</script>
